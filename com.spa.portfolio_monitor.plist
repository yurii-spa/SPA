<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
    L2 — Portfolio Drift Monitor (каждые 5 минут)
    Module: spa_core/paper_trading/portfolio_monitor.py
    Функция: мониторит отклонение реальных весов от целевых.
             Alerts: INFO ≥3pp, WARNING ≥5pp, CRITICAL >10pp / T2-cap нарушение.
             Считает health score (0–100): APY 35pt + Risk 35pt + Divers 30pt.
    Пишет:   data/monitor_snapshots.json  (ring-buffer, atomic)
    CLI:     python3 -m spa_core.paper_trading.portfolio_monitor - -run
    Установка:
      cp scripts/com.spa.portfolio_monitor.plist ~/Library/LaunchAgents/
      launchctl load ~/Library/LaunchAgents/com.spa.portfolio_monitor.plist
    -->

    <key>Label</key>
    <string>com.spa.portfolio_monitor</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/yuriikulieshov/miniconda3/bin/python3</string>
        <string>-m</string>
        <string>spa_core.paper_trading.portfolio_monitor</string>
        <string>--run</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/yuriikulieshov/Documents/SPA_Claude</string>

    <key>StartInterval</key>
    <integer>300</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>60</integer>

    <key>StandardOutPath</key>
    <string>/tmp/spa_portfolio_monitor.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/spa_portfolio_monitor_err.log</string>
</dict>
</plist>
