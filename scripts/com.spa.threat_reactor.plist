    <array>
        <string>/bin/bash</string>
        <string>/Users/yuriikulieshov/Documents/SPA_Claude/scripts/agent_threat_reactor.sh</string>
    </array>
    <key>WorkingDirectory</key><string>/Users/yuriikulieshov/Documents/SPA_Claude</string>
    <key>StartInterval</key><integer>300</integer>
    <key>RunAtLoad</key><true/>
    <key>StandardOutPath</key><string>/tmp/spa_threat_reactor.launchd.out</string>
    <key>StandardErrorPath</key><string>/tmp/spa_threat_reactor.launchd.err</string>
