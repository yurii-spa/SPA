<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!--
    MP-1427 (v10.43): Updated to use run_daily_paper_cycle.sh wrapper.
    Shell script wraps CPACycleWithEvidence (not cycle_runner directly),
    logs to logs/daily_cycle_YYYYMMDD.log per-day file.

    BUG FIX (TELEGRAM_AUDIT 2026-06-18):
        Was: StartInterval 1800 (every 30 minutes) — caused Telegram spam
             because _run_cycle_alerts fired send_red_flag / send_gap_alert
             (no dedup) every 30 min whenever red_flags.json was non-empty.
        Now: StartCalendarInterval 08:00 daily — one cycle per day as intended.
        CLAUDE.md has always said "ежедневно 08:00"; the plist was wrong.
-->
<dict>
    <key>Label</key>
    <string>com.spa.daily_cycle</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/yuriikulieshov/Documents/SPA_Claude/scripts/run_daily_paper_cycle.sh</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>RunAtLoad</key>
    <false/>
    <key>StandardOutPath</key>
    <string>/Users/yuriikulieshov/Documents/SPA_Claude/logs/launchd_stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/yuriikulieshov/Documents/SPA_Claude/logs/launchd_stderr.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>
