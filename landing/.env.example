# SPA Landing Environment Variables
# Copy to .env.local for local development
#
# NEVER commit .env.local to git — it is in .gitignore
# These are PUBLIC variables (exposed to browser); no secrets here.

# API endpoint for local development (SPA HTTP server)
PUBLIC_API_URL=http://localhost:8765

# Canonical site URL (used in meta tags, sitemap, OG tags)
PUBLIC_SITE_URL=https://earn-defi.com

# Feature flags
PUBLIC_SHOW_RESEARCH_TAB=true
