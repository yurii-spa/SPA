/risk-disclosure /risk-disclosure/index.html 200

# Canonical dashboard is now /dashboard (a first-class Astro page rendered in
# <Layout> — same chrome/tokens as the rest of earn-defi.com). /app is the legacy
# URL; keep it working as a safety net → /dashboard. The old 756KB public/app.html
# blob is retired.
/app /dashboard 301
/app.html /dashboard 301

# Old status shortcut → the dashboard go-live section.

# ─── Retired standalone HTML blobs → cohesive Astro equivalents (WS5.1) ───
# The old self-contained public/{agents,control,packages,tournament}.html (and
# docs/tournament.html) PRE-DATED the unified site — separate-entity blobs outside
# the cohesive design system. They are removed; the live surfaces they showed now
# live as first-class tabs/pages of the Astro site. Redirect (don't 404) so any
# bookmark or external link lands on the cohesive equivalent.
/tournament.html /dashboard#tournament 301
/agents          /dashboard#system 301
/agents.html     /dashboard#system 301
/control         /dashboard#system 301
/control.html    /dashboard#system 301

# Redirect www -> apex (canonical host = https://earn-defi.com). CF Pages processes full-URL
# host redirects here; belt-and-suspenders with a Cloudflare Redirect Rule (see PROGRESS deploy notes).
https://www.earn-defi.com/* https://earn-defi.com/:splat 301
