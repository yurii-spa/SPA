# Single authoritative header set. ONE Content-Security-Policy for the whole site:
# Cloudflare Pages applies BOTH a /* rule and any path-specific rule additively, and the
# browser enforces the INTERSECTION (strictest) of multiple CSP headers. Emitting a strict
# /* CSP plus a looser per-path CSP therefore BLOCKED Chart.js (cdnjs) + Google Fonts on
# /app and fonts on the marketing pages. Fix: one CSP here that covers every origin any
# page legitimately needs — no per-path CSP blocks (which would re-introduce the intersection).
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Robots-Tag: noindex, nofollow
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com https://cdnjs.cloudflare.com; connect-src 'self' https://api.earn-defi.com https://raw.githubusercontent.com https://api.llama.fi https://yields.llama.fi; frame-ancestors 'none'; base-uri 'self'

# Live pages (dashboard/packages/agents/tournament) must never be cached stale.
/app
  Cache-Control: no-cache
/packages
  Cache-Control: no-cache
/agents
  Cache-Control: no-cache
/tournament
  Cache-Control: no-cache

/api/*
  Cache-Control: no-cache, no-store, must-revalidate

# Hashed, content-addressed bundles — Astro emits them under /_assets/ (underscore).
/_assets/*
  Cache-Control: public, max-age=31536000, immutable
/assets/*
  Cache-Control: public, max-age=31536000, immutable
