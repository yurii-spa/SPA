---
const riskParams = [
  {
    label: 'TVL Floor',
    value: '$5M+',
    detail: 'Minimum TVL per pool',
    icon: 'shield',
  },
  {
    label: 'Per-Protocol Cap',
    value: '40%',
    detail: 'Max single protocol (T1)',
    icon: 'lock',
  },
  {
    label: 'Cash Buffer',
    value: '≥ 5%',
    detail: 'Always held in reserve',
    icon: 'buffer',
  },
  {
    label: 'Kill Switch',
    value: '-5%',
    detail: 'Monthly drawdown → close all',
    icon: 'alert',
  },
];
---

<section id="risk-gates" class="py-24 px-4 sm:px-6 lg:px-8 bg-[#0d1117]">
  <div class="max-w-5xl mx-auto">

    <!-- Header -->
    <div class="mb-12 max-w-2xl">
      <p class="text-teal-400 text-sm font-mono uppercase tracking-widest mb-3" data-ru="Параметры риска">Risk Parameters</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4 leading-tight" data-ru="Жёстко зашитые риск-гейты">
        Hard-Coded Risk Gates
      </h2>
      <p class="text-white/50 leading-relaxed" data-ru="RiskPolicy v1.0 детерминирована и не может быть переопределена. Ни человек, ни ИИ, ни стратегия не могут обойти эти лимиты. Каждое нарушение публично логируется.">
        RiskPolicy v1.0 is deterministic and non-overridable. No human, no AI, no strategy
        can bypass these limits. Every breach is logged publicly.
      </p>
    </div>

    <!-- Risk parameters grid -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">

      <div class="rounded-xl border border-teal-500/20 bg-teal-500/5 p-6 text-center">
        <div class="text-3xl font-mono font-bold text-white mb-2">$5M+</div>
        <div class="text-sm text-white/60 font-medium mb-1" data-ru="Минимум TVL">TVL Floor</div>
        <div class="text-xs text-white/30" data-ru="Минимальный TVL на пул">Minimum TVL per pool</div>
      </div>

      <div class="rounded-xl border border-teal-500/20 bg-teal-500/5 p-6 text-center">
        <div class="text-3xl font-mono font-bold text-white mb-2">40%</div>
        <div class="text-sm text-white/60 font-medium mb-1" data-ru="Лимит на протокол">Per-Protocol Cap</div>
        <div class="text-xs text-white/30" data-ru="Макс. доля одного протокола (T1)">Max single protocol (T1)</div>
      </div>

      <div class="rounded-xl border border-teal-500/20 bg-teal-500/5 p-6 text-center">
        <div class="text-3xl font-mono font-bold text-white mb-2">&ge; 5%</div>
        <div class="text-sm text-white/60 font-medium mb-1" data-ru="Денежный буфер">Cash Buffer</div>
        <div class="text-xs text-white/30" data-ru="Всегда удерживается в резерве">Always held in reserve</div>
      </div>

      <div class="rounded-xl border border-red-500/20 bg-red-500/5 p-6 text-center">
        <div class="text-3xl font-mono font-bold text-red-400 mb-2">-5%</div>
        <div class="text-sm text-white/60 font-medium mb-1" data-ru="Kill switch">Kill Switch</div>
        <div class="text-xs text-white/30" data-ru="Просадка &rarr; закрыть все позиции">Drawdown &rarr; close all positions</div>
      </div>

    </div>

    <!-- Architecture note -->
    <div class="mt-8 rounded-xl bg-white/[0.02] border border-white/8 p-5 flex flex-col sm:flex-row sm:items-start gap-4">
      <span class="inline-flex items-center px-2.5 py-1 rounded text-xs font-mono bg-teal-500/10 text-teal-400 border border-teal-500/20 flex-shrink-0">
        LLM_FORBIDDEN
      </span>
      <p class="text-sm text-white/40 leading-relaxed" data-ru="Риск-движок, слой исполнения и системы мониторинга содержат ноль обращений к LLM. Prompt injection в распределение капитала рассматривается как критический вектор атаки. Каждый параметр выше восходит к детерминированному правилу, а не к выводу модели.">
        The risk engine, execution layer, and monitoring systems contain zero LLM calls.
        Prompt injection into capital allocation is treated as a critical attack vector.
        Every parameter above traces to a deterministic rule — not a model output.
      </p>
    </div>

  </div>
</section>
