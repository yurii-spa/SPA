---
import StrategyCard from './StrategyCard.astro';
import strategies from '../data/strategy_config.json';
---

<section id="strategies" class="py-24 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-6 max-w-2xl mx-auto">
      <p class="text-accent-400 text-sm font-mono uppercase tracking-widest mb-3" data-ru="Инвестиционные стратегии">Investment Strategies</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4 leading-tight" data-ru="Выберите свою стратегию">
        Choose Your Strategy
      </h2>
      <p class="text-white/50 leading-relaxed" data-ru="Три профиля риска. Один системный фреймворк. APY переменный и не гарантирован.">
        Three risk profiles. One systematic framework. APY variable and not guaranteed.
      </p>
    </div>

    <!-- Risk gradient bar -->
    <div class="max-w-xl mx-auto mb-12">
      <div class="flex items-center gap-3">
        <span class="text-xs text-white/30 font-mono whitespace-nowrap" data-ru="Ниже риск">Lower Risk</span>
        <div class="flex-1 h-1.5 rounded-full bg-gradient-to-r from-blue-500 via-accent-400 to-amber-400 opacity-40"></div>
        <span class="text-xs text-white/30 font-mono whitespace-nowrap" data-ru="Выше риск">Higher Risk</span>
      </div>
    </div>

    <!-- Strategy cards grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {strategies.strategies.map((strategy) => (
        <StrategyCard strategy={strategy} />
      ))}
    </div>

    <!-- Disclaimer -->
    <p class="text-center text-xs text-white/20 mt-8 max-w-2xl mx-auto" data-ru="Показатели APY переменны и не гарантированы. Прошлые результаты бумажной торговли не гарантируют будущих результатов. Возможна потеря капитала.">
      {strategies.global.apy_disclaimer}
    </p>

  </div>
</section>
