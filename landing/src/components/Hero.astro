---
// Hero.astro — v2 reframe: research project, no capital-raising signals
// Блок 0: systematic onchain stablecoin yield, personal research project
---

<!-- Research project banner (Блок 0) -->
<div class="w-full bg-amber-500/10 border-b border-amber-500/20 px-4 py-2.5 text-center">
  <p class="text-xs text-amber-400/80 leading-relaxed" data-ru="Личный исследовательский проект — сейчас на этапе paper-тестирования и настройки, не на стадии привлечения капитала.">
    Personal research project — currently in paper-testing and tuning, not at a capital-raising stage.
  </p>
</div>

<section class="relative min-h-screen flex flex-col justify-center px-4 sm:px-6 lg:px-8 pt-20 pb-16 overflow-hidden">

  <!-- Subtle background gradient — no animation to keep LCP fast -->
  <div class="absolute inset-0 bg-gradient-to-br from-[#0a0a0a] via-[#0d1520] to-[#0a0a0a] pointer-events-none" aria-hidden="true"></div>

  <!-- Top nav removed — canonical SiteHeader (Layout) now owns site chrome.
       This component is retired/unused; index.astro is the Console homepage. -->

  <!-- Hero content -->
  <div class="relative max-w-5xl mx-auto w-full">

    <!-- Status badge — paper trading transparency first -->
    <div class="inline-flex items-center gap-2 mb-8 px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-xs text-white/60">
      <span class="inline-block w-2 h-2 rounded-full bg-amber-400 animate-pulse-slow" aria-hidden="true"></span>
      <span data-ru="Режим бумажной торговли">Paper Trading Mode</span>
      <span class="text-white/30 mx-1">·</span>
      <span id="hero-paper-day" data-ru="подтверждённый трек с 10 июня 2026 · детали на /track-record">evidenced track since June 10, 2026 · details on /track-record</span>
    </div>

    <!-- H1 — Блок 0 reframe -->
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-[1.1] tracking-tight mb-6">
      <span data-ru="Систематическая ончейн">Systematic onchain</span><br />
      <span class="text-accent-400" data-ru="доходность по стейблкоинам.">stablecoin yield.</span>
    </h1>

    <!-- Subheadline -->
    <p class="text-lg sm:text-xl text-white/60 max-w-2xl leading-relaxed mb-4" data-ru="Личный исследовательский проект по созданию и проверке детерминированного оптимизатора доходности в DeFi. Paper-тестирование на живых данных с 10 июня 2026 — каждое размещение, риск-гейт и ребалансировка логируются и публичны.">
      A personal research project building and validating a deterministic DeFi yield optimizer.
      Live-data paper testing since June 10, 2026 — every allocation, risk gate, and rebalance is logged and public.
    </p>

    <!-- Research framing (Блок 0) -->
    <p class="text-sm text-white/40 max-w-xl mb-10 leading-relaxed" data-ru="Открытый журнал методологии. Отслеживаем реальные данные по APY через несколько read-only DeFi-адаптеров. Капитал не привлекаем — сначала формируем track record.">
      Open methodology journal. Tracking real APY data across several read-only DeFi adapters.
      Not raising capital — building a track record first.
    </p>

    <!-- CTA buttons — журнал, не продажа -->
    <div class="flex flex-col sm:flex-row gap-4 mb-16">
      <a
        href="/methodology"
        class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-lg bg-accent-500 hover:bg-accent-400 text-white font-semibold text-sm transition-colors shadow-lg shadow-accent-500/20"
        data-ru="Журнал методологии"
      >
        Methodology Journal
      </a>
      <a
        href="/app"
        class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-lg border border-white/15 hover:border-white/30 text-white/70 hover:text-white font-medium text-sm transition-all"
        data-ru="Смотреть paper-результаты"
      >
        View Paper Results
      </a>
    </div>

    <!-- Protocols monitored -->
    <div class="flex flex-wrap items-center gap-x-6 gap-y-3 text-xs text-white/30">
      <span class="uppercase tracking-widest text-white/20 text-[10px]" data-ru="Отслеживаемые протоколы (read-only)">Protocols monitored (read-only)</span>
      {['Aave V3', 'Morpho Steakhouse', 'Compound V3', 'Yearn V3', 'Euler V2', 'Maple', 'Pendle'].map((protocol) => (
        <span class="px-2.5 py-1 rounded border border-white/10 bg-white/3 text-white/40 font-mono text-[11px]">
          {protocol}
        </span>
      ))}
    </div>

  </div>
</section>

<!-- Live status: keep the hero day-count + APY current from the live API (never stale).
     HONEST count: only cycle-log-evidenced days count (we reset the track — earlier
     days were flat-rate backfill). Source = /api/v1/golive.real_track_days. -->
<script is:inline>
  (function () {
    var API = (location.hostname === 'localhost' || location.hostname === '127.0.0.1')
      ? 'http://localhost:8765' : 'https://api.earn-defi.com';
    function isRu(){ try { return (localStorage.getItem('spa_lang') || 'en') === 'ru'; } catch (e) { return false; } }
    var apySuffix = '';
    function render(days) {
      var el = document.getElementById('hero-paper-day');
      if (!el || days == null) return;
      var en = days + ' evidenced days · anchor 2026-06-22' + apySuffix;
      var ru = days + ' подтверждённых дней · якорь 2026-06-22' + apySuffix;
      el.setAttribute('data-ru', ru);
      el.textContent = isRu() ? ru : en;
    }
    fetch(API + '/api/health-public').then(function (r) { return r.json(); }).then(function (d) {
      if (d && d.ytd_apy_pct != null) apySuffix = ' · ~' + Number(d.ytd_apy_pct).toFixed(1) + '% APY';
    }).catch(function () {}).finally(function () {
      fetch(API + '/api/v1/golive').then(function (r) { return r.json(); }).then(function (g) {
        if (g && g.real_track_days != null) render(g.real_track_days);
      }).catch(function () { /* keep static text */ });
    });
  })();
</script>
