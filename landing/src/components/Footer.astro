              data-ru="Дашборд ↗"
            >
              Dashboard ↗
            </a>
          </li>
        </ul>
      </div>

      <!-- Documentation -->
      <div>
        <h4 class="text-xs text-white/30 uppercase tracking-widest mb-4" data-ru="Документация">Documentation</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/risk" class="text-white/40 hover:text-white/70 transition-colors" data-ru="Риск">Risk</a></li>
          <li><a href="/trust" class="text-white/40 hover:text-white/70 transition-colors" data-ru="Доверие">Trust</a></li>
          <li><a href="/security" class="text-white/40 hover:text-white/70 transition-colors" data-ru="Безопасность">Security</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-xs text-white/30 uppercase tracking-widest mb-4" data-ru="Юридическое">Legal</h4>
        <ul class="space-y-2 text-sm">
