---
// Footer.astro
// GDPR notice, links, copyright
---

<footer class="py-12 px-4 sm:px-6 lg:px-8 bg-[#080808] border-t border-white/5">
  <div class="max-w-5xl mx-auto">

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-10">

      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <img src="/favicon.svg" alt="" class="w-6 h-6" aria-hidden="true" />
          <span class="font-semibold text-white text-sm">SPA</span>
        </div>
        <p class="text-xs text-white/30 leading-relaxed max-w-xs">
          Smart Passive Aggregator — autonomous DeFi yield optimizer for family offices.
          Paper trading since June 10, 2026.
        </p>
        <div class="mt-4 inline-flex items-center gap-1.5 text-xs text-amber-400/60">
          <span class="w-1.5 h-1.5 rounded-full bg-amber-400/60 animate-pulse-slow" aria-hidden="true"></span>
          Paper Trading Mode
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="text-xs text-white/30 uppercase tracking-widest mb-4">Navigation</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/strategies" class="text-white/40 hover:text-white/70 transition-colors">Strategies</a></li>
          <li><a href="/strategies/core" class="text-white/40 hover:text-white/70 transition-colors">Core Strategy</a></li>
          <li><a href="#how-it-works" class="text-white/40 hover:text-white/70 transition-colors">Methodology</a></li>
          <li><a href="#fees" class="text-white/40 hover:text-white/70 transition-colors">Fee Structure</a></li>
          <li><a href="/risk-disclosure" class="text-white/40 hover:text-white/70 transition-colors">Risk Disclosure</a></li>
        </ul>
      </div>

      <!-- Contact + legal -->
      <div>
        <h4 class="text-xs text-white/30 uppercase tracking-widest mb-4">Contact & Legal</h4>
        <ul class="space-y-2 text-sm">
          <li>
            <a
              href="https://dashboard.earn-defi.com"
              target="_blank" rel="noopener noreferrer"
              class="text-accent-400/60 hover:text-accent-400 transition-colors"
            >
              Live Dashboard ↗
            </a>
          </li>
          <li><a href="/risk-disclosure" class="text-white/40 hover:text-white/70 transition-colors">Risk Disclosure</a></li>
          <li>
            <!-- GDPR: Privacy Policy link — replace with real URL when available -->
            <a href="/privacy-policy" class="text-white/40 hover:text-white/70 transition-colors">
              Privacy Policy (GDPR)
            </a>
          </li>
        </ul>
      </div>

    </div>

    <!-- Bottom row -->
    <div class="pt-8 border-t border-white/5 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <p class="text-xs text-white/20">
        © 2026 earn-defi.com · Not investment advice · Not regulated
      </p>
      <p class="text-xs text-white/15 max-w-sm text-right">
        GDPR: We collect minimal usage data in accordance with EU Regulation 2016/679.
        No personal data is sold or shared with third parties.
      </p>
    </div>

  </div>
</footer>
