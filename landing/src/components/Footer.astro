  <div class="max-w-5xl mx-auto">

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-10">

      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <img src="/favicon.svg" alt="" class="w-6 h-6" aria-hidden="true" />
