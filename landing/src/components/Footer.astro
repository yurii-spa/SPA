          <span data-ru="Режим бумажной торговли">Paper Trading Mode</span>
        </div>
      </div>

      <!-- Research -->
      <div>
        <h4 class="text-xs text-white/30 uppercase tracking-widest mb-4" data-ru="Исследование">Research</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/methodology" class="text-white/40 hover:text-white/70 transition-colors" data-ru="Методология">Methodology</a></li>
