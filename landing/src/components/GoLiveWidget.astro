---
/**
 * GoLiveWidget.astro  (MP-1400 · v10.16)
 * Go-live readiness score + ETA widget for SPA Dashboard
 */

interface Props {
  score?: number;       // 0–100
  etaDays?: number;     // days until estimated go-live
  status?: "BLOCKED" | "IN_PROGRESS" | "READY";
}

const { score = 35, etaDays = 29, status = "BLOCKED" } = Astro.props;

// ── Derived values ───────────────────────────────────────────────
const etaDate = (() => {
  const d = new Date("2026-06-19");
  d.setDate(d.getDate() + etaDays);
  return d.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" });
})();

const statusConfig = {
  BLOCKED:     { emoji: "🔴", label: "BLOCKED",     labelRu: "ЗАБЛОКИРОВАНО", borderColor: "border-red-500/30",    bgColor: "bg-red-500/10",    textColor: "text-red-400",    barColor: "bg-red-500/50" },
  IN_PROGRESS: { emoji: "🟡", label: "IN PROGRESS", labelRu: "В ПРОЦЕССЕ",    borderColor: "border-amber-500/30",  bgColor: "bg-amber-500/10",  textColor: "text-amber-400",  barColor: "bg-amber-500/60" },
  READY:       { emoji: "🟢", label: "READY",       labelRu: "ГОТОВО",        borderColor: "border-emerald-500/30",bgColor: "bg-emerald-500/10",textColor: "text-emerald-400",barColor: "bg-emerald-500/70" },
} as const;

const cfg = statusConfig[status];

// Category breakdown from golive_readiness_report.py buckets (0-100 total)
const categories = [
  { name: "Gates",          nameRu: "Гейты",          current: 10, max: 20, description: "4-phase CPA gate progression",            descriptionRu: "Прохождение 4-фазного CPA-гейта" },
  { name: "Evidence",       nameRu: "Доказательства", current:  0, max: 25, description: "Paper trading evidence points",            descriptionRu: "Очки доказательств бумажной торговли" },
  { name: "Infrastructure", nameRu: "Инфраструктура", current: 12, max: 20, description: "launchd, autopush, Telegram, monitoring",  descriptionRu: "launchd, autopush, Telegram, мониторинг" },
  { name: "Financial",      nameRu: "Финансы",        current:  8, max: 15, description: "APY track, drawdown, Sharpe, Calmar",      descriptionRu: "Трек APY, просадка, Sharpe, Calmar" },
  { name: "Data Sources",   nameRu: "Источники данных", current: 3, max: 10, description: "Clean evidence coverage (8/24 sources)",  descriptionRu: "Покрытие чистыми данными (8/24 источника)" },
  { name: "Documentation",  nameRu: "Документация",   current:  2, max: 10, description: "ADR confirmations, risk snapshots",        descriptionRu: "Подтверждения ADR, снимки риска" },
] as const;
---

<div class="rounded-xl border border-white/10 bg-white/3 overflow-hidden">

  <!-- Header -->
  <div class="px-5 pt-5 pb-3 border-b border-white/5 flex items-start justify-between gap-4">
    <div>
      <h2 class="text-sm font-semibold text-white uppercase tracking-wider" data-ru="Готовность к GoLive">GoLive Readiness</h2>
      <p class="text-[11px] text-white/30 mt-0.5" data-ru={`Чекер go-live по 29 критериям · правило передачи ADR-002 · цель: ${etaDate}`}>
        29-criterion go-live checker · ADR-002 transfer rule · target: {etaDate}
      </p>
    </div>
    <!-- Status badge -->
    <span class={`shrink-0 text-[10px] font-mono font-semibold px-2.5 py-1 rounded-full border ${cfg.borderColor} ${cfg.bgColor} ${cfg.textColor} flex items-center gap-1.5`}>
      {cfg.emoji} <span data-ru={cfg.labelRu}>{cfg.label}</span>
    </span>
  </div>

  <!-- Main score + big progress bar -->
  <div class="px-5 py-5 border-b border-white/5">
    <div class="flex items-end gap-6 mb-4 flex-wrap">
      <div>
        <div class="text-[10px] text-white/25 uppercase tracking-wider mb-1" data-ru="Оценка готовности">Readiness Score</div>
        <div class="font-mono text-4xl font-bold text-white leading-none">
          {score}
          <span class="text-white/25 text-xl font-normal"> / 100</span>
        </div>
      </div>
      <div>
        <div class="text-[10px] text-white/25 uppercase tracking-wider mb-1" data-ru="Срок">ETA</div>
        <div class="font-mono text-lg text-white/70">~{etaDate}</div>
        <div class="text-[10px] text-white/20 mt-0.5" data-ru={`осталось дней: ${etaDays}`}>{etaDays} days remaining</div>
      </div>
      <div>
        <div class="text-[10px] text-white/25 uppercase tracking-wider mb-1" data-ru="Критерии">Criteria</div>
        <div class="font-mono text-lg text-white/70">16 <span class="text-white/25">/ 26</span></div>
        <div class="text-[10px] text-white/20 mt-0.5" data-ru="пройдено">pass</div>
      </div>
    </div>

    <!-- Big progress bar -->
    <div class="relative h-4 rounded-full bg-white/8 overflow-hidden mb-2">
      <div
        class={`h-full rounded-full transition-all ${cfg.barColor}`}
        style={`width:${score}%`}
      ></div>
      <!-- 100pt tick marks every 25 -->
      {[25, 50, 75].map(tick => (
        <div
          class="absolute top-0 bottom-0 w-px bg-white/10"
          style={`left:${tick}%`}
        ></div>
      ))}
    </div>
    <div class="flex justify-between text-[9px] font-mono text-white/15 px-0.5">
      <span>0</span><span>25</span><span>50</span><span>75</span><span>100</span>
    </div>
  </div>

  <!-- Category breakdown -->
  <div class="divide-y divide-white/5">
    {categories.map(cat => {
      const pct = Math.round((cat.current / cat.max) * 100);
      const barCls = cat.current === 0
        ? "bg-white/15"
        : cat.current >= cat.max * 0.7
          ? "bg-emerald-500/60"
          : "bg-amber-500/50";
      return (
        <div class="px-5 py-3 flex items-center gap-4">
          <div class="w-28 shrink-0">
            <div class="text-[11px] font-mono text-white/55" data-ru={cat.nameRu}>{cat.name}</div>
            <div class="text-[10px] text-white/20 leading-tight mt-0.5" data-ru={cat.descriptionRu}>{cat.description}</div>
          </div>
          <div class="flex-1 min-w-0">
            <div class="h-1.5 rounded-full bg-white/8 overflow-hidden">
              <div class={`h-full rounded-full ${barCls}`} style={`width:${pct}%`}></div>
            </div>
          </div>
          <div class="shrink-0 text-right w-20">
            <span class="font-mono text-[11px] text-white/50">{cat.current}</span>
            <span class="font-mono text-[11px] text-white/20"> / {cat.max}</span>
            <span class="font-mono text-[10px] text-white/20" data-ru=" очк."> pts</span>
          </div>
        </div>
      );
    })}
  </div>

  <!-- Key blockers -->
  <div class="px-5 py-4 border-t border-white/5 bg-white/1">
    <div class="text-[10px] font-mono text-white/25 uppercase tracking-wider mb-2" data-ru="Ключевые блокеры">Key Blockers</div>
    <ul class="space-y-1.5">
      {[
        { en: "Paper trading not started (0/30 evidence pts needed)", ru: "Бумажная торговля не начата (нужно 0/30 очков доказательств)" },
        { en: "gap_monitor 30-day continuity track not started", ru: "gap_monitor: 30-дневный непрерывный трек не начат" },
        { en: "autopush launchd daemon not installed (com.spa.autopush)", ru: "launchd-демон autopush не установлен (com.spa.autopush)" },
        { en: "5/6 RS-001 data sources missing — acquisition required", ru: "Отсутствует 5/6 источников данных RS-001 — требуется получение" },
        { en: "GoLiveChecker: 10 of 29 criteria failing", ru: "GoLiveChecker: 10 из 29 критериев не пройдены" },
      ].map(b => (
        <li class="flex items-start gap-2 text-[11px] text-white/30 leading-snug">
          <span class="text-red-400/50 shrink-0 mt-0.5">✗</span>
          <span data-ru={b.ru}>{b.en}</span>
        </li>
      ))}
    </ul>
  </div>

  <!-- Footer -->
  <div class="px-5 py-3 border-t border-white/5">
    <p class="text-[10px] font-mono text-white/15">
      data/golive_status.json · spa_core/paper_trading/golive_checker.py · updated each daily cycle
    </p>
  </div>

</div>
