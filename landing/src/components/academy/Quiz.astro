---
/*
 * Quiz.astro — the PUBLIC quiz component Agents 1+2 import in module pages.
 *
 * It is a thin Astro wrapper around the interactive <QuizIsland> (Quiz.jsx). It:
 *   - auto-derives `moduleId` from the page slug (Astro.url.pathname → /academy/<id>)
 *     so module pages do NOT need to pass it (one less thing to get wrong), and
 *   - renders the island with client:visible so the quiz is interactive and marks
 *     the module complete in localStorage. The quiz always sits at the END of a
 *     lesson (below the fold), so deferring hydration until it scrolls into view
 *     shaves lesson-page JS off first paint with no behavior change — the user
 *     cannot interact with it before it is visible anyway.
 *
 * USAGE (the contract Agents 1+2 follow):
 *   import Quiz from '../../components/academy/Quiz.astro';
 *   <Quiz questions={questions} />            // moduleId auto-derived from the URL
 *   <Quiz questions={questions} passAll={false} moduleId="capstone" />   // overrides optional
 *
 * QUESTION SCHEMA (RU-first plain strings — the schema the lessons use):
 *   { q: string,                  // question text (RU)
 *     options: string[],          // answer options (RU)
 *     correct: number,            // index into options of the correct answer
 *     explanation: string }       // shown after answering (RU)
 */
import QuizIsland from './Quiz.jsx';

interface Props {
  questions: any[];
  moduleId?: string;
  passAll?: boolean;
}
const { questions, moduleId, passAll = true } = Astro.props;

// Derive the module id from the route: /academy/<id> → <id>
const path = Astro.url.pathname.replace(/\/+$/, '');
const derived = path.split('/').filter(Boolean).pop() || '';
const mid = moduleId ?? (derived && derived !== 'academy' ? derived : 'unknown');
---
<QuizIsland questions={questions} moduleId={mid} passAll={passAll} client:visible />
