---
// SiteHeader.astro — canonical site chrome (spec §4.1).
// ONE header on every page (rendered by Layout). Replaces all inline page navs
// and the in-Hero nav. EN|RU toggle lives here and reuses the Layout i18n runtime
// (buttons carry data-lang; the inlined runtime in Layout wires #spa-lang-toggle).
const path = Astro.url.pathname;
// The Research hub (/structural-desk) is canonical for the whole research surface — keep it
// highlighted across its sub-desks (/rates-desk, /rwa-backstop, /research).
const RESEARCH_PATHS = ['/structural-desk', '/rates-desk', '/rwa-backstop', '/research', '/refusals', '/exit-nav', '/proof-of-reserves'];
const isActive = (href) => {
  if (href === '/structural-desk') return RESEARCH_PATHS.some((p) => path === p || path.startsWith(p + '/'));
  return href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
};

const nav = [
  { href: '/methodology',  en: 'Methodology',  ru: 'Методология' },
  { href: '/strategies',   en: 'Strategies',   ru: 'Стратегии' },
  { href: '/track-record', en: 'Track Record', ru: 'Трек-рекорд' },
  { href: '/structural-desk', en: 'Research', ru: 'Исследование' },
  { href: '/system',       en: 'System',        ru: 'Система' },
];
---

<header class="site-header">
  <div class="header-inner">
    <a class="brand" href="/" aria-label="SPA home">
      <img src="/favicon.svg" alt="" aria-hidden="true" />
      <span class="wordmark">SPA</span>
      <span class="domain">earn-defi.com</span>
    </a>

    <nav class="nav" aria-label="Primary">
      {nav.map((item) => (
        <a class:list={["navlink", { active: isActive(item.href) }]} href={item.href}
           aria-current={isActive(item.href) ? 'page' : undefined} data-ru={item.ru}>{item.en}</a>
      ))}
    </nav>

    <div class="header-right">
      <a class="cta-outline" href="/dashboard" data-ru="Дашборд ↗">Dashboard ↗</a>
      <div id="spa-lang-toggle" class="lang-toggle" role="group" aria-label="Language">
        <button type="button" data-lang="en" aria-pressed="true">EN</button>
        <button type="button" data-lang="ru" aria-pressed="false">RU</button>
      </div>
      <button type="button" class="hamburger" aria-label="Menu" aria-expanded="false" data-menu-toggle>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
    </div>
  </div>

  <div class="mobile-panel" id="mobilePanel">
    {nav.map((item) => (
      <a href={item.href} data-ru={item.ru}>{item.en}</a>
    ))}
    <a class="cta-outline" href="/dashboard" data-ru="Дашборд ↗">Dashboard ↗</a>
  </div>
</header>

<style>
  .site-header{
    position:sticky; top:0; z-index:50;
    background:rgba(10,12,16,.8); backdrop-filter:blur(12px); -webkit-backdrop-filter:blur(12px);
    border-bottom:1px solid var(--border);
  }
  .header-inner{max-width:1152px; margin:0 auto; height:64px; padding:0 24px; display:flex; align-items:center; justify-content:space-between; gap:24px}
  .brand{display:flex; align-items:center; gap:10px}
  .brand img{width:28px; height:28px}
  .brand .wordmark{font-weight:700; color:var(--text-primary); letter-spacing:-.01em; font-size:1.0625rem}
  .brand .domain{font-family:var(--font-mono); font-size:.75rem; color:var(--text-muted)}
  .nav{display:flex; align-items:center; gap:28px}
  .nav a.navlink{color:var(--text-secondary); font-size:.875rem; font-weight:500; padding:2px 0; border-bottom:2px solid transparent; transition:color 120ms var(--ease)}
  .nav a.navlink:hover{color:var(--text-primary)}
  .nav a.navlink.active{color:var(--text-primary); border-bottom-color:var(--accent)}
  .header-right{display:flex; align-items:center; gap:16px}
  .cta-outline{
    display:inline-flex; align-items:center; gap:6px; font-size:.8125rem; font-weight:600;
    padding:8px 16px; border-radius:var(--r-sm); border:1px solid rgba(91,141,239,.5);
    color:var(--accent); transition:all 120ms var(--ease); white-space:nowrap;
  }
  .cta-outline:hover{border-color:var(--accent); color:var(--accent-hover); background:var(--accent-bg)}
  /* lang-toggle reuses Layout i18n runtime; restyle to header palette */
  .lang-toggle{display:flex; align-items:center; gap:0; position:static; padding:0; background:transparent; border:1px solid var(--border); border-radius:var(--r-sm); overflow:hidden; box-shadow:none; backdrop-filter:none; -webkit-backdrop-filter:none}
  .lang-toggle button{background:transparent; border:none; color:var(--text-muted); padding:5px 9px; cursor:pointer; font-family:var(--font-mono); font-size:.75rem; transition:all 120ms var(--ease); border-radius:0}
  .lang-toggle button:hover{color:var(--text-secondary)}
  .lang-toggle button.spa-lang-active{background:var(--accent-bg); color:var(--accent)}
  .hamburger{display:none; background:transparent; border:1px solid var(--border); border-radius:var(--r-sm); padding:7px; cursor:pointer; color:var(--text-secondary)}
  .mobile-panel{display:none; flex-direction:column; gap:4px; padding:12px 24px 20px; border-bottom:1px solid var(--border); background:var(--bg-base)}
  .mobile-panel.open{display:flex}
  .mobile-panel a{color:var(--text-secondary); font-size:.95rem; padding:10px 0; border-bottom:1px solid var(--border)}
  .mobile-panel a:hover{color:var(--text-primary)}
  .mobile-panel .cta-outline{margin-top:10px; justify-content:center; border-bottom:1px solid rgba(91,141,239,.5)}

  @media (max-width:900px){
    .nav, .header-right .cta-outline{display:none}
    .hamburger{display:inline-flex}
  }
  @media (max-width:520px){
    .brand .domain{display:none}
  }
</style>

<script is:inline>
  (function () {
    var btn = document.querySelector('[data-menu-toggle]');
    var panel = document.getElementById('mobilePanel');
    if (btn && panel) {
      btn.addEventListener('click', function () {
        var open = panel.classList.toggle('open');
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
      panel.addEventListener('click', function (e) {
        if (e.target.tagName === 'A') { panel.classList.remove('open'); btn.setAttribute('aria-expanded', 'false'); }
      });
    }
  })();
</script>
