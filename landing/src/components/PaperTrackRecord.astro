---
---

<section id="track-record" class="py-24 px-4 sm:px-6 lg:px-8 bg-[#0d1117]">
  <div class="max-w-5xl mx-auto">

    <!-- Paper trading banner -->
    <div class="rounded-xl border border-amber-500/30 bg-amber-500/5 px-6 py-4 mb-10 flex flex-col sm:flex-row items-start sm:items-center gap-3">
      <div class="flex items-center gap-2 flex-shrink-0">
        <span class="inline-block w-2 h-2 rounded-full bg-amber-400 animate-pulse-slow" aria-hidden="true"></span>
        <span class="text-amber-400 text-sm font-semibold uppercase tracking-wider">Paper Trading</span>
      </div>
      <p class="text-sm text-white/50">
        Virtual $100,000 USDC portfolio. No live execution. No real capital at risk. All metrics below are simulated.
      </p>
    </div>

    <!-- Header -->
    <div class="mb-12 max-w-2xl">
      <p class="text-accent-400 text-sm font-mono uppercase tracking-widest mb-3">Core Strategy · Paper Track Record</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4 leading-tight">
        Verified Daily. Publicly Auditable.
      </h2>
      <p class="text-white/50 leading-relaxed">
        Every rebalance, every risk gate decision, every equity curve update — logged and
        accessible. Building the track record before asking for capital.
      </p>
    </div>

    <!-- Metrics grid -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-10">

      <div class="rounded-xl border border-white/10 bg-white/[0.03] p-6 text-center">
        <div class="text-xs text-white/30 uppercase tracking-wider font-mono mb-2">Tracking Since</div>
        <div class="text-2xl font-mono font-bold text-white">Jun 10</div>
        <div class="text-xs text-white/25 mt-1">2026</div>
      </div>

      <div class="rounded-xl border border-accent-500/20 bg-accent-500/5 p-6 text-center">
        <div class="text-xs text-accent-400/60 uppercase tracking-wider font-mono mb-2">Paper APY</div>
        <div class="text-2xl font-mono font-bold text-accent-400">6–14%</div>
        <div class="text-xs text-white/25 mt-1">Variable, not guaranteed</div>
      </div>

      <div class="rounded-xl border border-white/10 bg-white/[0.03] p-6 text-center">
        <div class="text-xs text-white/30 uppercase tracking-wider font-mono mb-2">Go-Live Criteria</div>
        <div class="text-2xl font-mono font-bold text-white">20<span class="text-white/30">/26</span></div>
        <div class="text-xs text-white/25 mt-1">Passing</div>
      </div>

      <div class="rounded-xl border border-white/10 bg-white/[0.03] p-6 text-center">
        <div class="text-xs text-white/30 uppercase tracking-wider font-mono mb-2">Go-Live Target</div>
        <div class="text-2xl font-mono font-bold text-white">Aug 1</div>
        <div class="text-xs text-white/25 mt-1">2026</div>
      </div>

    </div>

    <!-- Dashboard link -->
    <div class="text-center">
      <a
        href="/app"
        class="inline-flex items-center gap-2 text-accent-400 hover:text-accent-300 text-sm font-medium transition-colors"
      >
        View Full Dashboard
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
          <path fill-rule="evenodd" d="M8.636 3.5a.5.5 0 0 0-.5-.5H1.5A1.5 1.5 0 0 0 0 4.5v10A1.5 1.5 0 0 0 1.5 16h10a1.5 1.5 0 0 0 1.5-1.5V7.864a.5.5 0 0 0-1 0V14.5a.5.5 0 0 1-.5.5h-10a.5.5 0 0 1-.5-.5v-10a.5.5 0 0 1 .5-.5h6.636a.5.5 0 0 0 .5-.5"/>
          <path fill-rule="evenodd" d="M16 .5a.5.5 0 0 0-.5-.5h-5a.5.5 0 0 0 0 1h3.793L6.146 9.146a.5.5 0 1 0 .708.708L15 1.707V5.5a.5.5 0 0 0 1 0z"/>
        </svg>
      </a>
    </div>

  </div>
</section>
