---
/*
 * Badge.astro — one badge, one geometry, everywhere (V2 §3.4).
 * props:
 *   tone: 'ok'|'warn'|'danger'|'accent'|'teal'|'muted'  (default 'muted')
 *   dot?: boolean   — leading status dot in the tone color
 *   ru?: string     — RU translation (passed through the site data-ru runtime)
 * Renders bg/border/color from the §3.3 tint tokens. Mono, uppercase-safe.
 */
interface Props {
  tone?: 'ok' | 'warn' | 'danger' | 'accent' | 'teal' | 'muted';
  dot?: boolean;
  ru?: string;
  class?: string;
}
const { tone = 'muted', dot = false, ru, class: cls = '' } = Astro.props;
---
<span class:list={['ui-badge', `t-${tone}`, cls]} data-ru={ru}>
  {dot && <span class="ui-badge-dot" aria-hidden="true"></span>}
  <slot />
</span>

<style>
  .ui-badge{
    display:inline-flex; align-items:center; gap:6px; white-space:nowrap;
    font-family:var(--font-mono); font-size:.6875rem; font-weight:500; line-height:1;
    padding:4px 10px; border-radius:var(--r-full); border:1px solid transparent;
  }
  .ui-badge-dot{width:6px; height:6px; border-radius:50%; background:currentColor; flex-shrink:0}
  .t-ok{color:var(--ok); background:var(--ok-bg); border-color:var(--ok-border)}
  .t-warn{color:var(--warn); background:var(--warn-bg); border-color:var(--warn-border)}
  .t-danger{color:var(--danger); background:var(--danger-bg); border-color:var(--danger-border)}
  .t-accent{color:var(--accent-hover); background:var(--accent-bg); border-color:var(--accent-border)}
  .t-teal{color:var(--data-teal); background:var(--teal-bg); border-color:var(--teal-border)}
  .t-muted{color:var(--text-muted); background:var(--bg-surface-2); border-color:var(--border-strong)}
</style>
