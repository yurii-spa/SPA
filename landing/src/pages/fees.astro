---
import Layout from '../layouts/Layout.astro';
import Disclaimer from '../components/Disclaimer.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Fee Structure — Performance-Aligned Fees | SPA earn-defi.com"
  description="Performance-aligned fee model with high-water mark protection. Fees discussed individually during onboarding. Early participants receive preferential terms."
>

  <!-- Nav -->
  <nav class="flex items-center justify-between px-4 sm:px-6 lg:px-8 py-5 border-b border-white/5">
    <div class="flex items-center gap-2">
      <a href="/" class="flex items-center gap-2">
        <img src="/favicon.svg" alt="" class="w-7 h-7" aria-hidden="true" />
        <span class="font-semibold text-white tracking-tight">SPA</span>
      </a>
      <span class="text-white/15 mx-2">/</span>
      <span class="text-sm text-white/50">Fees</span>
    </div>
    <div class="flex items-center gap-6 text-sm text-white/50">
      <a href="/" class="hover:text-white transition-colors hidden sm:inline">Home</a>
      <a href="/strategies" class="hover:text-white transition-colors hidden sm:inline">Strategies</a>
      <a
        href="/dashboard"
        class="px-3 py-1.5 rounded-md border border-accent-500/50 text-accent-400 text-xs font-medium hover:border-accent-400 hover:text-accent-300 transition-all"
      >
        Dashboard ↗
      </a>
    </div>
  </nav>

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Hero -->
    <section class="pt-20 pb-12">
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4 leading-tight">
        Fee Structure
      </h1>
      <p class="text-xl text-white/50 leading-relaxed max-w-2xl">
        Performance-aligned. No hidden charges.
      </p>
    </section>

    <!-- 1. Private MVP Phase -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-6">Private Phase</p>
      <div class="rounded-xl border border-accent-500/20 bg-accent-500/5 p-6 mb-6">
        <p class="text-white/70 leading-relaxed mb-4">
          SPA is currently in a private invite-only phase. Fee terms are discussed individually
          during onboarding &mdash; early participants receive preferential terms.
        </p>
        <p class="text-white/50 leading-relaxed">
          Our model is performance-aligned: management fees cover operational costs,
          performance fees are only charged on profits above the high-water mark.
        </p>
      </div>
    </section>

    <!-- 2. Fee Components -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-6">Fee Components</p>
      <div class="space-y-3">
        <div class="flex items-center gap-4 rounded-lg border border-white/10 bg-white/[0.03] p-4">
          <span class="text-accent-400 flex-shrink-0">&#10003;</span>
          <div>
            <p class="text-sm text-white/80 font-medium">Management Fee</p>
            <p class="text-xs text-white/40">Annual fee on assets under management. Covers infrastructure, monitoring, and reporting.</p>
          </div>
        </div>
        <div class="flex items-center gap-4 rounded-lg border border-white/10 bg-white/[0.03] p-4">
          <span class="text-accent-400 flex-shrink-0">&#10003;</span>
          <div>
            <p class="text-sm text-white/80 font-medium">Performance Fee</p>
            <p class="text-xs text-white/40">Charged only on net profits above the high-water mark. We earn when you earn.</p>
          </div>
        </div>
        <div class="flex items-center gap-4 rounded-lg border border-white/10 bg-white/[0.03] p-4">
          <span class="text-accent-400 flex-shrink-0">&#10003;</span>
          <div>
            <p class="text-sm text-white/80 font-medium">High-Water Mark</p>
            <p class="text-xs text-white/40">No performance fee until previous portfolio peak is recovered. No double-charging on recoveries.</p>
          </div>
        </div>
        <div class="flex items-center gap-4 rounded-lg border border-white/10 bg-white/[0.03] p-4">
          <span class="text-accent-400 flex-shrink-0">&#10003;</span>
          <div>
            <p class="text-sm text-white/80 font-medium">No Withdrawal Fee</p>
            <p class="text-xs text-white/40">No fees charged on withdrawals.</p>
          </div>
        </div>
        <div class="flex items-center gap-4 rounded-lg border border-white/10 bg-white/[0.03] p-4">
          <span class="text-accent-400 flex-shrink-0">&#10003;</span>
          <div>
            <p class="text-sm text-white/80 font-medium">No Lock-Up</p>
            <p class="text-xs text-white/40">No mandatory lock-up period for your capital.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 3. High-Water Mark -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-4">High-Water Mark</p>
      <div class="rounded-xl border border-white/10 bg-white/[0.03] p-6">
        <p class="text-white/60 leading-relaxed">
          The high-water mark is the previous peak value of the portfolio. Performance fee is only
          charged on profits above this mark. If the portfolio declines, no performance fee is
          collected until the previous peak is recovered. This aligns manager incentives with
          investor outcomes &mdash; we only earn when you earn.
        </p>
      </div>
    </section>

    <!-- 4. Illustrative Example -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-accent-400 uppercase tracking-wider font-mono mb-4">How It Works &mdash; Conceptual Example</p>
      <div class="rounded-xl border border-white/10 bg-white/[0.03] p-6">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-sm">
          <div>
            <div class="text-white/30 uppercase tracking-wider text-[10px] font-mono mb-2">Year 1: Portfolio grows</div>
            <div class="text-white/70">Portfolio appreciates above starting value</div>
            <div class="text-white/40 text-xs mt-1">Performance fee charged on gains above high-water mark. New HWM set at peak.</div>
          </div>
          <div>
            <div class="text-white/30 uppercase tracking-wider text-[10px] font-mono mb-2">Year 2: Portfolio dips</div>
            <div class="text-white/70">Portfolio drops below the high-water mark</div>
            <div class="text-white/40 text-xs mt-1">No performance fee charged. Management fee continues to accrue.</div>
          </div>
          <div>
            <div class="text-white/30 uppercase tracking-wider text-[10px] font-mono mb-2">Year 3: Recovery</div>
            <div class="text-white/70">Portfolio recovers past previous peak</div>
            <div class="text-white/40 text-xs mt-1">Performance fee only on gains above the old HWM &mdash; no double-charging on recovery.</div>
          </div>
        </div>
        <p class="text-xs text-white/25 mt-6">
          Actual returns are variable and not guaranteed. This example is illustrative only.
          Specific fee rates are discussed during onboarding.
        </p>
      </div>
    </section>

    <!-- 5. Paper Trading Period -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-4">Paper Trading Period</p>
      <div class="rounded-xl border border-amber-500/20 bg-amber-500/5 p-5 flex items-start gap-3">
        <span class="text-amber-400 flex-shrink-0 mt-0.5">&#9888;</span>
        <div>
          <p class="text-sm text-white/60 leading-relaxed mb-2">
            During the paper trading period (through August 1, 2026), <strong class="text-white/80">no fees are charged</strong>.
            Fee structure applies from go-live date only.
          </p>
          <p class="text-xs text-white/35">
            Paper trading uses virtual $100,000 USDC &mdash; no real capital, no fee accrual.
          </p>
        </div>
      </div>
    </section>

    <!-- 6. FAQ -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-6">Frequently Asked Questions</p>
      <div class="space-y-6">

        <div>
          <h4 class="text-sm font-semibold text-white mb-2">When do fees start?</h4>
          <p class="text-sm text-white/40 leading-relaxed">
            From the go-live date (August 1, 2026 target). No fees are charged during the paper
            trading period.
          </p>
        </div>

        <div>
          <h4 class="text-sm font-semibold text-white mb-2">What's a high-water mark?</h4>
          <p class="text-sm text-white/40 leading-relaxed">
            The previous portfolio peak. Performance fee is only charged on profits above it.
            If the portfolio drops, no performance fee until it recovers to the previous high.
          </p>
        </div>

        <div>
          <h4 class="text-sm font-semibold text-white mb-2">Are there withdrawal fees?</h4>
          <p class="text-sm text-white/40 leading-relaxed">
            No withdrawal fee is planned for the MVP.
          </p>
        </div>

        <div>
          <h4 class="text-sm font-semibold text-white mb-2">Will fees change?</h4>
          <p class="text-sm text-white/40 leading-relaxed">
            Fee terms are agreed individually during onboarding. Any changes to agreed terms
            would come with advance notice.
          </p>
        </div>

      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 border-t border-white/5">
      <div class="rounded-xl border border-accent-500/20 bg-accent-500/5 p-8 text-center">
        <h3 class="text-lg font-semibold text-white mb-3">Interested in joining?</h3>
        <p class="text-sm text-white/50 mb-6">
          Fee terms are discussed individually during onboarding. Early participants receive preferential terms.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="/due-diligence" class="px-5 py-2.5 rounded-lg bg-accent-500 hover:bg-accent-400 text-white text-sm font-medium transition-colors">
            Request Access
          </a>
          <a href="mailto:yuriycooleshov@gmail.com" class="px-5 py-2.5 rounded-lg border border-white/10 text-white/50 hover:text-white hover:border-white/20 text-sm transition-all">
            yuriycooleshov@gmail.com
          </a>
        </div>
      </div>
    </section>

    <!-- Continue DD links -->
    <section class="pb-16">
      <div class="text-center">
        <p class="text-sm text-white/30 mb-6">Continue your due diligence</p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="/methodology" class="px-5 py-2.5 rounded-lg border border-white/10 text-white/50 hover:text-white hover:border-white/20 text-sm transition-all">
            Methodology
          </a>
          <a href="/risk-disclosure" class="px-5 py-2.5 rounded-lg border border-white/10 text-white/50 hover:text-white hover:border-white/20 text-sm transition-all">
            Risk Disclosure
          </a>
          <a href="/strategies" class="px-5 py-2.5 rounded-lg border border-white/10 text-white/50 hover:text-white hover:border-white/20 text-sm transition-all">
            All Strategies
          </a>
        </div>
      </div>
    </section>

  </main>

  <Disclaimer />
  <Footer />

</Layout>
