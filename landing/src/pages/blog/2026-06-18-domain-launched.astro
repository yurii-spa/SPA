---
import Layout from '../../layouts/Layout.astro';
import Disclaimer from '../../components/Disclaimer.astro';
const post = {
  title: "earn-defi.com Launched",
  titleRu: "Запуск earn-defi.com",
  date: "2026-06-18",
  tag: "Launch",
  tagRu: "Запуск",
  tagColor: "text-ok",
  summary: "The public landing site for SPA goes live on Cloudflare Pages. Institutional-grade presentation with live GoLive readiness tracking.",
  summaryRu: "Публичный сайт SPA запущен на Cloudflare Pages. Презентация институционального уровня с отслеживанием готовности к go-live в реальном времени.",
};
---

<Layout
  title="earn-defi.com Launched — SPA Blog"
  description="The public landing site for SPA goes live on Cloudflare Pages with institutional-grade presentation and live GoLive readiness tracking."
  canonical="https://earn-defi.com/blog/2026-06-18-domain-launched"
>

  <!-- Nav -->
  <main class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <section class="pt-16 pb-10">
      <div class="flex items-center gap-3 mb-4">
        <span class={`text-xs font-mono uppercase tracking-wider ${post.tagColor}`} data-ru={post.tagRu}>{post.tag}</span>
        <span class="text-xs text-white/25 font-mono">{post.date}</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4 leading-tight" data-ru={post.titleRu}>
        {post.title}
      </h1>
      <p class="text-white/50 text-lg leading-relaxed" data-ru={post.summaryRu}>{post.summary}</p>
    </section>

    <!-- Body -->
    <article class="pb-16 space-y-8 text-white/60 leading-relaxed">

      <section>
        <p>
          <a href="https://earn-defi.com" class="text-accent-400 hover:text-accent-300 underline underline-offset-2">earn-defi.com</a> <span data-ru="теперь работает — публичное лицо SPA (Stablecoin Portfolio Algorithm). Сайт развёрнут на">is
          now live — the public face of SPA (Stablecoin Portfolio Algorithm). The site is deployed
          on</span> <strong class="text-white">Cloudflare Pages</strong> <span data-ru="с автоматическими деплоями из ветки main. Время сборки: ~45 секунд. Глобальное распространение по CDN: мгновенное.">with automatic deployments from the
          main branch. Build time: ~45 seconds. Global CDN propagation: instant.</span>
        </p>
      </section>

      <!-- What's on the site -->
      <section>
        <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-4" data-ru="Структура сайта">Site Structure</p>
        <div class="overflow-x-auto rounded-xl border border-white/10">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-white/10 bg-white/[0.03]">
                <th class="text-left px-5 py-3 text-xs text-white/30 font-medium uppercase tracking-wider" data-ru="Страница">Page</th>
                <th class="text-left px-5 py-3 text-xs text-white/30 font-medium uppercase tracking-wider" data-ru="Назначение">Purpose</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/5">
              {[
                ['/', 'Hero — institutional pitch, GoLive widget, track record', 'Hero — институциональный питч, виджет GoLive, track record'],
                ['/dashboard', 'Live paper trading metrics, equity curve, positions', 'Метрики бумажной торговли в реальном времени, кривая капитала, позиции'],
                ['/methodology', 'CPA approach, 4-state gate, evidence system', 'Подход CPA, гейт из 4 состояний, система доказательств'],
                ['/strategies', 'Strategy profiles: Preserve, Core, Max Yield', 'Профили стратегий: Preserve, Core, Max Yield'],
                ['/risk', 'Risk architecture, RiskPolicy v1.0 parameters', 'Архитектура рисков, параметры RiskPolicy v1.0'],
                ['/security', 'Multisig, kill switch, execution isolation', 'Мультисиг, kill switch, изоляция исполнения'],
                ['/faq', 'Investor FAQ in Russian', 'FAQ для инвесторов на русском'],
                ['/fees', 'Performance-aligned fee structure', 'Структура комиссий, привязанная к результату'],
                ['/due-diligence', 'Full DD center for prospective investors', 'Полный центр due diligence для потенциальных инвесторов'],
                ['/status', 'System operational status', 'Операционный статус системы'],
                ['/blog', 'This page — public updates and changelog', 'Эта страница — публичные обновления и журнал изменений'],
              ].map(([page, desc, descRu]) => (
                <tr>
                  <td class="px-5 py-3 font-mono text-xs text-accent-400">{page}</td>
                  <td class="px-5 py-3 text-xs text-white/50" data-ru={descRu}>{desc}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <!-- Tech stack -->
      <section>
        <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-4" data-ru="Технологический стек">Tech Stack</p>
        <div class="flex flex-wrap gap-2">
          {[
            'Astro 4.x', 'Tailwind CSS', 'React (LiveStats widget)', 'TypeScript',
            'Cloudflare Pages', 'Static output', 'Zero external JS deps in runtime',
          ].map(tech => (
            <span class="px-2.5 py-1.5 rounded border border-white/10 bg-white/[0.03] text-white/45 font-mono text-xs">
              {tech}
            </span>
          ))}
        </div>
      </section>

      <!-- Design principles -->
      <section>
        <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-4" data-ru="Принципы дизайна">Design Principles</p>
        <div class="space-y-2 text-sm">
          {[
            { en: 'Dark-first — matches institutional product aesthetics; no jarring light flash on load', ru: 'Тёмная тема в приоритете — соответствует эстетике институциональных продуктов; без резкой световой вспышки при загрузке' },
            { en: 'Performance-first — static output, no SSR, Cloudflare CDN globally distributed', ru: 'Производительность в приоритете — статичный вывод, без SSR, глобально распределённый CDN Cloudflare' },
            { en: 'Evidence-first — every claim on the site is backed by on-chain verifiable data', ru: 'Доказательства в приоритете — каждое утверждение на сайте подкреплено проверяемыми on-chain данными' },
            { en: 'Progressive disclosure — summary on homepage, deep detail on sub-pages', ru: 'Постепенное раскрытие — сводка на главной, подробности на внутренних страницах' },
            { en: 'No marketing noise — no "revolutionary" language, no inflated APY projections', ru: 'Никакого маркетингового шума — без «революционных» формулировок и завышенных прогнозов APY' },
          ].map(item => (
            <div class="flex items-start gap-3 px-4 py-3 rounded-lg bg-white/[0.02] border border-white/5">
              <span class="text-ok flex-shrink-0 mt-0.5">›</span>
              <span class="text-white/50" data-ru={item.ru}>{item.en}</span>
            </div>
          ))}
        </div>
      </section>

    </article>

    <!-- Nav between posts -->
    <div class="py-8 border-t border-white/5 flex items-center justify-between">
      <a href="/blog" class="text-sm text-white/40 hover:text-white transition-colors" data-ru="← Все записи">← All posts</a>
      <a href="/blog/2026-06-19-architecture-audit" class="text-sm text-white/40 hover:text-white transition-colors" data-ru="Аудит архитектуры →">
        Architecture Audit →
      </a>
    </div>

  </main>

  <Disclaimer />
</Layout>
