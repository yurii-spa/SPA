const questions = [
  {
    q: 'Что показывает кривая edge_at_scale на $100k / $1M / $10M?',
    options: [
      'Uplift растёт с капиталом',
      '+1.08pp на $100k → −2.00pp на $1M → −0.99pp на $10M: edge становится ОТРИЦАТЕЛЬНЫМ при росте капитала',
      'Uplift постоянный +1.08pp везде',
      'Edge удваивается на каждом уровне',
    ],
    correct: 1,
    explanation: 'data/edge_at_scale.json: uplift_pp = +1.08 ($100k), −2.00 ($1M), −0.99 ($10M). edge_survives_at_max_aum=false, edge_below_materiality_at_aum_usd=1000000.',
  },
  {
    q: 'ПОЧЕМУ edge не масштабируется через yield?',
    options: [
      'Растут комиссии',
      'Оптимизатор концентрируется в высокодоходных МЕЛКИХ пулах; на $1M+ доля превышает cap 1% TVL, и большая часть капитала «выпадает» в кэш (earns 0)',
      'APY падает с инфляцией',
      'Нейросеть ошибается',
    ],
    correct: 1,
    explanation: 'CARRY_TRUTH.md WS-1.3: оптимизатор концентрируется в small-TVL пулах (euler_v2 ~$14M, pendle ~$7M). На $1M слуг 20% превышает 1%-of-TVL cap (MP-209/ADR-009) → capacity-capped капитал = idle cash, earns 0. В данных: на $1M optimized capped-out $700k.',
  },
  {
    q: 'До какого размера ограничен carry (FixedCarry venue-cap)?',
    options: [
      'Неограничен',
      '~$1.5–1.7M суммарно: все книги делят один Pendle/USDe exit-rail, поэтому ёмкость общая, а не на книгу',
      '$100M на книгу',
      '$50 на книгу',
    ],
    correct: 1,
    explanation: 'CARRY_TRUTH.md / FUNDABILITY.md: carry venue-capped — exit-ликвидность Pendle/USDe конечна и общая для всех книг. Нельзя «развести» ёмкость по нескольким книгам, если они выходят через один и тот же rail.',
  },
  {
    q: 'Как честно интерпретировать +1.08pp на $100k?',
