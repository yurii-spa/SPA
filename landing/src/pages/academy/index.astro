---
/*
 * /academy — SPA Академия portal home (RU-first).
 *
 * 3 tracks, module cards (FREE navigation — no lock-until-prev; progress shown per
 * card via localStorage), the portal-wide progress bar, and a «начни здесь» CTA.
 *
 * Built on the canonical Layout (header/footer/paper-strip) + Console design tokens.
 * The manifest (src/data/academy_modules.json) is the single source for the module list.
 */
import Layout from '../../layouts/Layout.astro';
import ModuleProgress from '../../components/academy/ModuleProgress.jsx';
import manifest from '../../data/academy_modules.json';

const modules = manifest.modules;
const tracks = manifest._meta.tracks;
const allIds = modules.map((m) => m.id);
const firstId = modules[0]?.id;

const trackColor = (t) => (t === 1 ? 'var(--data-teal)' : t === 2 ? 'var(--accent)' : 'var(--warn)');
const grouped = [1, 2, 3].map((t) => ({
  t,
  info: tracks[String(t)],
  mods: modules.filter((m) => m.track === t).sort((a, b) => a.order - b.order),
}));
---
<Layout title="SPA Академия — обучение аналитика от нуля" description="Интерактивный курс: DeFi с нуля + всё, что изобрели в SPA. RU-first, с живыми данными и интерактивными виджетами.">
  <main class="ac-index">
    <header class="ac-hero">
      <div class="ac-eyebrow">SPA АКАДЕМИЯ</div>
      <h1 class="ac-h1">От нуля до структурного андеррайтинга</h1>
      <p class="ac-lede">
        Интерактивный курс для аналитика: сначала база DeFi (как устроены доходность и риск),
        затем — всё, что изобрели в SPA: <strong>refusal-first</strong>, вето структурным
        хейркатом, двухуровневый kill-switch, edge на масштабе. Живые данные, симуляторы,
        квизы. Навигация свободная — проходи в любом порядке.
      </p>

      <div class="ac-hero-actions">
        <a class="ac-cta-primary" href={`/academy/${firstId}`} data-ru="Начни здесь →">Start here →</a>
        <span class="ac-hero-note" data-ru="Прогресс сохраняется в этом браузере (localStorage).">Progress is saved in this browser (localStorage).</span>
      </div>

      <div class="ac-progressbar">
        <ModuleProgress moduleIds={allIds} label_ru="Общий прогресс" client:load />
      </div>
    </header>

    {grouped.map((g) => (
      <section class="ac-track">
        <div class="ac-track-head" style={`border-left:3px solid ${trackColor(g.t)};`}>
          <div class="ac-track-eyebrow" style={`color:${trackColor(g.t)};`}>ТРЕК {g.t}</div>
          <h2 class="ac-track-title">{g.info.title_ru}</h2>
          <p class="ac-track-sub">{g.info.subtitle_ru}</p>
        </div>

        <div class="ac-cards">
          {g.mods.map((m) => (
            <a class="ac-card" href={`/academy/${m.id}`}>
              <div class="ac-card-top">
                <span class="ac-card-num" style={`color:${trackColor(g.t)};`}>{String(m.order).padStart(2, '0')}</span>
                <ModuleProgress moduleId={m.id} client:load />
              </div>
              <h3 class="ac-card-title">{m.title_ru}</h3>
              <p class="ac-card-summary">{m.summary_ru}</p>
              {m.widget && (
                <span class="ac-card-widget" data-ru="интерактив">interactive</span>
              )}
            </a>
          ))}
        </div>
      </section>
    ))}

    <p class="ac-foot-note">
      Учебный материал. Не инвестиционная рекомендация. Все цифры — paper / advisory,
      реальный капитал не задействован.
    </p>
  </main>
</Layout>

<style>
  .ac-index { max-width: 1152px; margin: 0 auto; padding: 48px 20px 96px; }
  .ac-hero { max-width: 768px; margin-bottom: 56px; }
  .ac-eyebrow { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.14em; color: var(--text-faint); margin-bottom: 14px; }
  .ac-h1 { font-size: 2.75rem; line-height: 1.1; font-weight: 700; color: var(--text-primary); margin: 0 0 18px; }
  .ac-lede { font-size: 1.125rem; line-height: 1.65; color: var(--text-secondary); margin: 0 0 28px; }
  .ac-lede strong { color: var(--text-primary); }

  .ac-hero-actions { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; margin-bottom: 28px; }
  .ac-cta-primary {
    background: var(--accent); color: #fff; text-decoration: none;
    border-radius: var(--r-sm); padding: 12px 26px; font-size: 15px; font-weight: 600;
    box-shadow: var(--shadow-cta); transition: background 120ms;
  }
  .ac-cta-primary:hover { background: var(--accent-hover); }
  .ac-hero-note { font-size: 13px; color: var(--text-muted); }
  .ac-progressbar { max-width: 520px; }

  .ac-track { margin-bottom: 56px; }
  .ac-track-head { padding-left: 16px; margin-bottom: 24px; }
  .ac-track-eyebrow { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.12em; margin-bottom: 6px; }
  .ac-track-title { font-size: 1.6rem; font-weight: 600; color: var(--text-primary); margin: 0 0 6px; }
  .ac-track-sub { font-size: 15px; color: var(--text-secondary); margin: 0; }

  .ac-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
  .ac-card {
    display: flex; flex-direction: column;
    background: var(--bg-surface); border: 1px solid var(--border);
    border-radius: var(--r-lg); padding: 20px; text-decoration: none;
    transition: border-color 120ms, transform 200ms;
  }
  .ac-card:hover { border-color: var(--border-strong); transform: translateY(-2px); }
  .ac-card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
  .ac-card-num { font-family: var(--font-mono); font-size: 18px; font-weight: 700; }
  .ac-card-title { font-size: 1.05rem; font-weight: 600; color: var(--text-primary); margin: 0 0 8px; line-height: 1.3; }
  .ac-card-summary { font-size: 14px; line-height: 1.55; color: var(--text-secondary); margin: 0 0 12px; flex: 1; }
  .ac-card-widget {
    align-self: flex-start; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.08em;
    text-transform: uppercase; padding: 3px 9px; border-radius: var(--r-full);
    border: 1px solid var(--data-teal); color: var(--data-teal);
  }

  .ac-foot-note { font-size: 13px; color: var(--text-muted); text-align: center; margin-top: 24px; }

  @media (max-width: 640px) {
    .ac-h1 { font-size: 2rem; }
  }
</style>
