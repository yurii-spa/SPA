---
import Layout from '../layouts/Layout.astro';
import Disclaimer from '../components/Disclaimer.astro';

/*
 * Rates Desk — on-chain interest-rate & basis sleeve, surfaced publicly.
 *
 * The "distribution moat made legible": we publish the validated 4-sleeve table AND the
 * refusal/decision log — what we traded AND what we refused + why.
 *
 * Data sources:
 *   - The 4 trade shapes are rendered server-side from the committed promotion snapshot
 *     (data/rates_desk/rates_desk_promotion.json, 2026-06-26). This is the validated artifact;
 *     there is no /promotion API endpoint, so it is embedded honestly at build time.
 *   - The live surfaces are fetched client-side, graceful offline:
 *       GET /api/rates-desk/decisions      → the refusal/decision log (ENTRY + REFUSAL)
 *       GET /api/rates-desk/surface        → the current RateSurface quotes
 *       GET /api/rates-desk/opportunities  → the current opportunity scan
 *
 * Tailwind only compiles class strings it can see literally — every badge palette below is a
 * literal string (NOT runtime-built), matching the convention in system.astro.
 */

// The validated 4-sleeve promotion snapshot (committed artifact, 2026-06-26).
const RWA_FLOOR_PCT = 3.4;
const sleeves = [
  {
    shape: 'FixedCarry', shape_ru: 'Фиксированный кэрри',
    id: 'rates_desk_fixed_carry',
    stage: 'PAPER_CANDIDATE', net_apy_pct: 6.09, beats_floor: true,
    desc_en: 'Lock a Pendle fixed (PT) rate that is genuine carry, not unpriced tail. Hold to maturity; no leverage.',
    desc_ru: 'Зафиксировать ставку Pendle (PT), которая является настоящим кэрри, а не неоценённым хвостом. Держать до погашения; без плеча.',
  },
  {
    shape: 'LeveredCarry', shape_ru: 'Кэрри с плечом',
    id: 'rates_desk_levered_carry',
    stage: 'PAPER_CANDIDATE', net_apy_pct: 4.96, beats_floor: true,
    desc_en: 'The same priced carry, modestly levered against the lending rate when the spread is real and exit liquidity covers the size.',
    desc_ru: 'Тот же оценённый кэрри, с умеренным плечом против ставки кредитования, когда спред реален, а ликвидность на выход покрывает размер.',
  },
  {
    shape: 'BasisHedge', shape_ru: 'Базисный хедж',
    id: 'rates_desk_basis_hedge',
    stage: 'BLOCKED-NO-HEDGE', net_apy_pct: 0.0, beats_floor: false,
    desc_en: 'Carry hedged with a forward-funding short — would be β≈0. Blocked: Boros has no keyless/permissionless venue yet, so the hedge never forms. Reported as zero, never fabricated.',
    desc_ru: 'Кэрри, захеджированный форвардным шортом фондирования — был бы β≈0. Заблокировано: у Boros пока нет keyless/permissionless площадки, поэтому хедж не формируется. Показано как ноль, никогда не выдумано.',
  },
  {
    shape: 'RateMatrix', shape_ru: 'Матрица ставок',
    id: 'rates_desk_rate_matrix',
    stage: 'PAPER_CANDIDATE', net_apy_pct: 6.09, beats_floor: true,
    desc_en: 'Cross-venue rate arbitrage: capture the disagreement between PT-implied, lending and funding rates across the matrix of venues.',
    desc_ru: 'Межплощадочный арбитраж ставок: захватить расхождение между PT-implied, кредитной и funding-ставками по матрице площадок.',
  },
];

// Literal Tailwind class strings per stage (NOT constructed at runtime).
const STAGE_META = {
  PAPER_CANDIDATE: {
    en: 'Paper candidate', ru: 'Кандидат в paper',
    card: 'border-ok-border', dot: 'bg-ok', badge: 'bg-ok-bg border-ok-border text-ok',
  },
  'BLOCKED-NO-HEDGE': {
    en: 'Blocked — no hedge', ru: 'Заблокировано — нет хеджа',
    card: 'border-warn-border', dot: 'bg-warn', badge: 'bg-warn-bg border-warn-border text-warn',
  },
};
---

<Layout
  title="Rates Desk — on-chain interest-rate & basis sleeve | earn-defi.com"
  description="The SPA Rates Desk, surfaced publicly: an engine that prices the disagreement between Pendle implied yield, lending rates and perp funding — and REFUSES books where the high rate is just unpriced tail. The validated 4-sleeve table AND the refusal log. We publish what we refuse, not just what we trade. Paper research, advisory, not live."
  canonical="https://earn-defi.com/rates-desk"
>
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- ============================================================= a. WHAT IT IS -->
    <section class="pt-20 pb-10">
      <div class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full text-xs font-mono"
           style="background:var(--accent-bg);border:1px solid var(--accent-dim);color:var(--accent-hover)">
        <span class="w-1.5 h-1.5 rounded-full" style="background:var(--accent)" aria-hidden="true"></span>
        <span data-ru="Paper-исследование · advisory · не live">Paper research · advisory · not live</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold mb-4 leading-tight" style="color:var(--text-primary)"
          data-ru="Rates Desk · on-chain ставки и базис">
        Rates Desk · on-chain interest-rate &amp; basis sleeve
      </h1>
      <p class="text-xl leading-relaxed max-w-2xl" style="color:var(--text-secondary)"
         data-ru="Движок, который оценивает расхождение между implied-доходностью Pendle, ставками кредитования и funding'ом перпов — и ОТКАЗЫВАЕТСЯ от книг, где высокая ставка — это просто неоценённый хвостовой риск.">
        An engine that prices the disagreement between Pendle implied yield, lending rates and
        perp funding — and <strong style="color:var(--text-primary)">refuses</strong> books where the
        high rate is just unpriced tail.
      </p>

      <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="rounded-xl p-5" style="background:var(--bg-surface);border:1px solid var(--border)">
          <p class="text-xs uppercase tracking-wider font-mono mb-2" style="color:var(--text-muted)"
             data-ru="Что это, по-честному">What it is, plainly</p>
          <p class="text-sm leading-relaxed" style="color:var(--text-secondary)"
             data-ru="Не «находитель доходности». Это ценовой движок: он разлагает каждую котируемую ставку на настоящий кэрри и компенсацию за хвостовой риск, и берёт только ту часть, что является честным кэрри.">
            Not a "yield finder". It is a pricing engine: it decomposes every quoted rate into genuine
            carry and tail-risk compensation, and only takes the part that is honest carry.
          </p>
        </div>
        <div class="rounded-xl p-5" style="background:var(--bg-surface);border:1px solid var(--border)">
          <p class="text-xs uppercase tracking-wider font-mono mb-2" style="color:var(--text-muted)"
             data-ru="Статус">Status</p>
          <p class="text-sm leading-relaxed" style="color:var(--text-secondary)"
             data-ru="Paper-исследование. Advisory — не открывает live-позиции. Каждый вердикт детерминирован и хеширован (LLM запрещён в risk-гейте). Сравнивается с RWA-полом ~3.4%.">
            Paper research. Advisory — it opens no live positions. Every verdict is deterministic and
            hashed (LLM forbidden in the risk gate). Benchmarked against the ~3.4% RWA floor.
          </p>
        </div>
      </div>
    </section>

    <!-- ============================================================= b. THE 4 TRADE SHAPES -->
    <section class="py-10 border-t" style="border-color:var(--border)">
      <p class="text-xs uppercase tracking-wider font-mono mb-2" style="color:var(--text-muted)"
         data-ru="Четыре формы сделки">The four trade shapes</p>
      <p class="text-sm mb-6 leading-relaxed max-w-2xl" style="color:var(--text-secondary)"
         data-ru="Стадия и net APY — из бэктест-снимка промоушена (backtest / walk-forward), НЕ реализованный carry. Это цифры кандидата: в бэктесте рабочие формы обыгрывают RWA-пол ~3.4%. Живой paper-трек ещё короткий (~1 неделя) и пока НЕ обыгрывает пол — см. секцию ниже. BasisHedge показан честно заблокированным.">
        Stage and net APY are from the promotion <strong style="color:var(--text-primary)">backtest</strong>
        snapshot (backtest / walk-forward), <strong style="color:var(--text-primary)">not realized carry</strong>.
        These are candidate figures: in the backtest the working shapes clear the ~{RWA_FLOOR_PCT}% RWA floor.
        The live paper track is still short (~1 week) and does <strong style="color:var(--text-primary)">not</strong>
        yet beat the floor — see the live section below. BasisHedge is shown honestly blocked.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {sleeves.map((s) => {
          const meta = STAGE_META[s.stage] || STAGE_META.PAPER_CANDIDATE;
          const blocked = s.stage === 'BLOCKED-NO-HEDGE';
          return (
            <div class={`rounded-xl p-5 bg-white/[0.02] border ${meta.card}`}>
              <div class="flex items-center justify-between gap-3 flex-wrap mb-3">
                <span class="text-base font-semibold font-mono" style="color:var(--text-primary)" data-ru={s.shape_ru}>{s.shape}</span>
                <span class={`inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md border text-[11px] font-mono shrink-0 ${meta.badge}`}>
                  <span class={`w-1.5 h-1.5 rounded-full ${meta.dot}`} aria-hidden="true"></span>
                  <span data-ru={meta.ru}>{meta.en}</span>
                </span>
              </div>
              <div class="flex items-baseline gap-3 mb-3">
                <span class="text-2xl font-bold font-mono" style={blocked ? 'color:var(--text-muted)' : 'color:var(--ok)'}>
                  {blocked ? '—' : `${s.net_apy_pct.toFixed(2)}%`}
                </span>
                <span class="text-xs font-mono" style="color:var(--text-muted)" data-ru="net APY (бэктест)">net APY (backtest)</span>
                {s.beats_floor && (
                  <span class="ml-auto text-[11px] font-mono px-2 py-0.5 rounded-md bg-ok-bg border border-ok-border text-ok"
                        data-ru={`обыгрывает пол ${RWA_FLOOR_PCT}% (бэктест)`}>beats {RWA_FLOOR_PCT}% floor (backtest)</span>
                )}
              </div>
              <p class="text-xs leading-relaxed" style="color:var(--text-secondary)" data-ru={s.desc_ru}>{s.desc_en}</p>
            </div>
          );
        })}
      </div>
    </section>

    <!-- ============================================================= c. VALIDATED ON 2.5yr + 3 STRESS -->
    <section class="py-10 border-t" style="border-color:var(--border)">
      <p class="text-xs uppercase tracking-wider font-mono mb-2" style="color:var(--text-muted)"
         data-ru="Валидация">Validated on 2.5 yr + 3 stress events</p>
      <div class="rounded-xl p-6" style="background:var(--bg-surface);border:1px solid var(--border)">
        <p class="text-sm leading-relaxed mb-4" style="color:var(--text-secondary)"
           data-ru="Движок отказа сработал РАНО: токсичные ezETH / rsETH были завернуты ДО депег-событий (Aug-2024, Apr-2026), а не задним числом. Книга-выживших обыгрывает пол 3.4% через каждый стресс.">
          The refusal engine fired <strong style="color:var(--text-primary)">early</strong>: toxic
          ezETH / rsETH were vetoed <strong style="color:var(--text-primary)">before</strong> the
          depeg events (Aug-2024, Apr-2026), not in hindsight. In the backtest, the survivor book beats
          the {RWA_FLOOR_PCT}% floor through every stress (backtest verdict — not the realized live track).
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-5">
          <div class="rounded-lg p-4 bg-white/[0.02]" style="border:1px solid var(--border)">
            <p class="text-xs font-mono mb-1" style="color:var(--text-muted)" data-ru="Окно">Window</p>
            <p class="text-sm font-semibold" style="color:var(--text-primary)" data-ru="≈2.5 года истории">≈2.5 yr history</p>
          </div>
          <div class="rounded-lg p-4 bg-white/[0.02]" style="border:1px solid var(--border)">
            <p class="text-xs font-mono mb-1" style="color:var(--text-muted)" data-ru="Стресс-события">Stress events</p>
            <p class="text-sm font-semibold" style="color:var(--text-primary)" data-ru="3 (депеги/funding-флипы)">3 (depegs / funding flips)</p>
          </div>
          <div class="rounded-lg p-4 bg-white/[0.02]" style="border:1px solid var(--border)">
            <p class="text-xs font-mono mb-1" style="color:var(--text-muted)" data-ru="Отказ сработал">Refusal fired</p>
            <p class="text-sm font-semibold text-ok" data-ru="до события, не задним числом">before the event</p>
          </div>
        </div>
        <div class="rounded-lg p-4" style="background:var(--accent-bg);border:1px solid var(--accent-dim)">
          <p class="text-xs uppercase tracking-wider font-mono mb-1.5" style="color:var(--accent-hover)"
             data-ru="Честная оговорка">Honest caveat</p>
          <p class="text-xs leading-relaxed" style="color:var(--text-secondary)"
             data-ru="Deflated Sharpe вырождается для locked-кэрри (почти нулевая дисперсия по построению), поэтому GO НЕ опирается на Sharpe. GO — это вердикт БЭКТЕСТА: «net APY обыгрывает пол» in-sample, out-of-sample и в стрессе. Это НЕ реализованный трек: живой paper-carry ещё накапливается (см. ниже) и пока не обыгрывает пол. См. методологию.">
            Deflated Sharpe is degenerate for locked carry (near-zero variance by construction), so the
            GO does <strong style="color:var(--text-primary)">not</strong> rest on Sharpe. The GO is a
            <strong style="color:var(--text-primary)">backtest</strong> verdict — "net APY beats floor"
            in-sample, out-of-sample <em>and</em> through stress. It is <strong style="color:var(--text-primary)">not</strong>
            a realized track: the live paper carry is still accumulating (see below) and does not yet beat the floor.
          </p>
          <a href="/methodology" class="inline-block mt-3 text-xs font-mono hover:underline" style="color:var(--accent)"
             data-ru="Методология и определения гейта →">Methodology &amp; gate definitions →</a>
        </div>
      </div>
    </section>

    <!-- ============================================================= c2. LIVE PAPER TRACK (accruing) -->
    <section class="py-10 border-t" style="border-color:var(--border)">
      <div class="flex items-baseline justify-between gap-3 flex-wrap mb-2">
        <p class="text-xs uppercase tracking-wider font-mono" style="color:var(--text-muted)"
           data-ru="Живой paper-трек — rates desk, накапливается">Live paper track — the rates desk, accruing</p>
        <span class="text-[11px] font-mono" style="color:var(--text-faint)">
          <span data-ru="источник">source</span>: <span id="track-src" data-ru="статика / офлайн">static / offline</span>
          · <span id="track-asof">—</span>
        </span>
      </div>
      <p class="text-sm mb-2 leading-relaxed max-w-2xl" style="color:var(--text-primary)"
         data-ru="Валидированный sleeve FixedCarry теперь работает live в paper-режиме — накапливает форвардный трек.">
        <strong>The validated FixedCarry sleeve now runs live in paper — accruing a forward track.</strong>
      </p>
      <p class="text-sm mb-6 leading-relaxed max-w-2xl" style="color:var(--text-secondary)"
         data-ru="Валидированный sleeve FixedCarry работает live в paper-режиме (без капитала) через com.spa.rates_desk_paper, накапливая форвардный трек. Это advisory-исследование — не go-live-трек и не реальный капитал — но это тот же движок, что пойдёт в live, записанный прозрачно. Из /api/rates-desk/track.">
        The validated FixedCarry sleeve runs live in paper (no capital) via
        <span class="font-mono text-xs">com.spa.rates_desk_paper</span>, accruing a forward track. This
        is advisory research — <strong style="color:var(--text-primary)">not the go-live track, not real
        capital</strong> — but it's the same engine that will run live, recorded transparently. From
        <span class="font-mono text-xs">/api/rates-desk/track</span>.
      </p>

      <!-- Early-track honesty banner -->
      <div class="rounded-lg p-4 mb-5" style="background:var(--accent-bg);border:1px solid var(--accent-dim)">
        <p class="text-xs leading-relaxed" style="color:var(--text-secondary)"
           data-ru="Этот трек только начался в этом спринте — это РАННИЙ форвардный рекорд, не длинная история. Ниже — «N дней на сегодня», честно.">
          This track just started this sprint — it is an <strong style="color:var(--text-primary)">early</strong>
          forward record, not a long history. Below is "<span id="track-days-inline">N</span> days so far",
          honestly.
        </p>
      </div>

      <!-- Summary tiles: days · cumulative return · current equity -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-5">
        <div class="rounded-lg p-4 bg-white/[0.02]" style="border:1px solid var(--border)">
          <p class="text-xs font-mono mb-1" style="color:var(--text-muted)" data-ru="Дней накоплено">Days accrued</p>
          <p id="track-days" class="text-2xl font-bold font-mono" style="color:var(--text-primary)">—</p>
        </div>
        <div class="rounded-lg p-4 bg-white/[0.02]" style="border:1px solid var(--border)">
          <p class="text-xs font-mono mb-1" style="color:var(--text-muted)" data-ru="Кумулятивная доходность">Cumulative return</p>
          <p id="track-ret" class="text-2xl font-bold font-mono" style="color:var(--text-secondary)">—</p>
        </div>
        <div class="rounded-lg p-4 bg-white/[0.02]" style="border:1px solid var(--border)">
          <p class="text-xs font-mono mb-1" style="color:var(--text-muted)" data-ru="Текущий equity (paper)">Current equity (paper)</p>
          <p id="track-eq" class="text-2xl font-bold font-mono" style="color:var(--text-primary)">—</p>
        </div>
      </div>

      <!-- Lightweight inline-SVG sparkline of the equity series (no chart deps). -->
      <div id="track-spark-wrap" class="rounded-xl p-5 mb-5 hidden" style="background:var(--bg-surface);border:1px solid var(--border)">
        <p class="text-[11px] uppercase tracking-wider font-mono mb-3" style="color:var(--text-muted)"
           data-ru="Кривая equity (paper, форвард)">Equity curve (paper, forward)</p>
        <svg id="track-spark" viewBox="0 0 600 80" preserveAspectRatio="none" class="w-full h-20" aria-hidden="true"></svg>
      </div>

      <!-- Compact equity table (always rendered as the verifiable fallback). -->
      <div id="track-table-wrap" class="overflow-x-auto rounded-xl" style="border:1px solid var(--border)">
        <table class="w-full text-sm" style="color:var(--text-secondary)">
          <thead>
            <tr class="text-[11px] font-mono uppercase tracking-wider text-left" style="color:var(--text-muted);background:var(--bg-surface)">
              <th class="px-4 py-3" data-ru="Дата">Date</th>
              <th class="px-4 py-3 text-right" data-ru="Equity (paper)">Equity (paper)</th>
              <th class="px-4 py-3 text-right" data-ru="net APY">net APY</th>
            </tr>
          </thead>
          <tbody id="track-rows">
            <tr><td colspan="3" class="px-4 py-6 text-center" style="color:var(--text-muted)">
              <span data-ru="Трек запускается — ещё нет тиков.">Track starting — no ticks yet.</span>
            </td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- ============================================================= d. THE REFUSAL LOG (the moat) -->
    <section class="py-10 border-t" style="border-color:var(--border)">
      <div class="flex items-baseline justify-between gap-3 flex-wrap mb-2">
        <p class="text-xs uppercase tracking-wider font-mono" style="color:var(--text-muted)"
           data-ru="Лог отказов">The refusal log</p>
        <span class="text-[11px] font-mono" style="color:var(--text-faint)">
          <span data-ru="источник">source</span>: <span id="dec-src" data-ru="статика / офлайн">static / offline</span>
          · <span id="dec-counts">—</span>
        </span>
      </div>
      <p class="text-sm mb-2 leading-relaxed max-w-2xl" style="color:var(--text-primary)"
         data-ru="Мы публикуем то, от чего ОТКАЗЫВАЕМСЯ, а не только то, чем торгуем.">
        <strong>We publish what we refuse, not just what we trade.</strong>
      </p>
      <p class="text-sm mb-6 leading-relaxed max-w-2xl" style="color:var(--text-secondary)"
         data-ru="Это и есть артефакт доверия. Каждая строка — хешированный вердикт гейта (ENTRY или REFUSAL) с разложением доходности на хейркаты. Живой поток из /api/rates-desk/decisions, последние первыми.">
        This is the credibility artifact. Each row is a hashed gate verdict (ENTRY or REFUSAL) with its
        yield decomposition haircuts. A live feed from <span class="font-mono text-xs">/api/rates-desk/decisions</span>,
        most recent first.
      </p>
      <div id="dec-rows" class="space-y-3">
        <p class="text-sm" style="color:var(--text-muted)" data-ru="Загрузка лога решений…">Loading the decision log…</p>
      </div>
    </section>

    <!-- ============================================================= d2. PROOF OF REFUSAL (verifiable chain) -->
    <section class="py-10 border-t" style="border-color:var(--border)">
      <div class="flex items-baseline justify-between gap-3 flex-wrap mb-2">
        <p class="text-xs uppercase tracking-wider font-mono" style="color:var(--text-muted)"
           data-ru="Доказательство отказа — проверяемый лог решений">Proof of refusal — verifiable decision log</p>
        <span class="text-[11px] font-mono" style="color:var(--text-faint)">
          <span data-ru="источник">source</span>: <span id="proof-src" data-ru="статика / офлайн">static / offline</span>
        </span>
      </div>
      <p class="text-sm mb-2 leading-relaxed max-w-2xl" style="color:var(--text-primary)"
         data-ru="Каждое решение — что мы взяли И от чего отказались — захешировано в защищённую от подмены цепочку.">
        <strong>Every decision — what we harvested AND what we refused — is hashed into a
        tamper-evident chain.</strong>
      </p>
      <p class="text-sm mb-6 leading-relaxed max-w-2xl" style="color:var(--text-secondary)"
         data-ru="Любой может проверить, что мы не переписывали историю. Мы публикуем свои отказы, а не только свои победы. Этот сервер заново пересчитывает всю цепочку из /api/rates-desk/proof и сообщает, цела ли она.">
        Anyone can verify we didn't rewrite history. We publish our refusals, not just our wins. The
        server re-derives the whole chain from <span class="font-mono text-xs">/api/rates-desk/proof</span>
        and reports whether it is intact.
      </p>

      <!-- Chain summary: VERIFIED badge + length + head hash -->
      <div class="rounded-xl p-5 mb-5" style="background:var(--bg-surface);border:1px solid var(--border)">
        <div class="flex items-center justify-between gap-3 flex-wrap mb-4">
          <span id="proof-badge"
                class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md border text-xs font-mono"
                style="background:var(--bg-surface);border-color:var(--border);color:var(--text-muted)">
            <span id="proof-badge-dot" class="w-2 h-2 rounded-full" style="background:var(--text-muted)" aria-hidden="true"></span>
            <span id="proof-badge-text" data-ru="проверка цепочки…">verifying chain…</span>
          </span>
          <span class="text-[11px] font-mono" style="color:var(--text-faint)">
            <span data-ru="длина цепочки">chain length</span>: <span id="proof-len" style="color:var(--text-secondary)">—</span>
          </span>
        </div>
        <div>
          <p class="text-[11px] uppercase tracking-wider font-mono mb-1" style="color:var(--text-muted)"
             data-ru="Хеш головы (отпечаток истории в окне)">Head hash (fingerprint of the in-window history)</p>
          <p id="proof-head" class="text-xs font-mono break-all" style="color:var(--text-secondary)">—</p>
          <p class="text-[11px] leading-relaxed mt-2" style="color:var(--text-faint)"
             data-ru="Голова — пересчитываемое зеркало скользящего окна (последние 2000 решений): стабильна при дозаписи, пересчитывается при вытеснении старых строк. Неизменяемый журнал за всё время — audit_chain.jsonl.">
            Head is a re-based sliding-window mirror (last 2000 decisions): stable across appends, re-bases
            when old rows are evicted. The immutable all-time ledger is
            <span class="font-mono">audit_chain.jsonl</span>.
          </p>
        </div>
      </div>

      <!-- Recent decisions table: entry vs REFUSAL, underlying, reason, haircut, payload hash -->
      <div class="overflow-x-auto rounded-xl" style="border:1px solid var(--border)">
        <table class="w-full text-sm" style="color:var(--text-secondary)">
          <thead>
            <tr class="text-[11px] font-mono uppercase tracking-wider text-left" style="color:var(--text-muted);background:var(--bg-surface)">
              <th class="px-4 py-3" data-ru="Вердикт">Verdict</th>
              <th class="px-4 py-3" data-ru="Актив">Underlying</th>
              <th class="px-4 py-3" data-ru="Причина">Reason</th>
              <th class="px-4 py-3 text-right" data-ru="Хейркат">Haircut</th>
              <th class="px-4 py-3 text-right" data-ru="Хеш">Payload hash</th>
            </tr>
          </thead>
          <tbody id="proof-rows">
            <tr><td colspan="5" class="px-4 py-6 text-center" style="color:var(--text-muted)">
              <span data-ru="Загрузка proof-цепочки…">Loading the proof chain…</span>
            </td></tr>
          </tbody>
        </table>
      </div>

      <!-- How to verify -->
      <div class="mt-5 rounded-lg p-4" style="background:var(--accent-bg);border:1px solid var(--accent-dim)">
        <p class="text-xs uppercase tracking-wider font-mono mb-1.5" style="color:var(--accent-hover)"
           data-ru="Как это проверить">How to verify</p>
        <p class="text-xs leading-relaxed" style="color:var(--text-secondary)"
           data-ru="Цепочка только дописывается. Каждая запись хеширует предыдущую голову (SHA-256), поэтому подмена любого прошлого решения меняет его хеш — и следующая запись перестаёт ссылаться на него, ломая цепочку. Зелёный значок означает, что пересчёт всех хешей с нуля сошёлся: история не переписана.">
          The chain is <strong style="color:var(--text-primary)">append-only</strong>. Each entry hashes
          the prior head (SHA-256), so flipping any past decision changes its hash — and the next entry
          no longer links to it, breaking the chain. A green badge means a from-scratch recompute of
          every hash agreed: history was not rewritten.
        </p>
      </div>
    </section>

    <!-- ============================================================= e. RATE SURFACE (optional) -->
    <section class="py-10 border-t" style="border-color:var(--border)">
      <div class="flex items-baseline justify-between gap-3 flex-wrap mb-2">
        <p class="text-xs uppercase tracking-wider font-mono" style="color:var(--text-muted)"
           data-ru="Поверхность ставок">RateSurface</p>
        <span class="text-[11px] font-mono" style="color:var(--text-faint)">
          <span data-ru="источник">source</span>: <span id="surf-src" data-ru="статика / офлайн">static / offline</span>
          · <span id="surf-asof">—</span>
        </span>
      </div>
      <p class="text-sm mb-6 leading-relaxed max-w-2xl" style="color:var(--text-secondary)"
         data-ru="Текущие котировки фиксированных/implied ставок (PT / lending / boros), которые движок сканирует. Из /api/rates-desk/surface.">
        The current fixed/implied-rate quotes (PT / lending / boros) the engine scans. From
        <span class="font-mono text-xs">/api/rates-desk/surface</span>.
      </p>
      <div class="overflow-x-auto rounded-xl" style="border:1px solid var(--border)">
        <table class="w-full text-sm" style="color:var(--text-secondary)">
          <thead>
            <tr class="text-[11px] font-mono uppercase tracking-wider text-left" style="color:var(--text-muted);background:var(--bg-surface)">
              <th class="px-4 py-3" data-ru="Актив">Underlying</th>
              <th class="px-4 py-3" data-ru="Тип">Kind</th>
              <th class="px-4 py-3" data-ru="Площадка">Venue</th>
              <th class="px-4 py-3 text-right" data-ru="Ставка">Quoted</th>
              <th class="px-4 py-3 text-right" data-ru="TVL">TVL</th>
              <th class="px-4 py-3 text-right" data-ru="Выход">Exit liq.</th>
              <th class="px-4 py-3 text-center" data-ru="Хедж">Hedge</th>
            </tr>
          </thead>
          <tbody id="surf-rows">
            <tr><td colspan="7" class="px-4 py-6 text-center" style="color:var(--text-muted)">
              <span data-ru="Загрузка поверхности ставок…">Loading the rate surface…</span>
            </td></tr>
          </tbody>
        </table>
      </div>
      <p class="mt-4 text-xs" style="color:var(--text-muted)" data-ru="Сканер возможностей: /api/rates-desk/opportunities — текущие формы, ранжированные по net edge.">
        Opportunity scan: <span class="font-mono">/api/rates-desk/opportunities</span> — current shapes
        ranked by net edge. <span id="opp-summary" class="font-mono" style="color:var(--text-secondary)"></span>
      </p>
    </section>

  </main>

  <Disclaimer />

  <!-- ===================================================================== LIVE FETCH -->
  <script is:inline>
    /* Rates Desk live surfaces — api.earn-defi.com, localhost fallback, graceful offline.
       Mirrors the api-base + fail-quiet convention in system.astro. */
    (function () {
      var API = (location.hostname === 'localhost' || location.hostname === '127.0.0.1')
        ? 'http://localhost:8765'
        : 'https://api.earn-defi.com';
      function isRu() { try { return (localStorage.getItem('spa_lang') || 'en') === 'ru'; } catch (e) { return false; } }
      function esc(s) { var d = document.createElement('div'); d.textContent = String(s == null ? '' : s); return d.innerHTML; }
      function setText(id, t) { var el = document.getElementById(id); if (el) el.textContent = t; }
      function num(x) { var n = Number(x); return isFinite(n) ? n : null; }
      function pct(x) { var n = num(x); return n == null ? '—' : (n * 100).toFixed(2) + '%'; }
      function usd(x) {
        var n = num(x); if (n == null) return '—';
        if (n >= 1e9) return '$' + (n / 1e9).toFixed(2) + 'B';
        if (n >= 1e6) return '$' + (n / 1e6).toFixed(2) + 'M';
        if (n >= 1e3) return '$' + (n / 1e3).toFixed(1) + 'k';
        return '$' + n.toFixed(0);
      }

      /* ---- c2. Live paper forward-track (the validated FixedCarry sleeve, accruing) ----- */
      function trackRow(p) {
        var apy = num(p.net_apy_pct);
        var apyTxt = apy == null ? '—' : apy.toFixed(2) + '%';
        return '<tr style="border-top:1px solid var(--border)">' +
          '<td class="px-4 py-3 font-mono text-xs" style="color:var(--text-secondary)">' + esc(p.date || '?') + '</td>' +
          '<td class="px-4 py-3 font-mono text-right" style="color:var(--text-primary)">' + usd(p.equity != null ? p.equity : p.nav) + '</td>' +
          '<td class="px-4 py-3 font-mono text-right text-xs" style="color:var(--text-muted)">' + apyTxt + '</td>' +
        '</tr>';
      }

      function drawSparkline(series) {
        var svg = document.getElementById('track-spark');
        var wrap = document.getElementById('track-spark-wrap');
        if (!svg || !wrap) return;
        var pts = [];
        for (var i = 0; i < series.length; i++) {
          var v = num(series[i].equity != null ? series[i].equity : series[i].nav);
          if (v != null) pts.push(v);
        }
        if (pts.length < 2) return; // need at least 2 points for a line
        var W = 600, H = 80, PAD = 4;
        var lo = Math.min.apply(null, pts), hi = Math.max.apply(null, pts);
        var span = (hi - lo) || 1; // flat series → a centred line, not a divide-by-zero
        var coords = pts.map(function (v, i) {
          var x = PAD + (i / (pts.length - 1)) * (W - 2 * PAD);
          var y = PAD + (1 - (v - lo) / span) * (H - 2 * PAD);
          return x.toFixed(1) + ',' + y.toFixed(1);
        });
        var up = pts[pts.length - 1] >= pts[0];
        var stroke = up ? 'var(--ok)' : '#f87171';
        svg.innerHTML = '<polyline fill="none" stroke="' + stroke + '" stroke-width="2" ' +
          'stroke-linejoin="round" stroke-linecap="round" points="' + coords.join(' ') + '"></polyline>';
        wrap.classList.remove('hidden');
      }

      function loadTrack() {
        fetch(API + '/api/rates-desk/track').then(function (r) { return r.json(); }).then(function (d) {
          if (!d || typeof d.days === 'undefined') return;
          var ru = isRu();
          var days = num(d.days) || 0;
          setText('track-days', days + (ru ? (days === 1 ? ' день' : ' дней') : (days === 1 ? ' day' : ' days')));
          setText('track-days-inline', String(days));
          var ret = num(d.cumulative_return_pct);
          if (ret != null) {
            var retEl = document.getElementById('track-ret');
            var sign = ret > 0 ? '+' : '';
            if (retEl) {
              retEl.textContent = sign + ret.toFixed(2) + '%';
              retEl.style.color = ret > 0 ? 'var(--ok)' : (ret < 0 ? '#f87171' : 'var(--text-secondary)');
            }
          }
          var eq = num(d.current_equity);
          if (eq != null) setText('track-eq', usd(eq));
          var series = Array.isArray(d.daily_series) ? d.daily_series : [];
          var body = document.getElementById('track-rows');
          if (body && series.length) {
            var rows = series.slice();
            rows.reverse(); // most recent first
            body.innerHTML = rows.map(trackRow).join('');
            drawSparkline(series);
          } else if (body) {
            body.innerHTML = '<tr><td colspan="3" class="px-4 py-6 text-center" style="color:var(--text-muted)">' +
              esc(ru ? 'Трек запускается — ещё нет тиков.' : 'Track starting — no ticks yet.') + '</td></tr>';
          }
          setText('track-src', 'live');
          if (d.last_tick) setText('track-asof', d.last_tick);
        }).catch(function () {});
      }

      /* ---- d. Decision / refusal log ---------------------------------------------------- */
      function decisionCard(x) {
        var ru = isRu();
        var refused = x.kind === 'REFUSAL' || x.approved === false;
        var meta = refused
          ? { card: 'border-danger-border', badge: 'bg-danger-bg border-danger-border text-danger', dot: 'bg-danger', en: 'REFUSED', ru: 'ОТКАЗ' }
          : { card: 'border-ok-border', badge: 'bg-ok-bg border-ok-border text-ok', dot: 'bg-ok', en: 'ENTERED', ru: 'ВХОД' };
        var dec = x.decomposition || {};
        var under = (dec.underlying || x.underlying || '?');
        var verdictLbl = ru ? meta.ru : meta.en;
        var reason = '';
        if (refused) {
          var note = (x.detail && x.detail.note) || x.reason || '';
          reason = note || (ru ? 'отказ гейта' : 'gate refusal');
        } else {
          reason = (ru ? 'оценённый кэрри прошёл гейт' : 'priced carry cleared the gate');
        }

        // YieldDecomposition haircuts (refusals carry the full breakdown).
        var HC = [
          ['peg_haircut',          ru ? 'peg' : 'peg'],
          ['funding_flip_haircut', ru ? 'funding-флип' : 'funding-flip'],
          ['liquidity_haircut',    ru ? 'ликвидность' : 'liquidity'],
          ['oracle_haircut',       ru ? 'оракул' : 'oracle'],
          ['protocol_haircut',     ru ? 'протокол' : 'protocol']
        ];
        var chips = '';
        HC.forEach(function (h) {
          var v = num(dec[h[0]]);
          if (v != null && v > 0) {
            chips += '<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md border text-[11px] font-mono bg-white/[0.03]" ' +
              'style="border-color:var(--border);color:var(--text-secondary)">' + esc(h[1]) + ' ' + (v * 100).toFixed(2) + '%</span>';
          }
        });
        var totalHc = num(dec.total_haircut);
        if (totalHc != null) {
          chips += '<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md border text-[11px] font-mono bg-danger-bg border-danger-border text-danger">' +
            (ru ? 'итого хейркат ' : 'total haircut ') + (totalHc * 100).toFixed(2) + '%</span>';
        }

        var netEdge = num(x.net_edge);
        var size = num(x.approved_size_usd);
        var metaBits = [];
        metaBits.push((ru ? 'актив ' : 'underlying ') + esc(under));
        if (netEdge != null) metaBits.push((ru ? 'net edge ' : 'net edge ') + (netEdge * 100).toFixed(2) + '%');
        metaBits.push((ru ? 'размер ' : 'size ') + (size != null ? usd(size) : '$0'));
        var hashBit = x.proof_hash ? '<span title="' + esc(x.proof_hash) + '" class="font-mono" style="color:var(--text-faint)">#' + esc(String(x.proof_hash).slice(0, 8)) + '</span>' : '';

        return '<div class="rounded-xl p-4 bg-white/[0.02] border ' + meta.card + '">' +
          '<div class="flex items-baseline justify-between gap-3 flex-wrap mb-2.5">' +
            '<div class="flex items-baseline gap-2 flex-wrap min-w-0">' +
              '<span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md border text-[11px] font-mono shrink-0 ' + meta.badge + '">' +
                '<span class="w-1.5 h-1.5 rounded-full ' + meta.dot + '" aria-hidden="true"></span>' + esc(verdictLbl) +
              '</span>' +
              '<span class="text-sm font-semibold font-mono" style="color:var(--text-primary)">' + esc(under) + '</span>' +
              (x.as_of ? '<span class="text-[11px] font-mono" style="color:var(--text-faint)">' + esc(x.as_of) + '</span>' : '') +
            '</div>' + hashBit +
          '</div>' +
          '<p class="text-xs leading-relaxed mb-2" style="color:var(--text-secondary)">' + esc(reason) + '</p>' +
          (chips ? '<div class="flex flex-wrap gap-1.5 mb-2">' + chips + '</div>' : '') +
          '<p class="text-[11px] font-mono" style="color:var(--text-muted)">' + metaBits.join(' · ') + '</p>' +
        '</div>';
      }

      function loadDecisions() {
        fetch(API + '/api/rates-desk/decisions?limit=40').then(function (r) { return r.json(); }).then(function (d) {
          if (!d || !Array.isArray(d.decisions) || !d.decisions.length) return;
          var rowsEl = document.getElementById('dec-rows');
          if (!rowsEl) return;
          var rows = d.decisions.slice();
          // Most recent first; surface REFUSALS prominently (they are the moat).
          rows.reverse();
          rowsEl.innerHTML = rows.map(decisionCard).join('');
          var c = d.counts || {};
          var ru = isRu();
          setText('dec-counts', (c.REFUSAL || 0) + (ru ? ' отказов · ' : ' refused · ') + (c.ENTRY || 0) + (ru ? ' входов' : ' entered'));
          setText('dec-src', 'live');
        }).catch(function () {});
      }

      /* ---- d2. Proof of refusal — verifiable decision chain ----------------------------- */
      function proofRow(x) {
        var ru = isRu();
        var refused = x.kind === 'REFUSAL' || x.allowed === false;
        var meta = refused
          ? { badge: 'bg-danger-bg border-danger-border text-danger', dot: 'bg-danger', en: 'REFUSED', ru: 'ОТКАЗ' }
          : { badge: 'bg-ok-bg border-ok-border text-ok', dot: 'bg-ok', en: 'ENTERED', ru: 'ВХОД' };
        var reason = x.reason || (refused ? (ru ? 'отказ гейта' : 'gate refusal') : (ru ? 'оценённый кэрри' : 'priced carry'));
        var hc = num(x.haircut_total);
        var hcTxt = hc == null ? '—' : (hc * 100).toFixed(2) + '%';
        var ph = x.payload_hash ? String(x.payload_hash) : '';
        var phShort = ph ? '#' + ph.slice(0, 12) : '—';
        return '<tr style="border-top:1px solid var(--border)">' +
          '<td class="px-4 py-3">' +
            '<span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md border text-[11px] font-mono ' + meta.badge + '">' +
              '<span class="w-1.5 h-1.5 rounded-full ' + meta.dot + '" aria-hidden="true"></span>' + esc(ru ? meta.ru : meta.en) +
            '</span></td>' +
          '<td class="px-4 py-3 font-mono" style="color:var(--text-primary)">' + esc(x.underlying || '?') + '</td>' +
          '<td class="px-4 py-3 text-xs" style="color:var(--text-secondary)">' + esc(reason) + '</td>' +
          '<td class="px-4 py-3 font-mono text-right text-xs ' + (refused ? 'text-danger' : '') + '" ' + (refused ? '' : 'style="color:var(--text-secondary)"') + '>' + hcTxt + '</td>' +
          '<td class="px-4 py-3 font-mono text-right text-[11px]" style="color:var(--text-faint)" title="' + esc(ph) + '">' + esc(phShort) + '</td>' +
        '</tr>';
      }

      function setBadge(verified) {
        var ru = isRu();
        var badge = document.getElementById('proof-badge');
        var dot = document.getElementById('proof-badge-dot');
        var txt = document.getElementById('proof-badge-text');
        if (!badge || !dot || !txt) return;
        // Reset to literal Tailwind palettes (Tailwind only compiles classes it can see literally).
        // 3-state: true→green, false→red, null/absent→NEUTRAL (never implies verified).
        badge.className = 'inline-flex items-center gap-2 px-3 py-1.5 rounded-md border text-xs font-mono';
        if (verified === true) {
          badge.className += ' bg-ok-bg border-ok-border text-ok';
          dot.className = 'w-2 h-2 rounded-full bg-ok';
          txt.textContent = ru ? 'ПОДТВЕРЖДЕНО · цепочка цела' : 'VERIFIED · chain intact';
        } else if (verified === false) {
          badge.className += ' bg-danger-bg border-danger-border text-danger';
          dot.className = 'w-2 h-2 rounded-full bg-danger';
          txt.textContent = ru ? 'НЕ ПОДТВЕРЖДЕНО · цепочка нарушена' : 'NOT VERIFIED · chain broken';
        } else {
          badge.className += ' border-[var(--border)] text-[var(--text-muted)]';
          badge.style.background = 'var(--bg-surface)';
          dot.className = 'w-2 h-2 rounded-full';
          dot.style.background = 'var(--text-muted)';
          txt.textContent = ru ? 'проверка недоступна' : 'verification unavailable';
        }
      }

      function loadProof() {
        fetch(API + '/api/rates-desk/proof?last_n=12').then(function (r) { return r.json(); }).then(function (d) {
          if (!d || typeof d.verified === 'undefined') return;
          var ru = isRu();
          setBadge(d.verified);
          setText('proof-len', (d.chain_length != null ? d.chain_length : '—') + (ru ? ' решений' : ' decisions'));
          setText('proof-head', d.head_hash ? String(d.head_hash) : (ru ? '— (цепочка пуста)' : '— (empty chain)'));
          var body = document.getElementById('proof-rows');
          if (body) {
            var rows = Array.isArray(d.last_n_decisions) ? d.last_n_decisions.slice() : [];
            if (rows.length) {
              rows.reverse(); // most recent first
              body.innerHTML = rows.map(proofRow).join('');
            } else {
              body.innerHTML = '<tr><td colspan="5" class="px-4 py-6 text-center" style="color:var(--text-muted)">' +
                esc(ru ? 'Цепочка пуста — решений ещё не записано.' : 'Chain is empty — no decisions recorded yet.') + '</td></tr>';
            }
          }
          setText('proof-src', 'live');
        }).catch(function () {});
      }

      /* ---- e. RateSurface --------------------------------------------------------------- */
      function surfRow(q) {
        var ru = isRu();
        var hedge = q.hedge_available === true;
        return '<tr style="border-top:1px solid var(--border)">' +
          '<td class="px-4 py-3 font-mono" style="color:var(--text-primary)">' + esc(q.underlying || '?') + '</td>' +
          '<td class="px-4 py-3 font-mono text-xs" style="color:var(--text-secondary)">' + esc(q.kind || '—') + '</td>' +
          '<td class="px-4 py-3 font-mono text-xs" style="color:var(--text-secondary)">' + esc((q.venue || '') + (q.protocol ? ' · ' + q.protocol : '')) + '</td>' +
          '<td class="px-4 py-3 font-mono text-right" style="color:var(--text-primary)">' + pct(q.quoted_rate) + '</td>' +
          '<td class="px-4 py-3 font-mono text-right text-xs" style="color:var(--text-secondary)">' + usd(q.tvl_usd) + '</td>' +
          '<td class="px-4 py-3 font-mono text-right text-xs" style="color:var(--text-secondary)">' + usd(q.exit_liquidity_usd) + '</td>' +
          '<td class="px-4 py-3 text-center text-xs font-mono ' + (hedge ? 'text-ok' : '') + '" ' + (hedge ? '' : 'style="color:var(--text-muted)"') + '>' +
            (hedge ? (ru ? 'есть' : 'yes') : (ru ? 'нет' : 'no')) + '</td>' +
        '</tr>';
      }

      function loadSurface() {
        fetch(API + '/api/rates-desk/surface').then(function (r) { return r.json(); }).then(function (d) {
          if (!d || !Array.isArray(d.quotes) || !d.quotes.length) return;
          var body = document.getElementById('surf-rows');
          if (!body) return;
          body.innerHTML = d.quotes.map(surfRow).join('');
          setText('surf-src', 'live');
          if (d.as_of) setText('surf-asof', d.as_of);
        }).catch(function () {});
      }

      function loadOpportunities() {
        fetch(API + '/api/rates-desk/opportunities').then(function (r) { return r.json(); }).then(function (d) {
          if (!d || !Array.isArray(d.opportunities)) return;
          var ru = isRu();
          var n = d.opportunities.length;
          var best = null;
          d.opportunities.forEach(function (o) {
            var e = num(o.net_edge);
            if (e != null && (best == null || e > best)) best = e;
          });
          var txt = '· ' + n + (ru ? ' возможностей' : ' opportunities');
          if (best != null) txt += (ru ? ', лучший net edge ' : ', best net edge ') + (best * 100).toFixed(2) + '%';
          setText('opp-summary', txt);
        }).catch(function () {});
      }

      function init() { loadTrack(); loadDecisions(); loadProof(); loadSurface(); loadOpportunities(); }
      if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', init); }
      else { init(); }
    })();
  </script>
</Layout>
