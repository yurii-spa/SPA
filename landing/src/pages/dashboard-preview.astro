---
// Q-OWN-19 — Phase-1 dashboard-shell PREVIEW (owner chose the preview-route option).
//
// This is a SAFE, throwaway preview so the owner can visually judge the DeBank/Zapper-style shell
// (sidebar + sticky topbar + KPI strip + 12-col grid) BEFORE it ever touches the live /dashboard.
// The live /dashboard is UNCHANGED. The <DashboardLive /> island mounts here EXACTLY as it does on
// /dashboard — same client:load, same initialFacts, zero JSX changes (spec §3 Step 1: wrap, don't
// rewrite). noindex: this route must not be crawled/indexed. When approved, dashboard.astro adopts
// DashboardShell in one edit; if rejected, delete this file + the shell — zero blast radius.
import Layout from '../layouts/Layout.astro';
import Disclaimer from '../components/Disclaimer.astro';
import DashboardShell from '../components/shell/DashboardShell.astro';
import DashboardLive from '../components/DashboardLive.jsx';
import RtmrMonitor from '../components/RtmrMonitor.jsx';
import snap from '../data/track_snapshot.json';

// Same island seed as the live /dashboard (real committed snapshot numbers; live poll overrides).
const initialFacts = {
  current_equity: snap.nav_usd ?? snap.end_equity ?? null,
  apy_today_pct: snap.paper_apy_pct ?? null,
  real_track_days: snap.real_track_days ?? null,
  evidenced_anchor: snap.evidenced_anchor ?? null,
  go_live_target: snap.go_live_target ?? null,
  golive_passed: snap.gates_passed ?? null,
  golive_total: snap.gates_total ?? null,
  _snapshot: true,
};

const fmtUsd = (n) => (n == null ? '—' : '$' + Number(n).toLocaleString('en-US', { maximumFractionDigits: 0 }));
// KPI strip — real committed snapshot values, honestly labelled "snapshot · track-to-date". The live
// island below carries the authoritative polling numbers; this strip demonstrates the shell's KPI row.
const kpis = [
  { label: 'NAV (paper)',       labelRu: 'NAV (бумага)',        value: fmtUsd(snap.nav_usd ?? snap.end_equity), tone: '' },
  { label: 'Paper APY',         labelRu: 'Paper APY',           value: snap.paper_apy_pct != null ? snap.paper_apy_pct.toFixed(2) + '%' : '—', tone: 'ok' },
  { label: 'Evidenced days',    labelRu: 'Подтв. дней',         value: (snap.real_track_days ?? '—') + ' / 30', tone: '' },
  { label: 'Go-live gates',     labelRu: 'Гейты go-live',       value: (snap.gates_passed ?? '—') + ' / ' + (snap.gates_total ?? '—'), tone: 'warn' },
  { label: 'Go-live target',    labelRu: 'Цель go-live',        value: snap.go_live_target ?? '—', tone: '' },
];
---

<Layout
  title="Dashboard shell — PREVIEW (Q-OWN-19) | earn-defi.com"
  description="Internal preview of the Phase-1 DeBank-style dashboard shell. Not the live dashboard."
  noindex={true}
>
  <div style="max-width:1440px;margin:0 auto;padding:16px 24px 0">
    <div style="display:flex;flex-wrap:wrap;gap:10px;align-items:center;justify-content:space-between;
                border:1px solid var(--accent-dim);background:var(--accent-bg);border-radius:var(--r-md);padding:12px 16px">
      <p style="margin:0;font-size:.8125rem;color:var(--text-secondary)"
         data-ru="ПРЕДПРОСМОТР — новый макет дашборда (боковое меню · топбар · KPI · широкая сетка). Живой дашборд не изменён и остаётся основным.">
        <strong style="color:var(--accent)">PREVIEW</strong> — a redesigned dashboard layout (sidebar · topbar · KPI · wide grid).
        The live <a href="/dashboard" style="color:var(--accent);text-decoration:underline">dashboard</a> is unchanged and remains the canonical view.
      </p>
      <a href="/dashboard" style="font-size:.8125rem;color:var(--accent);text-decoration:underline;white-space:nowrap"
         data-ru="← Живой дашборд">← Live dashboard</a>
    </div>
  </div>

  <DashboardShell title="Overview" titleRu="Обзор">
    <!-- KPI strip (spec §3 Step 2 concept) — real snapshot numbers, honestly labelled. -->
    <div slot="kpi" class="prev-kpis">
      {kpis.map((k) => (
        <div class="prev-kpi">
          <div class="prev-kpi-l" data-ru={k.labelRu}>{k.label}</div>
          <div class:list={["prev-kpi-v", k.tone]}>{k.value}</div>
        </div>
      ))}
      <p class="prev-kpi-note" data-ru={`снимок · трек-на-дату · ${snap.as_of ?? ''}`}>snapshot · track-to-date · {snap.as_of ?? ''}</p>
    </div>

    <!-- MAIN: the live island, mounted UNCHANGED (same client:load + initialFacts as /dashboard). -->
    <DashboardLive client:load initialFacts={initialFacts} />

    <!-- RAIL: RTMR live risk monitor moves to the right context rail (spec §3). -->
    <div slot="rail">
      <h2 style="font-size:.9375rem;font-weight:700;color:var(--text-primary);margin:0 0 10px"
          data-ru="Живой мониторинг риска">Live risk monitoring</h2>
      <RtmrMonitor client:visible />
    </div>
  </DashboardShell>

  <Disclaimer />
</Layout>

<style>
  .prev-kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px; }
  .prev-kpi { background: var(--bg-surface); border: 1px solid var(--border); border-radius: var(--r-md); padding: 14px 16px; }
  .prev-kpi-l { font-size: .6875rem; text-transform: uppercase; letter-spacing: .06em; color: var(--text-muted); font-family: var(--font-mono); margin-bottom: 6px; }
  .prev-kpi-v { font-size: 1.375rem; font-weight: 800; color: var(--text-primary); font-family: var(--font-mono); }
  .prev-kpi-v.ok { color: var(--ok); }
  .prev-kpi-v.warn { color: var(--warn); }
  .prev-kpi-note { grid-column: 1 / -1; margin: 2px 0 0; font-size: .6875rem; color: var(--text-faint); font-family: var(--font-mono); }
</style>
