---
// Phase-1 B1 — /dashboard-preview: true SPA shell (Q-OWN-19, owner chose preview-route option).
//
// What's here:
//   - DashboardSPAApp (React island, client:load): sidebar view switching with NO page reload,
//     ONE shared live-data connection for the KPI strip, hash-based per-view URL routing
//     (/dashboard-preview#overview | #positions | #monitoring | #research).
//   - app={true} on Layout: suppresses marketing SiteHeader/PaperStrip/SiteFooter so the SPA
//     provides its own compact chrome (topbar + collapsible sidebar).
//   - DashboardLive island is UNCHANGED (imported inside DashboardSPAApp as-is, spec §3 Step 1).
//   - Fleet-card fix: STALE is shown distinctly from WARNING (not "WARNING · stale").
//   - "Last updated HH:MM:SS" in KPI strip.
//
// Owner approval needed before PROMOTION to live /dashboard (see STATUS.md B1).
// noindex: this preview must not appear in search results.
import Layout from '../layouts/Layout.astro';
import DashboardSPAApp from '../components/DashboardSPAApp.jsx';
import snap from '../data/track_snapshot.json';

// Build-time snapshot seed — live poll overrides immediately on hydration.
const initialFacts = {
  nav_usd:        snap.nav_usd ?? snap.end_equity ?? null,
  paper_apy_pct:  snap.paper_apy_pct ?? null,
  track_days:     snap.real_track_days ?? null,
  golive_passed:  snap.gates_passed ?? null,
  golive_total:   snap.gates_total ?? null,
  evidenced_anchor: snap.evidenced_anchor ?? null,
  go_live_target:   snap.go_live_target ?? null,
  _snapshot: true,
};
---

<Layout
  title="Dashboard — PREVIEW (Phase-1 B1) | earn-defi.com"
  description="Internal SPA shell preview. Not the live dashboard."
  noindex={true}
  app={true}
>
  <!-- preview warning banner — sits above the SPA shell -->
  <div style="padding:10px 24px;background:var(--accent-bg);border-bottom:1px solid var(--accent-dim);display:flex;flex-wrap:wrap;gap:8px;align-items:center;justify-content:space-between;box-sizing:border-box">
    <p style="margin:0;font-size:.8125rem;color:var(--text-secondary)"
       data-ru="ПРЕДПРОСМОТР — SPA-дашборд (боковое меню · no-reload · KPI · хэш-роутинг). Живой дашборд не изменён.">
      <strong style="color:var(--accent)">PREVIEW</strong> — SPA dashboard (sidebar · no-reload view switching · shared KPI · hash routing).
      Live <a href="/dashboard" style="color:var(--accent);text-decoration:underline">dashboard</a> is unchanged.
    </p>
    <a href="/dashboard" style="font-size:.8125rem;color:var(--accent);text-decoration:underline;white-space:nowrap"
       data-ru="← Живой дашборд">← Live dashboard</a>
  </div>

  <!-- SPA island: one React root, manages its own sidebar+topbar+routing+KPI -->
  <DashboardSPAApp client:load initialFacts={initialFacts} />
</Layout>
