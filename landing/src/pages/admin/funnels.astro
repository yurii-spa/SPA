---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Operator · Funnels" admin={true}>
  <main class="ac"><div class="ac-wrap">
    <h1 class="ac-h1">Funnels</h1>
    <p class="ac-sub">From our own privacy-friendly counter. Homepage view → Analyze-wallet click → (deeper steps need report-level events, honest placeholder). No IP/cookies/PII.</p>
    <section class="ac-sec"><div class="ac-sec-h">Main funnel <span class="ac-soon" id="f-state">loading…</span></div>
      <div class="funnel">
        <div class="fstep"><span class="l">Homepage / site views</span><span class="n" id="f-views">—</span></div>
        <div class="fstep"><span class="l">Analyze-wallet clicks</span><span class="n" id="f-aw">—</span></div>
        <div class="fstep"><span class="l">Strategy Lab clicks</span><span class="n" id="f-sl">—</span></div>
        <div class="fstep" style="opacity:.55"><span class="l">Report viewed → lead (needs event)</span><span class="n">soon</span></div>
      </div>
      <p style="font-size:.8rem;color:var(--text-faint);margin-top:12px">View→analyze conversion: <b id="f-conv" style="color:var(--text-secondary)">—</b></p>
    </section>

    <!-- Checkup → earn-defi campaign attribution (utm_campaign on the DeFi Checkup deep-CTA: which
         risk signal drove the click). Backend already attributes it (analytics summary top_campaigns);
         this surfaces it so the reverse funnel is measurable, not just captured. -->
    <section class="ac-sec"><div class="ac-sec-h">Checkup → earn-defi campaigns <span class="ac-soon" id="c-state">loading…</span></div>
      <p class="ac-sub" style="margin-bottom:10px">Which risk signal in the DeFi Checkup report drove the click here (depeg / leverage / idle_stables / concentration…). No IP/cookies/PII — campaign tag only.</p>
      <div class="funnel" id="c-list"><div class="fstep"><span class="l">—</span><span class="n">—</span></div></div>
    </section>

    <!-- Q2-5/Q2-8: real design-partner pilot funnel (PII-minimal — anonymous interest + opaque-label pipeline) -->
    <section class="ac-sec"><div class="ac-sec-h">Design-partner pilot funnel <span class="ac-soon" id="p-state">loading…</span></div>
      <div class="funnel">
        <div class="fstep"><span class="l">Pilot interest signals (anonymous)</span><span class="n" id="p-interest">—</span></div>
        <div class="fstep"><span class="l">Contact requests (full request → owner Telegram)</span><span class="n" id="p-requests">—</span></div>
        <div class="fstep"><span class="l">Prospects in pipeline</span><span class="n" id="p-prospects">—</span></div>
        <div class="fstep"><span class="l">DD artifact sent</span><span class="n" id="p-dd">—</span></div>
        <div class="fstep"><span class="l">Active (LEAD…DILIGENCE)</span><span class="n" id="p-active">—</span></div>
        <div class="fstep"><span class="l">Committed</span><span class="n" id="p-committed">—</span></div>
      </div>
      <!-- I1 (redesign): leads by SOURCE (opaque labels, no PII) — which surface converts. -->
      <div class="ac-sec-h" style="margin-top:14px;font-size:.9rem">Contact requests by source</div>
      <div class="funnel" id="p-by-source"><div class="fstep"><span class="l">—</span><span class="n">—</span></div></div>
      <p style="font-size:.8rem;color:var(--text-faint);margin-top:12px">PII-minimal: anonymous interest + opaque-label pipeline, no email/name/contact. Intake is legal-gated.</p>
    </section>
  </div></main>
</Layout>
<script is:inline>
  (function(){
    var API=(location.hostname==='localhost'||location.hostname==='127.0.0.1')?'http://localhost:8765':'https://api.earn-defi.com';
    function set(id,v){var e=document.getElementById(id);if(e)e.textContent=v;}
    function esc(s){return String(s).replace(/[&<>"]/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c];});}
    fetch(API+'/api/analytics/summary').then(function(r){return r.json();}).then(function(d){
      var ev=d.events||{};var views=d.total_views||0;var aw=ev.analyze_wallet||0;
      set('f-views',views);set('f-aw',aw);set('f-sl',ev.view_strategy_lab||0);
      set('f-conv',views>0?((aw/views*100).toFixed(1)+'%'):'—');
      set('f-state','live');
      // Checkup → earn-defi campaign attribution (top_campaigns = [{campaign, hits}]).
      var cl=document.getElementById('c-list'); var camps=d.top_campaigns||[];
      if(cl){
        if(camps.length){
          cl.innerHTML=camps.map(function(c){return '<div class="fstep"><span class="l">'+esc(c.campaign)+'</span><span class="n">'+(c.hits||0)+'</span></div>';}).join('');
        } else {
          cl.innerHTML='<div class="fstep"><span class="l" style="opacity:.6">no campaign clicks yet</span><span class="n">0</span></div>';
        }
      }
      set('c-state','live');
    }).catch(function(){set('f-state','offline');set('c-state','offline');});
    // Design-partner pilot funnel — real interest + pipeline data (PII-minimal).
    Promise.all([
      fetch(API+'/api/interest/summary').then(function(r){return r.json();}).catch(function(){return null;}),
      fetch(API+'/api/pilot/summary').then(function(r){return r.json();}).catch(function(){return null;}),
      fetch(API+'/api/pilot/requests/count').then(function(r){return r.json();}).catch(function(){return null;})
    ]).then(function(res){
      var i=res[0]||{}, p=res[1]||{}, rq=res[2]||{}, bs=(p.by_stage)||{};
      set('p-interest', (i.total_interest!=null)?i.total_interest:'—');
      set('p-requests', (rq.total_requests!=null)?(rq.total_requests+' ('+(rq.requests_today||0)+' today)'):'—');
      set('p-prospects', (p.n_prospects!=null)?p.n_prospects:'—');
      set('p-dd', (p.n_dd_sent!=null)?p.n_dd_sent:'—');
      set('p-active', (p.n_active!=null)?p.n_active:'—');
      set('p-committed', (bs.COMMITTED!=null)?bs.COMMITTED:'—');
      // I1: render contact requests broken down by source (opaque labels, no PII).
      var byS=(rq.by_source)||{}, keys=Object.keys(byS).sort(function(a,b){return byS[b]-byS[a];});
      var el=document.getElementById('p-by-source');
      if(el){ el.innerHTML = keys.length
        ? keys.map(function(k){ return '<div class="fstep"><span class="l">'+k+'</span><span class="n">'+byS[k]+'</span></div>'; }).join('')
        : '<div class="fstep"><span class="l">no requests yet</span><span class="n">0</span></div>'; }
      set('p-state','live');
    }).catch(function(){set('p-state','offline');});
  })();
</script>
<style>
  .ac{background:var(--bg-base);min-height:calc(100vh - 52px);padding:32px 0 80px}
  .ac-wrap{max-width:1100px;margin:0 auto;padding:0 24px}
  .ac-h1{font-size:1.6rem;font-weight:800;color:var(--text-primary);margin:0}
  .ac-sub{color:var(--text-secondary);font-size:.9375rem;margin:8px 0 28px;max-width:680px}
  .ac-sec{margin-bottom:30px}
  .ac-sec-h{font-family:var(--font-mono);font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--text-muted);margin-bottom:14px;display:flex;gap:12px;align-items:center}
  .ac-soon{color:var(--warn);font-weight:600;text-transform:none;font-family:var(--font-sans)}
  .ac-pg{display:flex;justify-content:space-between;gap:12px;font-size:.8125rem;padding:9px 0;border-bottom:1px solid var(--border);color:var(--text-secondary)}
  .ac-pg b{color:var(--text-primary)}
  .funnel{display:grid;gap:8px;max-width:560px}
  .fstep{background:var(--bg-surface);border:1px solid var(--border);border-radius:var(--r-md);padding:12px 16px;display:flex;justify-content:space-between;align-items:center}
  .fstep .n{font-size:1.2rem;font-weight:800;color:var(--text-primary)}
  .fstep .l{font-size:.85rem;color:var(--text-secondary)}
</style>
