---
// /admin — SPA Operator Console (Phase 3). Internal hub: two overview groups + a directory of the
// operator sections. Reuses EXISTING operator pages (real, just re-homed under /admin access);
// sections needing a backend (analytics, leads, funnels, decision-log, live-tests, settings) are
// honest "coming soon" scaffolds — never faked. Access control is Phase 5 (no auth yet — do not
// link publicly). Not in the public nav.
import Layout from '../../layouts/Layout.astro';
import snap from '../../data/track_snapshot.json';

const days = snap.real_track_days ?? '—';
const apy = snap.paper_apy_pct != null ? '~' + Number(snap.paper_apy_pct).toFixed(1) + '%' : '—';
const gates = (snap.gates_passed != null && snap.gates_total != null) ? `${snap.gates_passed}/${snap.gates_total}` : '—';
const dd = snap.max_drawdown_pct != null ? Number(snap.max_drawdown_pct).toFixed(2) + '%' : '—';

// Snapshot freshness (operator monitoring — the build no longer BLOCKS on staleness, so surface it
// here instead). Computed at build time from as_of vs build date; > 2 days = stale.
const snapAsOf = snap.as_of || snap.generated_at || null;
let snapDaysOld = null;
if (snapAsOf) {
  const a = new Date(String(snapAsOf).slice(0, 10) + 'T00:00:00Z');
  if (!isNaN(a.getTime())) snapDaysOld = Math.floor((Date.now() - a.getTime()) / 86400000);
}
const snapFresh = snapDaysOld == null ? 'unknown' : snapDaysOld <= 2 ? 'fresh' : 'stale';

// Operator directory. `href` = existing real page (re-homed under /admin access). `soon` = needs a
// backend (analytics/leads/funnels/etc.) → scaffold, honest, not faked.
const sections = [
  { en: 'Overview', href: '/admin', real: true },
  { en: 'Product Analytics', href: '/admin/analytics', real: true },
  { en: 'Users & Leads', soon: true },
  { en: 'Funnels', href: '/admin/funnels', real: true },
  { en: 'Agents', href: '/admin/system-health', real: true, note: 'system + agent posture' },
  { en: 'Monitoring (RTMR)', href: '/admin/monitoring', real: true },
  { en: 'Strategies', href: '/strategies', real: true },
  { en: 'Tournaments', href: '/tournament', real: true },
  { en: 'Risk Board', href: '/board', real: true },
  { en: 'Decision Log', href: '/admin/decision-log', real: true },
  { en: 'Rejected Opportunities', href: '/refusals', real: true },
  { en: 'Backtests', href: '/cockpit/backtest', real: true },
  { en: 'Paper Tests', href: '/track-record', real: true },
  { en: 'Live Tests', soon: true },
  { en: 'Yield Rates', href: '/rates-desk', real: true },
  { en: 'Protocol Due Diligence', href: '/due-diligence', real: true },
  { en: 'Approvals / Security', href: '/security', real: true },
  { en: 'System Health', href: '/admin/system-health', real: true },
  { en: 'Research Desk', href: '/structural-desk', real: true, note: 'strategy framework + research' },
  { en: 'Settings', soon: true },
];
---

<Layout title="SPA Operator Console" admin={true}>
  <main class="ac">
    <div class="ac-wrap">
      <h1 class="ac-h1">Operator Console</h1>
      <p class="ac-sub">Internal command surface. Public site shows outputs; this shows inputs, signals, and operations. Access control lands in Phase 5.</p>

      <!-- Group 1: Strategy / System Operations -->
      <section class="ac-sec">
        <div class="ac-sec-h">Strategy / System Operations</div>
        <div class="ac-tiles">
          <a class="ac-tile" href="/track-record"><div class="k">Evidenced days</div><div class="v">{days}</div></a>
          <a class="ac-tile" href="/track-record"><div class="k">Current APY</div><div class="v teal">{apy}</div></a>
          <a class="ac-tile" href="/track-record"><div class="k">Max drawdown</div><div class="v">{dd}</div></a>
          <a class="ac-tile" href="/status"><div class="k">Go-live gates</div><div class="v">{gates}</div></a>
          <a class="ac-tile" href="/system"><div class="k">System health</div><div class="v" style="font-size:1rem">open →</div></a>
          <a class="ac-tile" href="/board"><div class="k">Risk board</div><div class="v" style="font-size:1rem">open →</div></a>
          <a class="ac-tile" href="/refusals"><div class="k">Latest refusals</div><div class="v" style="font-size:1rem">open →</div></a>
          <a class="ac-tile" href="/rates-desk"><div class="k">Yield rates</div><div class="v" style="font-size:1rem">open →</div></a>
          <div class="ac-tile" title="Track snapshot freshness — build no longer blocks on staleness (warn-only)">
            <div class="k">Track snapshot</div>
            <div class="v" style={`font-size:1rem;color:${snapFresh === 'stale' ? 'var(--warn)' : snapFresh === 'fresh' ? 'var(--data-teal)' : 'var(--text-muted)'}`}>
              {snapFresh === 'stale' ? `⚠ stale (${snapDaysOld}d)` : snapFresh === 'fresh' ? `✓ fresh (${snapDaysOld}d)` : 'unknown'}
            </div>
          </div>
        </div>
      </section>

      <!-- Group 2: Product / Site Performance (live from our own privacy-friendly counter) -->
      <section class="ac-sec">
        <div class="ac-sec-h">Product / Site Performance <span class="ac-soon" id="an-state">loading…</span></div>
        <div class="ac-tiles">
          <div class="ac-tile"><div class="k">Views today</div><div class="v" id="an-today">—</div></div>
          <div class="ac-tile"><div class="k">Views 7d</div><div class="v" id="an-7d">—</div></div>
          <div class="ac-tile"><div class="k">Analyze-wallet clicks</div><div class="v" id="an-analyze">—</div></div>
          <div class="ac-tile"><div class="k">Strategy Lab clicks</div><div class="v" id="an-strat">—</div></div>
          <div class="ac-tile"><div class="k">Pilot interest (7d)</div><div class="v" id="an-interest">—</div></div>
          <div class="ac-tile soon"><div class="k">Funnel completion</div><div class="v">—</div></div>
          <div class="ac-tile soon"><div class="k">Bounce rate</div><div class="v">—</div></div>
          <div class="ac-tile soon"><div class="k">Returning users</div><div class="v">—</div></div>
        </div>
        <div class="ac-pages" id="an-pages"></div>
        <p class="ac-note">Views &amp; CTA clicks are live from our own privacy-friendly counter (page + event + coarse time, no IP/cookies/PII). Leads, funnels, bounce and returning-user metrics need deeper event tracking — honest placeholders until then, never fabricated.</p>
      </section>
      <script is:inline>
        (function(){
          var API = (location.hostname==='localhost'||location.hostname==='127.0.0.1') ? 'http://localhost:8765' : 'https://api.earn-defi.com';
          function set(id,v){ var el=document.getElementById(id); if(el) el.textContent=v; }
          fetch(API+'/api/analytics/summary').then(function(r){return r.json();}).then(function(d){
            if(!d) return;
            set('an-today', d.views_today!=null?d.views_today:'—');
            set('an-7d', d.views_7d!=null?d.views_7d:'—');
            var ev=d.events||{};
            set('an-analyze', ev.analyze_wallet!=null?ev.analyze_wallet:0);
            set('an-strat', ev.view_strategy_lab!=null?ev.view_strategy_lab:0);
            set('an-state','live');
            var pg=document.getElementById('an-pages');
            if(pg && d.top_pages && d.top_pages.length){
              pg.innerHTML='<div class="ac-pages-h">Top pages</div>'+d.top_pages.map(function(p){return '<div class="ac-pg"><span>'+p.page+'</span><b>'+p.views+'</b></div>';}).join('');
            }
          }).catch(function(){ set('an-state','offline — API not reachable'); });
          // Q2-5: real anonymous pilot-interest count (PII-minimal sink) — replaces the placeholder tile.
          fetch(API+'/api/interest/summary').then(function(r){return r.json();}).then(function(d){
            if(d && d.interest_7d!=null) set('an-interest', d.interest_7d + (d.total_interest!=null?(' / '+d.total_interest+' total'):''));
          }).catch(function(){});
        })();
      </script>

      <!-- Readiness & safety proofs (composes the go-live/proof/safety artifacts into one operator view) -->
      <section class="ac-sec">
        <div class="ac-sec-h">Readiness &amp; Safety proofs <span class="ac-soon" id="rp-state">loading…</span></div>
        <div class="ac-tiles">
          <div class="ac-tile"><div class="k">Go-live gate</div><div class="v" id="rp-gate">—</div></div>
          <div class="ac-tile"><div class="k">Evidenced track</div><div class="v" id="rp-track">—</div></div>
          <div class="ac-tile"><div class="k">Track cum. return</div><div class="v" id="rp-cum">—</div></div>
          <div class="ac-tile"><div class="k">Governance defenses</div><div class="v" id="rp-gov">—</div></div>
          <div class="ac-tile"><div class="k">RTMR defenses</div><div class="v" id="rp-rtmr">—</div></div>
          <div class="ac-tile"><div class="k">Kill-switch drill</div><div class="v" id="rp-ksd">—</div></div>
        </div>
        <p class="ac-note">Live from <code>/api/readiness</code>: the go-live gate, the dated evidenced-track ledger, and the proven-to-FIRE defenses (daily-cycle kill ladder + the RTMR real-time reaction ladder) + the dated kill-switch latency drill. Every figure is reproducible with the standalone scripts — nothing fabricated.</p>
      </section>
      <script is:inline>
        (function(){
          var API = (location.hostname==='localhost'||location.hostname==='127.0.0.1') ? 'http://localhost:8765' : 'https://api.earn-defi.com';
          function set(id,v){ var el=document.getElementById(id); if(el) el.textContent=v; }
          fetch(API+'/api/readiness').then(function(r){return r.json();}).then(function(d){
            if(!d) return;
            var gl=d.go_live_gate||{}, tl=d.track_ledger||{}, g=d.governance_defenses||{}, rt=d.rtmr_defenses||{}, k=d.kill_switch_drill||{};
            if(gl.passed!=null) set('rp-gate', gl.passed+'/'+gl.total);
            var days=(tl.n_evidenced_days!=null)?tl.n_evidenced_days:gl.evidenced_days;
            if(days!=null) set('rp-track', days+'/'+((tl.days_needed)||gl.days_needed||30));
            if(tl.cumulative_return_pct!=null) set('rp-cum', tl.cumulative_return_pct+'%');
            if(g.fired!=null) set('rp-gov', g.fired+'/'+g.total+(g.all_fired?' ✓':''));
            if(rt.fired!=null) set('rp-rtmr', rt.fired+'/'+rt.total+(rt.all_fired?' ✓':''));
            if(k.latency_ms!=null) set('rp-ksd', k.latency_ms+'ms '+(k.passed?'✓':''));
            set('rp-state','live');
          }).catch(function(){ set('rp-state','offline — API not reachable'); });
        })();
      </script>

      <!-- Operator directory -->
      <section class="ac-sec">
        <div class="ac-sec-h">Operator sections</div>
        <div class="ac-dir">
          {sections.map((s) => (
            s.soon ? (
              <div class="ac-dir-item soon"><span class="lbl">{s.en}</span><span class="tag">soon</span></div>
            ) : (
              <a class="ac-dir-item" href={s.href}><span class="lbl">{s.en}</span>{s.note && <span class="desc">{s.note}</span>}<span class="arr">→</span></a>
            )
          ))}
        </div>
      </section>
    </div>
  </main>
</Layout>

<style>
  .ac{background:var(--bg-base); min-height:calc(100vh - 52px); padding:32px 0 80px}
  .ac-wrap{max-width:1100px; margin:0 auto; padding:0 24px}
  .ac-h1{font-size:1.6rem; font-weight:800; color:var(--text-primary); margin:0}
  .ac-sub{color:var(--text-secondary); font-size:.9375rem; margin:8px 0 28px; max-width:680px}
  .ac-sec{margin-bottom:30px}
  .ac-sec-h{font-family:var(--font-mono); font-size:.75rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:var(--text-muted); margin-bottom:14px; display:flex; gap:12px; align-items:center; flex-wrap:wrap}
  .ac-soon{color:var(--warn); font-weight:600; letter-spacing:0; text-transform:none; font-family:var(--font-sans); font-size:.75rem}
  .ac-tiles{display:grid; grid-template-columns:repeat(4,1fr); gap:12px}
  @media(max-width:820px){.ac-tiles{grid-template-columns:1fr 1fr}}
  .ac-tile{background:var(--bg-surface); border:1px solid var(--border); border-radius:var(--r-md); padding:16px 18px; text-decoration:none; transition:border-color 120ms}
  .ac-tile:hover{border-color:var(--border-strong)}
  .ac-tile.soon{opacity:.55}
  .ac-tile .k{font-size:.6875rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:.04em}
  .ac-tile .v{font-size:1.5rem; font-weight:800; color:var(--text-primary); margin-top:6px}
  .ac-tile .v.teal{color:var(--data-teal)}
  .ac-note{font-size:.8125rem; color:var(--text-faint); margin-top:12px}
  .ac-dir{display:grid; grid-template-columns:repeat(3,1fr); gap:10px}
  @media(max-width:820px){.ac-dir{grid-template-columns:1fr}}
  .ac-dir-item{display:flex; align-items:center; gap:8px; background:var(--bg-surface); border:1px solid var(--border); border-radius:var(--r-sm); padding:13px 15px; text-decoration:none; transition:border-color 120ms}
  .ac-dir-item:hover{border-color:var(--border-strong)}
  .ac-dir-item .lbl{color:var(--text-primary); font-size:.875rem; font-weight:600}
  .ac-dir-item .desc{color:var(--text-muted); font-size:.75rem}
  .ac-dir-item .arr{margin-left:auto; color:var(--accent)}
  .ac-dir-item.soon{opacity:.5}
  .ac-dir-item.soon .tag{margin-left:auto; font-family:var(--font-mono); font-size:.625rem; text-transform:uppercase; color:var(--text-muted); border:1px solid var(--border); border-radius:var(--r-full); padding:2px 8px}
  .ac-pages{margin-top:14px}
  .ac-pages-h{font-family:var(--font-mono); font-size:.6875rem; text-transform:uppercase; letter-spacing:.05em; color:var(--text-muted); margin-bottom:8px}
  .ac-pg{display:flex; justify-content:space-between; font-size:.8125rem; padding:6px 0; border-bottom:1px solid var(--border); color:var(--text-secondary)}
  .ac-pg b{color:var(--text-primary)}
</style>
