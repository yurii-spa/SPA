  <!-- ===================================================================== IN-BROWSER RE-HASH -->
  <script is:inline>
    /* Live re-hash demo. Fetches the PUBLIC decision log (raw rows, verbatim) and recomputes one
       row's entry_hash with Web Crypto SHA-256 over the §3 canonical JSON — reproducing the exact
       recipe scripts/verify_spa.py and docs/PROOF_CHAIN_SPEC.md publish. Graceful offline. */
    (function () {
      var API = (location.hostname === 'localhost' || location.hostname === '127.0.0.1')
        ? 'http://localhost:8765'
        : 'https://api.earn-defi.com';
      // §3 invariants (verbatim from the spec — NOT fetched from the server).
      var ENVELOPE = ['seq', 'ts', 'entry_hash', 'prev_hash'];
      var EVENT_TYPE = 'rates_desk_decision';

      function isRu() { try { return (localStorage.getItem('spa_lang') || 'en') === 'ru'; } catch (e) { return false; } }
      function setText(id, t) { var el = document.getElementById(id); if (el) el.textContent = t; }

      /* Canonical JSON matching Python json.dumps(sort_keys=True, separators=(',',':'),
         ensure_ascii=False). Recursive key sort; compact separators; JSON.stringify of a
         string already matches Python's ensure_ascii=False escaping for the published fields. */
      function canon(v) {
        if (v === null) return 'null';
        if (Array.isArray(v)) return '[' + v.map(canon).join(',') + ']';
        if (typeof v === 'object') {
          var keys = Object.keys(v).sort();
          var parts = [];
          for (var i = 0; i < keys.length; i++) {
            parts.push(JSON.stringify(keys[i]) + ':' + canon(v[keys[i]]));
          }
          return '{' + parts.join(',') + '}';
        }
        if (typeof v === 'string') return JSON.stringify(v);
        if (typeof v === 'boolean') return v ? 'true' : 'false';
        // Numbers: the published money/rate values are STRINGS, so a bare number here is a
        // structural int (e.g. seq). Render with the JSON default (no reformatting risk).
        return JSON.stringify(v);
      }

      function sha256Hex(str) {
        var bytes = new TextEncoder().encode(str);
        return crypto.subtle.digest('SHA-256', bytes).then(function (buf) {
          var arr = new Uint8Array(buf), hex = '';
          for (var i = 0; i < arr.length; i++) { hex += arr[i].toString(16).padStart(2, '0'); }
          return hex;
        });
      }

      function setBadge(state) {
        var ru = isRu();
        var badge = document.getElementById('vd-badge');
        var dot = document.getElementById('vd-badge-dot');
        var txt = document.getElementById('vd-badge-text');
        if (!badge || !dot || !txt) return;
        // Literal Tailwind palettes (Tailwind only compiles classes it can see literally).
        badge.className = 'inline-flex items-center gap-2 px-3 py-1.5 rounded-md border text-xs font-mono';
        if (state === 'match') {
          badge.className += ' bg-ok-bg border-ok-border text-ok';
          dot.className = 'w-2 h-2 rounded-full bg-ok';
          txt.textContent = ru ? 'СОВПАЛО · хеш пересчитан здесь' : 'MATCH · re-derived right here';
        } else if (state === 'mismatch') {
          badge.className += ' bg-danger-bg border-danger-border text-danger';
          dot.className = 'w-2 h-2 rounded-full bg-danger';
          txt.textContent = ru ? 'НЕ СОВПАЛО' : 'MISMATCH';
        } else {
          badge.className += ' border-[var(--border)] text-[var(--text-muted)]';
          badge.style.background = 'var(--bg-surface)';
          dot.className = 'w-2 h-2 rounded-full';
          dot.style.background = 'var(--text-muted)';
          txt.textContent = ru ? 'демо недоступно (API офлайн)' : 'demo unavailable (API offline)';
        }
      }

      function recompute(row) {
        // Build the §3 hashed object: payload = row minus the 4 envelope keys.
        var payload = {};
        for (var k in row) {
          if (Object.prototype.hasOwnProperty.call(row, k) && ENVELOPE.indexOf(k) === -1) {
            payload[k] = row[k];
          }
        }
        var obj = {
          seq: row.seq, ts: row.ts, event_type: EVENT_TYPE, payload: payload, prev_hash: row.prev_hash,
        };
        var preimage = canon(obj);
        var canonEl = document.getElementById('vd-canon');
        if (canonEl) {
          // show a head + tail so the box stays readable but is clearly the real bytes
          canonEl.textContent = preimage.length > 1400
            ? preimage.slice(0, 700) + '\n  … (' + preimage.length + ' bytes total) …\n' + preimage.slice(-700)
            : preimage;
        }
        setText('vd-seq', String(row.seq));
        setText('vd-underlying', String((row.decomposition && row.decomposition.underlying) || row.underlying || '?'));
        setText('vd-published', String(row.entry_hash || '—'));
        sha256Hex(preimage).then(function (hex) {
          setText('vd-computed', hex);
          setBadge(hex === row.entry_hash ? 'match' : 'mismatch');
        });
      }

      function init() {
        if (!crypto || !crypto.subtle) { setBadge('offline'); return; }
        fetch(API + '/api/rates-desk/decisions?limit=12').then(function (r) { return r.json(); }).then(function (d) {
          var rows = (d && Array.isArray(d.decisions)) ? d.decisions : [];
          // pick the latest row that carries a full envelope (seq + entry_hash + prev_hash + ts).
          var pick = null;
          for (var i = rows.length - 1; i >= 0; i--) {
            var r = rows[i];
            if (r && typeof r.seq === 'number' && r.entry_hash && r.prev_hash && r.ts) { pick = r; break; }
          }
          if (!pick) { setBadge('offline'); return; }
          setText('vd-src', 'live');
          recompute(pick);
        }).catch(function () { setBadge('offline'); });
      }
      if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', init); }
      else { init(); }
    })();
  </script>
