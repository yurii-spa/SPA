        <div class="rounded-lg p-4 overflow-x-auto" style="background:var(--bg-base);border:1px solid var(--border)">
          <code class="text-xs sm:text-sm font-mono break-all" style="color:var(--text-secondary)">pip install opentimestamps-client &amp;&amp; ots verify proofs/ots/&lt;head&gt;.head.ots</code>
