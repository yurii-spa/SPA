---
// Homepage — Direction C "Console" (spec §7-C). Canonical chrome (header, paper
// strip, footer) comes from Layout; this page is just the Console body + sections.
import Layout from '../layouts/Layout.astro';
import snap from '../data/track_snapshot.json';

// Build-time honest static fallback (last evidenced snapshot) — mirrors the pattern
// track-record.astro uses. Live values from api.earn-defi.com override these client-side;
// this keeps the hero + track glance readable (real last-evidenced numbers, not bare "—")
// when the API is offline. Numbers are NOT hardcoded — they come from the committed
// snapshot derived from data/golive_status.json + data/equity_curve_daily.json.
// ONE source (FIX-2): every hero number comes from track_snapshot.json (built from the committed
// golive_status + equity_curve + paper_trading_status — the same authority the API serves). NO
// hardcoded fallback: a missing value renders an honest em-dash, never a stale/invented number.
const snapDays = snap.real_track_days != null ? snap.real_track_days : '—';
const snapGates = (snap.gates_passed != null && snap.gates_total != null) ? `${snap.gates_passed}/${snap.gates_total}` : '—';
const snapBars = Array.isArray(snap.bars) ? snap.bars : [];
const snapApy = snap.paper_apy_pct != null ? '~' + Number(snap.paper_apy_pct).toFixed(1) + '%' : '—';
const snapDd = snap.max_drawdown_pct != null ? Number(snap.max_drawdown_pct).toFixed(2) + '%' : '—';
// Snapshot freshness label ("as of <date>") — the JS island flips it to live when the API answers.
const snapAsOf = snap.as_of || snap.generated_at || null;
// Equity series for the offline spark fallback (build-time, last snapshot).
const snapEquity = snapBars.map((b) => Number(b.equity)).filter((v) => isFinite(v));
---

<Layout
  title="SPA — systematic onchain stablecoin yield | earn-defi.com"
  description="Personal research project: a deterministic, LLM-free DeFi stablecoin-yield optimizer in paper validation, evidenced track anchored June 22, 2026. Not raising capital."
>
  <!-- ============ HERO (Direction C — Console, institutional) ============ -->
  <section class="hero">
    <div class="hero-inner">
      <span class="hero-eyebrow" data-ru="Детерминированный · без LLM · публичный">Deterministic · LLM-free · public</span>
      <h1>
        <span data-ru="Систематическая ончейн">Systematic onchain</span>
        <span class="accent" data-ru="доходность по стейблкоинам.">stablecoin yield.</span>
      </h1>
      <p class="sub" data-ru="Детерминированный оптимизатор доходности DeFi без LLM. Каждое решение — политика, а не модель: воспроизводимо, залогировано и публично проверяемо.">
        A deterministic, LLM-free DeFi yield optimizer. Every decision is policy, not a model —
        reproducible, logged, and publicly verifiable.
      </p>
      <div class="status-line" id="statusLine" aria-live="polite">
        <span class="dot" aria-hidden="true"></span>
        <span class="seg" data-ru="режим бумаги">paper mode</span>
        <span class="div">·</span><span class="num" id="sl-day">{snapDays}</span>&nbsp;<span data-ru="подтв. дней">evidenced days</span>
        <span class="div">·</span><span class="num" id="sl-apy">{snapApy}</span>&nbsp;<span data-ru="бумажный APY">paper APY</span>
        <span class="div">·</span><span class="num" id="sl-gates">{snapGates}</span>&nbsp;<span data-ru="критериев">criteria</span>
        {snapAsOf && <span class="div">·</span>}{snapAsOf && <span class="seg" id="sl-asof" style="opacity:.6" data-ru={`на ${snapAsOf}`}>as of {snapAsOf}</span>}
      </div>

      <!-- Journey chooser — pick a lens instead of a duplicated single CTA. -->
      <div class="journey" role="group" aria-label="Choose your path">
        <a class="jc" href="/track-record">
          <span class="jc-role" data-ru="Инвестор">Investor</span>
          <span class="jc-desc" data-ru="Начните с честного трека и фандабилити.">Start with the honest track record &amp; fundability.</span>
          <span class="jc-links">
            <span data-ru="Трек-рекорд">Track record</span> ·
            <span data-ru="Фандабилити">Fundability</span> ·
            <span data-ru="Проверка">Verify</span>
            <span class="jc-arrow" aria-hidden="true">→</span>
          </span>
        </a>
        <a class="jc" href="/board">
          <span class="jc-role" data-ru="Аналитик">Analyst</span>
          <span class="jc-desc" data-ru="Разберите риск пулов и научитесь читать деск.">Dig into pool-level risk and learn to read the desk.</span>
          <span class="jc-links">
            <span data-ru="Риск-борд">Risk Board</span> ·
            <span data-ru="Академия">Academy</span>
            <span class="jc-arrow" aria-hidden="true">→</span>
          </span>
        </a>
        <a class="jc" href="/verify">
          <span class="jc-role" data-ru="Скептик">Skeptic</span>
          <span class="jc-desc" data-ru="Не верьте нам — пересчитайте каждый хеш сами.">Don't trust us — re-derive every hash yourself.</span>
          <span class="jc-links">
            <span data-ru="Проверка">Verify</span> ·
            <span data-ru="Отказы">Refusals</span> ·
            <span data-ru="Доказательства">Proof</span>
            <span class="jc-arrow" aria-hidden="true">→</span>
          </span>
        </a>
      </div>

      <div class="hero-tail">
        <a class="btn btn-primary" href="/dashboard" data-ru="Открыть дашборд ↗">Open dashboard ↗</a>
        <a class="por-chip" id="porChip" href="/proof-of-reserves" title="Proof of Reserves">
          <span class="por-dot" aria-hidden="true"></span>
          <span data-ru="Доказательство резервов">Proof of Reserves</span>
          <span class="por-state" id="porChipState" data-ru="загрузка…">loading…</span>
          <span class="por-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ STRATEGIES — tier cards (main content) ============ -->
  <section class="band" id="strategies">
    <div class="container">
      <div class="sec-head">
        <span class="eyebrow" data-ru="Стратегии">Strategies</span>
        <h2 data-ru="Три профиля риска, одна детерминированная политика">Three risk profiles, one deterministic policy</h2>
        <p data-ru="Доходность бумажная и переменная, не гарантирована. Live-данные через api.earn-defi.com.">APY is paper and variable, not guaranteed. Live data via api.earn-defi.com.</p>
        <div class="pkg-meta-row">
          <span class="pkg-meta-chip" id="pkgMetaChip">
            <span class="dot" aria-hidden="true"></span>
            <span id="pkgMetaText" data-ru="Чистый APY — валидированный бэктест · advisory · не реализованный капитал">Net APY — validated backtest · advisory · not realized capital</span>
          </span>
        </div>
      </div>
      <div class="tier-grid" id="tierGrid">
        <div class="tier-card t-preserve">
          <h3>Preserve</h3>
          <span class="pill ok" data-ru="Бумажный трек">Paper-tracked</span>
          <div class="tier-apy" data-fb="apy">—<small> net APY</small></div>
          <div class="tier-cap" data-ru="бумажный · переменный · не гарантирован">paper · variable · not guaranteed</div>
          <ul class="tier-dl">
            <li><span class="k" data-ru="Профиль риска">Risk band</span><span class="v" data-ru="Низкий">Low</span></li>
            <li><span class="k" data-ru="Макс. просадка">Max drawdown</span><span class="v" data-fb="dd">—</span></li>
            <li><span class="k" data-ru="Состав">Tier mix</span><span class="v">T1</span></li>
          </ul>
          <p class="tier-who" data-ru="Капитал прежде всего — только пулы Уровня 1.">Capital-first — Tier 1 pools only.</p>
          <a class="btn-card" href="/strategies/preserve" data-ru="Подробнее →">View strategy details →</a>
        </div>
        <div class="tier-card t-core">
          <h3>Core</h3>
          <span class="pill ok" data-ru="Бумажный трек">Paper-tracked</span>
          <div class="tier-apy" data-fb="apy">—<small> net APY</small></div>
          <div class="tier-cap" data-ru="бумажный · переменный · не гарантирован">paper · variable · not guaranteed</div>
          <ul class="tier-dl">
            <li><span class="k" data-ru="Профиль риска">Risk band</span><span class="v" data-ru="Сбаланс.">Balanced</span></li>
            <li><span class="k" data-ru="Макс. просадка">Max drawdown</span><span class="v" data-fb="dd">—</span></li>
            <li><span class="k" data-ru="Состав">Tier mix</span><span class="v">T1 + T2</span></li>
          </ul>
          <p class="tier-who" data-ru="Сбалансированная база Уровней 1 и 2.">Balanced Tier 1 + Tier 2 blend.</p>
          <a class="btn-card" href="/strategies/core" data-ru="Подробнее →">View strategy details →</a>
        </div>
        <div class="tier-card t-max">
          <h3>Max Yield</h3>
          <span class="pill wait" data-ru="Целевой профиль">Target profile</span>
          <div class="tier-apy" data-fb="apy">—<small> net APY</small></div>
          <div class="tier-cap" data-ru="целевой диапазон · не в бумажном треке">target range · not in paper track</div>
          <ul class="tier-dl">
            <li><span class="k" data-ru="Профиль риска">Risk band</span><span class="v" data-ru="Выше">Higher</span></li>
            <li><span class="k" data-ru="Макс. просадка">Max drawdown</span><span class="v" data-fb="dd">—</span></li>
            <li><span class="k" data-ru="Состав">Tier mix</span><span class="v">T1 + T2</span></li>
          </ul>
          <p class="tier-who" data-ru="Шире диверсификация по Уровню 2; пока вне бумажного трека.">Wider Tier 2 diversification; not yet in paper track.</p>
          <a class="btn-card" href="/strategies/max-yield" data-ru="Подробнее →">View strategy details →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ TRACK-RECORD GLANCE ============ -->
  <section class="band" id="track">
    <div class="container">
      <div class="sec-head">
        <span class="eyebrow" data-ru="Трек-рекорд">Track Record</span>
        <h2 data-ru="Честный бумажный трек, в реальном времени">An honest paper track, live</h2>
      </div>
      <div class="track-band">
        <div class="track-metrics">
          <div class="metric-card"><div class="lbl" data-ru="Подтверждённых дней">Evidenced days</div><div class="val" id="m-days">{snapDays}</div></div>
          <div class="metric-card"><div class="lbl" data-ru="Бумажный APY">Paper APY</div><div class="val teal" id="m-apy">{snapApy}</div></div>
          <div class="metric-card"><div class="lbl" data-ru="Макс. просадка">Max drawdown</div><div class="val" id="m-dd">{snapDd}</div></div>
          <div class="metric-card"><div class="lbl" data-ru="Прогресс Go-Live">Go-live progress</div><div class="val" id="m-gates">{snapGates}</div></div>
        </div>
        <div class="spark-wrap">
          <div class="sh">
            <span class="eyebrow" data-ru="Кривая капитала">Equity curve</span>
            <span class="src" id="spark-src" data-ru="снимок">snapshot</span>
          </div>
          <svg id="spark" viewBox="0 0 400 120" preserveAspectRatio="none" role="img" aria-label="Paper equity curve" data-points={JSON.stringify(snapEquity)}></svg>
          <div class="spark-foot" data-ru="Виртуальный портфель $100,000 USDC · считаются только дни с логом цикла (мы сбросили трек) · реестр на /track-record">Virtual $100,000 USDC portfolio · only cycle-logged days count (we reset the track) · ledger at /track-record</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ HOW IT WORKS (compact) ============ -->
  <section class="band" id="how">
    <div class="container">
      <div class="sec-head">
        <span class="eyebrow" data-ru="Как это работает">How it works</span>
        <h2 data-ru="Детерминированный дневной цикл">A deterministic daily cycle</h2>
      </div>
      <div class="steps">
        <div class="step">
          <div class="n">01</div>
          <h4 data-ru="Считываем рынок">Read the market</h4>
          <p data-ru="Read-only адаптеры получают живые APY/TVL из whitelist-протоколов DeFi.">Read-only adapters pull live APY/TVL from whitelisted DeFi protocols.</p>
        </div>
        <div class="step">
          <div class="n">02</div>
          <h4 data-ru="Решает политика, не LLM">Policy decides, not an LLM</h4>
          <p data-ru="Детерминированная RiskPolicy задаёт лимиты TVL, концентрации и денежного буфера.">A deterministic RiskPolicy enforces TVL, concentration, and cash-buffer limits.</p>
        </div>
        <div class="step">
          <div class="n">03</div>
          <h4 data-ru="Логируем всё">Log everything</h4>
          <p data-ru="Каждая бумажная сделка, решение риск-гейта и точка кривой капитала публичны.">Every paper trade, risk-gate decision, and equity point is public.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ RESEARCH / STRUCTURAL DESK ============ -->
  <section class="band">
    <div class="container">
      <div class="sec-head">
        <span class="eyebrow" data-ru="Исследование">Research</span>
        <h2 data-ru="Реальный эдж — это структурная роль">The real edge is a structural role</h2>
      </div>
      <a class="research-card" href="/structural-desk">
        <p class="rc-lead" data-ru="Наш собственный бэктест доказал: обычная крипто-доходность — не эдж. Реальный эдж масштаба $10M — это прозрачный стол измерения и андеррайтинга для on-chain ставок, залога и риска. Три тезиса, де-рискнутых на нашем стеке: Rates Desk (GO), RWA-бэкстоп (measurement-GO), Кросс-доменный ликвидатор (NO-GO — мы публикуем то, что убили).">
          Our own backtest proved plain crypto yield isn't an edge. The real $10M-scale edge is a
          transparent measurement &amp; underwriting desk for on-chain rates, collateral and risk.
          Three theses, de-risked on our stack: Rates Desk (GO), RWA Backstop (measurement-GO),
          Cross-Domain Liquidator (NO-GO — we publish what we killed).
        </p>
        <span class="rc-cta" data-ru="Открыть Структурный стол →">Open the Structural Desk →</span>
      </a>
    </div>
  </section>

  <!-- ============ FINAL CTA ============ -->
  <section class="band">
    <div class="container final-cta">
      <h2 data-ru="Смотрите систему вживую">See the system, live</h2>
      <p data-ru="Дашборд, бумажные сделки и чек-лист go-live — публичны и обновляются ежедневно.">The dashboard, paper trades, and go-live checklist are public and updated daily.</p>
      <a class="btn btn-primary" href="/dashboard" data-ru="Открыть дашборд ↗">Open dashboard ↗</a>
    </div>
  </section>
</Layout>

<style is:global>
  /* Console homepage styles — consume global tokens from Layout (spec §3). */
  .container{max-width:1152px; margin:0 auto; padding:0 24px}
  .eyebrow{font-family:var(--font-mono); font-size:.75rem; font-weight:600; letter-spacing:.12em; text-transform:uppercase; color:var(--text-faint)}

  /* Hero */
  .hero{
    min-height:calc(100vh - 64px - 42px); display:flex; flex-direction:column; justify-content:center;
    padding:80px 0; position:relative; overflow:hidden;
  }
  .hero::before{
    content:""; position:absolute; inset:0; pointer-events:none;
    background:radial-gradient(ellipse 70% 55% at 50% 38%, rgba(91,141,239,.08), transparent 70%);
  }
  .hero-inner{position:relative; max-width:920px; margin:0 auto; padding:0 24px; text-align:center}
  .hero-eyebrow{display:inline-block; font-family:var(--font-mono); font-size:.75rem; font-weight:600; letter-spacing:.12em; text-transform:uppercase; color:var(--text-faint); margin-bottom:18px}
  .hero h1{font-size:clamp(2rem,6vw,3.5rem); line-height:1.05; font-weight:700; color:var(--text-primary); letter-spacing:-.02em; margin-bottom:20px}
  .hero h1 .accent{color:var(--accent)}
  .hero .sub{font-size:clamp(1rem,2.2vw,1.1875rem); color:var(--text-secondary); max-width:620px; margin:0 auto 28px; line-height:1.6}
  .btn{display:inline-flex; align-items:center; gap:8px; border-radius:var(--r-sm); font-weight:600; font-size:.9375rem; transition:all 120ms var(--ease); cursor:pointer; text-decoration:none}
  .btn-primary{background:var(--accent); color:#fff; padding:14px 26px; box-shadow:var(--shadow-cta)}
  .btn-primary:hover{background:var(--accent-hover); color:#fff; transform:translateY(-2px)}
  .status-line{display:inline-flex; align-items:center; gap:0; flex-wrap:wrap; justify-content:center; font-family:var(--font-mono); font-size:.8125rem; color:var(--text-muted); margin-bottom:36px}
  .status-line .dot{display:inline-block; width:8px; height:8px; border-radius:50%; background:var(--warn); margin-right:8px; animation:pulse 3s cubic-bezier(.4,0,.6,1) infinite}
  .status-line .seg{color:var(--text-secondary)}
  .status-line .div{color:var(--text-faint); margin:0 8px}
  .status-line .num{color:var(--data-teal)}

  /* Journey chooser — three lenses (Investor / Analyst / Skeptic) */
  .journey{display:grid; grid-template-columns:repeat(3,1fr); gap:16px; max-width:820px; margin:0 auto 32px; text-align:left}
  .jc{display:flex; flex-direction:column; gap:8px; padding:22px; border-radius:var(--r-lg); border:1px solid var(--border); background:var(--bg-surface); text-decoration:none; transition:border-color 120ms var(--ease), transform 200ms var(--ease)}
  .jc:hover{border-color:var(--border-strong); transform:translateY(-3px)}
  .jc-role{font-size:1rem; font-weight:600; color:var(--text-primary)}
  .jc-desc{font-size:.8125rem; color:var(--text-secondary); line-height:1.5; flex:1}
  .jc-links{font-family:var(--font-mono); font-size:.6875rem; color:var(--text-muted); display:flex; align-items:center; gap:5px; flex-wrap:wrap}
  .jc-arrow{color:var(--accent); margin-left:auto; transition:transform 120ms var(--ease)}
  .jc:hover .jc-arrow{transform:translateX(3px); color:var(--accent-hover)}

  .hero-tail{display:flex; align-items:center; justify-content:center; gap:16px; flex-wrap:wrap}
  .por-chip{display:inline-flex; align-items:center; gap:8px; padding:8px 14px; border-radius:var(--r-full); border:1px solid var(--border); background:var(--bg-surface); font-family:var(--font-mono); font-size:.75rem; color:var(--text-secondary); text-decoration:none; transition:all 120ms var(--ease)}
  .por-chip:hover{border-color:var(--border-strong); color:var(--text-primary)}
  .por-chip .por-dot{width:7px; height:7px; border-radius:50%; background:var(--text-faint)}
  .por-chip.ok .por-dot{background:var(--data-teal); box-shadow:0 0 8px rgba(54,194,180,.6)}
  .por-chip.warn .por-dot{background:var(--warn)}
  .por-chip .por-state{color:var(--text-muted)}
  .por-chip.ok .por-state{color:var(--data-teal)}
  .por-chip.warn .por-state{color:var(--warn)}
  .por-chip .por-arrow{color:var(--text-faint); transition:transform 120ms var(--ease)}
  .por-chip:hover .por-arrow{transform:translateX(2px); color:var(--text-secondary)}

  /* Section scaffold */
  section.band{padding:96px 0; border-top:1px solid var(--border)}
  .sec-head{text-align:center; margin-bottom:48px}
  .sec-head .eyebrow{display:block; margin-bottom:12px}
  .sec-head h2{font-size:1.5rem; font-weight:600; color:var(--text-primary); line-height:1.25; letter-spacing:-.01em}
  .sec-head p{color:var(--text-secondary); max-width:560px; margin:12px auto 0; font-size:.9375rem}

  /* Honesty chip (tier packages = validated backtest, not realized) */
  .pkg-meta-row{margin-top:16px; display:flex; justify-content:center}
  .pkg-meta-chip{display:inline-flex; align-items:center; gap:7px; font-family:var(--font-mono); font-size:.6875rem; text-transform:uppercase; letter-spacing:.04em; padding:5px 12px; border-radius:var(--r-full); background:rgba(242,181,60,.08); color:var(--warn); border:1px solid rgba(242,181,60,.28)}
  .pkg-meta-chip .dot{width:6px; height:6px; border-radius:var(--r-full); background:var(--warn); opacity:.85}

  /* Tier cards */
  .tier-grid{display:grid; grid-template-columns:repeat(3,1fr); gap:24px; align-items:stretch}
  .tier-card{background:var(--bg-surface); border:1px solid var(--border); border-radius:var(--r-lg); border-top:3px solid var(--border); padding:32px; display:flex; flex-direction:column; transition:border-color 120ms var(--ease), transform 200ms var(--ease)}
  .tier-card:hover{border-color:var(--border-strong); transform:translateY(-3px)}
  .tier-card.t-preserve{border-top-color:var(--data-teal)}
  .tier-card.t-core{border-top-color:var(--accent)}
  .tier-card.t-max{border-top-color:var(--warn)}
  .tier-card h3{font-size:1.25rem; font-weight:600; color:var(--text-primary); margin-bottom:10px}
  .pill{display:inline-flex; align-items:center; gap:6px; align-self:flex-start; font-family:var(--font-mono); font-size:.6875rem; font-weight:600; letter-spacing:.04em; padding:4px 10px; border-radius:var(--r-full); margin-bottom:20px; text-transform:uppercase}
  .pill.ok{background:rgba(52,211,153,.12); color:var(--ok); border:1px solid rgba(52,211,153,.25)}
  .pill.wait{background:rgba(242,181,60,.10); color:var(--warn); border:1px solid rgba(242,181,60,.22)}
  .tier-apy{font-family:var(--font-mono); font-size:2.5rem; line-height:1; font-weight:700; color:var(--text-primary); margin-bottom:6px}
  .tier-apy small{font-size:.8125rem; font-weight:500; color:var(--text-muted); letter-spacing:0}
  .tier-cap{font-size:.6875rem; color:var(--text-muted); margin-bottom:24px}
  .tier-dl{list-style:none; margin:0 0 24px; padding:0}
  .tier-dl li{display:flex; justify-content:space-between; gap:12px; padding:8px 0; border-bottom:1px solid var(--border); font-size:.8125rem}
  .tier-dl li:last-child{border-bottom:none}
  .tier-dl .k{color:var(--text-muted)}
  .tier-dl .v{font-family:var(--font-mono); color:var(--text-secondary)}
  .tier-who{font-size:.8125rem; color:var(--text-secondary); margin-bottom:24px; line-height:1.5; flex:1}
  .tier-card .btn-card{margin-top:auto; display:flex; align-items:center; justify-content:center; gap:6px; padding:12px; border-radius:var(--r-sm); border:1px solid var(--border); color:var(--text-secondary); font-size:.8125rem; font-weight:600; text-decoration:none; transition:all 120ms var(--ease)}
  .tier-card .btn-card:hover{border-color:var(--border-strong); color:var(--text-primary)}

  /* Track-record glance */
  .track-band{display:grid; grid-template-columns:1.1fr 1fr; gap:48px; align-items:center}
  .track-metrics{display:grid; grid-template-columns:repeat(2,1fr); gap:16px}
  .metric-card{background:var(--bg-surface); border:1px solid var(--border); border-radius:var(--r-md); padding:20px}
  .metric-card .lbl{font-family:var(--font-mono); font-size:.6875rem; text-transform:uppercase; letter-spacing:.08em; color:var(--text-muted); margin-bottom:8px}
  .metric-card .val{font-family:var(--font-mono); font-size:1.75rem; font-weight:700; color:var(--text-primary); line-height:1}
  .metric-card .val.teal{color:var(--data-teal)}
  .spark-wrap{background:var(--bg-surface); border:1px solid var(--border); border-radius:var(--r-lg); padding:24px}
  .spark-wrap .sh{display:flex; align-items:center; justify-content:space-between; margin-bottom:16px}
  .spark-wrap .sh .eyebrow{color:var(--accent)}
  .spark-wrap .sh .src{font-family:var(--font-mono); font-size:.6875rem; color:var(--text-muted)}
  #spark{width:100%; height:120px; display:block}
  .spark-foot{font-size:.6875rem; color:var(--text-muted); margin-top:12px; text-align:center}

  /* How it works */
  .steps{display:grid; grid-template-columns:repeat(3,1fr); gap:24px}
  .step{background:var(--bg-surface); border:1px solid var(--border); border-radius:var(--r-lg); padding:28px; transition:border-color 120ms var(--ease)}
  .step:hover{border-color:var(--border-strong)}
  .step .n{font-family:var(--font-mono); font-size:.75rem; color:var(--accent); margin-bottom:14px; letter-spacing:.1em}
  .step h4{font-size:1rem; font-weight:600; color:var(--text-primary); margin-bottom:8px}
  .step p{font-size:.875rem; color:var(--text-secondary); line-height:1.55}

  /* Final CTA */
  .final-cta{text-align:center}
  .final-cta h2{font-size:1.75rem; font-weight:700; color:var(--text-primary); margin-bottom:14px; letter-spacing:-.01em}
  .final-cta p{color:var(--text-secondary); max-width:480px; margin:0 auto 28px}

  /* Research / Structural Desk card */
  .research-card{display:block; max-width:760px; margin:0 auto; padding:28px 32px; border-radius:var(--r-lg); border:1px solid var(--border); background:var(--bg-surface); transition:all 120ms var(--ease); text-decoration:none}
  .research-card:hover{border-color:var(--border-strong); transform:translateY(-2px)}
  .research-card .rc-lead{color:var(--text-secondary); font-size:.9375rem; line-height:1.65; margin:0 0 18px}
  .research-card .rc-cta{display:inline-flex; align-items:center; gap:6px; color:var(--accent); font-weight:600; font-size:.9375rem}
  .research-card:hover .rc-cta{color:var(--accent-hover)}

  @media (max-width:900px){
    .tier-grid,.steps,.journey{grid-template-columns:1fr}
    .track-band{grid-template-columns:1fr; gap:32px}
    section.band{padding:64px 0}
  }
  @media (max-width:520px){
    section.band{padding:48px 0}
    .track-metrics{grid-template-columns:1fr 1fr}
  }
</style>

<script is:inline>
  /* Live data (api.earn-defi.com, localhost fallback, graceful offline). */
  (function(){
    var API = (location.hostname === 'localhost' || location.hostname === '127.0.0.1')
      ? 'http://localhost:8765'
      : 'https://api.earn-defi.com';
    var LANG = function(){ try{ return localStorage.getItem('spa_lang') || 'en'; }catch(e){ return 'en'; } };
    function setText(id, txt){ var el = document.getElementById(id); if(el){ el.textContent = txt; } }

    function loadHealth(){
      fetch(API + '/api/health-public').then(function(r){ return r.json(); }).then(function(d){
        if(!d) return;
        // NOTE: day count comes from loadGoLive() (honest evidenced count), NOT
        // from d.track_days here (that counts raw/backfill bars).
        var apy = d.ytd_apy_pct != null ? Number(d.ytd_apy_pct).toFixed(1) : null;
        setText('sl-apy', apy != null ? '~' + apy + '%' : '~—%');
        setText('m-apy', apy != null ? apy + '%' : '—');
        setText('m-dd', d.max_drawdown_pct != null ? Number(d.max_drawdown_pct).toFixed(2) + '%' : '—');
      }).catch(function(){});
    }

    // Honest evidenced day count + gates straight from GoLiveChecker output.
    function loadGoLive(){
      fetch(API + '/api/v1/golive').then(function(r){ return r.json(); }).then(function(d){
        if(!d) return;
        var day = d.real_track_days != null ? d.real_track_days : '—';
        var pass = d.passed != null ? d.passed : d.risk_gates_passed;
        var total = d.total != null ? d.total : d.risk_gates_total;
        var gates = (pass != null && total != null) ? (pass + '/' + total) : '—/—';
        setText('sl-day', day);
        setText('m-days', day);
        setText('sl-gates', gates);
        setText('m-gates', gates);
        // P0-2: the API answered → flip the "as of <date>" static-snapshot label to live.
        var ru = (document.documentElement.getAttribute('data-lang') === 'ru' || document.documentElement.lang === 'ru');
        setText('sl-asof', ru ? 'вживую' : 'live');
      }).catch(function(){});
    }

    var PKG_ORDER = ['conservative','balanced','aggressive'];
    function loadPackages(){
      fetch(API + '/api/tier1/packages').then(function(r){ return r.json(); }).then(function(d){
        var pkgs = (d && d.packages) || {};
        // Honesty chip — prefer the API meta.disclaimer (verbatim, EN); the static
        // bilingual copy already in the DOM stands when offline or in RU.
        if (d && d.meta && d.meta.disclaimer && LANG() !== 'ru'){
          var mt = document.getElementById('pkgMetaText');
          if (mt){ mt.textContent = d.meta.disclaimer; mt.removeAttribute('data-ru'); }
        }
        var cards = document.querySelectorAll('#tierGrid .tier-card');
        PKG_ORDER.forEach(function(key, i){
          var p = pkgs[key]; var card = cards[i]; if(!p || !card) return;
          var apy = (p.blended_net_apy_pct != null) ? Number(p.blended_net_apy_pct).toFixed(1) + '%' : '—';
          var apyEl = card.querySelector('[data-fb="apy"]');
          if(apyEl){
            var small = apyEl.querySelector('small');
            if(small){ apyEl.innerHTML = apy + small.outerHTML; } else { apyEl.textContent = apy; }
          }
          var ddEl = card.querySelector('[data-fb="dd"]');
          if(ddEl){
            var dd = (p.worst_dd_pct != null) ? Number(p.worst_dd_pct).toFixed(1) + '%'
                   : (p.max_dd_limit_pct != null) ? '≤ ' + p.max_dd_limit_pct + '%' : '—';
            ddEl.textContent = dd;
          }
        });
      }).catch(function(){});
    }

    function drawSpark(points){
      var svg = document.getElementById('spark'); if(!svg || !points || points.length < 2) return;
      var W = 400, H = 120, pad = 6;
      var min = Math.min.apply(null, points), max = Math.max.apply(null, points);
      var range = (max - min) || 1;
      var n = points.length;
      var coords = points.map(function(v, i){
        var x = pad + (i / (n - 1)) * (W - 2 * pad);
        var y = H - pad - ((v - min) / range) * (H - 2 * pad);
        return x.toFixed(1) + ',' + y.toFixed(1);
      });
      var line = 'M' + coords.join(' L');
      var area = line + ' L' + (W - pad).toFixed(1) + ',' + (H - pad) + ' L' + pad + ',' + (H - pad) + ' Z';
      svg.innerHTML =
        '<defs><linearGradient id="sg" x1="0" y1="0" x2="0" y2="1">' +
        '<stop offset="0%" stop-color="rgba(54,194,180,.25)"/>' +
        '<stop offset="100%" stop-color="rgba(54,194,180,0)"/></linearGradient></defs>' +
        '<path d="' + area + '" fill="url(#sg)"/>' +
        '<path d="' + line + '" fill="none" stroke="var(--data-teal)" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/>';
    }
    function loadEvidence(){
      fetch(API + '/api/v1/evidence').then(function(r){ return r.json(); }).then(function(resp){
        var data = resp && resp.data;
        var daily = (data && data.daily) || (Array.isArray(data) ? data : null);
        if(!daily || !daily.length) return;
        var pts = daily.map(function(row){
          return row.close_equity != null ? row.close_equity
               : row.equity != null ? row.equity
               : row.nav != null ? row.nav : null;
        }).filter(function(v){ return v != null; });
        if(pts.length >= 2){ drawSpark(pts); setText('spark-src', 'live'); }
      }).catch(function(){});
    }

    function loadNav(){
      fetch(API + '/api/tier1/nav').then(function(r){ return r.json(); }).then(function(d){
        if(!d || d.reconciliation_ok == null) return;
        var chip = document.getElementById('porChip');
        var state = document.getElementById('porChipState');
        if(!chip || !state) return;
        var ru = LANG() === 'ru';
        var ok = d.reconciliation_ok === true;
        chip.classList.remove('ok','warn');
        chip.classList.add(ok ? 'ok' : 'warn');
        state.textContent = ok ? (ru ? '✓ сверено' : '✓ reconciled') : (ru ? '⚠ расхождение' : '⚠ delta');
      }).catch(function(){});
    }

    // Build-time snapshot fallback: draw the last evidenced equity curve immediately so
    // the spark is never blank when the API is offline. loadEvidence() overrides on success.
    function drawSnapshot(){
      var svg = document.getElementById('spark'); if(!svg) return;
      try{
        var pts = JSON.parse(svg.getAttribute('data-points') || '[]');
        if(pts && pts.length >= 2){ drawSpark(pts); }
      }catch(e){}
    }

    function init(){ drawSnapshot(); loadHealth(); loadGoLive(); loadPackages(); loadEvidence(); loadNav(); }
    if(document.readyState === 'loading'){ document.addEventListener('DOMContentLoaded', init); }
    else { init(); }
  })();
</script>
