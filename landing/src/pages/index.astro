---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import StrategySelector from '../components/StrategySelector.astro';
import PaperTrackRecord from '../components/PaperTrackRecord.astro';
import HowItWorks from '../components/HowItWorks.astro';
import TrustSignals from '../components/TrustSignals.astro';
import RiskGatesSnapshot from '../components/RiskGatesSnapshot.astro';
import FeeStructure from '../components/FeeStructure.astro';
import CompetitorTable from '../components/CompetitorTable.astro';
import Disclaimer from '../components/Disclaimer.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="SPA — Institutional-Grade DeFi Yield. Verified Daily. | earn-defi.com"
  description="Autonomous yield optimizer for family offices. Three risk profiles, deterministic risk policy, 30-day verified paper track record. Built on Aave, Morpho, Compound. Go-live August 2026."
>

  <!-- 1. Hero -->
  <Hero />

  <!-- 2. Strategy Selector -->
  <StrategySelector />

  <!-- 3. Paper Track Record -->
  <PaperTrackRecord />

  <!-- 4. How It Works -->
  <HowItWorks />

  <!-- 5. Trust Signals -->
  <TrustSignals />

  <!-- 6. Risk Gates Snapshot -->
  <RiskGatesSnapshot />

  <!-- 7. Fee Structure -->
  <FeeStructure />

  <!-- 8. Due Diligence CTA -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 text-center">
    <div class="max-w-2xl mx-auto">
      <p class="text-xs text-white/30 uppercase tracking-widest font-mono mb-4">Due Diligence</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        Ready for Deeper Analysis?
      </h2>
      <p class="text-white/50 mb-10 leading-relaxed">
        The dashboard is public. Every trade, every risk decision, every equity curve update
        is there. Start your due diligence now — we'll tell you when we're ready for capital.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8">
        <a
          href="https://dashboard.earn-defi.com"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-7 py-4 rounded-lg bg-accent-500 hover:bg-accent-400 text-white font-semibold transition-colors shadow-lg shadow-accent-500/20"
        >
          Start Due Diligence
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
            <path fill-rule="evenodd" d="M8.636 3.5a.5.5 0 0 0-.5-.5H1.5A1.5 1.5 0 0 0 0 4.5v10A1.5 1.5 0 0 0 1.5 16h10a1.5 1.5 0 0 0 1.5-1.5V7.864a.5.5 0 0 0-1 0V14.5a.5.5 0 0 1-.5.5h-10a.5.5 0 0 1-.5-.5v-10a.5.5 0 0 1 .5-.5h6.636a.5.5 0 0 0 .5-.5"/>
            <path fill-rule="evenodd" d="M16 .5a.5.5 0 0 0-.5-.5h-5a.5.5 0 0 0 0 1h3.793L6.146 9.146a.5.5 0 1 0 .708.708L15 1.707V5.5a.5.5 0 0 0 1 0z"/>
          </svg>
        </a>
        <a
          href="/risk-disclosure"
          class="inline-flex items-center gap-2 px-7 py-4 rounded-lg border border-white/15 hover:border-white/30 text-white/60 hover:text-white font-medium transition-all text-sm"
        >
          Read Full Risk Disclosure
        </a>
      </div>
      <p class="text-sm text-white/30">
        Talk to us: <a href="mailto:yuriycooleshov@gmail.com" class="text-accent-400/70 hover:text-accent-400 transition-colors">yuriycooleshov@gmail.com</a>
      </p>
    </div>
  </section>

  <!-- 9. Competitor Table -->
  <CompetitorTable />

  <!-- 10. Disclaimer + Footer -->
  <Disclaimer />
  <Footer />

</Layout>
