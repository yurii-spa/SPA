// Homepage — Direction C "Console" (spec §7-C). Canonical chrome (header, paper
// strip, footer) comes from Layout; this page is just the Console body + sections.
import Layout from '../layouts/Layout.astro';
import snap from '../data/track_snapshot.json';
import WalletCheck from '../components/WalletCheck.jsx';

// Build-time honest static fallback (last evidenced snapshot) — mirrors the pattern
// track-record.astro uses. Live values from api.earn-defi.com override these client-side;
// this keeps the hero + track glance readable (real last-evidenced numbers, not bare "—")
// when the API is offline. Numbers are NOT hardcoded — they come from the committed
// snapshot derived from data/golive_status.json + data/equity_curve_daily.json.
// ONE source (FIX-2): every hero number comes from track_snapshot.json (built from the committed
// golive_status + equity_curve + paper_trading_status — the same authority the API serves). NO
// hardcoded fallback: a missing value renders an honest em-dash, never a stale/invented number.
const snapDays = snap.real_track_days != null ? snap.real_track_days : '—';
const snapGates = (snap.gates_passed != null && snap.gates_total != null) ? `${snap.gates_passed}/${snap.gates_total}` : '—';
const snapBars = Array.isArray(snap.bars) ? snap.bars : [];
const snapApy = snap.paper_apy_pct != null ? '~' + Number(snap.paper_apy_pct).toFixed(1) + '%' : '—';
const snapDd = snap.max_drawdown_pct != null ? Number(snap.max_drawdown_pct).toFixed(2) + '%' : '—';
// Snapshot freshness label ("as of <date>") — the JS island flips it to live when the API answers.
const snapAsOf = snap.as_of || snap.generated_at || null;
// Site-Custodian kill-rule (ADR-YL-011): when degraded, show a plaque instead of a possibly-wrong number
// (refusal-first — honest absence beats a false figure).
const degraded = snap.degraded === true;
// Tier-card net-APY static fallback from snapshot.packages (same source /api/tier1/packages fills). A tier
// with no computed backend value stays '—' (honest absence, never a hardcoded number); JS overrides live.
const pkgApy = (k) => { const v = snap.packages && snap.packages[k] && snap.packages[k].apy_pct; return v != null ? Number(v).toFixed(1) + '%' : '—'; };
// #46 — render the TAIL (worst drawdown) at the point of tier choice, server-side, so a card NEVER
// shows a bare "—" for its drawdown at first paint. Realized dd from the live snapshot when present
// (conservative); otherwise the measured BACKTEST worst from the single tier_bands source (clearly
// tagged "(bt)", evidence-tagged on /packages) — a real measured value, never invented. JS still
// overrides the data-fb="dd" cells live.
import TIER_BANDS from '../lib/tier_bands.json';
const pkgDD = (k) => {
  const v = snap.packages && snap.packages[k] && snap.packages[k].dd_pct;
  if (typeof v === 'number') return Number(v).toFixed(1) + '%';
  return (TIER_BANDS[k] && TIER_BANDS[k].dd_short_en) || '—';
};
const pkgDDru = (k) => {
  const v = snap.packages && snap.packages[k] && snap.packages[k].dd_pct;
  if (typeof v === 'number') return Number(v).toFixed(1) + '%';
  return (TIER_BANDS[k] && TIER_BANDS[k].dd_short_ru) || '—';
};
// Equity series for the offline spark fallback (build-time, last snapshot).
// P1-5: chart plots ONLY evidenced + reconstructed bars — drops the synthetic warmup/backfill series
// so there is no cross-series seam (the −$205 06-09/06-10 jump). Those bars stay in the downloadable
// data + the /track-record ledger table, just not on the curve.
const snapEquity = snapBars.filter((b) => b.evidenced === true || b.source === 'reconstructed').map((b) => Number(b.equity)).filter((v) => isFinite(v));
