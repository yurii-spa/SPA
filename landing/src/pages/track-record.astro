  <Disclaimer />

  <script is:inline>
    /* Live track record — api.earn-defi.com, localhost fallback, graceful offline. */
    (function(){
      var API = (location.hostname === 'localhost' || location.hostname === '127.0.0.1')
        ? 'http://localhost:8765'
        : 'https://api.earn-defi.com';
      var DAYS_NEEDED = 30;
      function setText(id, txt){ var el = document.getElementById(id); if(el){ el.textContent = txt; } }
      function setWidth(id, pct){ var el = document.getElementById(id); if(el){ el.style.width = Math.max(0, Math.min(100, pct)) + '%'; } }
      function isRu(){ try{ return (localStorage.getItem('spa_lang') || 'en') === 'ru'; }catch(e){ return false; } }

      // APY / drawdown / gates only — NOT the day count. days_running in this feed
      // counts raw bars (incl. backfill); the honest evidenced count comes from
      // /api/v1/golive.real_track_days, which is what we render here.
      function loadHealth(){
        fetch(API + '/api/health-public').then(function(r){ return r.json(); }).then(function(d){
          if(!d) return;
          var apy = d.ytd_apy_pct != null ? Number(d.ytd_apy_pct).toFixed(1) : null;
          setText('tr-apy', apy != null ? apy + '%' : '—');
          setText('tr-dd', d.max_drawdown_pct != null ? Number(d.max_drawdown_pct).toFixed(2) + '%' : '—');
        }).catch(function(){});
      }

      // Honest source of truth for evidenced days + gates + go-live target.
      // LIVE day-30 readiness (WS5) — the auto/verifiable/hash-anchored artifact drives the
      // evidenced day-count + the readiness bar so the page is never a stale snapshot. The gate
      // (loadGoLive) still fills the 29-criteria pass/total + target. Fail-safe: a missing/empty
      // /day30 leaves loadGoLive's values in place.
      function loadReadiness(){
        fetch(API + '/api/v1/day30').then(function(r){ return r.json(); }).then(function(d){
          if(!d || d.error) return;
          var ev = (d.evidenced && d.evidenced.evidenced_days != null) ? d.evidenced.evidenced_days : null;
          if(ev != null){
            setText('tr-days', ev + ' / ' + DAYS_NEEDED);
            setText('tr-days-2', ev);
            setText('tr-reset-days', ev);
          }
          if(d.readiness_pct != null){ setWidth('tr-days-bar', d.readiness_pct); }
          if(d.evidenced && d.evidenced.evidenced_anchor){ setText('tr-reset-anchor', d.evidenced.evidenced_anchor); }
        }).catch(function(){});
      }

      function loadGoLive(){
        fetch(API + '/api/v1/golive').then(function(r){ return r.json(); }).then(function(d){
          if(!d) return;
          var days = d.real_track_days != null ? d.real_track_days : null;
          var pass = d.passed != null ? d.passed : d.risk_gates_passed;
          var total = d.total != null ? d.total : d.risk_gates_total;
          if(days != null){
            setText('tr-days', days + ' / ' + DAYS_NEEDED);
            setText('tr-days-2', days);
            setText('tr-reset-days', days);
            setWidth('tr-days-bar', (days / DAYS_NEEDED) * 100);
          }
          if(pass != null){ setText('tr-gates-pass', pass); }
          if(total != null){ setText('tr-gates-total', total); }
          if(pass != null && total != null){ setWidth('tr-gates-bar', (pass / total) * 100); }
          // Go-live target = the ONE honest evidenced-anchored value. Prefer the
          // top-level target_date the gate now surfaces; fall back to the
          // per-criterion target_date for older API payloads.
          var tgt = d.target_date || null;
          if(!tgt && Array.isArray(d.criteria)){
            for(var i = 0; i < d.criteria.length; i++){
              var c = d.criteria[i];
              if((c.name === 'min_track_days_30' || c.name === 'gap_monitor_30d') && c.target_date){ tgt = c.target_date; break; }
            }
          }
          if(tgt){ setText('tr-reset-target', tgt); setText('tr-days-target', tgt); }
          if(d.evidenced_anchor){ setText('tr-reset-anchor', d.evidenced_anchor); }
        }).catch(function(){});
      }

      function loadFacts(){
        fetch(API + '/api/ssot/facts').then(function(r){ return r.json(); }).then(function(d){
          var f = (d && (d.facts || d.data || d)) || {};
          var eq = f.current_equity != null ? f.current_equity
                 : f.equity != null ? f.equity
                 : f.nav != null ? f.nav : null;
          if(eq != null){
            setText('tr-equity', '$' + Number(eq).toLocaleString('en-US', {maximumFractionDigits: 0}));
          }
        }).catch(function(){});
      }

      function drawSpark(points){
        var svg = document.getElementById('tr-spark'); if(!svg || !points || points.length < 2) return;
        var W = 800, H = 200, pad = 8;
        var min = Math.min.apply(null, points), max = Math.max.apply(null, points);
        var range = (max - min) || 1;
        var n = points.length;
        var coords = points.map(function(v, i){
          var x = pad + (i / (n - 1)) * (W - 2 * pad);
          var y = H - pad - ((v - min) / range) * (H - 2 * pad);
          return x.toFixed(1) + ',' + y.toFixed(1);
        });
        var line = 'M' + coords.join(' L');
        var area = line + ' L' + (W - pad).toFixed(1) + ',' + (H - pad) + ' L' + pad + ',' + (H - pad) + ' Z';
        svg.innerHTML =
          '<defs><linearGradient id="trsg" x1="0" y1="0" x2="0" y2="1">' +
          '<stop offset="0%" stop-color="rgba(54,194,180,.25)"/>' +
          '<stop offset="100%" stop-color="rgba(54,194,180,0)"/></linearGradient></defs>' +
          '<path d="' + area + '" fill="url(#trsg)"/>' +
          '<path d="' + line + '" fill="none" stroke="#36C2B4" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round"/>';
      }

      var SRC_META = {
        cycle:         { en: 'cycle', ru: 'цикл',          dot: 'bg-teal-400', tag: 'text-teal-300 border-teal-500/30 bg-teal-500/10' },
        reconstructed: { en: 'reconstructed', ru: 'реконструкция', dot: 'bg-amber-400', tag: 'text-amber-300 border-amber-500/30 bg-amber-500/10' },
        backfill:      { en: 'backfill', ru: 'бэкфилл',    dot: 'bg-white/30', tag: 'text-white/40 border-border bg-white/[0.03]' },
        warmup:        { en: 'warmup', ru: 'прогрев',      dot: 'bg-white/20', tag: 'text-white/30 border-border bg-white/[0.02]' }
      };
      function srcMeta(s){ return SRC_META[s] || SRC_META.warmup; }
      function esc(s){ return String(s).replace(/[&<>"]/g, function(c){ return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'})[c]; }); }

      function renderBars(rows){
        var host = document.getElementById('tr-bars'); if(!host) return;
        var ru = isRu();
        var tail = rows.slice(-18).reverse();
        var html = tail.map(function(b){
          var src = b.source || 'warmup';
          var ev = b.evidenced === true;
          var m = srcMeta(src);
          var eq = b.close_equity != null ? b.close_equity : (b.equity != null ? b.equity : b.nav);
          var eqTxt = eq != null ? '$' + Number(eq).toLocaleString('en-US', {maximumFractionDigits: 0}) : '—';
          var label = ru ? m.ru : m.en;
          return '<div class="flex items-center gap-3 px-4 py-2.5' + (ev ? '' : ' opacity-50') + '">' +
            '<span class="w-2 h-2 rounded-full shrink-0 ' + m.dot + '" aria-hidden="true"></span>' +
            '<span class="font-mono text-sm text-white/70 w-24 shrink-0">' + esc(b.date || '') + '</span>' +
            '<span class="font-mono text-sm text-white/80 w-28 shrink-0 text-right">' + eqTxt + '</span>' +
            '<span class="ml-auto inline-flex items-center gap-1.5 text-xs font-mono px-2 py-0.5 rounded-full border shrink-0 ' + m.tag + '">' +
            (ev ? '<span aria-hidden="true">✓</span>' : '') +
            '<span data-ru="' + m.ru + '">' + label + '</span></span>' +
          '</div>';
        }).join('');
        host.innerHTML = html;
        setText('tr-bars-src', 'live');
      }

      function loadEvidence(){
        fetch(API + '/api/v1/evidence').then(function(r){ return r.json(); }).then(function(resp){
          var data = resp && (resp.data || resp);
          var daily = (data && data.daily) || (Array.isArray(data) ? data : null);
          if(!daily || !daily.length) return;
          var pts = daily.map(function(row){
            return row.close_equity != null ? row.close_equity
                 : row.equity != null ? row.equity
                 : row.nav != null ? row.nav : null;
          }).filter(function(v){ return v != null; });
          if(pts.length >= 2){
            drawSpark(pts);
            setText('tr-spark-src', 'live');
            setText('tr-equity', '$' + Number(pts[pts.length-1]).toLocaleString('en-US', {maximumFractionDigits: 0}));
          }
          // Render the per-bar ledger only if the feed carries source/evidenced
          // labels (equity-curve fallback shape). Otherwise keep the static SSR list.
          if(daily.some(function(r){ return r && r.source != null; })){ renderBars(daily); }
        }).catch(function(){});
      }

      function fmtUsd(v){ return '$' + Number(v).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}); }

      function loadNav(){
        fetch(API + '/api/tier1/nav').then(function(r){ return r.json(); }).then(function(d){
          if(!d || d.computed_nav_usd == null) return;
          if(d.deployed_usd != null) setText('por-deployed', fmtUsd(d.deployed_usd));
          if(d.cash_usd != null) setText('por-cash', fmtUsd(d.cash_usd));
          if(d.accrued_yield_usd != null) setText('por-accrued', fmtUsd(d.accrued_yield_usd));
          if(d.computed_nav_usd != null) setText('por-nav', fmtUsd(d.computed_nav_usd));

          // reconciliation chip
          var chip = document.getElementById('por-recon');
          if(chip){
            var ok = d.reconciliation_ok === true;
            chip.className = 'inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-mono shrink-0 border ' +
              (ok ? 'bg-teal-500/10 border-teal-500/30 text-teal-300'
                  : 'bg-amber-500/10 border-amber-500/30 text-amber-300');
            chip.innerHTML = '<span class="w-1.5 h-1.5 rounded-full ' + (ok ? 'bg-teal-400' : 'bg-amber-400') +
              '" aria-hidden="true"></span>' +
              (ok ? (isRu() ? 'сверено ✓' : 'reconciled ✓')
                  : (isRu() ? 'расхождение ⚠' : 'delta ⚠'));
          }

          if(d.reconciliation_delta_usd != null){
            var dp = d.reconciliation_delta_pct != null ? ' (' + Number(d.reconciliation_delta_pct).toFixed(4) + '%)' : '';
            setText('por-delta', fmtUsd(d.reconciliation_delta_usd) + dp);
          }
          if(Array.isArray(d.positions)) setText('por-positions', String(d.positions.length));
          var ts = d.ts || d.generated_at;
          if(ts){ try{ setText('por-ts', new Date(ts).toISOString().replace('T',' ').slice(0,16) + 'Z'); }catch(e){ setText('por-ts', ts); } }
          if(d.nav_hash){ setText('por-hash', d.nav_hash.slice(0,24) + '…' + d.nav_hash.slice(-8)); }
          if(d.components_hash){ setText('por-comphash', d.components_hash.slice(0,16) + '…' + d.components_hash.slice(-8)); }
          setText('por-src', 'live');
        }).catch(function(){});
      }

      function init(){ loadHealth(); loadGoLive(); loadReadiness(); loadFacts(); loadEvidence(); loadNav(); }
      if(document.readyState === 'loading'){ document.addEventListener('DOMContentLoaded', init); }
      else { init(); }
    })();
  </script>
</Layout>
