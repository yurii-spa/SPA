---
import Layout from '../layouts/Layout.astro';
import Disclaimer from '../components/Disclaimer.astro';
import snap from '../data/track_snapshot.json';

// Honest, build-time static fallback (last evidenced snapshot). Live values
// override these client-side from api.earn-defi.com; this keeps the page honest
// and readable when the API is offline. Numbers are NOT hardcoded inline — they
// are derived from data/golive_status.json + data/equity_curve_daily.json at build.
const realDays = snap.real_track_days ?? 5;
const daysNeeded = snap.days_needed ?? 30;
const goLiveTarget = snap.go_live_target ?? '2026-07-21';
const anchor = snap.evidenced_anchor ?? '2026-06-22';
const gatesPassed = snap.gates_passed ?? 27;
const gatesTotal = snap.gates_total ?? 29;
const bars = snap.bars ?? [];

// Per-bar source presentation tokens (Console palette). evidenced cycle bars are
// the only ones that count toward go-live; everything else is shown but dimmed.
const SOURCE_META = {
  cycle:         { en: 'cycle', ru: 'цикл',          dot: 'bg-teal-400',   tag: 'text-teal-300 border-teal-500/30 bg-teal-500/10' },
  reconstructed: { en: 'reconstructed', ru: 'реконструкция', dot: 'bg-amber-400', tag: 'text-amber-300 border-amber-500/30 bg-amber-500/10' },
  backfill:      { en: 'backfill', ru: 'бэкфилл',    dot: 'bg-white/30',   tag: 'text-white/40 border-border bg-white/[0.03]' },
  warmup:        { en: 'warmup', ru: 'прогрев',      dot: 'bg-white/20',   tag: 'text-white/30 border-border bg-white/[0.02]' },
};
function meta(src) { return SOURCE_META[src] || SOURCE_META.warmup; }
---

<Layout
  title="Track Record — We Reset Our Own Track, Honestly | earn-defi.com"
  description="We audited our own paper track and reset it: only days backed by a real daily-cycle log count. 5 evidenced days (anchor 2026-06-22), not 15 padded ones. Live from api.earn-defi.com — paper/advisory, not investment advice."
  canonical="https://earn-defi.com/track-record"
>
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Hero -->
    <section class="pt-20 pb-10">
      <div class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full bg-teal-500/10 border border-teal-500/30 text-xs text-teal-300 font-medium">
        <span class="w-1.5 h-1.5 rounded-full bg-teal-400 animate-pulse" aria-hidden="true"></span>
        <span data-ru="Трек сброшен — честно">Track reset — honestly</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4 leading-tight" data-ru="Мы сбросили собственный трек">
        We reset our own track
      </h1>
      <p class="text-xl text-white/50 leading-relaxed max-w-2xl" data-ru="Мы провели аудит собственного бумажного трека и обнулили его. Считаются только дни, подтверждённые реальным логом ежедневного цикла. Сейчас это 5 честных дней (якорь 2026-06-22), а не 15 «надутых». Каждая точка кривой капитала и метка её источника публичны.">
        We audited our own paper track and reset it. Only days backed by a real
        daily-cycle log count. Right now that is {realDays} honest days (anchor {anchor}),
        not 15 padded ones. Every equity point and its source label is public.
      </p>
    </section>

    <!-- The reset — core trust signal -->
    <section class="pb-10">
      <div class="rounded-2xl border border-teal-500/25 bg-gradient-to-b from-teal-500/[0.07] to-transparent p-6 sm:p-8">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-xs font-mono uppercase tracking-wider text-teal-300/70" data-ru="Доказуемая честность">Provable honesty</span>
        </div>
        <h2 class="text-2xl font-bold text-white mb-3 leading-snug" data-ru="Мы публикуем 5 настоящих дней, а не 15 «надутых»">
          We publish {realDays} real days, not 15 padded ones
        </h2>
        <p class="text-white/55 leading-relaxed max-w-2xl mb-5" data-ru="Аудит собственного трека показал, что ранние дни были бэкфиллом по фиксированной ставке — не результатом реального ежедневного цикла. Мы их не считаем. Теперь засчитывается только день, у которого есть реальный лог daily-cycle. Мы предпочтём показать 5 честных дней, чем 15 надутых. Сам этот сброс — и есть сигнал доверия.">
          Auditing our own track found the earlier days were a flat-rate backfill — not
          the output of a real daily cycle. We don't count them. A day now counts only if
          it has a genuine daily-cycle log behind it. We would rather show {realDays} honest
          days than 15 padded ones. The reset itself is the trust signal.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <div class="rounded-lg border border-border bg-bg-surface px-4 py-3">
            <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-1" data-ru="Якорь подтверждения">Evidence anchor</p>
            <p class="text-sm font-mono text-white/80">{anchor}</p>
          </div>
          <div class="rounded-lg border border-border bg-bg-surface px-4 py-3">
            <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-1" data-ru="Подтверждено / нужно">Evidenced / needed</p>
            <p class="text-sm font-mono text-teal-300"><span id="tr-reset-days">{realDays}</span> / {daysNeeded} <span class="text-white/30" data-ru="дней">days</span></p>
          </div>
          <div class="rounded-lg border border-border bg-bg-surface px-4 py-3">
            <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-1" data-ru="Цель go-live">Go-live target</p>
            <p class="text-sm font-mono text-white/80" id="tr-reset-target">{goLiveTarget}</p>
          </div>
        </div>
        <p class="text-xs text-white/30 mt-4 leading-relaxed" data-ru="Бумажный/исследовательский трек на виртуальном портфеле $100k. Не инвестиционный совет, не прогноз. Метки источника на каждом баре ниже — видно, какие дни реальные.">
          Paper / research track on a virtual $100k book. Not investment advice, not a
          forecast. Per-bar source labels are shown below — you can see which days are real.
        </p>
      </div>
    </section>

    <!-- Live metric strip -->
    <section class="pb-10">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="rounded-xl border border-border bg-bg-surface p-5">
          <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-2" data-ru="Капитал">Equity</p>
          <p class="text-2xl font-mono font-bold text-white" id="tr-equity">—</p>
          <p class="text-xs text-white/30 mt-1" data-ru="виртуальные $100k">virtual $100k base</p>
        </div>
        <div class="rounded-xl border border-border bg-bg-surface p-5">
          <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-2" data-ru="Бумажный APY">Paper APY</p>
          <p class="text-2xl font-mono font-bold text-teal-400" id="tr-apy">—</p>
          <p class="text-xs text-white/30 mt-1" data-ru="переменный · не гарантирован">variable · not guaranteed</p>
        </div>
        <div class="rounded-xl border border-border bg-bg-surface p-5">
          <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-2" data-ru="Макс. просадка">Max drawdown</p>
          <p class="text-2xl font-mono font-bold text-white" id="tr-dd">—</p>
          <p class="text-xs text-white/30 mt-1" data-ru="с начала трека">since track start</p>
        </div>
        <div class="rounded-xl border border-teal-500/20 bg-teal-500/[0.04] p-5">
          <p class="text-xs text-teal-300/50 uppercase tracking-wider font-mono mb-2" data-ru="Подтверждённых дней">Evidenced days</p>
          <p class="text-2xl font-mono font-bold text-teal-400"><span id="tr-days">{realDays}</span><span class="text-white/30 text-lg"> / {daysNeeded}</span></p>
          <p class="text-xs text-white/30 mt-1" data-ru="только дни с логом цикла">cycle-logged days only</p>
        </div>
      </div>
    </section>

    <!-- Equity curve -->
    <section class="py-10 border-t border-border">
      <div class="flex items-baseline justify-between mb-4 flex-wrap gap-2">
        <p class="text-xs text-white/30 uppercase tracking-wider font-mono" data-ru="Кривая капитала (бумажная)">Equity curve (paper)</p>
        <p class="text-xs text-white/25 font-mono">
          <span data-ru="источник:">source:</span> <span id="tr-spark-src">static fallback</span>
        </p>
      </div>
      <div class="rounded-xl border border-border-strong bg-bg-surface p-5">
        <svg id="tr-spark" viewBox="0 0 800 200" preserveAspectRatio="none" class="w-full h-48" role="img" aria-label="Paper equity curve"></svg>
        <p class="text-xs text-white/30 mt-3 text-center" id="tr-spark-note" data-ru="Кривая загружается из живого фида доказательств. При офлайне показывается последний статический снимок.">
          Curve loads from the live evidence feed. When offline, the last static snapshot is shown.
        </p>
      </div>
    </section>

    <!-- Per-bar evidence ledger: which days are real vs backfill vs warmup -->
    <section class="py-10 border-t border-border">
      <div class="flex items-baseline justify-between mb-2 flex-wrap gap-2">
        <p class="text-xs text-white/30 uppercase tracking-wider font-mono" data-ru="Реестр баров — что считается">Bar ledger — what counts</p>
        <p class="text-xs text-white/25 font-mono">
          <span data-ru="источник:">source:</span> <span id="tr-bars-src">static fallback</span>
        </p>
      </div>
      <p class="text-sm text-white/45 leading-relaxed mb-4 max-w-2xl" data-ru="Каждый бар помечен своим источником. Только бары «цикл» подтверждены логом и засчитываются в go-live. «Бэкфилл» и «прогрев» приглушены — они показаны для прозрачности, но не считаются.">
        Each bar is tagged with its source. Only <span class="text-teal-300 font-medium">cycle</span>
        bars are evidenced by a log and count toward go-live. <span class="text-white/40">Backfill</span>
        and <span class="text-white/40">warmup</span> bars are dimmed — shown for transparency, but not counted.
      </p>
      <div class="rounded-xl border border-border-strong bg-bg-surface overflow-hidden">
        <div id="tr-bars" class="divide-y divide-border">
          {bars.slice().reverse().map((b) => (
            <div class={`flex items-center gap-3 px-4 py-2.5 ${b.evidenced ? '' : 'opacity-50'}`}>
              <span class={`w-2 h-2 rounded-full shrink-0 ${meta(b.source).dot}`} aria-hidden="true"></span>
              <span class="font-mono text-sm text-white/70 w-24 shrink-0">{b.date}</span>
              <span class="font-mono text-sm text-white/80 w-28 shrink-0 text-right">${Number(b.equity).toLocaleString('en-US', { maximumFractionDigits: 0 })}</span>
              <span class={`ml-auto inline-flex items-center gap-1.5 text-xs font-mono px-2 py-0.5 rounded-full border ${meta(b.source).tag} shrink-0`}>
                {b.evidenced && <span aria-hidden="true">✓</span>}
                <span data-ru={meta(b.source).ru}>{meta(b.source).en}</span>
              </span>
            </div>
          ))}
        </div>
      </div>
      <div class="flex flex-wrap items-center gap-x-5 gap-y-2 mt-3 text-xs text-white/40 font-mono">
        <span class="inline-flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-teal-400" aria-hidden="true"></span><span data-ru="цикл · подтверждён · считается">cycle · evidenced · counts</span></span>
        <span class="inline-flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-amber-400" aria-hidden="true"></span><span data-ru="реконструкция · помечена">reconstructed · flagged</span></span>
        <span class="inline-flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-white/30" aria-hidden="true"></span><span data-ru="бэкфилл/прогрев · не считается">backfill/warmup · not counted</span></span>
      </div>
    </section>

    <!-- Proof of Reserves -->
    <section class="py-10 border-t border-border">
      <div class="flex items-baseline justify-between mb-4 flex-wrap gap-2">
        <p class="text-xs text-white/30 uppercase tracking-wider font-mono" data-ru="Доказательство резервов">Proof of Reserves</p>
        <p class="text-xs text-white/25 font-mono">
          <span data-ru="источник:">source:</span> <span id="por-src">static fallback</span>
        </p>
      </div>

      <div class="rounded-xl border border-border-strong bg-bg-surface p-6">
        <div class="flex items-start justify-between gap-4 flex-wrap mb-6">
          <div>
            <p class="text-lg font-semibold text-white mb-1" data-ru="Каждый доллар учтён — криптографически проверяемо">Every dollar accounted for, cryptographically verifiable</p>
            <p class="text-sm text-white/45 max-w-xl leading-relaxed" data-ru="NAV пересчитывается из своих частей (вложено + кэш + начислено) и сверяется с заявленным капиталом. Это бумажное доказательство резервов: проверяемая методология на виртуальном портфеле $100k, не реальное кастоди.">
              The NAV is recomputed from its parts (deployed + cash + accrued) and reconciled
              against the reported equity. This is a paper proof-of-reserves: the verifiable
              methodology on the virtual $100k book, not real custody.
            </p>
          </div>
          <div id="por-recon" class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-bg-surface-2 border border-border-strong text-xs font-mono text-white/40 shrink-0">
            <span class="w-1.5 h-1.5 rounded-full bg-white/30" aria-hidden="true"></span>
            <span data-ru="загрузка…">loading…</span>
          </div>
        </div>

        <!-- NAV breakdown: deployed + cash + accrued = equity -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-5">
          <div class="rounded-lg border border-border bg-bg-surface p-4">
            <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-2" data-ru="Вложено">Deployed</p>
            <p class="text-xl font-mono font-bold text-white" id="por-deployed">—</p>
          </div>
          <div class="rounded-lg border border-border bg-bg-surface p-4">
            <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-2" data-ru="Кэш">Cash</p>
            <p class="text-xl font-mono font-bold text-white" id="por-cash">—</p>
          </div>
          <div class="rounded-lg border border-border bg-bg-surface p-4">
            <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-2" data-ru="Начислено">Accrued</p>
            <p class="text-xl font-mono font-bold text-white" id="por-accrued">—</p>
          </div>
          <div class="rounded-lg border border-teal-500/20 bg-teal-500/[0.05] p-4">
            <p class="text-xs text-teal-300/50 uppercase tracking-wider font-mono mb-2" data-ru="NAV (= капитал)">NAV (= equity)</p>
            <p class="text-xl font-mono font-bold text-teal-400" id="por-nav">—</p>
          </div>
        </div>

        <!-- reconciliation + meta row -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-5">
          <div class="rounded-lg bg-bg-surface border border-border px-4 py-3">
            <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-1" data-ru="Расхождение сверки">Reconciliation delta</p>
            <p class="text-sm font-mono text-white/70" id="por-delta">—</p>
          </div>
          <div class="rounded-lg bg-bg-surface border border-border px-4 py-3">
            <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-1" data-ru="Позиций">Positions</p>
            <p class="text-sm font-mono text-white/70" id="por-positions">—</p>
          </div>
          <div class="rounded-lg bg-bg-surface border border-border px-4 py-3">
            <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-1" data-ru="Последняя проверка">Last verified</p>
            <p class="text-sm font-mono text-white/70" id="por-ts">—</p>
          </div>
        </div>

        <!-- verification hash -->
        <div class="rounded-lg bg-black/30 border border-border px-4 py-3">
          <div class="flex items-center justify-between gap-2 mb-2 flex-wrap">
            <p class="text-xs text-white/30 uppercase tracking-wider font-mono" data-ru="Хэш проверки (NAV)">Verification hash (NAV)</p>
            <span class="text-xs text-teal-300/60 font-mono" data-ru="проверяемо · защищено от подмены">verifiable · tamper-evident</span>
          </div>
          <p class="text-xs sm:text-sm font-mono text-teal-300/80 break-all" id="por-hash">—</p>
          <p class="text-xs text-white/25 font-mono mt-1">
            <span data-ru="компоненты:">components:</span> <span id="por-comphash" class="break-all">—</span>
          </p>
        </div>

        <p class="text-xs text-white/30 mt-4 leading-relaxed" data-ru="NAV = Σ(позиции по протоколам) + кэш + начисленный доход. components_hash = sha256 канонического JSON отсортированных позиций; nav_hash связывает NAV с его компонентами и временем. Любой может пересчитать опубликованный NAV из компонентов через nav_proof.verify_proof().">
          NAV = Σ(per-protocol positions) + cash + accrued yield. components_hash = sha256 of the
          canonical JSON of the sorted positions; nav_hash binds the NAV to its components and timestamp.
          Anyone can recompute the published NAV from its components via nav_proof.verify_proof().
        </p>
      </div>
    </section>

    <!-- Go-live progress -->
    <section class="py-10 border-t border-border">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-4" data-ru="Прогресс Go-Live">Go-live progress</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="rounded-xl border border-border-strong bg-bg-surface p-6">
          <div class="text-sm text-white/40 uppercase tracking-wider mb-3" data-ru="Критерии GoLiveChecker">GoLiveChecker criteria</div>
          <div class="flex items-end gap-2 mb-3">
            <span class="text-5xl font-mono font-bold text-amber-400" id="tr-gates-pass">—</span>
            <span class="text-2xl text-white/30 mb-1">/ <span id="tr-gates-total">29</span></span>
          </div>
          <div class="h-2 bg-white/10 rounded-full overflow-hidden mb-2">
            <div class="h-full bg-amber-400 rounded-full transition-all" id="tr-gates-bar" style="width:0%"></div>
          </div>
          <p class="text-white/50 text-sm" data-ru="детерминированные критерии (ADR-002) — все должны пройти до go-live">deterministic criteria (ADR-002) — all must pass before go-live</p>
        </div>
        <div class="rounded-xl border border-border-strong bg-bg-surface p-6">
          <div class="text-sm text-white/40 uppercase tracking-wider mb-3" data-ru="Подтверждённые дни трека">Evidenced track days</div>
          <div class="flex items-end gap-2 mb-3">
            <span class="text-5xl font-mono font-bold text-teal-400" id="tr-days-2">{realDays}</span>
            <span class="text-2xl text-white/30 mb-1">/ {daysNeeded} <span data-ru="дней">days</span></span>
          </div>
          <div class="h-2 bg-white/10 rounded-full overflow-hidden mb-2">
            <div class="h-full bg-teal-400 rounded-full transition-all" id="tr-days-bar" style={`width:${Math.round((realDays / daysNeeded) * 100)}%`}></div>
          </div>
          <p class="text-white/50 text-sm"><span data-ru="Якорь подтверждения">Evidence anchor</span> {anchor} <span data-ru="· цель go-live">· go-live target</span> <span id="tr-days-target">{goLiveTarget}</span></p>
        </div>
      </div>
    </section>

    <!-- The honest-track narrative -->
    <section class="py-10 border-t border-border">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-4" data-ru="Как мы считаем честность">How we count honesty</p>
      <div class="space-y-3">
        <div class="rounded-lg bg-bg-surface border border-border px-5 py-4">
          <p class="text-sm text-white/55 leading-relaxed">
            <span class="text-white/80 font-semibold" data-ru="Подтверждённые дни, не сырые бары.">Evidenced days, not raw bars.</span>
            <span data-ru="Каждый бар в файле equity помечен полем source (warmup / backfill / reconstructed / cycle) и evidenced (true/false). Засчитываются только бары cycle — те, у которых есть реальный лог ежедневного цикла. Ранние бары были бэкфиллом по фиксированной ставке; мы их не считаем, хотя и показываем для прозрачности.">
              Each bar in the equity file is tagged with a <code class="text-teal-300/80">source</code>
              (warmup / backfill / reconstructed / cycle) and <code class="text-teal-300/80">evidenced</code>
              flag. Only <code class="text-teal-300/80">cycle</code> bars — those with a real daily-cycle
              log behind them — count. The earlier bars were a flat-rate backfill; we don't count them,
              though we still show them for transparency.</span>
          </p>
        </div>
        <div class="rounded-lg bg-bg-surface border border-border px-5 py-4">
          <p class="text-sm text-white/55 leading-relaxed">
            <span class="text-white/80 font-semibold" data-ru="Заметка о реконструированном дне.">Reconstructed-day note.</span>
            <span data-ru="Если автономный цикл пропустил день (например, при перезагрузке хоста), пропуск фиксируется gap_monitor, а пробел заполняется реконструированным баром — он помечается, а не выдаётся за живой. Непрерывность за 30 дней — отдельный критерий go-live.">
              If the autonomous cycle missed a day (e.g. during a host restart), the gap is recorded
              by gap_monitor and the hole is filled with a reconstructed bar — which is flagged, not
              passed off as live. 30-day continuity is itself a separate go-live criterion.</span>
          </p>
        </div>
        <div class="rounded-lg bg-bg-surface border border-border px-5 py-4">
          <p class="text-sm text-white/55 leading-relaxed">
            <span class="text-white/80 font-semibold" data-ru="Бумажная, переменная, не прогноз.">Paper, variable, not a forecast.</span>
            <span data-ru="Все цифры отражают симулированную торговлю на виртуальном портфеле $100,000 USDC. Симуляция не учитывает реальное проскальзывание, влияние на ликвидность и риск исполнения смарт-контрактов. Прошлая бумажная доходность ничего не гарантирует.">
              All figures reflect simulated trading on a virtual $100,000 USDC portfolio. The
              simulation does not account for live slippage, liquidity impact, or smart-contract
              execution risk. Past paper performance guarantees nothing.</span>
