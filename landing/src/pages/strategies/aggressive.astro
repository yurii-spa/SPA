---
import Layout from '../../layouts/Layout.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import strategies from '../../data/strategy_config.json';

const maxYield = strategies.strategies.find(s => s.id === 'max-yield')!;
const global = strategies.global;
---

<Layout
  title="Aggressive Strategy — Advanced DeFi Mechanics | SPA earn-defi.com"
  description="Up to 20% target APY. The aggressive strategies are actively paper-tested in the Aggressive Lab (live forward track) but REFUSED for live capital — the yield compensates for tail risk (~50% drawdown through the ETH crash), not edge. Research/paper, shown WITH its real tail."
>

  <!-- Nav -->
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Coming Soon Banner -->
    <div class="mt-8 rounded-xl border border-warn-border bg-warn-bg p-5 flex items-start gap-3">
      <span class="text-warn flex-shrink-0 text-lg mt-0.5">&#9888;</span>
      <div>
        <p class="text-sm text-white/70 font-medium mb-1" data-ru="ЦЕЛЕВОЙ ПРОФИЛЬ — RESEARCH/PAPER, ОТКАЗАН ДЛЯ LIVE">TARGET PROFILE — RESEARCH/PAPER, REFUSED FOR LIVE</p>
        <p class="text-sm text-white/50 leading-relaxed" data-ru="Целевой APY приведён только для иллюстрации. Высокодоходный тир теперь честно задокументирован: 12–20% стратегии, от которых деск ОТКАЗЫВАЕТСЯ для live, paper-тестируются в Aggressive Lab С реальным датированным хвостом (нехеджированная directional-книга потеряла ~50% на обвале ETH). Стабильные 15% — это не альфа, а хвост.">
          Target APY is illustrative only. The higher-yield tier is now honestly documented: the 12–20% strategies the desk REFUSES for live are paper-tested in the Aggressive Lab WITH their real, dated tail (the unhedged directional book lost ~50% through the ETH crash). A stable 15% is not alpha — it is a tail.
        </p>
        <div class="flex flex-wrap gap-3 mt-3">
          <a data-track="aggressive_to_packages" href="/packages" class="text-sm text-accent-400 underline" data-ru="Тир Aggressive в пакетах →">The Aggressive tier in packages →</a>
          <a href="/aggressive-lab" class="text-sm text-accent-400 underline" data-ru="Живой paper-тест агрессивных стратегий →">Live paper-test of the aggressive strategies →</a>
        </div>
      </div>
    </div>

    <!-- 1. Hero -->
    <section class="pt-12 pb-12">
      <div class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full bg-warn-bg border border-warn-border text-xs text-warn font-medium">
        <span class="w-1.5 h-1.5 rounded-full bg-warn" aria-hidden="true"></span>
        <span data-ru="Research · Paper">Research · Paper</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4 leading-tight" data-ru="Стратегия Aggressive">
        Aggressive Strategy
      </h1>
      <p class="text-xl text-white/50 leading-relaxed max-w-2xl">
        <span data-ru={maxYield.taglineRu}>{maxYield.tagline}</span>. <span data-ru="Плечевой PT-carry, points-фарминг и нехеджированный directional-рестейкинг — paper-тест в Aggressive Lab, отказан для live-капитала. Реальный хвост каскадных ликвидаций и депега (нехеджированная книга — ~50% на обвале ETH), показан честно.">Levered PT carry, points farming, and unhedged directional restaking — paper-tested in the Aggressive Lab, refused for live capital. Real liquidation-cascade and depeg tail (an unhedged book saw ~50% through the ETH crash), shown honestly.</span>
      </p>
    </section>

    <!-- 2. Target APY -->
    <section class="py-10 border-t border-white/5">
      <div class="flex flex-col sm:flex-row sm:items-center gap-6">
        <div>
          <p class="text-xs text-white/50 uppercase tracking-wider font-mono mb-2" data-ru="Целевой APY">Target APY</p>
          <div class="flex items-baseline gap-2">
            <span class="text-5xl font-mono font-bold text-accent-400">up to 20%</span>
            <span class="text-sm text-white/50 font-mono">target APY</span>
          </div>
          <p class="text-xs text-white/25 mt-2" data-ru={maxYield.target_apy_note_ru}>{maxYield.target_apy_note}</p>
        </div>
      </div>
    </section>

    <!-- 3. Risk Level -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/50 uppercase tracking-wider font-mono mb-3" data-ru="Уровень риска">Risk Level</p>
      <div class="flex items-center gap-3">
        <div class="flex gap-1" aria-label="Risk level: 3 of 3">
          <span class="inline-block w-8 h-3 rounded-sm bg-danger" aria-hidden="true"></span>
          <span class="inline-block w-8 h-3 rounded-sm bg-danger" aria-hidden="true"></span>
          <span class="inline-block w-8 h-3 rounded-sm bg-danger" aria-hidden="true"></span>
        </div>
        <span class="text-white/60 text-sm font-medium" data-ru="Повышенный риск">Higher Risk</span>
      </div>
      <p class="text-xs text-white/50 mt-2" data-ru="Продвинутая механика хранилищ. Более высокая терпимость к доходности с управляемыми параметрами риска.">
        Advanced vault mechanics. Higher yield tolerance with managed risk parameters.
      </p>
    </section>

    <!-- 4. Current Status -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/50 uppercase tracking-wider font-mono mb-4" data-ru="Текущий статус">Current Status</p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="rounded-xl border border-warn-border bg-warn-bg p-5">
          <div class="text-xs text-white/50 mb-1" data-ru="Фаза">Phase</div>
          <div class="text-warn font-semibold flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-warn" aria-hidden="true"></span>
            <span data-ru="Paper-тест (Aggressive Lab)">Paper-Tested (Aggressive Lab)</span>
          </div>
        </div>
        <div class="rounded-xl border border-white/10 bg-white/[0.03] p-5">
          <div class="text-xs text-white/50 mb-1" data-ru="Бумажный трек">Paper Tracking</div>
          <div class="text-white/50 font-semibold" data-ru="Активен — advisory">Active — advisory</div>
        </div>
        <div class="rounded-xl border border-white/10 bg-white/[0.03] p-5">
          <div class="text-xs text-white/50 mb-1" data-ru="Live-капитал">Live Capital</div>
          <div class="text-white/50 font-semibold" data-ru="Отказан">Refused</div>
        </div>
      </div>
    </section>

    <!-- 5. Who It's For -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/50 uppercase tracking-wider font-mono mb-3" data-ru="Для кого">Who It's For</p>
      <p class="text-white/60 leading-relaxed" data-ru="Опытные инвесторы, принимающие повышенную волатильность и просадку ради потенциала доходности.">
        Experienced allocators accepting higher volatility and drawdown for yield upside.
      </p>
      <div class="mt-4 rounded-xl bg-accent-500/5 border border-accent-500/15 p-5">
        <p class="text-sm text-white/50 leading-relaxed" data-ru={maxYield.descriptionRu}>
          {maxYield.description}
        </p>
      </div>
    </section>

    <!-- 6. What's Inside -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/50 uppercase tracking-wider font-mono mb-3" data-ru="Что внутри">What's Inside</p>
      <p class="text-white/50 text-sm leading-relaxed mb-4" data-ru="Aggressive — это плечевой PT-carry, points/incentive-фарминг и нехеджированный directional-рестейкинг. Он несёт реальный риск каскадных ликвидаций и депега — paper-тест в Aggressive Lab, отказан для live-капитала. Более сложные стратегии могут добавляться после отдельной бумажной валидации.">
        Aggressive is levered PT carry, points / incentive farming, and unhedged directional restaking. It carries
        real liquidation-cascade and depeg risk — paper-tested in the Aggressive Lab, refused for live capital. More complex strategies may be added after separate paper validation.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="rounded-xl bg-white/[0.03] border border-white/8 p-5">
          <p class="text-xs text-accent-400 font-mono uppercase tracking-wider mb-3" data-ru="Механика">Mechanics</p>
          <ul class="space-y-2 text-sm text-white/50">
            <li class="flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-accent-400 flex-shrink-0" aria-hidden="true"></span>
              <span data-ru="Плечевые PT-carry петли">Levered PT carry loops</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-accent-400 flex-shrink-0" aria-hidden="true"></span>
              <span data-ru="Points / incentive-фарминг">Points / incentive farming</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-accent-400 flex-shrink-0" aria-hidden="true"></span>
              <span data-ru="Нехеджированный directional-рестейкинг">Unhedged directional restaking</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-accent-400 flex-shrink-0" aria-hidden="true"></span>
              <span data-ru="Реальный риск каскадных ликвидаций и депега">Real liquidation-cascade &amp; depeg risk</span>
            </li>
          </ul>
        </div>
        <div class="rounded-xl bg-white/[0.03] border border-white/8 p-5">
          <p class="text-xs text-data-teal font-mono uppercase tracking-wider mb-3" data-ru="Мониторинг">Monitoring</p>
          <ul class="space-y-2 text-sm text-white/50">
            <li class="flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-data-teal flex-shrink-0" aria-hidden="true"></span>
              <span data-ru="Оповещения об отклонении цены оракула">Oracle price deviation alerts</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-data-teal flex-shrink-0" aria-hidden="true"></span>
              <span data-ru="Мониторинг уровня утилизации">Utilisation rate monitoring</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-data-teal flex-shrink-0" aria-hidden="true"></span>
              <span data-ru="Проверки здоровья позиций">Position health checks</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-data-teal flex-shrink-0" aria-hidden="true"></span>
              <span data-ru="Автоматические триггеры риска">Automated risk triggers</span>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- 7. Yield Sources -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/50 uppercase tracking-wider font-mono mb-4" data-ru="Источники доходности">Yield Sources</p>
      <div class="flex flex-wrap gap-2">
        {maxYield.yield_sources.map((source: string) => (
          <span class="px-3 py-1.5 rounded-lg text-sm font-mono bg-white/5 text-white/50 border border-white/10">
            {source}
          </span>
        ))}
      </div>
      <p class="text-xs text-white/25 mt-3" data-ru="Доходность усиливается за счёт плеча. Более высокая доходность сопряжена с пропорционально более высоким риском потерь.">
        Yield amplified through leverage. Higher returns come with proportionally higher risk of loss.
      </p>
    </section>

    <!-- 8. What This Strategy Does NOT Do -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/50 uppercase tracking-wider font-mono mb-4" data-ru="Чего эта стратегия НЕ делает">What This Strategy Does NOT Do</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {[
          { en: 'Move real / live capital — paper-only, refused for live', ru: 'Двигать реальный / live-капитал — только paper, отказан для live' },
          { en: 'Allocate without risk gate approval', ru: 'Размещать средства без одобрения риск-гейта' },
          { en: 'Bypass RiskPolicy deterministic gate', ru: 'Обходить детерминированный гейт RiskPolicy' },
          { en: 'Override kill switch in any scenario', ru: 'Переопределять kill switch в любом сценарии' },
        ].map((item) => (
          <div class="flex items-center gap-3 px-4 py-3 rounded-lg bg-white/[0.02] border border-white/5">
            <span class="text-danger flex-shrink-0">&#10005;</span>
            <span class="text-sm text-white/50" data-ru={item.ru}>{item.en}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- 9. Risk Controls -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-data-teal uppercase tracking-wider font-mono mb-4" data-ru="Контроль рисков — RiskPolicy v1.0">Risk Controls — RiskPolicy v1.0</p>
      <p class="text-sm text-white/55 mb-6 leading-relaxed" data-ru="Aggressive — это advisory-исследование ВНЕ RiskPolicy v1.0: детерминированный гейт ОТКАЗЫВАЕТ его для live-капитала. Параметры ниже — это живой гейт, который тир не проходит; сам механизм несёт реальный риск каскадных ликвидаций и депега.">
        Aggressive is advisory research OUTSIDE RiskPolicy v1.0 — the deterministic gate REFUSES it for live capital.
        The parameters below are the live gate it does not pass; the aggressive mechanic itself carries real liquidation-cascade and depeg risk.
      </p>
      <div class="overflow-x-auto rounded-xl border border-white/10">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/10 bg-white/[0.03]">
              <th class="text-left px-5 py-3 text-xs text-white/50 font-medium uppercase tracking-wider" data-ru="Параметр">Parameter</th>
              <th class="text-left px-5 py-3 text-xs text-white/50 font-medium uppercase tracking-wider" data-ru="Значение">Value</th>
              <th class="text-left px-5 py-3 text-xs text-white/50 font-medium uppercase tracking-wider" data-ru="Эффект">Effect</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5">
            <tr>
              <td class="px-5 py-3 text-white/60 font-mono" data-ru="Минимальный TVL">TVL floor</td>
              <td class="px-5 py-3 text-white font-mono font-semibold">&ge; $5M</td>
              <td class="px-5 py-3 text-white/55" data-ru="Пулы ниже этого порога исключаются">Pools below this threshold excluded</td>
            </tr>
            <tr>
              <td class="px-5 py-3 text-white/60 font-mono" data-ru="Лимит на протокол">Per-protocol cap</td>
              <td class="px-5 py-3 text-white font-mono font-semibold" data-ru="40% T1 / 20% T2">40% T1 / 20% T2</td>
              <td class="px-5 py-3 text-white/55" data-ru="Макс. аллокация в один протокол по Tier">Max allocation to single protocol, by Tier</td>
            </tr>
            <tr>
              <td class="px-5 py-3 text-white/60 font-mono" data-ru="Всего T2">T2 total cap</td>
              <td class="px-5 py-3 text-white font-mono font-semibold">&le; 50%</td>
              <td class="px-5 py-3 text-white/55" data-ru="Совокупный лимит на Tier 2">Aggregate cap on Tier 2 exposure</td>
            </tr>
            <tr>
              <td class="px-5 py-3 text-white/60 font-mono" data-ru="Диапазон APY">APY range</td>
              <td class="px-5 py-3 text-white font-mono font-semibold">1% – 30%</td>
              <td class="px-5 py-3 text-white/55" data-ru="Позиции вне диапазона отклоняются">Positions outside range rejected</td>
            </tr>
            <tr>
              <td class="px-5 py-3 text-white/60 font-mono" data-ru="Денежный буфер">Cash buffer</td>
              <td class="px-5 py-3 text-white font-mono font-semibold">&ge; 5%</td>
              <td class="px-5 py-3 text-white/55" data-ru="Всегда удерживается в резерве">Always held in reserve</td>
            </tr>
            <tr>
              <td class="px-5 py-3 text-white/60 font-mono" data-ru="Риск ликвидации">Liquidation risk</td>
              <td class="px-5 py-3 text-danger font-mono font-semibold" data-ru="Реальный (каскад)">Real (cascade)</td>
              <td class="px-5 py-3 text-white/55" data-ru="Плечевые петли и directional-рестейкинг несут каскад ликвидаций и депег — причина, по которой гейт отказывает live">Levered loops + directional restaking carry cascade &amp; depeg — why the gate refuses live</td>
            </tr>
            <tr>
              <td class="px-5 py-3 text-warn font-mono" data-ru="Kill switch — SOFT">Kill switch — SOFT</td>
              <td class="px-5 py-3 text-warn font-mono font-semibold" data-ru="&ge; 5% просадки от пика">&ge; 5% peak drawdown</td>
              <td class="px-5 py-3 text-white/55" data-ru="Де-риск: стоп новых входов и увеличения позиций, без ликвидации">De-risk: halt new entries &amp; increases, no liquidation</td>
            </tr>
            <tr>
              <td class="px-5 py-3 text-danger font-mono" data-ru="Kill switch — HARD">Kill switch — HARD</td>
              <td class="px-5 py-3 text-danger font-mono font-semibold" data-ru="&ge; 10% просадки от пика">&ge; 10% peak drawdown</td>
              <td class="px-5 py-3 text-white/55" data-ru="Весь портфель переводится в кэш">Move whole portfolio to cash</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- 10. Performance / Validation Status -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/50 uppercase tracking-wider font-mono mb-4" data-ru="Статус валидации">Validation Status</p>
      <div class="rounded-xl border border-warn-border bg-warn-bg p-6">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-2 h-2 rounded-full bg-warn" aria-hidden="true"></span>
          <span class="text-sm text-warn font-medium" data-ru="Активный paper-тест · отказан для live-капитала">Paper-tested · refused for live capital</span>
        </div>
        <p class="text-sm text-white/55 leading-relaxed" data-ru="Агрессивные стратегии активно paper-тестируются в Aggressive Lab (несколько книг, живой forward-трек) — С реальным датированным хвостом. Для LIVE-капитала деск их ОТКАЗЫВАЕТ: доходность здесь — компенсация за хвостовой риск, а не эдж. APY — целевой диапазон, не гарантия.">
          The aggressive strategies are actively <a href="/aggressive-lab" class="text-accent-400 underline">paper-tested in the Aggressive Lab</a> (several books, a live forward track) — WITH their real, dated tail. The desk REFUSES them for LIVE capital: the yield here is compensation for tail risk, not edge. APY is a target range, not a guarantee.
        </p>
      </div>
    </section>

    <!-- 11. Strategy-Specific Risks -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-danger uppercase tracking-wider font-mono mb-4" data-ru="Риски, специфичные для стратегии">Strategy-Specific Risks</p>
      <p class="text-sm text-white/55 mb-6 leading-relaxed" data-ru="Aggressive несёт все риски Balanced плюс риски плеча и directional-экспозиции. Он имеет реальный риск каскадных ликвидаций и депега — нехеджированная книга потеряла ~50% на обвале ETH. Отказан для live-капитала.">
        Aggressive carries all risks of the Balanced strategy plus leverage and directional risks. It has
        real liquidation-cascade and depeg risk — an unhedged book saw ~50% through the ETH crash. Refused for live capital.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="rounded-xl border border-white/8 bg-white/[0.02] p-5">
          <h4 class="text-sm font-semibold text-white mb-2" data-ru="Риск смарт-контрактов">Smart Contract Risk</h4>
          <p class="text-xs text-white/55 leading-relaxed" data-ru="Продвинутая механика хранилищ взаимодействует с большим числом слоёв протоколов, увеличивая площадь потенциальных уязвимостей.">
            Advanced vault mechanics interact with more protocol layers, increasing
            the surface area for potential vulnerabilities.
          </p>
        </div>
        <div class="rounded-xl border border-white/8 bg-white/[0.02] p-5">
          <h4 class="text-sm font-semibold text-white mb-2" data-ru="Риск депега стейблкоина">Stablecoin Depeg Risk</h4>
          <p class="text-xs text-white/55 leading-relaxed" data-ru="USDT или USDC могут временно или навсегда потерять привязку. Kill switch реагирует по уровню: SOFT де-риск при просадке от пика ≥5%, HARD (всё в кэш) при ≥10%, независимо от причины.">
            USDT or USDC may temporarily or permanently lose their peg.
            The kill switch responds by tier: SOFT de-risk at ≥5% peak drawdown, HARD (all to cash) at ≥10%, regardless of cause.
          </p>
        </div>
        <div class="rounded-xl border border-white/8 bg-white/[0.02] p-5">
          <h4 class="text-sm font-semibold text-white mb-2" data-ru="Риск оракулов">Oracle Risk</h4>
          <p class="text-xs text-white/55 leading-relaxed" data-ru="Ценовые фиды от оракулов могут запаздывать или быть подвержены манипуляциям. Стратегия использует агрегированные фиды для данных по APY.">
            Price feeds from oracles may be delayed or manipulated.
            Strategy relies on aggregated feeds for APY data.
          </p>
        </div>
        <div class="rounded-xl border border-white/8 bg-white/[0.02] p-5">
          <h4 class="text-sm font-semibold text-white mb-2" data-ru="Риск сложности">Complexity Risk</h4>
          <p class="text-xs text-white/55 leading-relaxed" data-ru="У продвинутых стратегий больше движущихся частей. Выше требования к мониторингу и шире спектр возможных сценариев отказа.">
            Advanced strategies have more moving parts. Higher monitoring requirements
            and wider range of potential failure modes.
          </p>
        </div>
        <div class="rounded-xl border border-white/8 bg-white/[0.02] p-5">
          <h4 class="text-sm font-semibold text-white mb-2" data-ru="Риск ликвидности">Liquidity Risk</h4>
