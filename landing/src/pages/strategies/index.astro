---
import Layout from '../../layouts/Layout.astro';
import StrategyCard from '../../components/StrategyCard.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import strategies from '../../data/strategy_config.json';
---

<Layout
  title="Investment Strategies — SPA | earn-defi.com"
  description="Three risk profiles for DeFi yield: Preserve, Core, and Max Yield. Deterministic risk gates, public paper track record. Variable APY, not guaranteed."
>

  <!-- Nav -->
  <!-- Hero -->
  <section class="py-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-6xl mx-auto">

      <div class="text-center mb-6 max-w-2xl mx-auto">
        <p class="text-accent-400 text-eyebrow font-mono uppercase tracking-[0.12em] mb-3" data-ru="Инвестиционные стратегии">Investment Strategies</p>
        <h1 class="text-4xl sm:text-5xl font-bold text-text-primary mb-6 leading-tight" data-ru="Один фреймворк. Три профиля риска.">
          One Framework. Three Risk Profiles.
        </h1>
        <p class="text-lg text-text-secondary leading-relaxed" data-ru="Тот же детерминированный риск-движок. Те же неотменяемые гейты. Разные аллокации, оптимизированные под вашу терпимость к риску. Все показатели APY переменные и не гарантированы.">
          Same deterministic risk engine. Same non-overridable gates. Different allocations
          optimised for your risk tolerance. All APY figures are variable and not guaranteed.
        </p>
      </div>

      <!-- Risk gradient bar -->
      <div class="max-w-xl mx-auto mb-16">
        <div class="flex items-center gap-3">
          <span class="text-xs text-text-muted font-mono whitespace-nowrap" data-ru="Ниже риск">Lower Risk</span>
          <div class="flex-1 h-1.5 rounded-full bg-gradient-to-r from-data-teal via-accent to-warn opacity-50"></div>
          <span class="text-xs text-text-muted font-mono whitespace-nowrap" data-ru="Выше риск">Higher Risk</span>
        </div>
      </div>

      <!-- Strategy cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        {strategies.strategies.map((strategy) => (
          <StrategyCard strategy={strategy} />
        ))}
      </div>

      <!-- How candidates are vetted → Tournament -->
      <div class="max-w-3xl mx-auto mb-12 rounded-xl p-5 flex items-start gap-4"
           style="background:var(--bg-surface);border:1px solid var(--border)">
        <div class="min-w-0">
          <p class="text-sm font-semibold text-text-primary mb-1" data-ru="Как отбираются новые стратегии">How new strategies are vetted</p>
          <p class="text-sm text-text-secondary leading-relaxed" data-ru="Кандидаты соревнуются в турнире backtest → paper → live. Промоушен получают только победители на достоверных данных — гейт fail-closed отказывает на вырожденных данных. Смотрите живую турнирную таблицу и лестницу промоушена.">
            Candidates compete in a tournament backtest → paper → live. Only credible-data winners
            promote — the fail-closed gate refuses on degenerate data. See the live leaderboard and
            promotion ladder.
          </p>
        </div>
        <a href="/tournament" class="shrink-0 inline-flex items-center gap-1.5 text-sm font-mono whitespace-nowrap px-3 py-1.5 rounded-md border"
           style="border-color:var(--accent-border);color:var(--accent-hover);background:var(--accent-bg)"
           data-ru="Открыть турнир →">Open the tournament →</a>
      </div>

      <!-- Honest tier breakdown → /packages -->
      <div class="max-w-3xl mx-auto mb-12 rounded-xl p-5 flex items-start gap-4"
           style="background:var(--bg-surface);border:1px solid var(--border)">
        <div class="min-w-0">
          <p class="text-sm font-semibold text-text-primary mb-1" data-ru="Тиры честно — с хвостом">The tiers, honestly — with the tail</p>
          <p class="text-sm text-text-secondary leading-relaxed" data-ru="Conservative — реальный ~3.3% (подтверждён, fundable). Balanced и Aggressive — research/paper, показаны С реальным датированным хвостом и отказаны для live-капитала. Чем выше тир, тем больше хвост — измерен, не спрятан.">
            Conservative is the real ~3.3% (evidenced, fundable). Balanced and Aggressive are research/paper,
            shown WITH their real dated tail and refused for live capital. The higher the tier, the bigger the
            tail — measured, not hidden.
          </p>
        </div>
        <a href="/packages" class="shrink-0 inline-flex items-center gap-1.5 text-sm font-mono whitespace-nowrap px-3 py-1.5 rounded-md border"
           style="border-color:var(--accent-border);color:var(--accent-hover);background:var(--accent-bg)"
           data-ru="Открыть пакеты →">Open packages →</a>
      </div>

      <!-- Beyond stablecoins — strategies we ASSESS / REFUSE (not what we hold) -->
      <div class="max-w-3xl mx-auto mb-12">
        <div class="mb-4">
          <p class="text-text-faint text-eyebrow font-mono uppercase tracking-[0.12em] mb-1" data-ru="За пределами стейблов — оценено, не в портфеле">Beyond stablecoins — assessed, not held</p>
          <p class="text-sm text-text-secondary leading-relaxed" data-ru="Наглядно и честно: стратегии, которые деск ОЦЕНИВАЕТ (BTC) или ОТКАЗЫВАЕТ для live (плечевые петли) — advisory, не то, что мы держим.">
            Visual and honest: strategies the desk <strong class="text-text-primary">assesses</strong> (BTC)
            or <strong class="text-text-primary">refuses</strong> for live (leverage loops) — advisory, not
            what we hold.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <a href="/strategies/btc" class="block rounded-xl p-5 transition-colors" style="background:var(--bg-surface);border:1px solid var(--border);border-left:3px solid var(--data-teal)">
            <div class="flex items-center justify-between gap-3 mb-2">
              <span class="text-sm font-semibold text-text-primary" data-ru="BTC-кредитование, наглядно">BTC lending, visualized</span>
              <span class="text-[10px] font-mono uppercase tracking-wider px-2 py-0.5 rounded-full" style="background:var(--warn-bg);color:var(--warn);border:1px solid var(--warn-border)" data-ru="advisory">advisory</span>
            </div>
            <p class="text-xs text-text-secondary leading-relaxed" data-ru="Честные ~0% on-chain — почему BTC почти не занимают и почему мы не притворяемся иначе.">The honest ~0% on-chain — why BTC is barely borrowed, and why we don't pretend otherwise.</p>
          </a>
          <a href="/strategies/leverage-loops" class="block rounded-xl p-5 transition-colors" style="background:var(--bg-surface);border:1px solid var(--border);border-left:3px solid var(--warn)">
            <div class="flex items-center justify-between gap-3 mb-2">
              <span class="text-sm font-semibold text-text-primary" data-ru="Плечевые петли, наглядно">Leverage loops, visualized</span>
              <span class="text-[10px] font-mono uppercase tracking-wider px-2 py-0.5 rounded-full" style="background:var(--danger-bg);color:var(--danger);border:1px solid var(--danger-border)" data-ru="класс C · отказ">class C · refused</span>
            </div>
            <p class="text-xs text-text-secondary leading-relaxed" data-ru="N× доход, N× ликвидация — и настоящий датированный хвост -35%, который петля стоила в advisory-лаборатории.">N× yield, N× liquidation — and the real dated -35% tail looping cost in the advisory lab.</p>
          </a>
        </div>
      </div>

      <!-- Disclaimer -->
      <p class="text-center text-xs text-white/20 max-w-2xl mx-auto mb-12">
        {strategies.global.apy_disclaimer}
      </p>

    </div>
  </section>

  <!-- ====================================================================== -->
  <!-- STRATEGY LAB — research sleeves (live /api/strategy-lab)                -->
  <!-- ====================================================================== -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 border-t border-border">
    <div class="max-w-6xl mx-auto">

      <!-- Section header -->
      <div class="max-w-3xl mb-10">
        <p class="text-text-faint text-eyebrow font-mono uppercase tracking-[0.12em] mb-3" data-ru="Strategy Lab — исследовательские слипы">Strategy Lab — research sleeves</p>
        <h2 class="text-2xl sm:text-3xl font-bold text-text-primary mb-4 leading-tight" data-ru="Что мы тестируем за пределами трёх продуктовых тиров">
          What we test beyond the three product tiers
        </h2>
        <p class="text-base text-text-secondary leading-relaxed" data-ru="Это паперный бэктест-стенд: исследовательские слипы, прогоняемые через тот же детерминированный риск-движок. Слипы внизу — это исследование, рекомендательное (advisory), не живое. Это не предлагаемые продукты, и они не входят в наш паперный трек.">
          This is a paper backtest bench: research sleeves run through the same deterministic
          risk engine. The sleeves below are research, advisory, and not live. They are not
          offered products and are not part of our paper track record.
        </p>
      </div>

      <!-- Honest finding callout -->
      <div class="rounded-lg border border-warn/25 bg-warn/[0.07] p-5 mb-8">
        <p class="text-eyebrow font-mono uppercase tracking-[0.12em] text-warn/80 mb-2" data-ru="Честный вывод">Honest finding</p>
        <p class="text-sm text-text-secondary leading-relaxed" data-ru="Крипто-слипы доходности (ETH/BTC) — это диверсификаторы, а не «победители над полом доходности»: маркет-нейтральные книги имеют низкую волатильность, но не перекрывают ~3.4% пол RWA; направленные книги забирают полную крипто-просадку. Только стейбл-движки (Engine A/B/C + RWA) перекрывают пол.">
          Crypto (ETH/BTC) yield sleeves are <strong class="text-text-primary">diversifiers, not
          floor-beaters</strong>: the neutral books are low-vol but don't clear the ~3.4% RWA
          floor; directional books take the full crypto drawdown. Only the stable engines
          (Engine A/B/C + RWA) clear the floor.
        </p>
      </div>

      <!-- Honesty chip: backtest / advisory / not realized (from API meta.disclaimer) -->
      <div class="mb-6">
        <span id="lab-meta-chip" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-mono uppercase tracking-wider border border-warn/30 bg-warn/[0.08] text-warn/90">
          <span class="w-1.5 h-1.5 rounded-full bg-warn/80" aria-hidden="true"></span>
          <span id="lab-meta-text" data-ru="Бэктест · advisory · не реализованный капитал">Backtest · advisory · not realized capital</span>
        </span>
      </div>

      <!-- Meta strip: RWA floor + window + source -->
      <div class="flex flex-wrap items-center gap-x-6 gap-y-2 mb-8 text-eyebrow font-mono">
        <span class="text-text-muted">
          <span data-ru="Пол RWA (безрисковый бенч):">RWA floor (risk-free bench):</span>
          <span class="text-data-teal font-semibold" id="lab-floor">—</span>
        </span>
        <span class="text-text-muted">
          <span data-ru="Окно бэктеста:">Backtest window:</span>
          <span class="text-text-secondary" id="lab-window">—</span>
        </span>
        <span class="text-text-muted">
          <span data-ru="источник:">source:</span>
          <span class="text-text-secondary" id="lab-src">offline</span>
        </span>
      </div>

      <!-- Offline / loading state -->
      <div id="lab-status" class="rounded-lg border border-border bg-bg-surface p-6 mb-8 text-sm text-text-muted">
        <span data-ru="Загрузка исследовательских слипов из живого фида…">Loading research sleeves from the live feed…</span>
      </div>

      <!-- Mandate groups rendered here -->
      <div id="lab-groups" class="space-y-10 hidden"></div>

      <p class="text-xs text-text-faint max-w-3xl mt-8 leading-relaxed" data-ru="Все цифры — паперный бэктест на исторических данных, переменные, не гарантированные и не являются инвестиционным советом. β(ETH) — оценочная чувствительность к доходности ETH. «Убит» означает, что детерминированный риск-гейт закрыл слип в бэктесте (kill-switch или fail-closed по отсутствующим данным).">
        All figures are paper backtest on historical data, variable, not guaranteed, and not
        investment advice. β(ETH) is the estimated sensitivity to ETH returns. "Killed" means the
        deterministic risk gate closed the sleeve during the backtest (kill-switch, or fail-closed
        on missing data).
      </p>

      <!-- Back link -->
      <div class="mt-12">
        <a href="/" class="text-sm text-text-muted hover:text-text-secondary transition-colors" data-ru="&larr; Назад на главную">
          &larr; Back to Homepage
        </a>
      </div>

    </div>
  </section>

  <Disclaimer />

  <script is:inline>
    /* Strategy Lab — live /api/strategy-lab, localhost fallback, graceful offline. */
    (function () {
      var API = (location.hostname === 'localhost' || location.hostname === '127.0.0.1')
        ? 'http://localhost:8765'
        : 'https://api.earn-defi.com';

      function isRu() { try { return (localStorage.getItem('spa_lang') || 'en') === 'ru'; } catch (e) { return false; } }
      function t(en, ru) { return isRu() ? ru : en; }
      function esc(s) { return String(s == null ? '' : s).replace(/[&<>"]/g, function (c) { return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]; }); }
      function pct(v, dp) { return v == null ? '—' : Number(v).toFixed(dp == null ? 2 : dp) + '%'; }

      // mandate -> display label + accent color
      var MANDATES = {
        stable:      { en: 'Stable', ru: 'Стейбл',       color: 'var(--data-teal)', desc_en: 'Stablecoin / RWA books — the floor-clearing engines.', desc_ru: 'Книги на стейблах / RWA — движки, перекрывающие пол.' },
        neutral:     { en: 'Neutral', ru: 'Нейтральные', color: 'var(--accent)',    desc_en: 'Market-neutral (delta-hedged) crypto carry — low vol, diversifiers.', desc_ru: 'Маркет-нейтральные (дельта-хедж) крипто-керри — низкая волатильность, диверсификаторы.' },
        directional: { en: 'Directional', ru: 'Направленные', color: 'var(--warn)', desc_en: 'Unhedged crypto exposure (β ≈ 1) — takes the full drawdown.', desc_ru: 'Нехеджированная крипто-экспозиция (β ≈ 1) — забирает полную просадку.' }
      };
      var ORDER = ['stable', 'neutral', 'directional'];

      var state = null; // cached payload for re-render on lang toggle

      function badge(s, color) {
        return '<span class="inline-block px-2 py-0.5 rounded-full text-[10px] font-mono uppercase tracking-wider" style="background:' + color + '1a;color:' + color + ';border:1px solid ' + color + '40">' + esc(s) + '</span>';
      }

      // yield_basis honesty tag: assumed (engine_b/c) | live_feed (rwa) | realized.
      // Pulls verbatim from the API; absent → no tag (conservative, not fabricated).
      function basisTag(s) {
        var b = s.yield_basis;
        if (b === 'assumed') {
          var note = (s.id === 'engine_c')
            ? t('representative target yield — LP fee-only, impermanent loss not modeled — not realized',
                'ориентир целевой доходности — только комиссии LP, непостоянные потери не моделируются — не реализовано')
            : t('representative target yield — HY band-median proxy — not realized',
                'ориентир целевой доходности — прокси по медиане HY-диапазона — не реализовано');
          return '<div class="mt-3">' +
              '<span class="inline-block px-2 py-0.5 rounded-full text-[10px] font-mono uppercase tracking-wider" style="background:var(--warn)1a;color:var(--warn);border:1px solid var(--warn)40">' +
                t('assumed', 'предполагаемый') + '</span>' +
              '<p class="text-[11px] text-text-faint mt-1.5 leading-snug">' + esc(note) + '</p>' +
            '</div>';
        }
        if (b === 'live_feed') {
          return '<div class="mt-3">' +
              '<span class="inline-block px-2 py-0.5 rounded-full text-[10px] font-mono uppercase tracking-wider" style="background:var(--data-teal)1a;color:var(--data-teal);border:1px solid var(--data-teal)40">' +
                t('live feed', 'живой фид') + '</span></div>';
        }
        return ''; // realized → clean
      }

      function card(s) {
        var floorOk = s.beats_rwa_floor;
        var floorCell = floorOk
          ? '<span class="text-ok font-semibold">✓ ' + t('beats', 'выше') + '</span>'
          : '<span class="text-danger/80">✗ ' + t('below', 'ниже') + '</span>';
        var killRow = '';
        if (s.killed) {
          killRow =
            '<div class="mt-3 pt-3 border-t border-border/60">' +
            badge(t('Killed', 'Убит'), 'var(--danger)') +
            '<p class="text-xs text-text-muted mt-2 leading-snug font-mono">' + esc(s.kill_reason || '') + '</p>' +
            '</div>';
        }
        var m = MANDATES[s.mandate] || { color: 'var(--text-faint)' };
        var apyColor = s.net_apy_pct != null && s.net_apy_pct < 0 ? 'text-danger' : 'text-text-primary';

        return '' +
          '<div class="rounded-lg border border-border bg-bg-surface p-5 hover:border-border-strong transition-colors" style="border-top:3px solid ' + m.color + '">' +
            '<div class="flex items-start justify-between gap-3 mb-3">' +
              '<h4 class="text-sm font-semibold text-text-primary leading-snug">' + esc(s.name) + '</h4>' +
              (s.killed ? '' : badge(t('Active', 'Активен'), 'var(--ok)')) +
            '</div>' +
            '<div class="grid grid-cols-2 gap-x-4 gap-y-3 text-xs">' +
              '<div><p class="text-text-muted font-mono uppercase tracking-wider mb-0.5">' + t('Net APY', 'Чистый APY') + '</p><p class="text-base font-mono font-bold ' + apyColor + '">' + pct(s.net_apy_pct) + '</p></div>' +
              '<div><p class="text-text-muted font-mono uppercase tracking-wider mb-0.5">' + t('Max drawdown', 'Макс. просадка') + '</p><p class="text-base font-mono font-bold text-text-primary">' + pct(s.max_drawdown_pct) + '</p></div>' +
              '<div><p class="text-text-muted font-mono uppercase tracking-wider mb-0.5">β(ETH)</p><p class="text-sm font-mono text-text-secondary">' + (s.beta_to_eth == null ? '—' : Number(s.beta_to_eth).toFixed(2)) + '</p></div>' +
              '<div><p class="text-text-muted font-mono uppercase tracking-wider mb-0.5">' + t('Beats RWA floor', 'Перекрывает пол RWA') + '</p><p class="text-sm font-mono">' + floorCell + '</p></div>' +
            '</div>' +
            basisTag(s) +
            killRow +
          '</div>';
      }

      function render() {
        if (!state) return;
        var d = state;
        // Honesty chip — prefer the API's meta.disclaimer (verbatim, EN-only from server);
        // fall back to the bilingual static copy already in the DOM (data-ru handled by i18n).
        var chipText = document.getElementById('lab-meta-text');
        if (chipText && d.meta && d.meta.disclaimer && !isRu()) {
          chipText.textContent = d.meta.disclaimer;
          chipText.removeAttribute('data-ru');
        }
        var floorEl = document.getElementById('lab-floor');
        if (floorEl) floorEl.textContent = d.rwa_floor_pct != null ? Number(d.rwa_floor_pct).toFixed(2) + '%' : '—';
        var winEl = document.getElementById('lab-window');
        if (winEl) winEl.textContent = (d.window_start || '?') + ' → ' + (d.window_end || '?');

        var groupsEl = document.getElementById('lab-groups');
        var statusEl = document.getElementById('lab-status');
        if (!groupsEl) return;

        var byMandate = {};
        (d.strategies || []).forEach(function (s) {
          var k = MANDATES[s.mandate] ? s.mandate : 'directional';
          (byMandate[k] = byMandate[k] || []).push(s);
        });

        var html = '';
        ORDER.forEach(function (k) {
          var list = byMandate[k];
          if (!list || !list.length) return;
          var m = MANDATES[k];
          html +=
            '<div>' +
              '<div class="flex items-baseline gap-3 mb-4">' +
                '<span class="text-eyebrow font-mono uppercase tracking-[0.12em] font-semibold" style="color:' + m.color + '">' + (isRu() ? m.ru : m.en) + '</span>' +
                '<span class="text-xs text-text-muted">' + (isRu() ? m.desc_ru : m.desc_en) + '</span>' +
              '</div>' +
              '<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">' +
                list.map(card).join('') +
              '</div>' +
            '</div>';
        });

        groupsEl.innerHTML = html;
        groupsEl.classList.remove('hidden');
        if (statusEl) statusEl.classList.add('hidden');
      }

      function load() {
        fetch(API + '/api/strategy-lab').then(function (r) { return r.json(); }).then(function (d) {
          if (!d || !d.strategies) throw new Error('no data');
          state = d;
          var srcEl = document.getElementById('lab-src');
          if (srcEl) srcEl.textContent = 'live';
          render();
        }).catch(function () {
          var statusEl = document.getElementById('lab-status');
          if (statusEl) {
            statusEl.textContent = t(
              'Research sleeves are loaded from the live feed (api.earn-defi.com). The feed is offline right now — check back shortly.',
              'Исследовательские слипы загружаются из живого фида (api.earn-defi.com). Сейчас фид офлайн — загляните чуть позже.'
            );
          }
        });
      }

      // re-render labels on language toggle (i18n runtime calls window.__renderLive)
      window.__renderLive = (function (prev) {
        return function () { try { if (prev) prev(); } catch (e) {} try { render(); } catch (e) {} };
      })(window.__renderLive);

      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', load);
      else load();
    })();
  </script>
</Layout>
