---
import Layout from '../../layouts/Layout.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import strategies from '../../data/strategy_config.json';

const core = strategies.strategies.find(s => s.id === 'core')!;
const global = strategies.global;
---

<Layout
  title="Core Strategy — Systematic DeFi Yield | SPA earn-defi.com"
  description="Systematic DeFi yield with paper track record since June 2026. Tier 1 + Tier 2 protocols, deterministic risk gates, target 4–6% APY (actual paper ~3.6%). Paper tracked since June 10, 2026. USDT and USDC."
>

  <!-- Nav -->
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- 1. Hero -->
    <section class="pt-20 pb-12">
      <div class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full bg-green-500/10 border border-green-800 text-xs text-green-400 font-medium">
        <span class="w-1.5 h-1.5 rounded-full bg-green-400" aria-hidden="true"></span>
        <span data-ru="Бумажный трек">Paper Tracked</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4 leading-tight" data-ru="Стратегия Core">
        Core Strategy
      </h1>
      <p class="text-xl text-white/50 leading-relaxed max-w-2xl" data-ru="Систематическая доходность в DeFi с подтверждённым бумажным треком. Детерминированная ребалансировка с риск-гейтами по протоколам Tier 1 и отдельным Tier 2. Бумажная торговля с 10 июня 2026 года.">
        Systematic DeFi yield with a paper track record since June 2026. Deterministic
        risk-gated rebalancing across Tier 1 and selected Tier 2 protocols.
        Paper tracked since June 10, 2026.
      </p>
    </section>

    <!-- 2. Target APY -->
    <section class="py-10 border-t border-white/5">
      <div class="flex flex-col sm:flex-row sm:items-center gap-6">
        <div>
          <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-2" data-ru="Целевой диапазон APY">Target APY Range</p>
          <div class="flex items-baseline gap-2">
            <span class="text-5xl font-mono font-bold text-accent-400">4–6%</span>
            <span class="text-sm text-white/30 font-mono">APY</span>
          </div>
          <p class="text-xs text-white/25 mt-2"><span data-ru="Бумажный трек с">Paper tracked since</span> {global.paper_trading_start}. <span data-ru="Переменный APY, не гарантирован.">Variable APY, not guaranteed.</span></p>
        </div>
      </div>
    </section>

    <!-- 3. Risk Level -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-3" data-ru="Уровень риска">Risk Level</p>
      <div class="flex items-center gap-3">
        <div class="flex gap-1" aria-label="Risk level: 2 of 3">
          <span class="inline-block w-8 h-3 rounded-sm bg-accent-400" aria-hidden="true"></span>
          <span class="inline-block w-8 h-3 rounded-sm bg-accent-400" aria-hidden="true"></span>
          <span class="inline-block w-8 h-3 rounded-sm bg-white/10" aria-hidden="true"></span>
        </div>
        <span class="text-white/60 text-sm font-medium" data-ru="Средний риск">Medium Risk</span>
      </div>
      <p class="text-xs text-white/30 mt-2" data-ru="Использует протоколы Tier 1 и отдельные Tier 2. Без плеча, без лупинга.">
        Uses Tier 1 + selected Tier 2 protocols. No leverage, no looping.
      </p>
    </section>

    <!-- 4. Current Status -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-4" data-ru="Текущий статус">Current Status</p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="rounded-xl border border-white/10 bg-white/[0.03] p-5">
          <div class="text-xs text-white/30 mb-1" data-ru="Фаза">Phase</div>
          <div class="text-white font-semibold flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-amber-400 animate-pulse-slow" aria-hidden="true"></span>
            <span data-ru="Бумажная торговля">Paper Trading</span>
          </div>
        </div>
        <div class="rounded-xl border border-white/10 bg-white/[0.03] p-5">
          <div class="text-xs text-white/30 mb-1" data-ru="Отслеживается с">Tracking Since</div>
          <div class="text-white font-semibold">{global.paper_trading_start}</div>
        </div>
        <div class="rounded-xl border border-white/10 bg-white/[0.03] p-5">
          <div class="text-xs text-white/30 mb-1" data-ru="Цель запуска">Go-Live Target</div>
          <div class="text-white font-semibold">{global.go_live_target}</div>
        </div>
      </div>
    </section>

    <!-- 5. Who It's For -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-3" data-ru="Для кого">Who It's For</p>
      <p class="text-white/60 leading-relaxed" data-ru="Семейные офисы и частные инвесторы, которым нужна систематическая и прозрачная доходность в DeFi.">
        Family offices and individual allocators seeking systematic, transparent DeFi yield.
      </p>
      <div class="mt-4 rounded-xl bg-accent-500/5 border border-accent-500/15 p-5">
        <p class="text-sm text-white/50 leading-relaxed" data-ru={core.descriptionRu}>
          {core.description}
        </p>
      </div>
    </section>

    <!-- 6. What's Inside -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-3" data-ru="Что внутри">What's Inside</p>
      <p class="text-white/50 text-sm leading-relaxed mb-4" data-ru="Стратегия Core распределяет капитал по аудированным DeFi-протоколам кредитования с высоким TVL. Ребалансировка запускается ежедневно cycle runner'ом и проходит через RiskPolicy v1.0 — детерминированный, неотменяемый риск-движок.">
        The Core strategy allocates across audited, high-TVL DeFi lending protocols. Rebalancing
        is triggered daily by the cycle runner and gated by RiskPolicy v1.0 — a deterministic,
        non-overridable risk engine.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="rounded-xl bg-white/[0.03] border border-white/8 p-5">
          <p class="text-xs text-teal-400 font-mono uppercase tracking-wider mb-3" data-ru="Tier 1 — Основной">Tier 1 — Primary</p>
          <ul class="space-y-2 text-sm text-white/50">
            <li class="flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-teal-400 flex-shrink-0" aria-hidden="true"></span>
              <span data-ru="Aave V3 (Ethereum) — ~3,5% APY">Aave V3 (Ethereum) — ~3.5% APY</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-teal-400 flex-shrink-0" aria-hidden="true"></span>
              <span data-ru="Compound V3 (Comet USDC) — ~4,8% APY">Compound V3 (Comet USDC) — ~4.8% APY</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-teal-400 flex-shrink-0" aria-hidden="true"></span>
              <span data-ru="Morpho Steakhouse — ~6,5% APY">Morpho Steakhouse — ~6.5% APY</span>
            </li>
          </ul>
        </div>
        <div class="rounded-xl bg-white/[0.03] border border-white/8 p-5">
          <p class="text-xs text-accent-400 font-mono uppercase tracking-wider mb-3" data-ru="Tier 2 — Дополнительный">Tier 2 — Supplementary</p>
          <ul class="space-y-2 text-sm text-white/50">
            <li class="flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-accent-400 flex-shrink-0" aria-hidden="true"></span>
              <span data-ru="Morpho Blue USDC">Morpho Blue USDC</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-accent-400 flex-shrink-0" aria-hidden="true"></span>
              <span data-ru="Yearn V3 USDC (ERC-4626)">Yearn V3 USDC (ERC-4626)</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-accent-400 flex-shrink-0" aria-hidden="true"></span>
              <span data-ru="Euler V2 USDC (ERC-4626)">Euler V2 USDC (ERC-4626)</span>
            </li>
          </ul>
          <p class="text-xs text-white/25 mt-3" data-ru="Совокупный T2 ограничен 50% портфеля (ADR-019)">T2 total capped at 50% of portfolio (ADR-019)</p>
        </div>
      </div>
    </section>

    <!-- 7. Yield Sources -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-4" data-ru="Источники доходности">Yield Sources</p>
      <div class="flex flex-wrap gap-2">
        {core.yield_sources.map((source: string) => (
          <span class="px-3 py-1.5 rounded-lg text-sm font-mono bg-white/5 text-white/50 border border-white/10">
            {source}
          </span>
        ))}
      </div>
      <p class="text-xs text-white/25 mt-3" data-ru="Вся доходность формируется из процентных ставок рынков кредитования. Без фарминга governance-токенов, без предоставления ликвидности, без плеча.">
        All yield comes from lending market interest rates. No governance token farming,
        no liquidity provision, no leverage.
      </p>
    </section>

    <!-- 8. What This Strategy Does NOT Do -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-4" data-ru="Чего эта стратегия НЕ делает">What This Strategy Does NOT Do</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {core.does_not.map((item: string, i: number) => (
          <div class="flex items-center gap-3 px-4 py-3 rounded-lg bg-white/[0.02] border border-white/5">
            <span class="text-red-400/70 flex-shrink-0">&#10005;</span>
            <span class="text-sm text-white/50" data-ru={core.does_not_ru?.[i]}>{item}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- 9. Risk Controls -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-teal-400 uppercase tracking-wider font-mono mb-4" data-ru="Контроль рисков — RiskPolicy v1.0">Risk Controls — RiskPolicy v1.0</p>
      <p class="text-sm text-white/40 mb-6 leading-relaxed" data-ru="Каждая предлагаемая аллокация проходит через детерминированный, жёстко зашитый риск-гейт. Ни человек, ни ИИ, ни стратегия не могут переопределить эти параметры.">
        Every proposed allocation passes through a deterministic, hard-coded risk gate.
        No human, no AI, no strategy can override these parameters.
      </p>
      <div class="overflow-x-auto rounded-xl border border-white/10">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/10 bg-white/[0.03]">
              <th class="text-left px-5 py-3 text-xs text-white/30 font-medium uppercase tracking-wider" data-ru="Параметр">Parameter</th>
              <th class="text-left px-5 py-3 text-xs text-white/30 font-medium uppercase tracking-wider" data-ru="Значение">Value</th>
              <th class="text-left px-5 py-3 text-xs text-white/30 font-medium uppercase tracking-wider" data-ru="Эффект">Effect</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5">
            <tr>
              <td class="px-5 py-3 text-white/60 font-mono" data-ru="Минимальный TVL">TVL floor</td>
              <td class="px-5 py-3 text-white font-mono font-semibold">&ge; $5M</td>
              <td class="px-5 py-3 text-white/40" data-ru="Пулы ниже этого порога исключаются">Pools below this threshold are excluded</td>
            </tr>
            <tr>
              <td class="px-5 py-3 text-white/60 font-mono" data-ru="Лимит на протокол (T1)">Per-protocol cap (T1)</td>
              <td class="px-5 py-3 text-white font-mono font-semibold">40%</td>
              <td class="px-5 py-3 text-white/40" data-ru="Макс. аллокация в один протокол T1">Max allocation to any single T1 protocol</td>
            </tr>
            <tr>
              <td class="px-5 py-3 text-white/60 font-mono" data-ru="Лимит на протокол (T2)">Per-protocol cap (T2)</td>
              <td class="px-5 py-3 text-white font-mono font-semibold">20%</td>
              <td class="px-5 py-3 text-white/40" data-ru="Макс. аллокация в один протокол T2">Max allocation to any single T2 protocol</td>
            </tr>
            <tr>
              <td class="px-5 py-3 text-white/60 font-mono" data-ru="Совокупный лимит T2">T2 total cap</td>
              <td class="px-5 py-3 text-white font-mono font-semibold">&le; 50%</td>
              <td class="px-5 py-3 text-white/40" data-ru="Все протоколы T2 суммарно (ADR-019)">All T2 protocols combined (ADR-019)</td>
            </tr>
            <tr>
              <td class="px-5 py-3 text-white/60 font-mono" data-ru="Диапазон APY">APY range</td>
              <td class="px-5 py-3 text-white font-mono font-semibold">1% – 30%</td>
              <td class="px-5 py-3 text-white/40" data-ru="Позиции вне диапазона отклоняются">Positions outside range are rejected</td>
            </tr>
            <tr>
              <td class="px-5 py-3 text-white/60 font-mono" data-ru="Денежный буфер">Cash buffer</td>
              <td class="px-5 py-3 text-white font-mono font-semibold">&ge; 5%</td>
              <td class="px-5 py-3 text-white/40" data-ru="Всегда удерживается в резерве">Always held in reserve</td>
            </tr>
            <tr>
              <td class="px-5 py-3 text-red-400/80 font-mono" data-ru="Аварийный стоп (kill switch)">Kill switch</td>
              <td class="px-5 py-3 text-red-400 font-mono font-semibold" data-ru="&ge; 5% просадки">&ge; 5% drawdown</td>
              <td class="px-5 py-3 text-white/40" data-ru="Немедленно закрыть все позиции">Close all positions immediately</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- 10. Performance / Validation Status -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-4" data-ru="Результаты и статус валидации">Performance & Validation Status</p>

      <div class="rounded-xl border border-amber-500/20 bg-amber-500/5 p-4 mb-6 flex items-start gap-3">
        <span class="text-amber-400 flex-shrink-0 mt-0.5">&#9888;</span>
        <p class="text-sm text-white/50" data-ru="Все данные о результатах отражают бумажную торговлю на виртуальном портфеле $100 000 USDT/USDC. Не является показателем будущих результатов.">
          All performance data reflects paper trading on a virtual $100,000 USDT/USDC portfolio.
          Not indicative of future results.
        </p>
      </div>

      <div class="rounded-xl border border-white/10 bg-white/[0.03] p-6">
        <div class="flex items-center justify-between mb-4">
          <span class="text-sm text-white/60 font-medium" data-ru="GoLiveChecker">GoLiveChecker</span>
          <span class="text-sm font-mono text-white">20<span class="text-white/30" data-ru=" / 29 критериев выполнено"> / 29 criteria met</span></span>
        </div>
        <div class="w-full bg-white/10 rounded-full h-2 mb-4">
          <div class="bg-accent-500 h-2 rounded-full" style="width: 77%"></div>
        </div>
        <p class="text-xs text-white/30" data-ru="Все 29 критериев должны выполняться 7 дней подряд до активации реального капитала (ADR-002). Текущие блокеры видны на дашборде.">
          All 29 criteria must pass for 7 consecutive days before live capital activation (ADR-002).
          Current blockers visible on dashboard.
        </p>
      </div>
    </section>

    <!-- 11. Strategy-Specific Risks -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-red-400/60 uppercase tracking-wider font-mono mb-4" data-ru="Риски, специфичные для стратегии">Strategy-Specific Risks</p>
      <p class="text-sm text-white/40 mb-6 leading-relaxed" data-ru="Инвестирование в DeFi-протоколы несёт существенные риски. Эта стратегия не устраняет их — она управляет экспозицией в рамках заданных параметров.">
        Investing in DeFi protocols carries material risks. This strategy does not eliminate
        these risks — it manages exposure within defined parameters.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="rounded-xl border border-white/8 bg-white/[0.02] p-5">
          <h4 class="text-sm font-semibold text-white mb-2" data-ru="Риск смарт-контрактов">Smart Contract Risk</h4>
          <p class="text-xs text-white/40 leading-relaxed" data-ru="Код протокола может содержать необнаруженные уязвимости. Мы размещаем средства только в протоколах с несколькими независимыми аудитами, но аудиты не устраняют риск.">
            Protocol code may contain undiscovered vulnerabilities. We only allocate to
            protocols with multiple independent audits, but audits do not eliminate risk.
          </p>
        </div>
        <div class="rounded-xl border border-white/8 bg-white/[0.02] p-5">
          <h4 class="text-sm font-semibold text-white mb-2" data-ru="Риск депега стейблкоина">Stablecoin Depeg Risk</h4>
          <p class="text-xs text-white/40 leading-relaxed" data-ru="USDC или другие стейблкоины могут временно или навсегда потерять привязку. Аварийный стоп срабатывает при просадке 5% независимо от причины.">
            USDC or other stablecoins may temporarily or permanently lose their peg.
            The kill switch triggers at 5% drawdown regardless of cause.
          </p>
        </div>
        <div class="rounded-xl border border-white/8 bg-white/[0.02] p-5">
          <h4 class="text-sm font-semibold text-white mb-2" data-ru="Риск оракулов">Oracle Risk</h4>
          <p class="text-xs text-white/40 leading-relaxed" data-ru="Ценовые фиды от оракулов (Chainlink, Pyth) могут запаздывать или быть подвержены манипуляциям. Стратегия использует агрегированные фиды DeFiLlama для данных по APY.">
            Price feeds from oracles (Chainlink, Pyth) may be delayed or manipulated.
            The strategy relies on DeFiLlama aggregated feeds for APY data.
          </p>
        </div>
        <div class="rounded-xl border border-white/8 bg-white/[0.02] p-5">
          <h4 class="text-sm font-semibold text-white mb-2" data-ru="Риск ликвидности">Liquidity Risk</h4>
          <p class="text-xs text-white/40 leading-relaxed" data-ru="В экстремальных рыночных условиях вывод средств из пулов кредитования может быть временно задержан, если уровень утилизации приближается к 100%.">
            In extreme market conditions, withdrawals from lending pools may be temporarily
            delayed if utilisation rates approach 100%.
          </p>
        </div>
      </div>
    </section>

    <!-- 12. Emergency Behavior -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-4" data-ru="Поведение в аварийной ситуации">Emergency Behavior</p>
      <div class="rounded-xl border border-red-500/15 bg-red-500/5 p-6">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-lg bg-red-500/10 border border-red-500/20 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#ef4444" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"/>
            </svg>
          </div>
          <div>
            <h4 class="text-sm font-semibold text-white mb-2" data-ru="Аварийный стоп: просадка -5% за месяц">Kill Switch: -5% Monthly Drawdown</h4>
            <p class="text-sm text-white/50 leading-relaxed mb-3" data-ru="Если капитал портфеля падает на 5% или более от месячного пика, все позиции закрываются, а средства переводятся в денежный буфер. Это неотменяемо — ни человек, ни ИИ, ни логика стратегии не могут предотвратить срабатывание.">
              If portfolio equity drops 5% or more from the monthly peak, all positions are
              closed and capital moves to cash buffer. This is non-overridable — no human,
              no AI, no strategy logic can prevent the trigger.
            </p>
            <p class="text-xs text-white/30" data-ru="Аварийный стоп — последняя линия защиты. Он не устраняет убытки, а ограничивает дальнейшую экспозицию после наступления просадки.">
              The kill switch is the last line of defense. It does not eliminate losses — it
              limits further exposure after a drawdown event has occurred.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- 13. Fees -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-4" data-ru="Структура комиссий">Fee Structure</p>
      <div class="rounded-xl border border-white/10 bg-white/[0.03] p-6">
        <p class="text-sm text-white/50 leading-relaxed mb-3" data-ru="Структура комиссий обсуждается индивидуально при онбординге. Действует принцип high-water mark — комиссия за результат не взимается до восстановления предыдущего пика.">
          Fee structure is discussed individually during onboarding. High-water mark applies —
          no performance fee until the previous peak is recovered.
        </p>
        <p class="text-xs text-white/30" data-ru="В период бумажной торговли комиссии отсутствуют.">
          No fees during paper trading period.
        </p>
      </div>
    </section>

    <!-- 14. FAQ -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-6" data-ru="Часто задаваемые вопросы">Frequently Asked Questions</p>
      <div class="space-y-6">

        <div>
