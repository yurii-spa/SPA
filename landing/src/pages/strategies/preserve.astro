---
import Layout from '../../layouts/Layout.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import strategies from '../../data/strategy_config.json';

const preserve = strategies.strategies.find(s => s.id === 'preserve')!;
const global = strategies.global;
---

<Layout
  title="Preserve Strategy — Capital-Preservation DeFi Yield | SPA earn-defi.com"
  description="Capital-preservation focused yield. Tier 1 protocols only, no leverage, no looping. ~6% target APY (variable, not guaranteed). Target profile — not yet paper tracked."
>

  <!-- Nav -->
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- 1. Hero -->
    <section class="pt-20 pb-12">
      <div class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full bg-amber-500/10 border border-amber-500/30 text-xs text-amber-400 font-medium">
        <span class="w-1.5 h-1.5 rounded-full bg-amber-400" aria-hidden="true"></span>
        <span data-ru="Целевой профиль — ожидает валидации">Target Profile — Validation Pending</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4 leading-tight" data-ru="Стратегия Preserve">
        Preserve Strategy
      </h1>
      <p class="text-xl text-white/50 leading-relaxed max-w-2xl">
        <span data-ru={preserve.taglineRu}>{preserve.tagline}</span>. <span data-ru="Только протоколы Tier 1 — максимальная стабильность, минимум сложности.">Tier 1 protocols only — maximum stability, minimum complexity.</span>
      </p>
    </section>

    <!-- 2. Target APY -->
    <section class="py-10 border-t border-white/5">
      <div class="flex flex-col sm:flex-row sm:items-center gap-6">
        <div>
          <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-2" data-ru="Целевой APY">Target APY</p>
          <div class="flex items-baseline gap-2">
            <span class="text-5xl font-mono font-bold text-accent-400">~6%</span>
            <span class="text-sm text-white/30 font-mono">APY</span>
          </div>
          <p class="text-xs text-white/25 mt-2" data-ru={preserve.target_apy_note_ru}>{preserve.target_apy_note}</p>
        </div>
      </div>
    </section>

    <!-- 3. Risk Level -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-3" data-ru="Уровень риска">Risk Level</p>
      <div class="flex items-center gap-3">
        <div class="flex gap-1" aria-label="Risk level: 1 of 3">
          <span class="inline-block w-8 h-3 rounded-sm bg-accent-400" aria-hidden="true"></span>
          <span class="inline-block w-8 h-3 rounded-sm bg-white/10" aria-hidden="true"></span>
          <span class="inline-block w-8 h-3 rounded-sm bg-white/10" aria-hidden="true"></span>
        </div>
        <span class="text-white/60 text-sm font-medium" data-ru="Пониженный риск">Lower Risk</span>
      </div>
      <p class="text-xs text-white/30 mt-2" data-ru="Только протоколы Tier 1. Без плеча, без лупинга, без аллокации в Tier 2 и выше.">
        Tier 1 protocols only. No leverage, no looping, no Tier 2+ allocation.
      </p>
    </section>

    <!-- 4. Current Status -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-4" data-ru="Текущий статус">Current Status</p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="rounded-xl border border-amber-500/20 bg-amber-500/5 p-5">
          <div class="text-xs text-white/30 mb-1" data-ru="Фаза">Phase</div>
          <div class="text-amber-400 font-semibold flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-amber-400" aria-hidden="true"></span>
            <span data-ru="Ожидает валидации">Validation Pending</span>
          </div>
        </div>
        <div class="rounded-xl border border-white/10 bg-white/[0.03] p-5">
          <div class="text-xs text-white/30 mb-1" data-ru="Бумажный трек">Paper Tracking</div>
          <div class="text-white/50 font-semibold" data-ru="Пока не активен">Not yet active</div>
        </div>
        <div class="rounded-xl border border-white/10 bg-white/[0.03] p-5">
          <div class="text-xs text-white/30 mb-1" data-ru="Цель запуска">Go-Live Target</div>
          <div class="text-white font-semibold">{global.go_live_target}</div>
        </div>
      </div>
    </section>

    <!-- 5. Who It's For -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-3" data-ru="Для кого">Who It's For</p>
      <p class="text-white/60 leading-relaxed" data-ru="Инвесторы, для которых стабильность и сохранение капитала важнее оптимизации доходности.">
        Allocators prioritising stability and capital preservation over yield optimisation.
      </p>
      <div class="mt-4 rounded-xl bg-accent-500/5 border border-accent-500/15 p-5">
        <p class="text-sm text-white/50 leading-relaxed" data-ru={preserve.descriptionRu}>
          {preserve.description}
        </p>
      </div>
    </section>

    <!-- 6. What's Inside -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-3" data-ru="Что внутри">What's Inside</p>
      <p class="text-white/50 text-sm leading-relaxed mb-4" data-ru="Стратегия Preserve размещает средства исключительно в протоколах кредитования Tier 1 — рынки DeFi-кредитования с наибольшим TVL, наиболее аудированные и дольше всех работающие. Денежный буфер выше, чем в Core.">
        The Preserve strategy allocates exclusively to Tier 1 lending protocols — the highest TVL,
        most audited, longest-running DeFi lending markets. Higher cash buffer than Core.
      </p>
      <div class="rounded-xl bg-white/[0.03] border border-white/8 p-5">
        <p class="text-xs text-teal-400 font-mono uppercase tracking-wider mb-3" data-ru="Только Tier 1 — Основная аллокация">Tier 1 Only — Primary Allocation</p>
        <ul class="space-y-2 text-sm text-white/50">
          <li class="flex items-center gap-2">
            <span class="w-1 h-1 rounded-full bg-teal-400 flex-shrink-0" aria-hidden="true"></span>
            <span data-ru="Aave V3 (Ethereum) — ~3,5% APY">Aave V3 (Ethereum) — ~3.5% APY</span>
          </li>
          <li class="flex items-center gap-2">
            <span class="w-1 h-1 rounded-full bg-teal-400 flex-shrink-0" aria-hidden="true"></span>
            <span data-ru="Compound V3 (Comet USDC) — ~4,8% APY">Compound V3 (Comet USDC) — ~4.8% APY</span>
          </li>
          <li class="flex items-center gap-2">
            <span class="w-1 h-1 rounded-full bg-teal-400 flex-shrink-0" aria-hidden="true"></span>
            <span data-ru="Spark sUSDS — ~5% APY">Spark sUSDS — ~5% APY</span>
          </li>
        </ul>
        <p class="text-xs text-white/25 mt-3" data-ru="Без протоколов Tier 2 или Tier 3. APY переменный, не гарантирован.">No Tier 2 or Tier 3 protocols. APY variable, not guaranteed.</p>
      </div>
    </section>

    <!-- 7. Yield Sources -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-4" data-ru="Источники доходности">Yield Sources</p>
      <div class="flex flex-wrap gap-2">
        {preserve.yield_sources.map((source: string) => (
          <span class="px-3 py-1.5 rounded-lg text-sm font-mono bg-white/5 text-white/50 border border-white/10">
            {source}
          </span>
        ))}
      </div>
      <p class="text-xs text-white/25 mt-3" data-ru="Вся доходность формируется из процентных ставок рынков кредитования. Без фарминга governance-токенов, без предоставления ликвидности, без плеча.">
        All yield comes from lending market interest rates. No governance token farming,
        no liquidity provision, no leverage.
      </p>
    </section>

    <!-- 8. What This Strategy Does NOT Do -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-4" data-ru="Чего эта стратегия НЕ делает">What This Strategy Does NOT Do</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {[
          { en: 'Use leverage', ru: 'Использовать плечо' },
          { en: 'Use looping', ru: 'Использовать лупинг' },
          { en: 'Allocate to Tier 2+ protocols', ru: 'Размещать средства в протоколах Tier 2 и выше' },
          { en: 'Chase extreme APY', ru: 'Гнаться за экстремальным APY' },
          { en: 'Bypass RiskPolicy gates', ru: 'Обходить гейты RiskPolicy' },
          { en: 'Make discretionary overrides', ru: 'Принимать произвольные переопределения' },
        ].map((item) => (
          <div class="flex items-center gap-3 px-4 py-3 rounded-lg bg-white/[0.02] border border-white/5">
            <span class="text-red-400/70 flex-shrink-0">&#10005;</span>
            <span class="text-sm text-white/50" data-ru={item.ru}>{item.en}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- 9. Risk Controls -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-teal-400 uppercase tracking-wider font-mono mb-4" data-ru="Контроль рисков — RiskPolicy v1.0">Risk Controls — RiskPolicy v1.0</p>
      <p class="text-sm text-white/40 mb-6 leading-relaxed" data-ru="Каждая предлагаемая аллокация проходит через детерминированный, жёстко зашитый риск-гейт. Стратегия Preserve применяет более строгие ограничения поверх базовой политики.">
        Every proposed allocation passes through a deterministic, hard-coded risk gate.
        Preserve strategy applies stricter constraints on top of the base policy.
      </p>
      <div class="overflow-x-auto rounded-xl border border-white/10">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/10 bg-white/[0.03]">
              <th class="text-left px-5 py-3 text-xs text-white/30 font-medium uppercase tracking-wider" data-ru="Параметр">Parameter</th>
              <th class="text-left px-5 py-3 text-xs text-white/30 font-medium uppercase tracking-wider" data-ru="Значение">Value</th>
              <th class="text-left px-5 py-3 text-xs text-white/30 font-medium uppercase tracking-wider" data-ru="Эффект">Effect</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5">
            <tr>
              <td class="px-5 py-3 text-white/60 font-mono" data-ru="Минимальный TVL">TVL floor</td>
              <td class="px-5 py-3 text-white font-mono font-semibold">&ge; $500M</td>
              <td class="px-5 py-3 text-white/40" data-ru="Пулы ниже этого порога исключаются">Pools below this threshold excluded</td>
            </tr>
            <tr>
              <td class="px-5 py-3 text-white/60 font-mono" data-ru="Ограничение по Tier">Tier restriction</td>
              <td class="px-5 py-3 text-white font-mono font-semibold" data-ru="Только T1">T1 only</td>
              <td class="px-5 py-3 text-white/40" data-ru="Без протоколов Tier 2 или Tier 3">No Tier 2 or Tier 3 protocols</td>
            </tr>
            <tr>
              <td class="px-5 py-3 text-white/60 font-mono" data-ru="Лимит на протокол">Per-protocol cap</td>
              <td class="px-5 py-3 text-white font-mono font-semibold">25%</td>
              <td class="px-5 py-3 text-white/40" data-ru="Макс. аллокация в один протокол">Max allocation to any single protocol</td>
            </tr>
            <tr>
              <td class="px-5 py-3 text-white/60 font-mono" data-ru="Денежный буфер">Cash buffer</td>
              <td class="px-5 py-3 text-white font-mono font-semibold">&ge; 5%</td>
              <td class="px-5 py-3 text-white/40" data-ru="Всегда удерживается в резерве">Always held in reserve</td>
            </tr>
            <tr>
              <td class="px-5 py-3 text-white/60 font-mono" data-ru="Диапазон APY">APY range</td>
              <td class="px-5 py-3 text-white font-mono font-semibold">2% – 40%</td>
              <td class="px-5 py-3 text-white/40" data-ru="Позиции вне диапазона отклоняются">Positions outside range rejected</td>
            </tr>
            <tr>
              <td class="px-5 py-3 text-red-400/80 font-mono" data-ru="Аварийный стоп (kill switch)">Kill switch</td>
              <td class="px-5 py-3 text-red-400 font-mono font-semibold" data-ru="&ge; 5% просадки">&ge; 5% drawdown</td>
              <td class="px-5 py-3 text-white/40" data-ru="Немедленно закрыть все позиции">Close all positions immediately</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- 10. Performance / Validation Status -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-4" data-ru="Статус валидации">Validation Status</p>
      <div class="rounded-xl border border-amber-500/20 bg-amber-500/5 p-6">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-2 h-2 rounded-full bg-amber-400" aria-hidden="true"></span>
          <span class="text-sm text-amber-400 font-medium" data-ru="Целевой профиль — ожидает валидации">Target Profile — Validation Pending</span>
        </div>
        <p class="text-sm text-white/40 leading-relaxed" data-ru="Бумажный трек для Preserve начнётся после валидации. Исторических данных о результатах пока нет. Все показатели APY являются лишь целевыми оценками.">
          Paper tracking for Preserve will begin after validation. No historical performance data yet.
          All APY figures are target estimates only.
        </p>
      </div>
    </section>

    <!-- 11. Strategy-Specific Risks -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-red-400/60 uppercase tracking-wider font-mono mb-4" data-ru="Риски, специфичные для стратегии">Strategy-Specific Risks</p>
      <p class="text-sm text-white/40 mb-6 leading-relaxed" data-ru="Даже при аллокации только в Tier 1 существенные риски сохраняются. Эта стратегия управляет экспозицией в рамках заданных параметров, но не устраняет риск.">
        Even with Tier 1 only allocation, material risks remain. This strategy manages exposure
        within defined parameters but does not eliminate risk.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="rounded-xl border border-white/8 bg-white/[0.02] p-5">
          <h4 class="text-sm font-semibold text-white mb-2" data-ru="Риск смарт-контрактов">Smart Contract Risk</h4>
          <p class="text-xs text-white/40 leading-relaxed" data-ru="Код протокола может содержать необнаруженные уязвимости. Протоколы Tier 1 имеют несколько аудитов и годы работы, но аудиты не устраняют риск.">
            Protocol code may contain undiscovered vulnerabilities. Tier 1 protocols have
            multiple audits and years of operation, but audits do not eliminate risk.
          </p>
        </div>
        <div class="rounded-xl border border-white/8 bg-white/[0.02] p-5">
          <h4 class="text-sm font-semibold text-white mb-2" data-ru="Риск депега стейблкоина">Stablecoin Depeg Risk</h4>
          <p class="text-xs text-white/40 leading-relaxed" data-ru="USDC или другие стейблкоины могут временно или навсегда потерять привязку. Аварийный стоп срабатывает при просадке 5% независимо от причины.">
            USDC or other stablecoins may temporarily or permanently lose their peg.
            The kill switch triggers at 5% drawdown regardless of cause.
          </p>
        </div>
        <div class="rounded-xl border border-white/8 bg-white/[0.02] p-5">
          <h4 class="text-sm font-semibold text-white mb-2" data-ru="Неплатёжеспособность протокола">Protocol Insolvency</h4>
          <p class="text-xs text-white/40 leading-relaxed" data-ru="Если протокол кредитования становится неплатёжеспособным, вкладчики могут потерять средства. Лимит на протокол ограничивает экспозицию в один протокол.">
            If a lending protocol becomes insolvent, depositors may lose funds.
            Per-protocol cap limits single-protocol exposure.
          </p>
        </div>
        <div class="rounded-xl border border-white/8 bg-white/[0.02] p-5">
          <h4 class="text-sm font-semibold text-white mb-2" data-ru="Риск оракулов">Oracle Risk</h4>
          <p class="text-xs text-white/40 leading-relaxed" data-ru="Ценовые фиды могут запаздывать или быть подвержены манипуляциям. Стратегия использует агрегированные фиды DeFiLlama для данных по APY.">
            Price feeds may be delayed or manipulated. Strategy relies on
            DeFiLlama aggregated feeds for APY data.
          </p>
        </div>
        <div class="rounded-xl border border-white/8 bg-white/[0.02] p-5">
          <h4 class="text-sm font-semibold text-white mb-2" data-ru="Сжатие APY">APY Compression</h4>
          <p class="text-xs text-white/40 leading-relaxed" data-ru="Ставки кредитования могут существенно снизиться в периоды низкого спроса. Целевой APY не гарантирован и может значительно недотягивать.">
            Lending rates can drop significantly during low-demand periods.
            Target APY is not guaranteed and may materially underperform.
          </p>
        </div>
        <div class="rounded-xl border border-white/8 bg-white/[0.02] p-5">
          <h4 class="text-sm font-semibold text-white mb-2" data-ru="Ограничения ликвидности">Liquidity Constraints</h4>
          <p class="text-xs text-white/40 leading-relaxed" data-ru="В экстремальных рыночных условиях вывод средств из пулов кредитования может быть временно задержан, если уровень утилизации приближается к 100%.">
            In extreme market conditions, withdrawals from lending pools may be
            temporarily delayed if utilisation rates approach 100%.
          </p>
        </div>
      </div>
    </section>

    <!-- 12. Emergency Behavior -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-4" data-ru="Поведение в аварийной ситуации">Emergency Behavior</p>
      <div class="rounded-xl border border-red-500/15 bg-red-500/5 p-6">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-lg bg-red-500/10 border border-red-500/20 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#ef4444" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"/>
            </svg>
          </div>
          <div>
            <h4 class="text-sm font-semibold text-white mb-2" data-ru="Аварийный стоп: просадка -5% за месяц">Kill Switch: -5% Monthly Drawdown</h4>
            <p class="text-sm text-white/50 leading-relaxed mb-3" data-ru="Если капитал портфеля падает на 5% или более от месячного пика, все позиции закрываются, а средства переводятся в 100% денежный буфер. Это неотменяемо.">
              If portfolio equity drops 5% or more from the monthly peak, all positions are
              closed and capital moves to 100% cash buffer. This is non-overridable.
            </p>
            <p class="text-xs text-white/30" data-ru="Аварийный стоп ограничивает дальнейшую экспозицию после наступления просадки. Он не устраняет убытки, а ограничивает их.">
              The kill switch limits further exposure after a drawdown event. It does not
              eliminate losses — it caps them.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- 13. Fees -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-4" data-ru="Структура комиссий">Fee Structure</p>
      <div class="rounded-xl border border-white/10 bg-white/[0.03] p-6">
        <p class="text-sm text-white/50 leading-relaxed mb-3" data-ru="Структура комиссий обсуждается индивидуально при онбординге. Действует принцип high-water mark — комиссия за результат не взимается до восстановления предыдущего пика.">
          Fee structure is discussed individually during onboarding. High-water mark applies —
          no performance fee until the previous peak is recovered.
        </p>
        <p class="text-xs text-white/30" data-ru="В период бумажной торговли комиссии отсутствуют.">
          No fees during paper trading period.
        </p>
      </div>
    </section>

    <!-- 14. FAQ -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-6" data-ru="Часто задаваемые вопросы">Frequently Asked Questions</p>
      <div class="space-y-6">

        <div>
          <h4 class="text-sm font-semibold text-white mb-2" data-ru="Почему только Tier 1?">Why Tier 1 only?</h4>
          <p class="text-sm text-white/40 leading-relaxed" data-ru="Протоколы Tier 1 (Aave, Compound, Spark) имеют наибольший TVL, самую долгую историю работы и наиболее полное аудиторское покрытие. Ограничение до T1 жертвует частью доходности ради снижения риска смарт-контрактов.">
            Tier 1 protocols (Aave, Compound, Spark) have the highest TVL, longest operating history,
            and most comprehensive audit coverage. Restricting to T1 sacrifices some yield
            for lower smart contract risk.
          </p>
        </div>

        <div>
          <h4 class="text-sm font-semibold text-white mb-2" data-ru="Чем это отличается от Core?">How does this differ from Core?</h4>
          <p class="text-sm text-white/40 leading-relaxed" data-ru="Core размещает средства как в Tier 1, так и в отдельных протоколах Tier 2 ради более высокой доходности. Preserve работает только с T1, с более строгими критериями и более высоким эффективным денежным буфером. Ниже ожидаемый APY, ниже профиль риска.">
            Core allocates to both Tier 1 and selected Tier 2 protocols for higher yield.
            Preserve is T1-only, with stricter eligibility and a higher effective cash buffer.
