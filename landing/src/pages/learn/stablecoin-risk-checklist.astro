---
// E1 (redesign spec 04) — SEO / answer-engine page #3: "The stablecoin holder's risk checklist
// (10 checks, 10 minutes)". Practical, actionable, leads straight into the snapshot. FAQ JSON-LD,
// snapshot CTA mid+end, funnel links. No fabricated numbers, no promised returns. Bilingual.
import Layout from '../../layouts/Layout.astro';
import Disclaimer from '../../components/Disclaimer.astro';

const checks = [
  { en: 'Do you actually hold the keys?', ru: 'Ключи реально у вас?', den: 'If it sits on an exchange, they control it, not you. Test a small withdrawal.', dru: 'Если на бирже — контролирует она, не вы. Проверьте вывод небольшой суммы.' },
  { en: 'Are you concentrated in one issuer?', ru: 'Не сконцентрированы ли в одном эмитенте?', den: 'One USDx being your whole balance is one break condition away from a bad day.', dru: 'Один USDx как весь баланс — это один сценарий поломки до плохого дня.' },
  { en: 'Do you know each stablecoin’s break condition?', ru: 'Знаете ли механизм поломки каждого стейбла?', den: 'Fiat-backed vs algo vs LST-collateralised fail in different ways. Know which you hold.', dru: 'Фиат / алго / LST-обеспеченные ломаются по-разному. Знайте, что держите.' },
  { en: 'Are any of your stables idle at 0%?', ru: 'Есть ли простаивающие под 0%?', den: 'Idle money is a silent cost. Even a safe ~3.3% is real over a year.', dru: 'Простаивающие деньги — тихий убыток. Даже безопасные ~3,3% реальны за год.' },
  { en: 'Have you checked your token approvals?', ru: 'Проверяли ли approvals (разрешения)?', den: 'Unlimited allowances are the most common drain vector. Revoke stale ones.', dru: 'Безлимитные разрешения — самый частый вектор слива. Отзовите старые.' },
  { en: 'Do you know your exit liquidity?', ru: 'Знаете ли ликвидность на выход?', den: 'A big position can move its own exit price. Book value ≠ exit value.', dru: 'Крупная позиция двигает свою же цену выхода. Балансовая ≠ выходная.' },
  { en: 'Are you being paid for a hidden tail?', ru: 'Не платят ли вам за скрытый хвост?', den: 'Yield far above ~3.4% is compensation for a risk. What is it?', dru: 'Доход сильно выше ~3,4% — компенсация за риск. За какой?' },
  { en: 'Can you react to a depeg in time?', ru: 'Успеете ли среагировать на депег?', den: 'Depegs happen in hours (USDC 2023). Do you monitor, or find out from a headline?', dru: 'Депеги за часы (USDC 2023). Мониторите или узнаёте из заголовка?' },
  { en: 'Do you understand the bridge/wrap risk?', ru: 'Понимаете ли риск моста/wrap?', den: 'A wrapped or bridged stable adds a second smart-contract risk on top of the issuer.', dru: 'Wrapped/bridged-стейбл добавляет второй смарт-контрактный риск поверх эмитента.' },
  { en: 'Can you verify the numbers you’re shown?', ru: 'Можете ли проверить показанные числа?', den: 'If a yield or a track can’t be re-derived, treat it as a claim, not a fact.', dru: 'Если доход или трек нельзя пересчитать — это заявление, а не факт.' },
];
const faq = [
  { q: 'How do I check if my stablecoins are safe?', a: 'Work through a short list: who holds the keys, issuer concentration, each coin’s break condition, idle yield, token approvals, exit liquidity, whether the yield hides a tail, depeg reaction time, bridge/wrap risk, and whether the numbers are verifiable. Our free 60-second snapshot turns that into a personalized result with no wallet connection.' },
  { q: 'What is the biggest hidden risk for stablecoin holders?', a: 'Two compete: token approvals (unlimited allowances that let a malicious contract drain a wallet) and custody concentration (all your stables on one exchange or in one issuer). Both are avoidable once you look.' },
];
const faqLd = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---
<Layout
  title="The stablecoin holder's risk checklist (10 checks, 10 minutes) | earn-defi.com"
  description="A practical 10-point risk checklist for stablecoin holders: keys, issuer concentration, break conditions, idle yield, approvals, exit liquidity, hidden tail, depeg reaction, bridge risk, verifiability. Run it in 10 minutes — or take the free 60-second snapshot. Not investment advice."
>
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
  <main class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-24">
    <p class="text-xs font-mono uppercase tracking-[0.12em] text-text-faint mb-4" data-ru="Чек-лист">The checklist</p>
    <h1 class="text-3xl sm:text-4xl font-bold text-white mb-5 leading-tight" data-ru="Чек-лист риска для держателя стейблкоинов (10 проверок, 10 минут)">The stablecoin holder's risk checklist (10 checks, 10 minutes)</h1>
    <p class="text-lg text-slate-400 leading-relaxed mb-8" data-ru="Десять честных вопросов к своим стейблам. Пройдите их за 10 минут — или доверьте нашему 60-секундному снимку (без кошелька, без email). Не инвестиционный совет.">
      Ten honest questions to ask about your own stables. Work through them in 10 minutes — or let our
      60-second snapshot do it (no wallet, no email). Not investment advice.
    </p>

    <ol class="space-y-3 mb-8">
      {checks.map((c, i) => (
        <li class="rounded-xl p-4 flex gap-3" style="background:var(--bg-surface);border:1px solid var(--border)">
          <span class="font-mono text-accent-400 font-bold" style="flex:0 0 auto">{i + 1}</span>
          <div>
            <div class="text-sm font-semibold text-white" data-ru={c.ru}>{c.en}</div>
            <div class="text-sm text-slate-400 leading-relaxed mt-1" data-ru={c.dru}>{c.den}</div>
          </div>
        </li>
      ))}
    </ol>

    <div class="rounded-xl p-5 my-8" style="background:rgba(52,211,153,.06);border:1px solid rgba(52,211,153,.25)">
      <p class="text-sm text-slate-300 leading-relaxed mb-3" data-ru="Не хотите проходить вручную? Наш 60-секундный снимок задаёт эти вопросы за вас и даёт честный персональный результат — без кошелька, без email.">Don't want to do it manually? Our 60-second snapshot asks these for you and gives an honest, personalized result — no wallet, no email.</p>
      <a href="/snapshot?src=learn" data-track="learn_cta_click" class="inline-flex items-center px-4 py-2.5 rounded-lg bg-accent-500 hover:bg-accent-400 text-white text-sm font-semibold transition-colors" data-ru="Пройти снимок →">Take the snapshot →</a>
    </div>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-white mb-3" data-ru="Почему именно эти проверки">Why these checks</h2>
      <p class="text-base text-slate-300 leading-relaxed" data-ru="Каждый пункт — реальный способ потерять деньги на «безопасных» стейблах: кастоди, концентрация, механизм пега, простой, approvals, ликвидность на выход, скрытый хвост, скорость депега, мосты и непроверяемость. Мы строим весь деск вокруг того, чтобы ИЗМЕРЯТЬ эти риски и ОТКАЗЫВАТЬ, когда доход — лишь компенсация за них.">
        Each item is a real way to lose money on "safe" stables: custody, concentration, the peg mechanism,
        idleness, approvals, exit liquidity, a hidden tail, depeg speed, bridges, and unverifiability. We
        built the whole desk around MEASURING these — and REFUSING when a yield is just compensation for them.
      </p>
      <div class="flex flex-wrap gap-3 mt-3">
        <a href="/refusals" data-track="learn_to_refusals" class="text-sm text-accent-400 underline" data-ru="Журнал отказов →">The refusal log →</a>
        <a href="/how-we-think" data-track="learn_to_bridge" class="text-sm text-accent-400 underline" data-ru="Наша честная рамка →">Our honest frame →</a>
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-xl font-semibold text-white mb-4" data-ru="Частые вопросы">FAQ</h2>
      {faq.map((f) => (
        <details class="mb-3 rounded-lg p-4" style="background:var(--bg-surface);border:1px solid var(--border)">
          <summary class="cursor-pointer text-sm font-semibold text-white list-none">{f.q}</summary>
          <p class="text-sm text-slate-400 leading-relaxed mt-2">{f.a}</p>
        </details>
      ))}
    </section>

    <div class="rounded-2xl border border-accent-500/20 bg-accent-500/[0.04] p-6">
      <p class="text-sm text-slate-400 leading-relaxed mb-4" data-ru="Хотите честный взгляд на свои стейблы — без обещаний доходности?">Want an honest look at your own stables — with no promised returns?</p>
      <div class="flex flex-wrap gap-3">
        <a href="/snapshot?src=learn" data-track="learn_cta_click" class="inline-flex items-center px-4 py-2.5 rounded-lg bg-accent-500 hover:bg-accent-400 text-white text-sm font-semibold transition-colors" data-ru="60-секундный снимок →">60-second snapshot →</a>
        <a href="/packages" data-track="learn_to_packages" class="inline-flex items-center px-4 py-2.5 rounded-lg border border-white/15 text-white text-sm font-medium hover:border-white/30 transition-colors" data-ru="Три честных тира →">The three honest tiers →</a>
      </div>
    </div>
  </main>
  <Disclaimer />

  <script is:inline>
    (function(){ try{ if(window.spaTrack) window.spaTrack('learn_view'); }catch(e){} })();
  </script>
</Layout>
