  <Disclaimer />

  <!-- Optional live desk summaries — graceful offline; the static narrative stands without them. -->
  <script is:inline>
    (function () {
      "use strict";
      // api-base detection: same-origin → api.<host>; localhost dev fallback.
      function apiBase() {
        try {
          var h = location.hostname;
          if (h === 'localhost' || h === '127.0.0.1') return 'http://127.0.0.1:8765';
          return location.protocol + '//api.' + h.replace(/^www\./, '');
        } catch (e) { return ''; }
      }
      var API = apiBase();
      function isRu() {
        try { return (document.documentElement.getAttribute('lang') || 'en') === 'ru'; } catch (e) { return false; }
      }
      function setLive(txt) {
        var el = document.getElementById('sd-live');
        if (el) { el.textContent = txt; el.removeAttribute('data-ru'); el.removeAttribute('data-en-orig'); }
      }
      var ratesOk = null, rwaUnsafe = null, done = 0;
      function render() {
        if (done < 2) return;
        var ru = isRu();
        var parts = [];
        if (ratesOk != null) parts.push((ru ? 'Rates Desk: ' + ratesOk + ' решений в логе' : 'Rates Desk: ' + ratesOk + ' decisions logged'));
        if (rwaUnsafe != null) parts.push((ru ? 'Safety Board: ' + rwaUnsafe + ' из 10 НЕ кэш-эквивалент' : 'Safety Board: ' + rwaUnsafe + ' of 10 NOT cash-like'));
        if (parts.length) setLive('Live · ' + parts.join('  ·  '));
        else setLive(ru ? 'Живые сводки недоступны — статичный нарратив актуален.' : 'Live summaries offline — the static narrative stands.');
      }
      // re-render on language toggle
      window.__renderLive = function () { try { render(); } catch (e) {} };

      function setEl(id, txt) { var el = document.getElementById(id); if (el) { el.textContent = txt; el.removeAttribute('data-ru'); el.removeAttribute('data-en-orig'); } }

      fetch(API + '/api/rates-desk/decisions').then(function (r) { return r.json(); }).then(function (d) {
        if (d && Array.isArray(d.decisions)) ratesOk = d.decisions.length;
        // Live verdict inputs for the GO seat: ENTRY/REFUSAL counts + as-of (provenance).
        var ru = isRu();
        var c = (d && d.counts) || {};
        if (c.ENTRY != null || c.REFUSAL != null) {
          setEl('sd-rd-inputs', (ru ? 'входов ' : 'entered ') + (c.ENTRY || 0) + ' · ' + (ru ? 'отказов ' : 'refused ') + (c.REFUSAL || 0) +
            ' · ' + (ru ? 'обыгрывает RWA-пол ~3.4%' : 'beats ~3.4% RWA floor'));
        }
        var rows = (d && Array.isArray(d.decisions)) ? d.decisions : [];
        var asof = rows.length ? (rows[rows.length - 1].as_of || (d && d.generated_at)) : (d && d.generated_at);
        if (asof) setEl('sd-rd-asof', String(asof).slice(0, 10));
      }).catch(function () {}).finally(function () { done++; render(); });

      fetch(API + '/api/rwa-safety-board').then(function (r) { return r.json(); }).then(function (d) {
        if (d && Array.isArray(d.assets)) {
          rwaUnsafe = d.assets.filter(function (a) { return a && a.verdict && a.verdict !== 'LIQUID'; }).length;
        }
        // Live verdict inputs for the MEASUREMENT-GO seat: verdict_counts + as-of (provenance).
        var ru = isRu();
        var vc = (d && d.verdict_counts) || null;
        var n = (d && d.n_assets != null) ? d.n_assets : (d && Array.isArray(d.assets) ? d.assets.length : null);
        if (vc) {
          setEl('sd-rwa-inputs', (ru ? 'из ' : 'of ') + (n != null ? n : '?') + ': ' +
            'LIQUID ' + (vc.LIQUID || 0) + ' · THIN ' + (vc.THIN || 0) + ' · ' +
            (ru ? 'РЕДЕМПШН ' : 'REDEMPTION ') + (vc.REDEMPTION_ONLY || 0) + ' · UNSAFE ' + (vc.UNSAFE || 0));
        }
        if (d && d.generated_at) setEl('sd-rwa-asof', String(d.generated_at).slice(0, 10));
      }).catch(function () {}).finally(function () { done++; render(); });

      // safety: if both fetches hang, settle to offline copy after 4s
      setTimeout(function () { if (done < 2) { done = 2; render(); } }, 4000);

      // ── Rates Desk — sleeve promotion map (reporting only, advisory; graceful offline) ──
      // Stage → literal badge class strings (Tailwind only compiles classes it sees literally).
      var STAGE_BADGE = {
        'PAPER_CANDIDATE': 'bg-teal-bg border-teal-border text-data-teal',
        'BACKTEST_PASS':   'bg-indigo-500/10 border-indigo-500/30 text-indigo-300',
        'REJECT':          'bg-danger-bg border-danger-border text-danger',
        'BLOCKED-NO-HEDGE':'bg-danger-bg border-danger-border text-danger'
      };
      function esc(s) { return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
        return { '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]; }); }
      function pct(v) { return (typeof v === 'number') ? ('~' + v.toFixed(2) + '%') : '—'; }
      function rdSleeveCard(s, ru) {
        var stage = (s && s.stage) || '';
        var badge = STAGE_BADGE[stage] || 'bg-white/5 border-white/10 text-gray-300';
        var label = (s && (s.shape_label || s.id)) || '?';
        var blocked = stage === 'BLOCKED-NO-HEDGE';
        var border = blocked ? 'rgba(242,109,109,.35)' : 'var(--border)';
        var meta;
        if (blocked) {
          var proxy = s && s.backtest_proxy;
          var p = proxy ? pct(proxy.net_apy_pct) : '~4.99%';
          meta = ru ? ('нет keyless forward-funding (Boros) · ' + p + ' — только бэктест-прокси, live заблокировано')
                    : ('no keyless forward-funding (Boros) · ' + p + ' backtest-proxy only, live-blocked');
        } else {
          meta = (ru ? 'нетто APY ' : 'net APY ') + pct(s && s.net_apy_pct) + ' · advisory';
        }
        return '' +
          '<div class="rounded-xl p-5 border bg-white/[0.02]" style="border-color:' + border + '">' +
            '<div class="flex items-center justify-between gap-2 mb-1.5">' +
              '<p class="text-sm font-bold" style="color:var(--text-primary)">' + esc(label) + '</p>' +
              '<span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-[11px] font-mono font-medium border ' + badge + '">' + esc(stage) + '</span>' +
            '</div>' +
            '<p class="text-xs font-mono" style="color:var(--text-muted)">' + esc(meta) + '</p>' +
          '</div>';
      }
      function setRdStatus(txt) {
        var el = document.getElementById('rd-promo-status');
        if (el) { el.textContent = txt; el.removeAttribute('data-ru'); }
      }
      fetch(API + '/api/strategy-lab/promotion').then(function (r) { return r.json(); }).then(function (d) {
        var ru = isRu();
        var rd = d && d.rates_desk;
        var sleeves = rd && Array.isArray(rd.sleeves) ? rd.sleeves : [];
        if (!sleeves.length) {
          setRdStatus(ru ? 'Живые стадии недоступны — статичный снимок актуален (advisory).'
                         : 'Live stages offline — the static snapshot stands (advisory).');
          return;
        }
        var grid = document.getElementById('rd-promo');
        if (grid) grid.innerHTML = sleeves.map(function (s) { return rdSleeveCard(s, ru); }).join('');
        var n = sleeves.length;
        setRdStatus('Live · ' + (ru ? (n + ' слива · reporting-only · IS_ADVISORY · не в live-аллокации')
                                    : (n + ' sleeves · reporting-only · IS_ADVISORY · not in live allocation')));
      }).catch(function () {
        setRdStatus(isRu() ? 'Живые стадии недоступны — статичный снимок актуален (advisory).'
                           : 'Live stages offline — the static snapshot stands (advisory).');
      });
    })();
  </script>
</Layout>
