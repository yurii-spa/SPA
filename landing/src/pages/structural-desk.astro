---
import Layout from '../layouts/Layout.astro';
import Disclaimer from '../components/Disclaimer.astro';

/*
 * Structural Desk — the convergent research hub (canonical /research story).
 *
 * Three deep DeFi-edge researches, each de-risked on our own stack, CONVERGE on one truth:
 * the real $10M-scale edge is NOT yield selection — it is occupying a structural
 * MEASUREMENT / UNDERWRITING role. We tell that story honestly, including the thesis we KILLED.
 *
 *   Thesis #1 — Rates Desk:        GO  (built + validated)            → /rates-desk
 *   Thesis #2 — RWA Repo Backstop: MEASUREMENT-GO (underwriting gated) → /rwa-backstop
 *   Thesis #3 — Cross-Domain Liquidator: NO-GO (killed cheaply)       → callout here
 *
 * Content is mostly static — the verdicts are settled. An optional live summary line is pulled
 * client-side from /api/rates-desk/* and /api/rwa-safety-board, graceful offline (the static
 * narrative renders regardless).
 *
 * Tailwind only compiles class strings it can see literally — every badge palette below is a
 * literal string (NOT runtime-built), matching the convention in rates-desk.astro / system.astro.
 */

// The three seats, each with its honest verdict. Literal Tailwind/token class strings per verdict.
const seats = [
  {
    n: '01',
    href: '/rates-desk',
    verdict: 'GO',
    verdict_en: 'GO — built + validated', verdict_ru: 'GO — построено + валидировано',
    title_en: 'Rates Desk', title_ru: 'Rates Desk',
    sub_en: 'On-chain interest-rate & basis', sub_ru: 'On-chain ставки и базис',
    edge_en: 'Price & harvest the disagreement between Pendle implied yield, lending rates and perp funding — and REFUSE books where the high rate is just unpriced tail.',
    edge_ru: 'Оценивать и собирать расхождение между implied-доходностью Pendle, ставками кредитования и funding-ом перпов — и ОТКАЗЫВАТЬСЯ от книг, где высокая ставка — это просто неоценённый хвост.',
    finding_en: 'Refusal fired early on toxic LRTs (vetoed before the Aug-2024 / Apr-2026 depegs). In the backtest, the validated FixedCarry sleeve clears the 3.4% RWA floor in/out-of-sample and through every stress — ~6.09% net APY is a backtest/candidate figure, NOT realized carry (advisory, reporting-only). The live paper track is still short (~1 week, ~0% net so far) and does not yet beat the floor.',
    finding_ru: 'Отказ сработал заранее на токсичных LRT (отклонены до депегов авг-2024 / апр-2026). В бэктесте валидированный sleeve FixedCarry обгоняет RWA-пол 3.4% in/out-of-sample и во всех стрессах — ~6.09% net APY это бэктест/кандидат, а НЕ реализованный carry (advisory, только отчётность). Живой paper-трек ещё короткий (~1 неделя, ~0% net) и пока не обгоняет пол.',
    cta_en: 'Open the Rates Desk', cta_ru: 'Открыть Rates Desk',
    // teal-leaning GO
    card: 'border-teal-border', badge: 'bg-teal-bg border-teal-border text-data-teal', dot: 'bg-data-teal', accent: 'group-hover:text-data-teal', arrow: 'group-hover:text-data-teal',
  },
  {
    n: '02',
    href: '/rwa-backstop',
    verdict: 'MEASUREMENT-GO',
    verdict_en: 'MEASUREMENT-GO — underwriting gated', verdict_ru: 'MEASUREMENT-GO — андеррайтинг под условием',
    title_en: 'RWA Repo Backstop', title_ru: 'RWA Repo Backstop',
    sub_en: 'Liquidation-safe collateral', sub_ru: 'Ликвидационно-безопасный залог',
    edge_en: 'Lend against Liquidation NAV, not marketing NAV — underwrite the executable exit of tokenized-RWA collateral, not the assumed $1.00.',
    edge_ru: 'Кредитовать под Ликвидационный NAV, а не маркетинговый — андеррайтить исполнимый выход токенизированного RWA-залога, а не предполагаемый $1.00.',
    finding_en: 'Built the live Collateral Safety Board: across the whole board, no tokenized-RWA asset is cash-like on an executable on-chain exit, and nearly all have ~$0 public on-chain exit (live counts on the board). We ship the measurement layer; the underwriting relationship/book is capital/legal-gated — off-code.',
    finding_ru: 'Построена живая Доска безопасности залога: на всей доске ни один токенизированный RWA НЕ кэш-эквивалент на исполнимом on-chain выходе, и почти у всех ~$0 публичного on-chain выхода (живые счётчики на доске). Мы поставляем измерительный слой; андеррайтинг-книга ограничена капиталом и юрисдикцией — off-code.',
    cta_en: 'Open the Collateral Safety Board', cta_ru: 'Открыть Доску безопасности залога',
    // indigo MEASUREMENT-GO
    card: 'border-indigo-700/40', badge: 'bg-indigo-500/10 border-indigo-500/30 text-indigo-300', dot: 'bg-indigo-400', accent: 'group-hover:text-indigo-300', arrow: 'group-hover:text-indigo-400',
  },
  {
    n: '03',
    href: null,
    verdict: 'NO-GO',
    verdict_en: 'NO-GO — killed cheaply', verdict_ru: 'NO-GO — убито дёшево',
    title_en: 'Cross-Domain Liquidator', title_ru: 'Кросс-доменный ликвидатор',
    sub_en: 'Balance-sheet long-tail liquidator', sub_ru: 'Балансовый ликвидатор long-tail',
    edge_en: 'Be the balance-sheet liquidator for long-tail collateral when MEV bots fail to clear it.',
    edge_ru: 'Быть балансовым ликвидатором для long-tail залога, когда MEV-боты не справляются с его расчисткой.',
    finding_en: 'KILLED. The addressable long-tail liquidation opportunity is ~$2–4M/yr gross (top-20 ≈ $2.2M) — 5–10× below the $20M bar that would justify the custody + CEX build. A naive $18M estimate was an artifact of MetaMorpho curator vaults (not liquidatable).',
    finding_ru: 'УБИТО. Адресуемая возможность по long-tail ликвидациям — ~$2–4M/год брутто (топ-20 ≈ $2.2M) — в 5–10× ниже планки $20M, которая оправдала бы постройку custody + CEX. Наивная оценка в $18M была артефактом кураторских хранилищ MetaMorpho (которые не ликвидируются).',
    cta_en: null, cta_ru: null,
    // red NO-GO
    card: 'border-danger-border', badge: 'bg-danger-bg border-danger-border text-danger', dot: 'bg-danger', accent: '', arrow: '',
  },
];
---

<Layout
  title="Structural Desk — the convergent research hub | earn-defi.com"
  description="Our own backtest proved plain crypto yield isn't edge. The real $10M-scale edge is a structural role: the transparent measurement / underwriting desk for on-chain rates, collateral and risk — not picking APY. Three theses, de-risked on our own stack: Rates Desk (GO), RWA Repo Backstop (measurement-GO), Cross-Domain Liquidator (NO-GO — we publish the kill: $2–4M/yr addressable, 5–10x below our bar). Paper research, advisory, not live."
  canonical="https://earn-defi.com/structural-desk"
>
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- ============================================================= a. THE THESIS -->
    <section class="pt-20 pb-10">
      <div class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full text-xs font-mono"
           style="background:var(--accent-bg);border:1px solid var(--accent-dim);color:var(--accent-hover)">
        <span class="w-1.5 h-1.5 rounded-full" style="background:var(--accent)" aria-hidden="true"></span>
        <span data-ru="Исследовательский хаб · конвергентный тезис · paper-исследование">Research hub · the convergent thesis · paper research</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold mb-5 leading-tight" style="color:var(--text-primary)"
          data-ru="Структурный стол">
        The Structural Desk
      </h1>
      <p class="text-xl leading-relaxed max-w-2xl" style="color:var(--text-secondary)"
         data-ru="Наш собственный бэктест доказал: обычная крипто-доходность — это не эдж. Реальный эдж масштаба $10M — это структурная роль: прозрачный стол измерения и андеррайтинга для on-chain ставок, залога и риска, а не подбор APY.">
        Our own backtest proved plain crypto yield isn't an edge. The real $10M-scale edge is a
        <strong style="color:var(--text-primary)">structural role</strong>: the transparent measurement
        and underwriting desk for on-chain rates, collateral and risk — <em>not</em> picking APY.
      </p>

      <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="rounded-xl p-5" style="background:var(--bg-surface);border:1px solid var(--border)">
          <p class="text-xs uppercase tracking-wider font-mono mb-2" style="color:var(--text-muted)"
             data-ru="Как мы сюда пришли">How we got here</p>
          <p class="text-sm leading-relaxed" style="color:var(--text-secondary)"
             data-ru="Мы провели три глубоких исследования DeFi-эджа и де-рискнули каждое на собственном стеке. Все три сходятся к одной истине: деньги не в том, ЧТО держать, а в том, чтобы занять роль того, кто честно ИЗМЕРЯЕТ и АНДЕРРАЙТИТ ставки, залог и риск.">
            We ran three deep DeFi-edge researches and de-risked each on our own stack. All three
            converge on one truth: the money is not in <em>what</em> to hold — it is in occupying the
            seat that honestly <strong style="color:var(--text-primary)">measures and underwrites</strong>
            rates, collateral and risk.
          </p>
        </div>
        <div class="rounded-xl p-5" style="background:var(--bg-surface);border:1px solid var(--border)">
          <p class="text-xs uppercase tracking-wider font-mono mb-2" style="color:var(--text-muted)"
             data-ru="Статус">Status</p>
          <p class="text-sm leading-relaxed" style="color:var(--text-secondary)"
             data-ru="Paper-исследование. Advisory — ничего не торгуется вживую. Каждый вердикт детерминирован (LLM запрещён в risk-гейте). Мы публикуем то, что построили, то, что ограничено условиями, И то, что убили.">
            Paper research. Advisory — nothing trades live. Every verdict is deterministic (LLM forbidden
            in the risk gate). We publish what we built, what we gated, <strong style="color:var(--text-primary)">and what we killed</strong>.
          </p>
        </div>
      </div>

      <!-- optional live summary line (graceful offline) -->
      <p class="mt-5 text-xs font-mono" style="color:var(--text-faint)">
        <span id="sd-live" data-ru="Живые сводки столов загружаются…">Loading live desk summaries…</span>
      </p>
    </section>

    <!-- ============================================================= b. THE THREE SEATS -->
    <section class="py-10 border-t" style="border-color:var(--border)">
      <p class="text-xs uppercase tracking-wider font-mono mb-2" style="color:var(--text-muted)"
         data-ru="Три места за столом">The three seats</p>
      <p class="text-sm leading-relaxed max-w-2xl mb-7" style="color:var(--text-secondary)"
         data-ru="Каждый тезис де-рискнут на нашем стеке и получил честный вердикт. Два — построены. Один — убит. Все три проверяют одну гипотезу: эдж — это роль, а не доходность.">
        Each thesis was de-risked on our stack and given an honest verdict. Two are built. One is
        killed. All three test the same hypothesis: the edge is a role, not a yield.
      </p>

      <!-- LIVE verdict provenance — each settled verdict shows its measured inputs + as-of (graceful offline) -->
      <div class="rounded-xl p-5 mb-6" style="background:var(--bg-surface);border:1px solid var(--border)">
        <p class="text-xs uppercase tracking-wider font-mono mb-3" style="color:var(--text-muted)"
           data-ru="Живые входы вердиктов">Live verdict inputs</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div class="rounded-lg p-4 bg-white/[0.02]" style="border:1px solid var(--border)">
            <div class="flex items-baseline justify-between gap-2 mb-1.5 flex-wrap">
              <span class="text-sm font-semibold" style="color:var(--text-primary)">Rates Desk · <span class="text-data-teal">GO</span></span>
              <span class="text-[11px] font-mono" style="color:var(--text-faint)" id="sd-rd-asof">—</span>
            </div>
            <p class="text-xs font-mono" style="color:var(--text-secondary)" id="sd-rd-inputs"
               data-ru="загрузка лога решений…">loading the decision log…</p>
          </div>
          <div class="rounded-lg p-4 bg-white/[0.02]" style="border:1px solid var(--border)">
            <div class="flex items-baseline justify-between gap-2 mb-1.5 flex-wrap">
              <span class="text-sm font-semibold" style="color:var(--text-primary)">RWA Backstop · <span class="text-indigo-300">MEASUREMENT-GO</span></span>
              <span class="text-[11px] font-mono" style="color:var(--text-faint)" id="sd-rwa-asof">—</span>
            </div>
            <p class="text-xs font-mono" style="color:var(--text-secondary)" id="sd-rwa-inputs"
               data-ru="загрузка доски безопасности…">loading the safety board…</p>
          </div>
        </div>
      </div>

      <div class="space-y-4">
        {seats.map((s) => (
          <div class:list={["group rounded-xl p-6 border bg-white/[0.02] transition-all", s.card]}>
            <div class="flex items-start justify-between gap-4 mb-3">
              <div class="flex items-center gap-3">
                <span class="text-xs font-mono" style="color:var(--text-faint)">{s.n}</span>
                <div>
                  <h2 class:list={["text-xl font-bold", s.accent]} style="color:var(--text-primary)" data-ru={s.title_ru}>{s.title_en}</h2>
                  <p class="text-xs font-mono mt-0.5" style="color:var(--text-muted)" data-ru={s.sub_ru}>{s.sub_en}</p>
                </div>
              </div>
              <span class:list={["inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-mono font-medium border flex-shrink-0", s.badge]}>
                <span class:list={["w-1.5 h-1.5 rounded-full", s.dot]} aria-hidden="true"></span>
                <span data-ru={s.verdict_ru}>{s.verdict_en}</span>
              </span>
            </div>

            <p class="text-xs uppercase tracking-wider font-mono mb-1" style="color:var(--text-muted)" data-ru="Эдж">The edge</p>
            <p class="text-sm leading-relaxed mb-4" style="color:var(--text-secondary)" data-ru={s.edge_ru}>{s.edge_en}</p>

            <p class="text-xs uppercase tracking-wider font-mono mb-1" style="color:var(--text-muted)" data-ru="Что показал де-риск">The de-risk finding</p>
            <p class="text-sm leading-relaxed" style="color:var(--text-secondary)" data-ru={s.finding_ru}>{s.finding_en}</p>

            {s.href && (
              <a href={s.href} class:list={["inline-flex items-center gap-1.5 mt-4 text-sm font-medium transition-colors", s.arrow]} style="color:var(--text-primary)">
                <span data-ru={s.cta_ru}>{s.cta_en}</span>
                <span aria-hidden="true">→</span>
              </a>
            )}
            {!s.href && (
              <p class="mt-4 text-xs font-mono" style="color:var(--text-faint)"
                 data-ru="Не построено. Полный разбор и цифры — ниже.">Not built. Full reasoning &amp; the numbers — below.</p>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- =================================================== b2. RATES DESK — PROMOTION (reporting only) -->
    <section class="py-10 border-t" style="border-color:var(--border)">
      <div class="flex items-center justify-between gap-3 mb-2 flex-wrap">
        <p class="text-xs uppercase tracking-wider font-mono" style="color:var(--text-muted)"
           data-ru="Rates Desk · карта продвижения слив">Rates Desk · sleeve promotion map</p>
        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-mono font-medium border bg-warn-bg border-warn-border text-warn">
          <span class="w-1.5 h-1.5 rounded-full bg-warn" aria-hidden="true"></span>
          <span data-ru="ADVISORY · reporting-only · не live">ADVISORY · reporting-only · not live</span>
        </span>
      </div>
      <p class="text-sm leading-relaxed max-w-2xl mb-6" style="color:var(--text-secondary)"
         data-ru="Четыре слива Rates Desk прогнаны через ТОТ ЖЕ детерминированный promotion-рубрик, что и Strategy Lab, и получили честную стадию. Это ОТЧЁТНОСТЬ: сливы IS_ADVISORY=True и НИКОГДА не попадают в live-турнир/аллокатор до go-live.">
        The four Rates-Desk sleeves are run through the SAME deterministic promotion rubric as the
        Strategy Lab and given an honest stage. This is <strong style="color:var(--text-primary)">reporting</strong>:
        the sleeves are <code>IS_ADVISORY=True</code> and are <em>never</em> routed to the live
        tournament/allocator before go-live.
      </p>

      <div id="rd-promo" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <!-- Static, honest fallback (graceful offline). Live values replace these in-place. -->
        <div class="rounded-xl p-5 border bg-white/[0.02]" style="border-color:var(--border)">
          <div class="flex items-center justify-between gap-2 mb-1.5">
            <p class="text-sm font-bold" style="color:var(--text-primary)">FixedCarry</p>
            <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-[11px] font-mono font-medium border bg-teal-bg border-teal-border text-data-teal">PAPER_CANDIDATE</span>
          </div>
          <p class="text-xs font-mono" style="color:var(--text-muted)" data-ru="бэктест net APY ~6.09% · advisory (не реализованный)">backtest net APY ~6.09% · advisory (not realized)</p>
        </div>
        <div class="rounded-xl p-5 border bg-white/[0.02]" style="border-color:var(--border)">
          <div class="flex items-center justify-between gap-2 mb-1.5">
            <p class="text-sm font-bold" style="color:var(--text-primary)">LeveredCarry</p>
            <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-[11px] font-mono font-medium border bg-teal-bg border-teal-border text-data-teal">PAPER_CANDIDATE</span>
          </div>
          <p class="text-xs font-mono" style="color:var(--text-muted)" data-ru="бэктест net APY ~4.96% · advisory (не реализованный)">backtest net APY ~4.96% · advisory (not realized)</p>
        </div>
        <div class="rounded-xl p-5 border bg-white/[0.02]" style="border-color:var(--border)">
          <div class="flex items-center justify-between gap-2 mb-1.5">
            <p class="text-sm font-bold" style="color:var(--text-primary)">RateMatrix</p>
            <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-[11px] font-mono font-medium border bg-teal-bg border-teal-border text-data-teal">PAPER_CANDIDATE</span>
          </div>
          <p class="text-xs font-mono" style="color:var(--text-muted)" data-ru="бэктест net APY ~6.09% · advisory (не реализованный)">backtest net APY ~6.09% · advisory (not realized)</p>
        </div>
        <div class="rounded-xl p-5 border bg-white/[0.02]" style="border-color:rgba(242,109,109,.35)">
          <div class="flex items-center justify-between gap-2 mb-1.5">
            <p class="text-sm font-bold" style="color:var(--text-primary)">BasisHedge</p>
            <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-[11px] font-mono font-medium border bg-danger-bg border-danger-border text-danger">BLOCKED-NO-HEDGE</span>
          </div>
          <p class="text-xs font-mono" style="color:var(--text-muted)"
             data-ru="нет keyless forward-funding (Boros) · ~4.99% — только бэктест-прокси, live заблокировано">no keyless forward-funding (Boros) · ~4.99% backtest-proxy only, live-blocked</p>
        </div>
      </div>
      <p class="mt-4 text-xs font-mono" style="color:var(--text-faint)">
        <span id="rd-promo-status" data-ru="Стадии слив загружаются…">Loading sleeve stages…</span>
      </p>
    </section>

    <!-- ============================================================= c. WE PUBLISH WHAT WE KILL -->
    <section class="py-10 border-t" style="border-color:var(--border)">
      <p class="text-xs uppercase tracking-wider font-mono mb-2" style="color:var(--text-muted)"
         data-ru="Мы публикуем то, что убиваем">We publish what we kill</p>

      <div class="rounded-2xl p-7 border" style="border-color:rgba(242,109,109,.35);background:rgba(242,109,109,.05)">
        <div class="flex items-center gap-2.5 mb-4">
          <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-mono font-medium border bg-danger-bg border-danger-border text-danger">
            <span class="w-1.5 h-1.5 rounded-full bg-danger" aria-hidden="true"></span>
            <span data-ru="NO-GO">NO-GO</span>
          </span>
          <span class="text-sm font-bold" style="color:var(--text-primary)" data-ru="Тезис #3 — Кросс-доменный ликвидатор">Thesis #3 — Cross-Domain Liquidator</span>
        </div>

        <p class="text-lg leading-relaxed mb-5" style="color:var(--text-primary)"
           data-ru="Мы протестировали тезис «балансового ликвидатора» и УБИЛИ его: ~$2–4M/год адресуемо, в 5–10× ниже нашей планки. Мы публикуем отрицательные результаты, потому что трек-рекорд честных отказов — это и есть ров.">
          We tested the balance-sheet-liquidator thesis and <strong>KILLED</strong> it:
          ~$2–4M/yr addressable, 5–10× below our bar. We publish negative results because a track
          record of <strong>honest refusals is the moat</strong>.
        </p>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-5">
          <div class="rounded-lg p-4" style="background:var(--bg-surface);border:1px solid var(--border)">
            <p class="text-2xl font-bold font-mono" style="color:var(--danger)">$2–4M</p>
            <p class="text-xs mt-1" style="color:var(--text-muted)" data-ru="адресуемо / год (брутто)">addressable / yr (gross)</p>
          </div>
          <div class="rounded-lg p-4" style="background:var(--bg-surface);border:1px solid var(--border)">
            <p class="text-2xl font-bold font-mono" style="color:var(--danger)">~$2.2M</p>
            <p class="text-xs mt-1" style="color:var(--text-muted)" data-ru="топ-20 пулов">top-20 pools</p>
          </div>
          <div class="rounded-lg p-4" style="background:var(--bg-surface);border:1px solid var(--border)">
            <p class="text-2xl font-bold font-mono" style="color:var(--text-primary)">$20M</p>
