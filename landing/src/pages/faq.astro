---
import Layout from '../layouts/Layout.astro';
import Disclaimer from '../components/Disclaimer.astro';
import Footer from '../components/Footer.astro';

const faqs = [
  {
    id: 'faq-what-is-spa',
    q: 'Что такое SPA?',
    a: 'SPA (Stablecoin Preservation Algorithm) — алгоритмическая стратегия DeFi, направленная на сохранение капитала и стабильный доход. Мы работаем исключительно со стейблкоинами, минимизируя волатильность. Система работает автономно: ежедневный цикл собирает живые данные APY/TVL из whitelisted-протоколов, прогоняет их через детерминированный RiskPolicy и ребалансирует портфель.',
    label: 'Продукт',
    labelColor: 'text-accent-400',
  },
  {
    id: 'faq-minimum',
    q: 'Какова минимальная сумма инвестиций?',
    a: 'Условия обсуждаются индивидуально при onboarding. Поддерживаются USDT (TRC-20, ERC-20) и USDC (ERC-20). Вход через запрос доступа — публичных лимитов нет.',
    label: 'Условия',
    labelColor: 'text-teal-400',
  },
  {
    id: 'faq-returns',
    q: 'Каков ожидаемый доход?',
    a: 'Наша цель — 8–25% годовых в зависимости от рыночного режима. Это консервативная оценка на основе исторических данных. Прошлые результаты не гарантируют будущих доходов. В периоды высокого рыночного стресса или сжатия доходностей система автоматически уходит в кэш, сохраняя капитал.',
    label: 'Доход',
    labelColor: 'text-accent-400',
  },
  {
    id: 'faq-lockup',
    q: 'Есть ли lock-up период?',
    a: 'Lock-up периода нет. Вывод средств обрабатывается по запросу. Стандартное время обработки — обычно в течение 1 рабочего дня, но крупные выводы или выводы, требующие расформирования позиций, могут занять до 5 рабочих дней. Комиссия за вывод не планируется для MVP.',
    label: 'Условия',
    labelColor: 'text-teal-400',
  },
  {
    id: 'faq-fees',
    q: 'Как работает комиссия?',
    a: 'Структура комиссий предоставляется индивидуально по итогам KYC и согласования договора. Мы не публикуем единую тарифную сетку — условия зависят от суммы, срока и стратегии. Свяжитесь с нами через контактную форму для получения индивидуального предложения.',
    label: 'Условия',
    labelColor: 'text-teal-400',
  },
  {
    id: 'faq-cpa',
    q: 'Что такое CPA методология?',
    a: 'Capital Preservation Algorithm (CPA) — наш подход к бэктестингу, использующий Point-in-Time данные. Только протоколы, существовавшие на дату симуляции, включаются в расчёт. Это устраняет look-ahead bias — наиболее распространённую причину завышенных результатов бэктестов в DeFi. Каждый протокол в whitelist-е несёт поле launch_date — симулятор отклоняет любой протокол, дата запуска которого позже даты симуляции.',
    label: 'Методология',
    labelColor: 'text-accent-400',
  },
  {
    id: 'faq-cash',
    q: 'Почему у вас 86.97% кэша в бэктесте?',
    a: 'В 2022–2023 большинство DeFi-протоколов ещё не существовали или не имели верифицированной on-chain истории. Наша строгая Point-in-Time методология честно отражает это: мы не используем ретроспективные данные, не экстраполируем и не делаем допущений. Капитал, который нельзя разместить в CLEAN_INCLUDED-протокол, хранится как USDC. Это честнее, чем показывать нереалистичную доходность, задним числом включая протоколы, которых ещё не было.',
    label: 'Методология',
    labelColor: 'text-accent-400',
  },
  {
    id: 'faq-security',
    q: 'Как защищены мои средства?',
    a: 'Используется Gnosis Safe (multisig) — ни одна транзакция не проходит без подтверждения нескольких подписантов. Встроен kill switch с автоматическим выводом при просадке портфеля ≥ 5%. Ежедневный мониторинг всех позиций логируется в неизменяемый JSON-журнал. Доступ к execution-домену изолирован от read-only аналитики.',
    label: 'Безопасность',
    labelColor: 'text-green-400',
  },
  {
    id: 'faq-launch',
    q: 'Когда запуск?',
    a: 'Мы проходим Paper Trading — 30-дневный период накопления доказательств с виртуальным капиталом $100,000 USDC. Трек запущен 2026-06-10. После прохождения GoLiveChecker (26 критериев), непрерывности gap_monitor 30 дней и ручного review Owner — планируем live запуск ориентировочно 2026-07-09.',
    label: 'Запуск',
    labelColor: 'text-amber-400',
  },
  {
    id: 'faq-apply',
    q: 'Как подать заявку?',
    a: 'Свяжитесь с нами через контактную форму на сайте. Мы проводим KYC вручную и рассматриваем каждую заявку индивидуально. После одобрения вы получите договор инвестора и инструкции по onboarding.',
    label: 'Процесс',
    labelColor: 'text-teal-400',
  },
];
---

<Layout
  title="FAQ — Часто задаваемые вопросы | SPA earn-defi.com"
  description="Ответы на вопросы об SPA: условия участия, ожидаемая доходность, вывод средств, CPA методология, безопасность средств и процесс подачи заявки."
  canonical="https://earn-defi.com/faq"
>

  <!-- Nav -->
  <nav class="flex items-center justify-between px-4 sm:px-6 lg:px-8 py-5 border-b border-white/5">
    <div class="flex items-center gap-2">
      <a href="/" class="flex items-center gap-2">
        <img src="/favicon.svg" alt="" class="w-7 h-7" aria-hidden="true" />
        <span class="font-semibold text-white tracking-tight">SPA</span>
      </a>
      <span class="text-white/15 mx-2">/</span>
      <span class="text-sm text-white/50">FAQ</span>
    </div>
    <div class="flex items-center gap-6 text-sm text-white/50">
      <a href="/" class="hover:text-white transition-colors hidden sm:inline">Home</a>
      <a href="/methodology" class="hover:text-white transition-colors hidden sm:inline">Methodology</a>
      <a href="/risk" class="hover:text-white transition-colors hidden sm:inline">Risk</a>
      <a
        href="/dashboard"
        class="px-3 py-1.5 rounded-md border border-accent-500/50 text-accent-400 text-xs font-medium hover:border-accent-400 hover:text-accent-300 transition-all"
      >
        Dashboard ↗
      </a>
    </div>
  </nav>

  <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <section class="pt-16 pb-10">
      <p class="text-xs text-accent-400 font-mono uppercase tracking-widest mb-3">Документация</p>
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4 leading-tight">
        Часто задаваемые вопросы
      </h1>
      <p class="text-white/50 text-lg leading-relaxed max-w-2xl">
        Всё, что нужно знать перед тем, как стать участником SPA Family Fund.
      </p>

      <!-- Quick nav anchors -->
      <div class="mt-8 flex flex-wrap gap-2">
        {faqs.map((faq) => (
          <a
            href={`#${faq.id}`}
            class="px-3 py-1.5 rounded-full text-xs bg-white/[0.03] border border-white/10 text-white/40 hover:text-white hover:border-white/20 transition-all font-mono"
          >
            #{faq.id.replace('faq-', '')}
          </a>
        ))}
      </div>
    </section>

    <!-- FAQ Items -->
    <section class="pb-16 space-y-4">
      {faqs.map((faq, i) => (
        <div
          id={faq.id}
          class="rounded-xl bg-white/[0.03] border border-white/10 p-6 scroll-mt-8 hover:border-white/20 transition-colors"
        >
          <!-- Label + number -->
          <div class="flex items-center gap-3 mb-3">
            <span class={`text-xs font-mono uppercase tracking-wider ${faq.labelColor}`}>
              {faq.label}
            </span>
            <span class="text-xs text-white/15 font-mono">#{String(i + 1).padStart(2, '0')}</span>
          </div>

          <!-- Q: question -->
          <h2 class="text-base sm:text-lg font-semibold text-white mb-3 leading-snug">
            <span class="text-white/20 font-mono text-xs mr-2">Q:</span>{faq.q}
          </h2>

          <!-- Divider -->
          <div class="h-px bg-white/5 mb-4" aria-hidden="true"></div>

          <!-- A: answer -->
          <p class="text-sm text-white/55 leading-relaxed">
            <span class="text-white/20 font-mono text-xs mr-2">A:</span>{faq.a}
          </p>
        </div>
      ))}
    </section>

    <!-- Contact CTA -->
    <section class="py-12 border-t border-white/5">
      <div class="rounded-xl bg-white/[0.02] border border-white/8 p-8 text-center">
        <p class="text-xs text-white/30 font-mono uppercase tracking-widest mb-3">Остались вопросы?</p>
        <h2 class="text-xl font-semibold text-white mb-3">Свяжитесь с нами</h2>
        <p class="text-sm text-white/50 mb-6 max-w-sm mx-auto leading-relaxed">
          Мы проводим KYC вручную и рассматриваем каждого инвестора индивидуально.
          Ответим в течение 24 часов.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <a
            href="mailto:invest@earn-defi.com"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-accent-500 hover:bg-accent-400 text-white font-medium text-sm transition-colors"
          >
            invest@earn-defi.com
          </a>
          <a
            href="/due-diligence"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-white/15 hover:border-white/30 text-white/60 hover:text-white text-sm transition-all"
          >
            Due Diligence →
          </a>
        </div>
      </div>
    </section>

    <!-- Related links -->
    <section class="py-12 border-t border-white/5">
      <div class="text-center">
        <p class="text-sm text-white/30 mb-6">Изучите подробнее</p>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <a href="/methodology" class="px-4 py-2 rounded-lg border border-white/10 text-white/50 hover:text-white hover:border-white/20 text-sm transition-all">
            Методология
          </a>
          <a href="/risk" class="px-4 py-2 rounded-lg border border-white/10 text-white/50 hover:text-white hover:border-white/20 text-sm transition-all">
            Риски
          </a>
          <a href="/security" class="px-4 py-2 rounded-lg border border-white/10 text-white/50 hover:text-white hover:border-white/20 text-sm transition-all">
            Безопасность
          </a>
          <a href="/fees" class="px-4 py-2 rounded-lg border border-white/10 text-white/50 hover:text-white hover:border-white/20 text-sm transition-all">
            Комиссии
          </a>
          <a href="/dashboard" class="px-4 py-2 rounded-lg border border-white/10 text-white/50 hover:text-white hover:border-white/20 text-sm transition-all">
            Dashboard
          </a>
        </div>
      </div>
    </section>

  </main>

  <Disclaimer />
  <Footer />

</Layout>
