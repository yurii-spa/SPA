---
import Layout from '../layouts/Layout.astro';
import Disclaimer from '../components/Disclaimer.astro';

// WS-3.6 NOTE (for the WS-7 dashboard panel — do NOT build the panel here):
// The cutover readiness scorecard is served fail-CLOSED at GET /api/execution/readiness
// (data/execution_readiness.json, written by spa_core.execution.cutover_scorecard).
// It exposes an HONEST code_readiness_pct (share of proven WS-3.x inert defenses:
// gate-chain ordered/total/fail-closed, reconciliation, signer-nonce, multisig-signable,
// MEV-guard abort, the e2e inert full-chain walk, the pre-cutover defense gate) PLUS the
// NAMED owner_only_blockers (custody/MPC, real capital, external audit, ≥30d track, and
// the human is_live flip). ready_for_live / would_cutover / is_live stay False — the flip
// is owner-gated. WS-7 should render this object as a panel; WS-3 only produces it.

// The 8 architectural planes (spec: Tier-1 8-plane build).
const planes = [
  { en: 'Validation', ru: 'Валидация', desc_en: 'Deflated Sharpe, PSR, min track length on every result', desc_ru: 'Deflated Sharpe, PSR, мин. длина трека на каждом результате' },
  { en: 'Risk', ru: 'Риск', desc_en: 'Deterministic RiskPolicy gate — no LLM, cannot be overridden', desc_ru: 'Детерминированный гейт RiskPolicy — без LLM, не переопределить' },
  { en: 'Audit', ru: 'Аудит', desc_en: 'Append-only audit trail of every cycle and decision', desc_ru: 'Только-добавление: аудит-трейл каждого цикла и решения' },
  { en: 'Execution readiness', ru: 'Готовность исполнения', desc_en: 'Pre-trade checks before any live capital deployment', desc_ru: 'Предторговые проверки до ввода реального капитала' },
  { en: 'Governance', ru: 'Управление', desc_en: 'Owner review gates, ADR-tracked policy changes', desc_ru: 'Гейты review Owner, изменения политики через ADR' },
  { en: 'SSOT', ru: 'Единый источник истины', desc_en: 'Single source of truth mirrored to the site', desc_ru: 'Единый источник истины, зеркалится на сайт' },
  { en: 'Disaster recovery', ru: 'Аварийное восстановление', desc_en: 'NAV reconciliation, state recovery after host restart', desc_ru: 'Сверка NAV, восстановление состояния после рестарта' },
  { en: 'Anomaly detection', ru: 'Детекция аномалий', desc_en: 'APY-spike, threat-reactor, kill-switch on critical threats', desc_ru: 'Всплески APY, threat-reactor, kill-switch при критич. угрозах' },
];

// Live operational surfaces — ALL fold into the cohesive Astro site now. The old
// standalone public/{agents,control,packages,tournament}.html blobs are RETIRED
// (folded into /dashboard tabs + /strategies); these deep-link to the cohesive
// equivalent instead of a separate-entity HTML page.
const surfaces = [
  { href: '/packages', en: 'Yield packages', ru: 'Йелд-пакеты', desc_en: 'Three honest tiers — Conservative (real ~3.3%), Balanced & Aggressive (research/paper, shown WITH the tail, refused for live)', desc_ru: 'Три честных тира — Conservative (реальный ~3.3%), Balanced и Aggressive (research/paper, показаны С хвостом, отказаны для live)' },
  { href: '/monitoring', en: 'Live risk monitoring (RTMR)', ru: 'Живой мониторинг риска (RTMR)', desc_en: 'The real-time watchman — depeg/TVL/oracle/liquidity every 45s across 5-10 sources, deterministic de-risk (paper)', desc_ru: 'Сторож реального времени — депег/TVL/оракул/ликвидность каждые 45с по 5-10 источникам, детерминированный де-риск (paper)' },
  { href: '/dashboard', en: 'Live dashboard', ru: 'Живой дашборд', desc_en: 'Canonical command center — equity, positions, go-live', desc_ru: 'Канонический командный центр — капитал, позиции, go-live' },
  { href: '/dashboard#system', en: 'Agent fleet', ru: 'Парк агентов', desc_en: 'The autonomous launchd agents that run the machine (dashboard · System tab)', desc_ru: 'Автономные launchd-агенты, управляющие системой (дашборд · вкладка System)' },
  { href: '/dashboard#tournament', en: 'Strategy tournament', ru: 'Турнир стратегий', desc_en: 'Backtest → paper → live promotion pipeline (dashboard · Tournament tab)', desc_ru: 'Конвейер промоушена backtest → paper → live (дашборд · вкладка Tournament)' },
  { href: '/strategies', en: 'Risk-tier packages', ru: 'Пакеты по риск-уровням', desc_en: 'Unified Preserve / Core / Max-Yield taxonomy', desc_ru: 'Единая таксономия Preserve / Core / Max-Yield' },
  { href: '/verify', en: 'Verify us', ru: 'Проверить нас', desc_en: 'Don\'t trust us — re-derive every published hash yourself', desc_ru: 'Не верьте на слово — пересчитайте каждый опубликованный хеш сами' },
];
---

<Layout
  title="System — How the Machine Runs | earn-defi.com"
  description="The SPA system hub: the 8-plane Tier-1 architecture, live operational surfaces (dashboard, agent fleet, tournament, control plane), and live agent fleet status from api.earn-defi.com."
  canonical="https://earn-defi.com/system"
>
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Hero -->
    <section class="pt-20 pb-10">
      <div class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full bg-teal-bg border border-teal-border text-xs text-data-teal font-medium">
        <span class="w-1.5 h-1.5 rounded-full bg-data-teal animate-pulse" aria-hidden="true"></span>
        <span data-ru="Машина, работающая автономно">The machine, running autonomously</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4 leading-tight" data-ru="Система">
        System
      </h1>
      <p class="text-xl text-white/50 leading-relaxed max-w-2xl" data-ru="Как устроена машина: восьмиплоскостная Tier-1 архитектура, живые операционные поверхности и парк автономных агентов, переживающих перезагрузку.">
        How the machine is built: the eight-plane Tier-1 architecture, the live operational
        surfaces, and the fleet of autonomous agents that survive a reboot.
      </p>
    </section>

    <section class="pb-6">
      <a href="/monitoring" class="block rounded-xl border border-teal-border bg-teal-bg/40 p-5 hover:border-data-teal transition-colors no-underline">
        <div class="flex items-center gap-2 mb-2">
          <span class="w-1.5 h-1.5 rounded-full bg-data-teal animate-pulse" aria-hidden="true"></span>
          <span class="text-xs text-data-teal font-medium" data-ru="Новое — живой мониторинг (RTMR)">New — live monitoring (RTMR)</span>
        </div>
        <p class="text-white font-semibold mb-1" data-ru="Система стала живым организмом.">The system is now a living organism.</p>
        <p class="text-sm text-slate-400 leading-relaxed" data-ru="Раньше — проверка раз в день. Теперь непрерывный сторож каждые ~45с следит за депегом, TVL, оракулами и ликвидностью по 5-10 источникам и мгновенно снижает риск. Детерминированно, на бумаге. Смотреть вживую →">Was a once-a-day check. Now a continuous watchman monitors depeg, TVL, oracles and liquidity across 5-10 sources every ~45s and de-risks instantly. Deterministic, paper. Watch it live →</p>
      </a>
    </section>

    <!-- Live agent fleet status -->
    <section class="pb-10">
      <div class="rounded-xl border border-white/10 bg-white/[0.03] p-6">
        <div class="flex items-baseline justify-between mb-4 flex-wrap gap-2">
          <p class="text-xs text-white/30 uppercase tracking-wider font-mono" data-ru="Парк агентов · в реальном времени">Agent fleet · live</p>
          <p class="text-xs text-white/25 font-mono"><span data-ru="источник:">source:</span> <span id="sys-src">offline</span></p>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          <div class="rounded-lg bg-white/[0.02] border border-white/8 p-4">
            <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-1" data-ru="Всего">Total</p>
            <p class="text-2xl font-mono font-bold text-white" id="sys-total">—</p>
          </div>
          <div class="rounded-lg bg-white/[0.02] border border-white/8 p-4">
            <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-1" data-ru="Здоровых">Healthy</p>
            <p class="text-2xl font-mono font-bold text-ok" id="sys-healthy">—</p>
          </div>
          <div class="rounded-lg bg-white/[0.02] border border-white/8 p-4">
            <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-1" data-ru="Внимание">Warning</p>
            <p class="text-2xl font-mono font-bold text-warn" id="sys-warn">—</p>
          </div>
          <div class="rounded-lg bg-white/[0.02] border border-white/8 p-4">
            <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-1" data-ru="Критич.">Critical</p>
            <p class="text-2xl font-mono font-bold text-danger" id="sys-crit">—</p>
          </div>
        </div>
        <p class="text-xs text-white/30 mt-4" data-ru="Статус читается из живого heartbeat агентов (agent_health, ежечасно). При офлайне поля показывают «—».">
          Status reads from the live agent heartbeat (agent_health, hourly). When offline, fields show "—".
        </p>
      </div>
    </section>

    <!-- 8-plane architecture -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-2" data-ru="Восьмиплоскостная архитектура (Tier-1)">Eight-plane architecture (Tier-1)</p>
      <p class="text-sm text-white/40 mb-6 leading-relaxed max-w-2xl" data-ru="Каждая плоскость — независимый, детерминированный слой защиты. Цикл fail-safe: если любая плоскость падает, торговля не идёт.">
        Each plane is an independent, deterministic safety layer. The cycle is fail-safe:
        if any plane fails, no trade goes through.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {planes.map((p, i) => (
          <div class="rounded-xl border border-white/8 bg-white/[0.02] p-5">
            <div class="flex items-center gap-3 mb-1.5">
              <span class="flex-shrink-0 w-6 h-6 rounded-md bg-teal-bg border border-teal-border flex items-center justify-center text-xs text-data-teal font-mono">{i + 1}</span>
              <p class="text-sm font-semibold text-white" data-ru={p.ru}>{p.en}</p>
            </div>
            <p class="text-xs text-white/40 leading-relaxed pl-9" data-ru={p.desc_ru}>{p.desc_en}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Live operational surfaces -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-6" data-ru="Живые операционные поверхности">Live operational surfaces</p>
      <div class="space-y-3">
        {surfaces.map((s) => (
          <a href={s.href} class="group flex items-center gap-4 rounded-xl border border-white/10 bg-white/[0.02] px-5 py-4 hover:border-white/20 hover:bg-white/[0.04] transition-all">
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-white group-hover:text-white/90" data-ru={s.ru}>{s.en}</p>
              <p class="text-xs text-white/35 mt-0.5" data-ru={s.desc_ru}>{s.desc_en}</p>
            </div>
            <span class="text-white/20 group-hover:text-accent-400 transition-colors flex-shrink-0">→</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Promotion pipeline (the honest decision layer) -->
    <section class="py-10 border-t border-white/5">
      <div class="flex items-baseline justify-between mb-2 flex-wrap gap-2">
        <p class="text-xs text-white/30 uppercase tracking-wider font-mono" data-ru="Конвейер промоушена · Strategy Lab">Promotion pipeline · Strategy Lab</p>
        <p class="text-xs text-white/25 font-mono"><span data-ru="источник:">source:</span> <span id="promo-src">offline</span></p>
      </div>
      <p class="text-sm text-white/40 mb-5 leading-relaxed max-w-2xl" data-ru="Решающий слой исследований: какие исследовательские sleeve'ы переходят backtest → paper → live и почему. Промоушен — это детерминированный риск-гейт, а не воронка продаж. Мы публикуем то, что ПРОВАЛИВАЕТСЯ, а не только то, что проходит.">
        The research decision layer: which research sleeves graduate backtest → paper → live, and why.
        Promotion is a deterministic risk gate, not a sales funnel. We publish what FAILS, not just what passes.
      </p>

      <!-- Honest framing banner -->
      <div class="rounded-xl border border-warn-border bg-warn-bg p-5 mb-6 flex items-start gap-3">
        <span class="flex-shrink-0 w-5 h-5 mt-0.5 rounded-md bg-warn-bg border border-warn-border flex items-center justify-center text-xs text-warn" aria-hidden="true">!</span>
        <div>
          <p class="text-sm font-semibold text-warn mb-1" data-ru="Бумажное исследование · advisory · не в проде. Честный вывод:">Paper research · advisory · not live. The honest finding:</p>
          <p class="text-sm text-white/55 leading-relaxed" data-ru="Только стабильные sleeve'ы достигают PAPER_CANDIDATE. Крипто-sleeve'ы (ETH/BTC) ОТКЛОНЕНЫ — они не обыгрывают безрисковый порог ~3.4% с поправкой на риск. Промоушен детерминирован: чистая арифметика по критериям, без LLM, не переопределяется.">
            Only the stable sleeves reach PAPER_CANDIDATE. The crypto (ETH/BTC) sleeves are REJECTED — they
            do not beat the ~3.4% risk-free floor on a risk-adjusted basis. The gate is deterministic: pure
            arithmetic over the criteria, no LLM, cannot be overridden.
          </p>
        </div>
      </div>

      <!-- The pipeline stepper -->
      <div class="rounded-xl border border-white/10 bg-white/[0.02] p-5 mb-6">
        <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-4" data-ru="Лестница промоушена">The promotion ladder</p>
        <div class="flex items-center gap-1.5 sm:gap-2 overflow-x-auto pb-1">
          {['RESEARCH', 'BACKTEST', 'WALK-FORWARD', 'PAPER', 'CANARY', 'FULL'].map((stage, i, arr) => (
            <>
              <div class="flex-shrink-0 flex flex-col items-center gap-1.5">
                <span class={`w-7 h-7 rounded-full border flex items-center justify-center text-xs font-mono ${i <= 3 ? 'bg-teal-bg border-teal-border text-data-teal' : 'bg-white/[0.02] border-white/10 text-white/30'}`}>{i + 1}</span>
                <span class={`text-[10px] sm:text-xs font-mono whitespace-nowrap ${i <= 3 ? 'text-white/60' : 'text-white/30'}`}>{stage}</span>
              </div>
              {i < arr.length - 1 && <span class={`flex-1 min-w-[12px] h-px ${i < 3 ? 'bg-data-teal' : 'bg-white/10'}`} aria-hidden="true"></span>}
            </>
          ))}
        </div>
        <p class="text-xs text-white/30 mt-4 leading-relaxed" data-ru="Стадии после backtest достигаются только при прохождении гейта. Текущая фаза трека — paper; ни один sleeve не идёт в live, пока трек не подтверждён. RWA-порог, против которого всё измеряется:">
          Stages past backtest are only reached by clearing the gate. The current track phase is paper; no sleeve
          goes live until the track is confirmed. RWA floor everything is measured against:
          <span class="font-mono text-data-teal" id="promo-floor">—</span>
        </p>
      </div>

      <!-- Stage summary counts -->
      <div class="grid grid-cols-3 gap-3 mb-6">
        <div class="rounded-lg bg-white/[0.02] border border-ok-border p-4">
          <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-1" data-ru="Кандидат в paper">Paper candidate</p>
          <p class="text-2xl font-mono font-bold text-ok" id="promo-cnt-paper">—</p>
        </div>
        <div class="rounded-lg bg-white/[0.02] border border-teal-border p-4">
          <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-1" data-ru="Прошёл backtest">Backtest pass</p>
          <p class="text-2xl font-mono font-bold text-data-teal" id="promo-cnt-backtest">—</p>
        </div>
        <div class="rounded-lg bg-white/[0.02] border border-danger-border p-4">
          <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-1" data-ru="Отклонён">Rejected</p>
          <p class="text-2xl font-mono font-bold text-danger" id="promo-cnt-reject">—</p>
        </div>
      </div>

      <!-- Per-sleeve verdicts, grouped by stage (rendered by script) -->
      <div id="promo-groups" class="space-y-6">
        <p class="text-sm text-white/30" data-ru="Загрузка вердиктов промоушена… При офлайне показываются критерии, но не живые значения.">Loading promotion verdicts… When offline, the criteria are shown but not live values.</p>
      </div>

      <p class="text-xs text-white/30 mt-6 leading-relaxed" data-ru="Критерии (детерминированы, из SSOT-конфига): обыгрывает порог · просадка в пределах · не убит реальным риском · устойчивость walk-forward · ёмкость · положительный net APY. data-gap kill (отсутствующее значение фида) толерируется как fail-closed safe-hold, не как риск-провал. Источник: spa_core/strategy_lab/promotion.py → /api/strategy-lab/promotion.">
        Criteria (deterministic, from the SSOT config): beats floor · drawdown within band · not killed by real risk ·
        walk-forward consistency · capacity · positive net APY. A data-gap kill (a missing feed value) is tolerated as
        a fail-closed safe-hold, not a risk failure. Source: spa_core/strategy_lab/promotion.py → /api/strategy-lab/promotion.
      </p>
    </section>

    <!-- Risk refusal — what we won't hold -->
    <section class="py-10 border-t border-white/5">
      <div class="flex items-baseline justify-between mb-2 flex-wrap gap-2">
        <p class="text-xs text-white/30 uppercase tracking-wider font-mono" data-ru="Отказ по риску · что мы НЕ держим">Risk refusal · what we won't hold</p>
        <p class="text-xs text-white/25 font-mono"><span data-ru="источник:">source:</span> <span id="ref-src">offline</span></p>
      </div>
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-3 leading-tight" data-ru="Активы, которые мы ОТКАЗЫВАЕМСЯ держать — и почему">
        The assets we REFUSE to hold — and why
      </h2>

      <!-- Honest framing banner (the core trust signal) -->
      <div class="rounded-xl border border-danger-border bg-danger-bg p-5 mb-6 flex items-start gap-3">
        <span class="flex-shrink-0 w-5 h-5 mt-0.5 rounded-md bg-danger-bg border border-danger-border flex items-center justify-center text-xs text-danger" aria-hidden="true">!</span>
        <div>
          <p class="text-sm font-semibold text-danger mb-1" data-ru="Бумажное исследование · измерительный/advisory движок · не финсовет">Paper research · a measurement / advisory engine · not financial advice</p>
          <p class="text-sm text-white/60 leading-relaxed" data-ru="Большинство yield-продуктов рекламируют APY. Мы публикуем активы, которые ОТКАЗЫВАЕМСЯ держать, и почему — движок риска, который пометил токсичные рестейкинг-токены (типа ezETH) ДО их обвала, проверенный на 2 годах данных, включая реальные события депега. Мы скорее упустим доходность, чем будем держать книгу, которая взорвётся.">
            Most yield products advertise APY. We publish the assets we REFUSE and why — a risk engine that
            flagged toxic restaking tokens (ezETH-type) before they collapsed, validated on 2 years of data
            including real depeg events. We'd rather miss yield than hold a book that blows up.
          </p>
          <p class="text-xs text-white/40 leading-relaxed mt-2" data-ru="Это измерительный/advisory движок, а не гарантия. Он оценивает tail-риск каждого доходного актива и выдаёт вердикт SAFE / WATCH / REFUSE / UNKNOWN. Источник: /api/refusal.">
            This is a measurement / advisory engine, not a guarantee. It scores the tail risk of each
            yield-bearing asset and emits a verdict of SAFE / WATCH / REFUSE / UNKNOWN. Source: /api/refusal.
          </p>
        </div>
      </div>

      <!-- Verdict legend + thresholds -->
      <div class="flex flex-wrap items-center gap-2 mb-5 text-[11px] font-mono">
        <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md border bg-teal-bg border-teal-border text-data-teal"><span class="w-1.5 h-1.5 rounded-full bg-data-teal" aria-hidden="true"></span><span data-ru="БЕЗОПАСЕН">SAFE</span></span>
        <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md border bg-warn-bg border-warn-border text-warn"><span class="w-1.5 h-1.5 rounded-full bg-warn" aria-hidden="true"></span><span data-ru="НАБЛЮДЕНИЕ">WATCH</span></span>
        <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md border bg-danger-bg border-danger-border text-danger"><span class="w-1.5 h-1.5 rounded-full bg-danger" aria-hidden="true"></span><span data-ru="ОТКАЗ">REFUSE</span></span>
        <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md border bg-white/5 border-white/15 text-white/40"><span class="w-1.5 h-1.5 rounded-full bg-white/30" aria-hidden="true"></span><span data-ru="НЕИЗВЕСТНО">UNKNOWN</span></span>
        <span class="text-white/25" id="ref-thresholds"></span>
      </div>

      <!-- Refusal rows (rendered by script) -->
      <div id="ref-rows" class="space-y-3">
        <p class="text-sm text-white/30" data-ru="Загрузка вердиктов движка отказа… При офлайне живые значения недоступны.">Loading refusal-engine verdicts… When offline, live values are unavailable.</p>
      </div>

      <p class="text-xs text-white/30 mt-6 leading-relaxed" data-ru="tail_score (0–1) — нормированная оценка хвостового риска: депег, downside-волатильность, режим фондирования. REFUSE/WATCH сверху. Вердикты — advisory; реальный детерминированный гейт исполнения — RiskPolicy (LLM запрещён). Источник: GET /api/refusal.">
        tail_score (0–1) is the normalised tail-risk score: depeg, downside volatility, funding regime.
        REFUSE/WATCH are listed first. Verdicts are advisory; the live deterministic execution gate is the
        RiskPolicy (LLM forbidden). Source: GET /api/refusal.
      </p>
    </section>

    <!-- Proof of Reserves (provenance plane) -->
    <section class="py-10 border-t border-white/5">
      <div class="flex items-baseline justify-between mb-6 flex-wrap gap-2">
        <p class="text-xs text-white/30 uppercase tracking-wider font-mono" data-ru="Доказательство резервов">Proof of Reserves</p>
        <p class="text-xs text-white/25 font-mono"><span data-ru="источник:">source:</span> <span id="sys-por-src">static fallback</span></p>
      </div>
      <a href="/track-record" class="group block rounded-xl border border-white/10 bg-white/[0.02] p-5 hover:border-white/20 hover:bg-white/[0.04] transition-all">
        <div class="flex items-start justify-between gap-4 flex-wrap mb-4">
          <p class="text-sm font-medium text-white group-hover:text-white/90" data-ru="Верифицируемый NAV — каждый доллар учтён, криптографически проверяемо">Verifiable NAV — every dollar accounted for, cryptographically verifiable</p>
          <span id="sys-por-recon" class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-mono text-white/40 shrink-0">
            <span class="w-1.5 h-1.5 rounded-full bg-white/30" aria-hidden="true"></span>
            <span data-ru="загрузка…">loading…</span>
          </span>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          <div>
            <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-1" data-ru="NAV (бумажный)">NAV (paper)</p>
            <p class="text-lg font-mono font-bold text-data-teal" id="sys-por-nav">—</p>
          </div>
          <div>
            <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-1" data-ru="Расхождение">Delta</p>
            <p class="text-lg font-mono font-bold text-white/70" id="sys-por-delta">—</p>
          </div>
          <div>
            <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-1" data-ru="Хэш проверки">Verification hash</p>
            <p class="text-sm font-mono text-data-teal break-all" id="sys-por-hash">—</p>
          </div>
        </div>
        <p class="text-xs text-white/30 mt-4" data-ru="NAV = вложено + кэш + начислено, сверяется с заявленным капиталом. Бумажное доказательство резервов (методология на виртуальном портфеле $100k, не реальное кастоди). Полная панель → /track-record">
          NAV = deployed + cash + accrued, reconciled against reported equity. Paper proof-of-reserves
          (methodology on the virtual $100k book, not real custody). Full panel → /track-record
        </p>
      </a>
    </section>

    <!-- Daily cycle -->
    <section class="py-10 border-t border-white/5">
      <p class="text-xs text-white/30 uppercase tracking-wider font-mono mb-6" data-ru="Ежедневный цикл">The daily cycle</p>
      <div class="rounded-xl border border-white/10 bg-white/[0.02] p-5 font-mono text-xs text-white/55 leading-relaxed overflow-x-auto">
        <span class="text-data-teal">06:00 UTC</span> · adapter orchestrator (read-only) → live APY/TVL<br/>
        &nbsp;&nbsp;&nbsp;&nbsp;→ multi-strategy runner (S0–S77, tournament)<br/>
        &nbsp;&nbsp;&nbsp;&nbsp;→ allocator → target allocation with caps<br/>
        &nbsp;&nbsp;&nbsp;&nbsp;→ <span class="text-warn">RiskPolicy gate (deterministic, LLM forbidden)</span><br/>
        &nbsp;&nbsp;&nbsp;&nbsp;→ virtual rebalance → daily yield accrual<br/>
        &nbsp;&nbsp;&nbsp;&nbsp;→ <span class="text-accent-400">GoLiveChecker → 29 criteria</span>
      </div>
      <p class="text-xs text-white/30 mt-4" data-ru="Стек: Python 3, только stdlib в runtime. Атомарные записи во все state-файлы. Агенты установлены через launchd и переживают перезагрузку.">
        Stack: Python 3, stdlib-only at runtime. Atomic writes to all state files. Agents are
        installed via launchd and survive reboots.
      </p>
    </section>

  </main>

  <Disclaimer />

  <script is:inline>
    /* Live agent fleet — api.earn-defi.com, localhost fallback, graceful offline. */
    (function(){
      var API = (location.hostname === 'localhost' || location.hostname === '127.0.0.1')
        ? 'http://localhost:8765'
        : 'https://api.earn-defi.com';
      function setText(id, txt){ var el = document.getElementById(id); if(el){ el.textContent = txt; } }

      function loadAgents(){
        fetch(API + '/api/live/agents').then(function(r){ return r.json(); }).then(function(d){
          if(!d || d.status === 'no_data' || d.status === 'error') return;
          var total = d.total_agents, healthy = d.healthy_count, warn = d.warning_count, crit = d.critical_count;
          if(total != null) setText('sys-total', total);
          if(healthy != null) setText('sys-healthy', healthy);
          if(warn != null) setText('sys-warn', warn);
          if(crit != null) setText('sys-crit', crit);
          if(total != null) setText('sys-src', 'live');
        }).catch(function(){});
      }

      function fmtUsd(v){ return '$' + Number(v).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}); }
      function isRu(){ try{ return (localStorage.getItem('spa_lang') || 'en') === 'ru'; }catch(e){ return false; } }

      function loadNav(){
        fetch(API + '/api/tier1/nav').then(function(r){ return r.json(); }).then(function(d){
          if(!d || d.computed_nav_usd == null) return;
          setText('sys-por-nav', fmtUsd(d.computed_nav_usd));
          if(d.reconciliation_delta_usd != null) setText('sys-por-delta', fmtUsd(d.reconciliation_delta_usd));
          if(d.nav_hash) setText('sys-por-hash', d.nav_hash.slice(0,20) + '…' + d.nav_hash.slice(-6));
          var chip = document.getElementById('sys-por-recon');
          if(chip){
            var ok = d.reconciliation_ok === true;
            chip.className = 'inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-mono shrink-0 border ' +
              (ok ? 'bg-teal-bg border-teal-border text-data-teal' : 'bg-warn-bg border-warn-border text-warn');
            chip.innerHTML = '<span class="w-1.5 h-1.5 rounded-full ' + (ok ? 'bg-data-teal' : 'bg-warn') + '" aria-hidden="true"></span>' +
              (ok ? (isRu() ? 'сверено ✓' : 'reconciled ✓') : (isRu() ? 'расхождение ⚠' : 'delta ⚠'));
          }
          setText('sys-por-src', 'live');
        }).catch(function(){});
      }

      /* Promotion pipeline — /api/strategy-lab/promotion, graceful offline. */
      function esc(s){ var d = document.createElement('div'); d.textContent = String(s == null ? '' : s); return d.innerHTML; }

      /* Explicit class strings (NOT constructed at runtime — Tailwind only compiles literal classes). */
      var STAGE_META = {
        PAPER_CANDIDATE: { en: 'Paper candidate', ru: 'Кандидат в paper', border: 'border-ok-border', dot: 'bg-ok', text: 'text-ok' },
        BACKTEST_PASS:   { en: 'Backtest pass',   ru: 'Прошёл backtest', border: 'border-teal-border',    dot: 'bg-data-teal',    text: 'text-data-teal' },
        REJECT:          { en: 'Rejected',        ru: 'Отклонён',        border: 'border-danger-border',     dot: 'bg-danger',     text: 'text-danger' }
      };
      // Criterion key → bilingual label.
      var CRIT_LABELS = {
        beats_rwa_floor:      { en: 'beats floor', ru: 'обыгрывает порог' },
        drawdown_within_band: { en: 'drawdown',    ru: 'просадка' },
        not_killed_real:      { en: 'not killed',  ru: 'не убит риском' },
        walk_forward_robust:  { en: 'walk-forward',ru: 'walk-forward' },
        capacity_sufficient:  { en: 'capacity',    ru: 'ёмкость' },
        positive_net_apy:     { en: 'net APY',     ru: 'net APY' }
      };
      var CRIT_ORDER = ['beats_rwa_floor', 'drawdown_within_band', 'not_killed_real', 'walk_forward_robust', 'capacity_sufficient', 'positive_net_apy'];

      function critChip(key, c){
        var ru = isRu();
        var lbl = CRIT_LABELS[key] ? (ru ? CRIT_LABELS[key].ru : CRIT_LABELS[key].en) : key;
        var pending = c && c.pending === true;
        var pass = c && c.pass === true;
        var color, mark;
        if(pending){ color = 'bg-white/5 border-white/15 text-white/40'; mark = '·'; }
        else if(pass){ color = 'bg-ok-bg border-ok-border text-ok'; mark = '✓'; }
        else { color = 'bg-danger-bg border-danger-border text-danger'; mark = '✗'; }
        var title = c && c.detail ? ' title="' + esc(c.detail) + '"' : '';
        return '<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md border text-[11px] font-mono ' + color + '"' + title + '>' + mark + ' ' + esc(lbl) + '</span>';
      }

      function sleeveCard(s){
        var ru = isRu();
        var meta = STAGE_META[s.stage] || { border: 'border-white/10' };
        var crits = '';
        CRIT_ORDER.forEach(function(k){ if(s.criteria && s.criteria[k]) crits += critChip(k, s.criteria[k]); });
        var napy = (s.net_apy_pct != null) ? Number(s.net_apy_pct).toFixed(2) + '%' : '—';
        var dd = (s.max_drawdown_pct != null) ? Number(s.max_drawdown_pct).toFixed(2) + '%' : '—';
        var score = (s.score != null && s.max_score != null) ? s.score + '/' + s.max_score : '—';
        return '<div class="rounded-xl border ' + meta.border + ' bg-white/[0.02] p-4">' +
          '<div class="flex items-baseline justify-between gap-3 flex-wrap mb-2">' +
            '<div class="flex items-baseline gap-2 flex-wrap min-w-0">' +
              '<span class="text-sm font-semibold text-white font-mono">' + esc(s.id) + '</span>' +
              '<span class="text-xs text-white/35 font-mono">' + esc(s.mandate || '') + '</span>' +
            '</div>' +
            '<span class="text-xs font-mono text-white/50 shrink-0">' + (ru ? 'счёт ' : 'score ') + score +
              ' · net APY ' + napy + ' · dd ' + dd + '</span>' +
          '</div>' +
          '<div class="flex flex-wrap gap-1.5 mb-2.5">' + crits + '</div>' +
          '<p class="text-xs text-white/45 leading-relaxed">' + esc(s.reason || '') + '</p>' +
        '</div>';
      }

      function renderPromotion(d){
        var ru = isRu();
        var floor = (d.rwa_floor_pct != null) ? Number(d.rwa_floor_pct).toFixed(2) + '%' : '—';
        setText('promo-floor', floor);
        var counts = d.stage_counts || {};
        setText('promo-cnt-paper', counts.PAPER_CANDIDATE != null ? counts.PAPER_CANDIDATE : 0);
        setText('promo-cnt-backtest', counts.BACKTEST_PASS != null ? counts.BACKTEST_PASS : 0);
        setText('promo-cnt-reject', counts.REJECT != null ? counts.REJECT : 0);

        var sleeves = Array.isArray(d.sleeves) ? d.sleeves : [];
        var groupsEl = document.getElementById('promo-groups');
        if(!groupsEl) return;
        if(!sleeves.length){
          groupsEl.innerHTML = '<p class="text-sm text-white/30">' +
            (ru ? 'Вердикты промоушена недоступны (офлайн или нет данных).' : 'Promotion verdicts unavailable (offline or no data).') + '</p>';
          return;
        }
        var order = ['PAPER_CANDIDATE', 'BACKTEST_PASS', 'REJECT'];
        var html = '';
        order.forEach(function(stage){
          var group = sleeves.filter(function(s){ return s.stage === stage; });
          if(!group.length) return;
          var meta = STAGE_META[stage] || { dot: 'bg-white/30', text: 'text-white/50' };
          var lbl = (ru ? meta.ru : meta.en) || stage;
          html += '<div>' +
            '<div class="flex items-center gap-2 mb-3">' +
              '<span class="w-2 h-2 rounded-full ' + meta.dot + '" aria-hidden="true"></span>' +
              '<p class="text-xs uppercase tracking-wider font-mono ' + meta.text + '">' + esc(lbl) + ' · ' + group.length + '</p>' +
            '</div>' +
            '<div class="space-y-3">' + group.map(sleeveCard).join('') + '</div>' +
          '</div>';
        });
        groupsEl.innerHTML = html;
      }

      function loadPromotion(){
        fetch(API + '/api/strategy-lab/promotion').then(function(r){ return r.json(); }).then(function(d){
          if(!d || typeof d !== 'object') return;
          renderPromotion(d);
          if((Array.isArray(d.sleeves) && d.sleeves.length) || d.rwa_floor_pct != null) setText('promo-src', 'live');
        }).catch(function(){});
      }

      /* Risk refusal engine — /api/refusal, graceful offline. */
      /* Explicit class strings (Tailwind only compiles literal classes). */
      var VERDICT_META = {
        SAFE:    { en: 'SAFE',    ru: 'БЕЗОПАСЕН',  border: 'border-teal-border',  badge: 'bg-teal-bg border-teal-border text-data-teal',  dot: 'bg-data-teal',  bar: 'bg-data-teal',  order: 3 },
        WATCH:   { en: 'WATCH',   ru: 'НАБЛЮДЕНИЕ', border: 'border-warn-border', badge: 'bg-warn-bg border-warn-border text-warn', dot: 'bg-warn', bar: 'bg-warn', order: 1 },
        REFUSE:  { en: 'REFUSE',  ru: 'ОТКАЗ',      border: 'border-danger-border',   badge: 'bg-danger-bg border-danger-border text-danger',     dot: 'bg-danger',   bar: 'bg-danger',   order: 0 },
        UNKNOWN: { en: 'UNKNOWN', ru: 'НЕИЗВЕСТНО', border: 'border-white/10',     badge: 'bg-white/5 border-white/15 text-white/40',         dot: 'bg-white/30',  bar: 'bg-white/30',     order: 2 }
      };

      function refusalRow(u){
        var ru = isRu();
        var v = String(u.verdict || 'UNKNOWN').toUpperCase();
        var meta = VERDICT_META[v] || VERDICT_META.UNKNOWN;
        var score = (typeof u.tail_score === 'number') ? Math.max(0, Math.min(1, u.tail_score)) : null;
        var scorePct = score != null ? Math.round(score * 100) : 0;
        var scoreLbl = score != null ? score.toFixed(2) : '—';
        var m = u.metrics || {};
        var metricBits = [];
        if(m.depeg_pct != null) metricBits.push((ru ? 'депег ' : 'depeg ') + Number(m.depeg_pct).toFixed(2) + '%');
        if(m.dd_vol != null) metricBits.push((ru ? 'downside-vol ' : 'downside-vol ') + Number(m.dd_vol).toFixed(2));
        if(m.funding_regime != null) metricBits.push((ru ? 'фондирование: ' : 'funding: ') + esc(m.funding_regime));
        var metricStr = metricBits.length ? metricBits.join(' · ') : '—';
        var verdictLbl = ru ? meta.ru : meta.en;
        return '<div class="rounded-xl border ' + meta.border + ' bg-white/[0.02] p-4">' +
          '<div class="flex items-baseline justify-between gap-3 flex-wrap mb-2.5">' +
            '<span class="text-sm font-semibold text-white font-mono">' + esc(u.symbol || '?') + '</span>' +
            '<span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md border text-[11px] font-mono shrink-0 ' + meta.badge + '">' +
              '<span class="w-1.5 h-1.5 rounded-full ' + meta.dot + '" aria-hidden="true"></span>' + esc(verdictLbl) +
            '</span>' +
          '</div>' +
          '<div class="flex items-center gap-2 mb-2.5">' +
            '<span class="text-[11px] font-mono text-white/30 w-16 shrink-0">' + (ru ? 'tail-риск' : 'tail-risk') + '</span>' +
            '<span class="flex-1 h-1.5 rounded-full bg-white/8 overflow-hidden"><span class="block h-full rounded-full ' + meta.bar + '" style="width:' + scorePct + '%"></span></span>' +
            '<span class="text-[11px] font-mono text-white/50 w-10 text-right shrink-0">' + scoreLbl + '</span>' +
          '</div>' +
          '<p class="text-xs text-white/50 leading-relaxed mb-1.5">' + esc(u.reason || '') + '</p>' +
          '<p class="text-[11px] font-mono text-white/30">' + metricStr + '</p>' +
        '</div>';
      }

      function renderRefusal(d){
        var ru = isRu();
        var rowsEl = document.getElementById('ref-rows');
        if(!rowsEl) return;
        var ul = Array.isArray(d.underlyings) ? d.underlyings.slice() : [];
        if(!ul.length){
          rowsEl.innerHTML = '<p class="text-sm text-white/30">' +
            (ru ? 'Вердикты движка отказа недоступны (офлайн или нет данных).' : 'Refusal-engine verdicts unavailable (offline or no data).') + '</p>';
          return;
        }
        // Sort REFUSE/WATCH first, then by tail_score descending.
        ul.sort(function(a, b){
          var oa = (VERDICT_META[String(a.verdict || 'UNKNOWN').toUpperCase()] || VERDICT_META.UNKNOWN).order;
          var ob = (VERDICT_META[String(b.verdict || 'UNKNOWN').toUpperCase()] || VERDICT_META.UNKNOWN).order;
          if(oa !== ob) return oa - ob;
          return (b.tail_score || 0) - (a.tail_score || 0);
        });
        rowsEl.innerHTML = ul.map(refusalRow).join('');
        // Thresholds line (optional).
        var th = d.thresholds;
        if(th && typeof th === 'object'){
          var bits = Object.keys(th).map(function(k){ return esc(k) + ': ' + esc(th[k]); });
          if(bits.length) setText('ref-thresholds', '· ' + bits.join(' · '));
        }
      }

      function loadRefusal(){
        fetch(API + '/api/refusal').then(function(r){ return r.json(); }).then(function(d){
          if(!d || typeof d !== 'object' || !Array.isArray(d.underlyings)) return;
          renderRefusal(d);
          if(d.underlyings.length) setText('ref-src', 'live');
        }).catch(function(){});
      }

      function init(){ loadAgents(); loadNav(); loadPromotion(); loadRefusal(); }
      if(document.readyState === 'loading'){ document.addEventListener('DOMContentLoaded', init); }
      else { init(); }
    })();
  </script>
</Layout>
