    <script>
    /* Multi-Chain Allocation Panel — client-side live fetch (MP-1490) */
    (function () {
      'use strict';

      const TOTAL_CAPITAL = 100_000;

      function fmt(pct) { return pct.toFixed(1) + '%'; }
      function fmtUsd(v) { return '$' + Math.round(v).toLocaleString(); }

      async function fetchChainAllocation() {
        try {
          const resp = await fetch('/api/chain-allocation', { signal: AbortSignal.timeout(4000) });
          if (!resp.ok) throw new Error('non-2xx');
          const d = await resp.json();

          const alloc = d.allocation ?? {};
          const ethFrac  = alloc.ethereum ?? 0.6;
          const baseFrac = alloc.base     ?? 0.4;

          const chains = d.chains ?? {};
          const ethApy  = chains.ethereum?.best_apy ?? null;
          const baseApy = chains.base?.best_apy     ?? null;

          document.getElementById('eth-alloc').textContent   = fmt(ethFrac  * 100);
          document.getElementById('base-alloc').textContent  = fmt(baseFrac * 100);
          document.getElementById('eth-capital').textContent  = fmtUsd(ethFrac  * TOTAL_CAPITAL);
          document.getElementById('base-capital').textContent = fmtUsd(baseFrac * TOTAL_CAPITAL);

          if (ethApy  !== null) document.getElementById('eth-apy').textContent  = ethApy.toFixed(2)  + '%';
          if (baseApy !== null) document.getElementById('base-apy').textContent = baseApy.toFixed(2) + '%';

          if (d.advisory) {
            document.getElementById('multichain-advisory').textContent = d.advisory;
          }
          if (d.apy_spread != null) {
            document.getElementById('multichain-spread').textContent = d.apy_spread.toFixed(2) + ' pp';
          }
          if (d.best_chain) {
            document.getElementById('multichain-best').textContent = d.best_chain;
          }

          const badge = document.getElementById('multichain-source-badge');
          if (badge) {
            badge.textContent = 'live API';
            badge.className = 'text-[10px] font-mono text-emerald-400/60';
          }
        } catch {
          /* Silently retain static advisory defaults */
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', fetchChainAllocation);
      } else {
        fetchChainAllocation();
      }
    })();
    </script>

    <!-- Bottom disclaimer -->
