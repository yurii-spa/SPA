---
import Layout from '../layouts/Layout.astro';
import LiveStatsWidget from '../components/LiveStatsWidget.jsx';
import Footer from '../components/Footer.astro';
import GoLiveWidget from '../components/GoLiveWidget.astro';

// Static fallback gate data (included in build from data/backtest/*.json)
// Live data fetched client-side from /api/backtest/gate
const GATE_STATIC = {
  backtest:  { label: 'Backtest (2022–2026)', status: 'PASS',      detail: 'P0/P1A/P2 closed — strict evidence mode' },
  pre_paper: { label: 'Pre-Paper Gate',        status: 'PASS',      detail: 'All strict blockers cleared' },
  paper:     { label: 'Paper Trading',         status: 'NOT_READY', detail: 'Owner acceptance pending' },
  live:      { label: 'Live Capital',          status: 'BLOCKED',   detail: 'Paper track + ADR-002 required' },
};
---

<Layout
  title="Dashboard — SPA Paper Trading Metrics | earn-defi.com"
  description="Live paper trading metrics for SPA strategies. Multi-strategy tabs: Overview, Core, Preserve, Max Yield, Risk Blocks, GoLive criteria, Changelog. Updated daily."
>

  <!-- Top nav (minimal) -->
  <nav class="flex items-center justify-between px-4 sm:px-6 lg:px-8 py-5 border-b border-white/5">
    <div class="flex items-center gap-2">
      <a href="/" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
        <img src="/favicon.svg" alt="" class="w-7 h-7" aria-hidden="true" />
        <span class="font-semibold text-white tracking-tight">SPA</span>
      </a>
      <span class="text-white/20 mx-2">/</span>
      <span class="text-white/60 text-sm font-medium">Dashboard</span>
    </div>
    <div class="flex items-center gap-6 text-sm text-white/50">
      <a href="/" class="hover:text-white transition-colors">&larr; Home</a>
      <a href="/strategies" class="hover:text-white transition-colors hidden sm:inline">Strategies</a>
      <a href="/risk" class="hover:text-white transition-colors hidden sm:inline">Risk</a>
    </div>
  </nav>

  <!-- Dashboard content -->
  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">Paper Trading Dashboard</h1>
      <p class="text-white/40 text-sm">
        Real-time paper trading metrics for SPA strategies. Data updated daily via automated cycle runner.
      </p>
    </div>

    <!-- ═══════════════════════════════════════════════════════
         SYSTEM GATE STATUS  (MP-1305)
         Data: /api/backtest/gate → fallback static build data
         ═══════════════════════════════════════════════════════ -->
    <section class="mb-8" aria-label="System Gate Status">
      <div class="rounded-xl border border-white/10 bg-white/3 overflow-hidden">
        <div class="px-5 pt-5 pb-3 flex items-center justify-between border-b border-white/5">
          <div>
            <h2 class="text-sm font-semibold text-white uppercase tracking-wider">System Gate Status</h2>
            <p class="text-[11px] text-white/30 mt-0.5">CPA 4-phase gate — required before live capital deployment</p>
          </div>
          <!-- Live API indicator, updated by client script -->
          <span id="gate-source-badge" class="text-[10px] font-mono text-white/20">static</span>
        </div>

        <div id="gate-panel" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 divide-y sm:divide-y-0 sm:divide-x divide-white/5">

          <!-- State 1: Backtest -->
          <div id="gate-backtest" class="gate-state px-5 py-4" data-status="PASS">
            <div class="flex items-start gap-3">
              <span class="gate-icon text-xl mt-0.5">✅</span>
              <div class="min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="text-sm font-medium text-white">{GATE_STATIC.backtest.label}</span>
                  <span class="gate-badge text-[10px] font-mono px-1.5 py-0.5 rounded border border-emerald-500/30 bg-emerald-500/10 text-emerald-400">PASS</span>
                </div>
                <p class="gate-detail text-[11px] text-white/35 mt-1 leading-relaxed">{GATE_STATIC.backtest.detail}</p>
              </div>
            </div>
          </div>

          <!-- State 2: Pre-Paper Gate -->
          <div id="gate-pre-paper" class="gate-state px-5 py-4" data-status="PASS">
            <div class="flex items-start gap-3">
              <span class="gate-icon text-xl mt-0.5">✅</span>
              <div class="min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="text-sm font-medium text-white">{GATE_STATIC.pre_paper.label}</span>
                  <span class="gate-badge text-[10px] font-mono px-1.5 py-0.5 rounded border border-emerald-500/30 bg-emerald-500/10 text-emerald-400">PASS</span>
                </div>
                <p class="gate-detail text-[11px] text-white/35 mt-1 leading-relaxed">{GATE_STATIC.pre_paper.detail}</p>
              </div>
            </div>
          </div>

          <!-- State 3: Paper Trading -->
          <div id="gate-paper" class="gate-state px-5 py-4" data-status="NOT_READY">
            <div class="flex items-start gap-3">
              <span class="gate-icon text-xl mt-0.5">⏳</span>
              <div class="min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="text-sm font-medium text-white">{GATE_STATIC.paper.label}</span>
                  <span class="gate-badge text-[10px] font-mono px-1.5 py-0.5 rounded border border-amber-500/30 bg-amber-500/10 text-amber-400">NOT READY</span>
                </div>
                <p class="gate-detail text-[11px] text-white/35 mt-1 leading-relaxed">{GATE_STATIC.paper.detail}</p>
              </div>
            </div>
          </div>

          <!-- State 4: Live Capital -->
          <div id="gate-live" class="gate-state px-5 py-4" data-status="BLOCKED">
            <div class="flex items-start gap-3">
              <span class="gate-icon text-xl mt-0.5">🔒</span>
              <div class="min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="text-sm font-medium text-white">{GATE_STATIC.live.label}</span>
                  <span class="gate-badge text-[10px] font-mono px-1.5 py-0.5 rounded border border-red-500/30 bg-red-500/10 text-red-400">BLOCKED</span>
                </div>
                <p class="gate-detail text-[11px] text-white/35 mt-1 leading-relaxed">{GATE_STATIC.live.detail}</p>
              </div>
            </div>
          </div>

        </div>

        <div id="gate-blockers-row" class="hidden border-t border-white/5 px-5 py-3">
          <p class="text-[11px] text-white/30">
            <span class="text-amber-400/70 font-mono">Blockers: </span>
            <span id="gate-blockers-text"></span>
          </p>
        </div>
      </div>
    </section>

    <!-- Main widget (multi-strategy tabs) -->
    <LiveStatsWidget client:load />

    <!-- ═══════════════════════════════════════════════════════
         RESEARCH TAB  (MP-1363 v9.79 — RS-001/RS-002)
         CPA gate status · paper progress · strategy cards · timeline
         ═══════════════════════════════════════════════════════ -->
    <section class="mt-10" aria-label="Research Strategies Tab">

      <!-- Tab nav bar -->
      <div class="flex gap-1 border-b border-white/10 mb-6">
        <button
          id="tab-btn-research"
          class="px-4 py-2 text-sm font-medium font-mono text-white bg-white/8 border border-white/10 border-b-transparent rounded-t -mb-px focus:outline-none"
          aria-selected="true"
        >Research</button>
      </div>

      <!-- Tab content: Research -->
      <div class="tab-content" id="tab-research">

        <!-- ── 1. CPA METHODOLOGY STATUS ─────────────────────────────── -->
        <div class="rounded-xl border border-white/10 bg-white/3 overflow-hidden mb-6">
          <div class="px-5 pt-5 pb-3 border-b border-white/5 flex items-start justify-between gap-4">
            <div>
              <h3 class="text-sm font-semibold text-white uppercase tracking-wider">CPA Methodology Status</h3>
              <p class="text-[11px] text-white/30 mt-0.5">4-phase capital protection architecture — strict evidence mode, no proxies</p>
            </div>
            <span class="shrink-0 text-[10px] font-mono px-2 py-0.5 rounded border border-amber-500/30 bg-amber-500/8 text-amber-400/70">Phase 3 of 4</span>
          </div>

          <!-- Phase grid -->
          <div class="grid grid-cols-2 sm:grid-cols-4 divide-y sm:divide-y-0 sm:divide-x divide-white/5">

            <!-- Phase 1: Backtest ✅ -->
            <div class="px-5 py-4">
              <div class="flex items-start gap-2">
                <span class="text-lg mt-0.5 shrink-0">✅</span>
                <div class="min-w-0">
                  <div class="text-xs font-semibold text-white mb-1">Phase 1 · Backtest</div>
                  <span class="text-[10px] font-mono px-1.5 py-0.5 rounded border border-emerald-500/30 bg-emerald-500/10 text-emerald-400">PASS</span>
                  <ul class="mt-2 space-y-1">
                    <li class="text-[10px] text-white/30 leading-snug">P0 — data integrity verified</li>
                    <li class="text-[10px] text-white/30 leading-snug">P1A — strict evidence only</li>
                    <li class="text-[10px] text-white/30 leading-snug">P2 — 2022–2026 window, 4yr</li>
                    <li class="text-[10px] text-white/30 leading-snug">P3 — crisis scenarios stress-tested</li>
                  </ul>
                </div>
              </div>
            </div>

            <!-- Phase 2: Pre-Paper ✅ -->
            <div class="px-5 py-4">
              <div class="flex items-start gap-2">
                <span class="text-lg mt-0.5 shrink-0">✅</span>
                <div class="min-w-0">
                  <div class="text-xs font-semibold text-white mb-1">Phase 2 · Pre-Paper</div>
                  <span class="text-[10px] font-mono px-1.5 py-0.5 rounded border border-emerald-500/30 bg-emerald-500/10 text-emerald-400">PASS</span>
                  <ul class="mt-2 space-y-1">
                    <li class="text-[10px] text-white/30 leading-snug">All strict blockers cleared</li>
                    <li class="text-[10px] text-white/30 leading-snug">RiskPolicy v1.0 snapshot locked</li>
                    <li class="text-[10px] text-white/30 leading-snug">ADR-002/019/020/021 confirmed</li>
                    <li class="text-[10px] text-white/30 leading-snug">Adapter audit complete (T1/T2)</li>
                  </ul>
                </div>
              </div>
            </div>

            <!-- Phase 3: Paper ⏳ -->
            <div class="px-5 py-4 bg-amber-500/3">
              <div class="flex items-start gap-2">
                <span class="text-lg mt-0.5 shrink-0">⏳</span>
                <div class="min-w-0">
                  <div class="text-xs font-semibold text-white mb-1">Phase 3 · Paper</div>
                  <span class="text-[10px] font-mono px-1.5 py-0.5 rounded border border-amber-500/30 bg-amber-500/10 text-amber-400">IN PROGRESS</span>
                  <ul class="mt-2 space-y-1">
                    <li class="text-[10px] text-white/30 leading-snug">30-day track required</li>
                    <li class="text-[10px] text-white/30 leading-snug">Evidence: <span class="text-amber-400/70">0/30 pts</span></li>
                    <li class="text-[10px] text-white/30 leading-snug">gap_monitor: no breaks allowed</li>
                    <li class="text-[10px] text-white/30 leading-snug">Owner acceptance pending</li>
                  </ul>
                </div>
              </div>
            </div>

            <!-- Phase 4: Live 🔒 -->
            <div class="px-5 py-4">
              <div class="flex items-start gap-2">
                <span class="text-lg mt-0.5 shrink-0">🔒</span>
                <div class="min-w-0">
                  <div class="text-xs font-semibold text-white mb-1">Phase 4 · Live</div>
                  <span class="text-[10px] font-mono px-1.5 py-0.5 rounded border border-red-500/30 bg-red-500/10 text-red-400">BLOCKED</span>
                  <ul class="mt-2 space-y-1">
                    <li class="text-[10px] text-white/30 leading-snug">READY 7+ days streak</li>
                    <li class="text-[10px] text-white/30 leading-snug">gap_monitor 30d no breaks</li>
                    <li class="text-[10px] text-white/30 leading-snug">ADR-002 manual review</li>
                    <li class="text-[10px] text-white/30 leading-snug">ETA: <span class="text-red-400/60">~2026-08-01</span></li>
                  </ul>
                </div>
              </div>
            </div>

          </div>

          <!-- Methodology note -->
          <div class="px-5 py-3 border-t border-white/5 bg-white/1">
            <p class="text-[11px] text-white/25 leading-relaxed">
              CPA (Capital Protection Architecture) enforces strict evidence requirements at each phase. No proxies, no synthetic data.
              Phase gate is one-way: downgrade not possible without full re-audit. LLM calls forbidden in risk/execution/monitoring domains.
            </p>
          </div>
        </div>

        <!-- ── 2. PAPER TRADING EVIDENCE PROGRESS ────────────────────── -->
        <div class="rounded-xl border border-white/10 bg-white/3 overflow-hidden mb-6">
          <div class="px-5 pt-5 pb-3 border-b border-white/5 flex items-center justify-between gap-4">
            <div>
              <h3 class="text-sm font-semibold text-white uppercase tracking-wider">Paper Trading Evidence Progress</h3>
              <p class="text-[11px] text-white/30 mt-0.5">30 pts required to unlock Phase 4 (Live) — evidence accumulates daily</p>
            </div>
            <span class="shrink-0 font-mono text-lg text-amber-400 font-bold">0<span class="text-white/20 text-sm">/30</span></span>
          </div>

          <!-- Main progress bar — 7 seed days / 30 target = 23% -->
          <div class="px-5 py-4 border-b border-white/5">
            <div class="flex items-center gap-4 mb-2">
              <div class="flex-1 h-3 rounded-full bg-white/8 overflow-hidden">
                <div class="h-full rounded-full bg-amber-500/60 transition-all" style="width:23%"></div>
              </div>
              <span class="shrink-0 text-xs font-mono text-amber-400">23%</span>
            </div>
            <div class="flex items-center gap-6 flex-wrap">
              <div class="flex items-center gap-2">
                <span class="text-[10px] text-white/25 uppercase tracking-wider">ETA</span>
                <span class="text-xs font-mono text-white/60">~July 18, 2026</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-[10px] text-white/25 uppercase tracking-wider">Seed days</span>
                <span class="text-xs font-mono text-amber-400">7 / 30</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-[10px] text-white/25 uppercase tracking-wider">Status</span>
                <span class="text-[10px] font-mono px-1.5 py-0.5 rounded border border-amber-500/30 bg-amber-500/8 text-amber-400">IN PROGRESS</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-[10px] text-white/25 uppercase tracking-wider">Need</span>
                <span class="text-xs font-mono text-white/50">23 more real days</span>
              </div>
            </div>
          </div>

          <!-- Category breakdown with live data -->
          <div class="divide-y divide-white/5">

            <div class="px-5 py-3 flex items-center gap-4">
              <div class="w-32 shrink-0">
                <div class="text-[10px] font-mono text-white/40">Daily Cycles</div>
                <div class="text-[10px] text-white/20">6.5 effective / 15</div>
              </div>
              <div class="flex-1 h-1.5 rounded-full bg-white/8 overflow-hidden">
                <div class="h-full rounded-full bg-amber-500/50" style="width:43%"></div>
              </div>
              <span class="shrink-0 text-[10px] font-mono text-amber-400/80 w-16 text-right">10 / 15 pts</span>
            </div>

            <div class="px-5 py-3 flex items-center gap-4">
              <div class="w-32 shrink-0">
                <div class="text-[10px] font-mono text-white/40">APY Track</div>
                <div class="text-[10px] text-white/20">equity_curve_daily</div>
              </div>
              <div class="flex-1 h-1.5 rounded-full bg-white/8 overflow-hidden">
                <div class="h-full rounded-full bg-white/20" style="width:0%"></div>
              </div>
              <span class="shrink-0 text-[10px] font-mono text-white/35 w-16 text-right">0 / 8 pts</span>
            </div>

            <div class="px-5 py-3 flex items-center gap-4">
              <div class="w-32 shrink-0">
                <div class="text-[10px] font-mono text-white/40">Risk Policy</div>
                <div class="text-[10px] text-white/20">risk_policy_blocks</div>
              </div>
              <div class="flex-1 h-1.5 rounded-full bg-white/8 overflow-hidden">
                <div class="h-full rounded-full bg-white/20" style="width:0%"></div>
              </div>
              <span class="shrink-0 text-[10px] font-mono text-white/35 w-16 text-right">0 / 7 pts</span>
            </div>

          </div>

          <!-- ── PAPER TRADING EVIDENCE TRACKER (MP-1465) ─────────────── -->
          <div class="border-t border-white/8 bg-white/1">
            <!-- Streak badges -->
            <div class="px-5 pt-4 pb-2 flex items-center gap-3 flex-wrap">
              <span class="text-[10px] font-mono px-2 py-1 rounded-full border border-emerald-500/40 bg-emerald-500/8 text-emerald-400">
                ✅ APY verified 6 days streak
              </span>
              <span class="text-[10px] font-mono px-2 py-1 rounded-full border border-amber-500/30 bg-amber-500/6 text-amber-400/80">
                🌱 7 seed days logged
              </span>
              <span class="text-[10px] text-white/25 ml-auto">Need 23 more real days (target: ~2026-07-18)</span>
            </div>

            <!-- Last 7 days table -->
            <div class="px-5 pb-4 overflow-x-auto">
              <table class="w-full text-[10px] font-mono">
                <thead>
                  <tr class="text-white/20 border-b border-white/5">
                    <th class="py-1.5 text-left font-normal">Date</th>
                    <th class="py-1.5 text-center font-normal">Cycle</th>
                    <th class="py-1.5 text-center font-normal">APY ✓</th>
                    <th class="py-1.5 text-center font-normal">Risk ✓</th>
                    <th class="py-1.5 text-right font-normal">Pts (×0.5)</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-white/4">
                  <tr><td class="py-1.5 text-white/30">2026-06-14</td><td class="py-1.5 text-center text-emerald-400">✓</td><td class="py-1.5 text-center text-emerald-400">✓</td><td class="py-1.5 text-center text-emerald-400">✓</td><td class="py-1.5 text-right text-amber-400/70">+0.5</td></tr>
                  <tr><td class="py-1.5 text-white/30">2026-06-15</td><td class="py-1.5 text-center text-emerald-400">✓</td><td class="py-1.5 text-center text-emerald-400">✓</td><td class="py-1.5 text-center text-emerald-400">✓</td><td class="py-1.5 text-right text-amber-400/70">+0.5</td></tr>
                  <tr><td class="py-1.5 text-white/30">2026-06-16</td><td class="py-1.5 text-center text-emerald-400">✓</td><td class="py-1.5 text-center text-emerald-400">✓</td><td class="py-1.5 text-center text-emerald-400">✓</td><td class="py-1.5 text-right text-amber-400/70">+0.5</td></tr>
                  <tr><td class="py-1.5 text-white/30">2026-06-17</td><td class="py-1.5 text-center text-emerald-400">✓</td><td class="py-1.5 text-center text-emerald-400">✓</td><td class="py-1.5 text-center text-emerald-400">✓</td><td class="py-1.5 text-right text-amber-400/70">+0.5</td></tr>
                  <tr><td class="py-1.5 text-white/30">2026-06-18</td><td class="py-1.5 text-center text-emerald-400">✓</td><td class="py-1.5 text-center text-emerald-400">✓</td><td class="py-1.5 text-center text-emerald-400">✓</td><td class="py-1.5 text-right text-amber-400/70">+0.5</td></tr>
                  <tr><td class="py-1.5 text-white/30">2026-06-19</td><td class="py-1.5 text-center text-emerald-400">✓</td><td class="py-1.5 text-center text-amber-400/50">–</td><td class="py-1.5 text-center text-emerald-400">✓</td><td class="py-1.5 text-right text-amber-400/70">+0.5</td></tr>
                  <tr><td class="py-1.5 text-white/60 font-semibold">2026-06-20</td><td class="py-1.5 text-center text-emerald-400">✓</td><td class="py-1.5 text-center text-emerald-400">✓</td><td class="py-1.5 text-center text-emerald-400">✓</td><td class="py-1.5 text-right text-amber-400/70">+0.5</td></tr>
                  <tr class="border-t border-white/10 text-white/40">
                    <td class="pt-2 pb-1" colspan="4">Total seed contribution</td>
                    <td class="pt-2 pb-1 text-right text-amber-400 font-semibold">3.5 pts</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
          <!-- /PAPER TRADING EVIDENCE TRACKER -->

          <div class="px-5 py-3 border-t border-white/5 bg-white/1">
            <p class="text-[11px] text-white/20 leading-relaxed">
              Seed days (×0.5 weight) bootstrap evidence scoring while real cycles accumulate. 3 real cycles logged · 7 seed cycles · 6.5 effective total · <span class="text-amber-400/60">GoLive target: 2026-08-01</span>
            </p>
          </div>
        </div>

        <!-- ── 3. SOURCE QUALITY MATRIX ──────────────────────────────── -->
        <div class="rounded-xl border border-white/10 bg-white/3 overflow-hidden mb-6">
          <div class="px-5 pt-5 pb-3 border-b border-white/5">
            <h3 class="text-sm font-semibold text-white uppercase tracking-wider">Source Quality Matrix</h3>
            <p class="text-[11px] text-white/30 mt-0.5">Evidence coverage across research universe — clean = strict criteria, no proxies</p>
          </div>

          <div class="overflow-x-auto">
            <table class="w-full text-[11px]">
              <thead>
                <tr class="border-b border-white/5">
                  <th class="px-5 py-2.5 text-left text-[10px] font-mono text-white/25 uppercase tracking-wider font-normal">Source</th>
                  <th class="px-3 py-2.5 text-left text-[10px] font-mono text-white/25 uppercase tracking-wider font-normal">Tier</th>
                  <th class="px-3 py-2.5 text-left text-[10px] font-mono text-white/25 uppercase tracking-wider font-normal">Status</th>
                  <th class="px-3 py-2.5 text-left text-[10px] font-mono text-white/25 uppercase tracking-wider font-normal">Strategy</th>
                  <th class="px-5 py-2.5 text-right text-[10px] font-mono text-white/25 uppercase tracking-wider font-normal">Evidence Pts</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-white/5">
                <!-- CLEAN sources -->
                {[
                  { src: 'aave_v2_usdc',      tier: 'T1', strategy: 'Core',    pts: 2 },
                  { src: 'compound_v2_usdc',   tier: 'T1', strategy: 'Core',    pts: 2 },
                  { src: 'aave_v3_usdc',       tier: 'T1', strategy: 'Core',    pts: 2 },
                  { src: 'compound_v3_usdc',   tier: 'T1', strategy: 'Core',    pts: 2 },
                  { src: 'aave_v3_base',       tier: 'T1', strategy: 'Core',    pts: 2 },
                  { src: 'morpho_blue',        tier: 'T2', strategy: 'Core',    pts: 2 },
