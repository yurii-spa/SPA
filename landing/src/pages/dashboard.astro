---
// /dashboard — the SINGLE canonical COMMAND CENTER for earn-defi.com.
//
// This is a FIRST-CLASS page of the unified site: it renders inside <Layout>
// (canonical SiteHeader + PaperStrip + SiteFooter + Console design tokens), so it
// looks like /track-record and /research — one site, not a separate app. The old
// 756KB self-contained public/app.html blob is retired; this replaces it.
//
// The live surface is the <DashboardLive /> React island (client:load): a tabbed
// hub with six sections — Overview, Parallel strategies (Strategy Lab sleeves),
// Tournament, Research desks (BTC/ETH/RWA), System, and How-to-use. Each section
// polls its OWN endpoint(s) on api.earn-defi.com every ~15s and shows an honest
// per-section LIVE / "offline" state; a dead endpoint degrades to "—" for that
// section only and never breaks the others. No fabricated numbers offline.
// Bilingual (EN|RU) via the same data-ru / spa_lang mechanism the rest of the
// site uses. The dashboard is the navigable HUB — it deep-links to /rates-desk,
// /structural-desk, /rwa-backstop, /tournament, /strategies, /system, /research.
import Layout from '../layouts/Layout.astro';
import Disclaimer from '../components/Disclaimer.astro';
import DashboardLive from '../components/DashboardLive.jsx';
import snap from '../data/track_snapshot.json';
// P1-6: seed the island headline (equity/APY/days) from the build-time snapshot so no-JS/crawlers see
// real numbers; the live poll overrides them. _snapshot marks it non-live (phase stays 'connecting').
const initialFacts = {
  current_equity: snap.nav_usd ?? snap.end_equity ?? null,
  apy_today_pct: snap.paper_apy_pct ?? null,
  real_track_days: snap.real_track_days ?? null,
  evidenced_anchor: snap.evidenced_anchor ?? null,
  go_live_target: snap.go_live_target ?? null,
  golive_passed: snap.gates_passed ?? null,
  golive_total: snap.gates_total ?? null,
  _snapshot: true,
};
---

<Layout
  title="Command Center — Live Dashboard | earn-defi.com"
  description="The SPA command center: paper track + go-live, the parallel Strategy-Lab sleeves, the strategy tournament, and the BTC/ETH/RWA research desks — all live from api.earn-defi.com in one navigable hub. Paper / research, not investment advice."
  canonical="https://earn-defi.com/dashboard"
>
  <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Page title block (mirrors the doc/marketing template header) -->
    <section class="pt-16 pb-8">
      <p class="text-xs font-mono uppercase tracking-[0.12em] text-text-faint mb-4" data-ru="Командный центр">Command center</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4 leading-tight" data-ru="Всё в одном живом хабе">
        Everything, in one live hub
      </h1>
      <p class="text-lg text-white/50 leading-relaxed max-w-2xl" data-ru="Единая desk-консоль. Вкладки: Обзор (equity / трек / go-live / готовность к 30 дням), Edge (оптимизатор A/B + захваченная книга + атрибуция sleeve’ов + турнир), Отказы и доказательства (tamper-evident лог + 7 proof-поверхностей + red-team вердикт), Риск (двухуровневая лестница kill-switch + scorecard cutover), Исследования и Система. Всё вживую из api.earn-defi.com, обновление каждые ~15с, честный live / офлайн по каждой панели. Всё бумажное и исследовательское, не инвестиционный совет.">
        One unified desk console. Tabs: Overview (equity / track / go-live / day-30 readiness),
        The Edge (optimizer A/B + captured book + sleeve attribution + tournament), Refusals &amp; proof
        (the tamper-evident log + the 7 proof surfaces + our red-team verdict), Risk (the two-tier
        kill-switch ladder + the cutover scorecard), plus Research desks and System — all live from
        <span class="font-mono text-white/70">api.earn-defi.com</span>. Each panel refreshes
        every ~15s and honestly flags live / offline. All paper / research, not investment advice.
      </p>
    </section>

    <!-- Cross-section lateral links — connect verifying (here) → doing (/board) → learning
         (/academy) so the site reads as ONE product, not stitched surfaces. -->
    <nav class="pb-8 flex flex-wrap gap-3" aria-label="Related product surfaces">
      <a href="/board" class="dash-lateral">
        <span class="dash-lateral-t" data-ru="Скринер пулов →">Screen pools →</span>
        <span class="dash-lateral-d" data-ru="Риск-борд DFB: класс A/B/C/D, ликвидность на выход, вердикт отказа">DFB risk board — A/B/C/D class, exit-liquidity, refuse verdict</span>
      </a>
      <a href="/academy" class="dash-lateral">
        <span class="dash-lateral-t" data-ru="Изучить метод →">Learn the method →</span>
        <span class="dash-lateral-d" data-ru="Академия: от нуля до refusal-first андеррайтинга">Academy — from zero to refusal-first underwriting</span>
      </a>
    </nav>

    <!-- The real-time island. client:load so it mounts + starts polling immediately. -->
    <section class="pb-16">
      <DashboardLive client:load initialFacts={initialFacts} />
    </section>

  </main>

  <Disclaimer />
</Layout>

<style>
  .dash-lateral {
    display: flex; flex-direction: column; gap: 4px; flex: 1 1 280px;
    background: var(--bg-surface); border: 1px solid var(--border);
    border-radius: var(--r-lg); padding: 14px 16px; text-decoration: none;
    transition: border-color 120ms var(--ease);
  }
  .dash-lateral:hover { border-color: var(--border-strong); }
  .dash-lateral-t { font-size: 14px; font-weight: 600; color: var(--text-primary); }
  .dash-lateral-d { font-size: 12px; color: var(--text-muted); line-height: 1.4; }
</style>
