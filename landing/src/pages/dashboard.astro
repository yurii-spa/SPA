---
// /dashboard — the SINGLE canonical COMMAND CENTER for earn-defi.com.
//
// PROMOTED (own-19, owner-approved 2026-07-15): adopts the DeBank/Zapper-style SPA shell that
// was validated on /dashboard-preview. The chrome is <DashboardSPAApp> — a single React root that
// owns its sidebar (Overview / Positions / Monitoring / Research, hash-routed, no page reload),
// a sticky topbar, a live Fleet card, and ONE shared live-data poll (/api/ssot/facts +
// /api/live/fleet) feeding the KPI strip independently of the active view. It mounts the
// <DashboardLive> island UNCHANGED for the Overview view (same client:load + initialFacts as
// before). app={true} suppresses the marketing SiteHeader / PaperStrip / SiteFooter so the app
// provides its own compact chrome — but the legal <Disclaimer/> is kept explicitly (honesty
// invariant #8: the canonical indexed page must carry the not-investment-advice notice).
//
// Numbers stay honest: the KPI strip reads the committed snapshot dynamically and the live poll
// overrides on hydration; a dead endpoint degrades to "—" per surface, never a fabricated number.
// Bilingual (EN|RU) via the same data-ru / spa_lang mechanism.
import Layout from '../layouts/Layout.astro';
import Disclaimer from '../components/Disclaimer.astro';
import DashboardSPAApp from '../components/DashboardSPAApp.jsx';
import snap from '../data/track_snapshot.json';

// Build-time snapshot seed — the live poll overrides immediately on hydration. Shape matches what
// DashboardSPAApp consumes for its KPI strip (and passes down to the DashboardLive island).
const initialFacts = {
  nav_usd:          snap.nav_usd ?? snap.end_equity ?? null,
  paper_apy_pct:    snap.paper_apy_pct ?? null,
  track_days:       snap.real_track_days ?? null,
  golive_passed:    snap.gates_passed ?? null,
  golive_total:     snap.gates_total ?? null,
  evidenced_anchor: snap.evidenced_anchor ?? null,
  go_live_target:   snap.go_live_target ?? null,
  _snapshot: true,
};
---

<Layout
  title="Command Center — Live Dashboard | earn-defi.com"
  description="The SPA command center: paper track + go-live, the parallel Strategy-Lab sleeves, the strategy tournament, and the BTC/ETH/RWA research desks — all live from api.earn-defi.com in one navigable hub. Paper / research, not investment advice."
  canonical="https://earn-defi.com/dashboard"
  app={true}
>
  <!-- SPA island: one React root manages sidebar + topbar + hash-routing + shared KPI/Fleet poll. -->
  <DashboardSPAApp client:load initialFacts={initialFacts} />

  <!-- Legal notice kept on the canonical page even in app-shell mode (honesty invariant #8). -->
  <Disclaimer />
</Layout>
