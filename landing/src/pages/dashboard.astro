---
// /dashboard — the SINGLE canonical dashboard for earn-defi.com.
//
// This is now a FIRST-CLASS page of the unified site: it renders inside <Layout>
// (canonical SiteHeader + PaperStrip + SiteFooter + Console design tokens), so it
// looks like /track-record and /research — one site, not a separate app. The old
// 756KB self-contained public/app.html blob is retired; this replaces it.
//
// The live, real-time surface is the <DashboardLive /> React island (client:load),
// which polls api.earn-defi.com every ~15s (SSOT facts + fleet + status + golive)
// and renders an honest LIVE / "snapshot — live API offline" state. No fabricated
// numbers offline. Bilingual (EN|RU) via the same data-ru / spa_lang mechanism the
// rest of the site uses.
import Layout from '../layouts/Layout.astro';
import Disclaimer from '../components/Disclaimer.astro';
import DashboardLive from '../components/DashboardLive.jsx';
---

<Layout
  title="Live Dashboard — Paper Track in Real Time | earn-defi.com"
  description="The live SPA dashboard: evidenced track days, go-live criteria, paper portfolio, agent fleet and safety state — updating in real time from api.earn-defi.com. Paper / research, not investment advice."
  canonical="https://earn-defi.com/dashboard"
>
  <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Page title block (mirrors the doc/marketing template header) -->
    <section class="pt-16 pb-8">
      <p class="text-xs font-mono uppercase tracking-[0.12em] text-text-faint mb-4" data-ru="Живой дашборд">Live dashboard</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4 leading-tight" data-ru="Бумажный трек в реальном времени">
        The paper track, in real time
      </h1>
      <p class="text-lg text-white/50 leading-relaxed max-w-2xl" data-ru="Каждая метрика обновляется вживую из api.earn-defi.com — подтверждённые дни трека, критерии go-live, бумажный портфель, парк агентов и состояние защиты. Всё бумажное и исследовательское, не инвестиционный совет.">
        Every metric updates live from <span class="font-mono text-white/70">api.earn-defi.com</span> —
        evidenced track days, go-live criteria, the paper portfolio, the agent fleet, and the
        safety state. All paper / research, not investment advice.
      </p>
    </section>

    <!-- The real-time island. client:load so it mounts + starts polling immediately. -->
    <section class="pb-16">
      <DashboardLive client:load />
    </section>

  </main>

  <Disclaimer />
</Layout>
