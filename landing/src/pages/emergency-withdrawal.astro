---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="No User Funds — SPA earn-defi.com"
  description="SPA is a personal paper-trading research project. No external funds are managed and there is no withdrawal process."
  canonical="https://earn-defi.com/emergency-withdrawal"
>

  <!-- Nav -->
  <nav class="flex items-center justify-between px-4 sm:px-6 lg:px-8 py-5 border-b border-white/5">
    <a href="/" class="flex items-center gap-2 text-white/60 hover:text-white transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/>
      </svg>
      <span class="text-sm">Back to earn-defi.com</span>
    </a>
    <span class="text-xs text-white/20 font-mono">emergency-withdrawal</span>
  </nav>

  <!-- Paper-only banner -->
  <div class="bg-amber-500/10 border-b border-amber-500/20 px-4 py-3 text-center">
    <p class="text-amber-400 text-sm font-medium">
      ⚠ Paper Trading Only — No user funds — paper simulation only.
    </p>
  </div>

  <main class="max-w-3xl mx-auto px-4 sm:px-6 py-16">

    <!-- Header -->
    <div class="mb-12">
      <p class="text-xs text-white/40 font-mono uppercase tracking-widest mb-3">No User Funds</p>
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">No User Funds — Paper Simulation Only</h1>
      <p class="text-white/50 text-lg leading-relaxed">
        There is no withdrawal process because there are no external funds to withdraw.
      </p>
    </div>

    <!-- Explanation -->
    <section class="mb-14">
      <div class="rounded-xl border border-white/10 bg-white/[0.02] p-6 space-y-4 text-sm text-white/60 leading-relaxed">
        <p>
          SPA is a personal paper-trading research project. It runs on a virtual
          $100,000 USDC portfolio to evaluate DeFi yield strategies. All trades are simulated.
        </p>
        <p>
          No external funds are managed. No deposits are accepted, no capital is held in
          custody, and there is no withdrawal process of any kind.
        </p>
        <p>
          Because no user funds exist, there is nothing to recover or withdraw — in an
          emergency or otherwise. Any source claiming to offer withdrawals, deposits, or
          fund access on behalf of SPA is not legitimate.
        </p>
      </div>
    </section>

    <!-- Back link -->
    <section class="mb-14">
      <a href="/methodology" class="inline-flex items-center gap-2 text-sm text-green-400/80 hover:text-green-400 transition-colors">
        <span>Read the methodology</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
        </svg>
      </a>
    </section>

  </main>

  <Footer />

</Layout>
