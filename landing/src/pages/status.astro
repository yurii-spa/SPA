---
import Layout from '../layouts/Layout.astro';
import snap from '../data/track_snapshot.json';

// Shows current system status: GoLive score, paper trading progress.
// SSR values are the last committed evidenced SNAPSHOT (data/golive_status.json +
// data/equity_curve_daily.json, derived into src/data/track_snapshot.json — NOT
// hand-typed literals that silently drift). The page then fetches LIVE values from
// api.earn-defi.com client-side and overrides the snapshot; if the API is offline,
// the honest snapshot stands and the page says so. The day count is the HONEST
// evidenced count (we reset the track — only cycle-logged days count; earlier days
// were flat-rate backfill). Anchor 2026-06-22. See /track-record.
const goLiveChecks = snap.gates_passed ?? 27;
const goLiveTotal = snap.gates_total ?? 29;
const goLiveReadinessPct = Math.round((goLiveChecks / goLiveTotal) * 100);
const evidenceDays = snap.real_track_days ?? 5;   // evidenced (cycle-logged) days
const evidenceTarget = snap.days_needed ?? 30;    // 30 honest days required (ADR-002)
const goLiveTarget = snap.go_live_target ?? "2026-07-21";
const trackStart = snap.evidenced_anchor ?? "2026-06-22";  // evidence anchor (NOT backfilled 06-10)

// Canonical blockers from data/golive_status.json (2 time-gated: same 30-day track wait).
const blockers = [
  "min_track_days_30 — 5/30 evidenced track days (time-gated, target 2026-07-21)",
  "gap_monitor_30d — 5/30 evidenced track days, continuity (time-gated, target 2026-07-21)"
];
const blockerCount = blockers.length;

type CheckStatus = "pass" | "warn" | "fail";

const checks: { label: string; labelRu: string; status: CheckStatus; detail: string }[] = [
  { label: "GoLive Criteria", labelRu: "Критерии GoLive", status: "warn", detail: `${goLiveChecks}/${goLiveTotal} checks pass — 2 time-gated (30-day track)` },
  { label: "Paper Track Record", labelRu: "Track record бумажной торговли", status: "warn", detail: `${evidenceDays}/${evidenceTarget} evidenced days · anchor ${trackStart} (target: ${goLiveTarget})` },
  { label: "Daily Cycle (launchd)", labelRu: "Ежедневный цикл (launchd)", status: "pass", detail: "com.spa.daily_cycle running at 08:00 UTC" },
  { label: "HTTP Dashboard", labelRu: "HTTP-дашборд", status: "pass", detail: "com.spa.httpserver on port 8765" },
  { label: "Cloudflare Tunnel", labelRu: "Cloudflare Tunnel", status: "pass", detail: "com.spa.cloudflared active" },
  { label: "Risk Policy Gate", labelRu: "Риск-гейт", status: "pass", detail: "RiskPolicy v1.0 — deterministic, LLM forbidden" },
  { label: "Adapter Health", labelRu: "Здоровье адаптеров", status: "pass", detail: "Aave V3, Compound V3, Morpho Steakhouse — all responding" },
  { label: "Auto-Push (GitHub)", labelRu: "Auto-Push (GitHub)", status: "pass", detail: "com.spa.autopush installed — pushes every 90 min" },
];

const statusColor: Record<CheckStatus, string> = {
  pass: "text-emerald-400",
  warn: "text-amber-400",
  fail: "text-red-400",
};
const statusIcon: Record<CheckStatus, string> = {
  pass: "✅",
  warn: "⚠️",
  fail: "❌",
};
const statusBg: Record<CheckStatus, string> = {
  pass: "border-emerald-500/30 bg-emerald-950/20",
  warn: "border-amber-500/30 bg-amber-950/20",
  fail: "border-red-500/30 bg-red-950/20",
};
---

<Layout
  title="System Status — SPA earn-defi.com"
  description="Live operational status of the SPA autonomous DeFi yield optimizer. GoLive criteria, paper track record progress, infrastructure health. Live from api.earn-defi.com, with an honest snapshot fallback when offline."
>
  <main class="min-h-screen bg-[#0a0a0a] text-white font-sans">

    <!-- Header -->
    <div class="max-w-4xl mx-auto px-6 py-12 space-y-10">

      <!-- Hero status banner -->
      <div class="rounded-2xl border border-amber-500/30 bg-amber-950/20 p-8">
        <div class="flex items-start gap-4">
          <div class="text-3xl mt-1">⚠️</div>
          <div>
            <h1 class="text-2xl font-bold text-amber-300 mb-2" data-ru="В ПРОЦЕССЕ — фаза бумажной торговли">IN PROGRESS — Paper Trading Phase</h1>
            <p class="text-white/60 leading-relaxed">
              <span data-ru="SPA сейчас работает в проверяемом режиме бумажной торговли с виртуальным капиталом $100,000 USDC. Перевод на реальный капитал (go-live) запланирован на">SPA is currently in verified paper trading mode with virtual capital of $100,000 USDC.
              Go-live transfer to real capital is planned for</span> <strong class="text-white">{goLiveTarget}</strong> <span data-ru="после 30 честных дней трека и ручного review Owner.">after 30 honest tracking days and manual Owner review.</span>
            </p>
          </div>
        </div>
      </div>

      <!-- Two main metrics -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">

        <!-- GoLive Readiness -->
        <div class="rounded-xl border border-white/10 bg-white/5 p-6">
          <div class="text-sm text-white/40 uppercase tracking-wider mb-3" data-ru="Готовность к GoLive">GoLive Readiness</div>
          <div class="flex items-end gap-2 mb-3">
            <span class="text-5xl font-bold text-amber-400" id="st-gates-pass">{goLiveChecks}</span>
            <span class="text-2xl text-white/30 mb-1">/ <span id="st-gates-total">{goLiveTotal}</span></span>
          </div>
          <!-- Progress bar -->
          <div class="h-2 bg-white/10 rounded-full overflow-hidden mb-2">
            <div
              id="st-gates-bar"
              class="h-full bg-amber-400 rounded-full transition-all"
              style={`width: ${goLiveReadinessPct}%`}
            ></div>
          </div>
          <p class="text-white/50 text-sm"><span id="st-gates-pct">{goLiveReadinessPct}</span><span data-ru={`% критериев пройдено — осталось ${blockerCount} блокера`}>% criteria pass — {blockerCount} blockers remaining</span></p>
        </div>

        <!-- Paper Track Record -->
        <div class="rounded-xl border border-white/10 bg-white/5 p-6">
          <div class="text-sm text-white/40 uppercase tracking-wider mb-3" data-ru="Честный track record">Honest Track Record</div>
          <div class="flex items-end gap-2 mb-3">
            <span class="text-5xl font-bold text-blue-400" id="st-days">{evidenceDays}</span>
            <span class="text-2xl text-white/30 mb-1">/ {evidenceTarget} <span data-ru="дней">days</span></span>
          </div>
          <!-- Progress bar -->
          <div class="h-2 bg-white/10 rounded-full overflow-hidden mb-2">
            <div
              id="st-days-bar"
              class="h-full bg-blue-400 rounded-full transition-all"
              style={`width: ${Math.round(evidenceDays / evidenceTarget * 100)}%`}
            ></div>
          </div>
          <p class="text-white/50 text-sm"><span data-ru="Реальный трек начат">Real track started</span> {trackStart} <span data-ru="(демо-данные исключены)">(demo data excluded)</span></p>
        </div>

      </div>

      <!-- Blockers -->
      {blockers.length > 0 && (
        <div class="rounded-xl border border-red-500/30 bg-red-950/20 p-6">
          <h2 class="text-red-400 font-semibold text-lg mb-4" data-ru="⛔ Активные блокеры">⛔ Active Blockers</h2>
          <ul class="space-y-2">
            {blockers.map(b => (
              <li class="flex items-start gap-3 text-white/70 text-sm">
                <span class="text-red-400 mt-0.5 shrink-0">•</span>
                <code class="font-mono text-red-300/80 text-xs bg-red-950/40 px-2 py-1 rounded">{b}</code>
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Component status checks -->
      <div>
        <h2 class="text-white font-semibold text-xl mb-4" data-ru="Проверки инфраструктуры">Infrastructure Checks</h2>
        <div class="space-y-3">
          {checks.map(c => (
            <div class={`rounded-xl border px-5 py-4 flex items-start gap-4 ${statusBg[c.status]}`}>
              <span class="text-xl shrink-0 mt-0.5">{statusIcon[c.status]}</span>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="font-medium text-white" data-ru={c.labelRu}>{c.label}</span>
                  <span class={`text-xs font-semibold uppercase ${statusColor[c.status]}`}>
                    {c.status}
                  </span>
                </div>
                <p class="text-white/50 text-sm mt-0.5">{c.detail}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Timeline -->
      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <h2 class="text-white font-semibold text-lg mb-6" data-ru="Таймлайн Go-Live">Go-Live Timeline</h2>
        <div class="relative pl-6">
          <div class="absolute left-0 top-2 bottom-2 w-px bg-white/10"></div>
          <div class="space-y-6">
            <div class="relative">
              <div class="absolute -left-6 top-1 w-3 h-3 rounded-full bg-emerald-400 ring-2 ring-emerald-400/30"></div>
              <div class="text-emerald-400 text-sm font-semibold">2026-06-22</div>
              <div class="text-white/70 text-sm mt-0.5" data-ru="Трек сброшен и заякорен на первом дне с реальным логом цикла. Ранний бэкфилл по фиксированной ставке не засчитывается.">Track reset, anchored to the first day with a real cycle log. Earlier flat-rate backfill is not counted.</div>
            </div>
            <div class="relative">
              <div class="absolute -left-6 top-1 w-3 h-3 rounded-full bg-amber-400 ring-2 ring-amber-400/30"></div>
              <div class="text-amber-400 text-sm font-semibold">2026-07-21 <span data-ru="(ориентировочно)">(estimated)</span></div>
              <div class="text-white/70 text-sm mt-0.5" data-ru="30 подтверждённых дней завершены — критерии GoLive полностью выполнены">30 evidenced days complete — GoLive criteria fully satisfied</div>
            </div>
            <div class="relative">
              <div class="absolute -left-6 top-1 w-3 h-3 rounded-full bg-blue-400 ring-2 ring-blue-400/30"></div>
              <div class="text-blue-400 text-sm font-semibold">~2026-07-21</div>
              <div class="text-white/70 text-sm mt-0.5" data-ru="Ручной review Owner + проверка непрерывности gap_monitor за 30 дней (ADR-002)">Manual Owner review + gap_monitor 30-day continuity check (ADR-002)</div>
            </div>
            <div class="relative">
              <div class="absolute -left-6 top-1 w-3 h-3 rounded-full bg-white/20 ring-2 ring-white/10"></div>
              <div class="text-white/40 text-sm font-semibold">2026-07-21 <span data-ru="(цель)">(target)</span></div>
              <div class="text-white/40 text-sm mt-0.5" data-ru="Go-live: ввод реального капитала после подтверждённого верифицированного трека в 30 дней">Go-live: real capital deployment after confirmed 30-day verified track</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Footer note — honest source label (live-or-snapshot, never a false "updated daily" claim) -->
      <div class="text-center text-white/30 text-sm pb-4">
        <p>
          <span data-ru="Источник:">Source:</span>
          <span id="st-src" class="font-mono text-white/40" data-ru="последний подтверждённый снимок">last evidenced snapshot</span>
          <span class="text-white/25">·</span>
          <span data-ru="Живые значения загружаются из api.earn-defi.com; при офлайне показывается последний подтверждённый снимок.">Live values load from api.earn-defi.com; the last evidenced snapshot is shown when the API is offline.</span>
        </p>
        <p class="mt-1">
          <a href="/due-diligence" class="text-white/50 hover:text-white transition-colors underline underline-offset-2" data-ru="Центр Due Diligence">Due Diligence Center</a>
          &nbsp;·&nbsp;
          <a href="/risk-disclosure" class="text-white/50 hover:text-white transition-colors underline underline-offset-2" data-ru="Раскрытие рисков">Risk Disclosure</a>
          &nbsp;·&nbsp;
          <a href="/" class="text-white/50 hover:text-white transition-colors underline underline-offset-2" data-ru="Главная">Home</a>
        </p>
      </div>

    </div>
  </main>

  <script is:inline>
    /* Live status — api.earn-defi.com (localhost fallback), graceful offline.
     * On success the SSR snapshot numbers are overridden with live values and the
     * source label flips to "live". On failure the honest snapshot stands and the
     * label keeps saying "last evidenced snapshot" — never a false "updated daily" claim. */
    (function(){
      var API = (location.hostname === 'localhost' || location.hostname === '127.0.0.1')
        ? 'http://localhost:8765'
        : 'https://api.earn-defi.com';
      var DAYS_NEEDED = 30;
      function setText(id, txt){ var el = document.getElementById(id); if(el){ el.textContent = txt; } }
      function setWidth(id, pct){ var el = document.getElementById(id); if(el){ el.style.width = Math.max(0, Math.min(100, pct)) + '%'; } }
      function isRu(){ try{ return (localStorage.getItem('spa_lang') || 'en') === 'ru'; }catch(e){ return false; } }

      function loadGoLive(){
        fetch(API + '/api/v1/golive').then(function(r){ return r.json(); }).then(function(d){
          if(!d) return;
          var days = d.real_track_days != null ? d.real_track_days : null;
          var pass = d.passed != null ? d.passed : d.risk_gates_passed;
          var total = d.total != null ? d.total : d.risk_gates_total;
          if(days != null){
            setText('st-days', days);
            setWidth('st-days-bar', (days / DAYS_NEEDED) * 100);
          }
          if(pass != null){ setText('st-gates-pass', pass); }
          if(total != null){ setText('st-gates-total', total); }
          if(pass != null && total != null){
            var pct = Math.round((pass / total) * 100);
            setText('st-gates-pct', pct);
            setWidth('st-gates-bar', pct);
          }
          // Flip the source label to "live" only once we actually have live data.
          var src = document.getElementById('st-src');
          if(src){
            src.textContent = isRu() ? 'api.earn-defi.com (вживую)' : 'api.earn-defi.com (live)';
            src.removeAttribute('data-ru');
          }
        }).catch(function(){ /* offline → SSR snapshot + honest label stand */ });
      }

      function init(){ loadGoLive(); }
      if(document.readyState === 'loading'){ document.addEventListener('DOMContentLoaded', init); }
      else { init(); }
    })();
  </script>
</Layout>
