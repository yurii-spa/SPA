---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Methodology &amp; Evidence — SPA earn-defi.com"
  description="Methodology and evidence journal for SPA. Current status, live data links, protocol whitelist, audit status, and documentation."
  canonical="https://earn-defi.com/due-diligence"
>

  <!-- Nav -->
  <main class="max-w-3xl mx-auto px-4 sm:px-6 py-16">

    <!-- Header -->
    <div class="mb-12">
      <p class="text-xs text-accent-400 font-mono uppercase tracking-widest mb-3" data-ru="Слой доказательств">Proof Layer</p>
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4" data-ru="Методология и доказательства">Methodology &amp; Evidence</h1>
      <p class="text-white/50 text-lg leading-relaxed" data-ru="Методология и журнал доказательств для SPA.">
        Methodology and evidence journal for SPA.
      </p>
    </div>

    <!-- Current Status -->
    <section class="mb-14">
      <h2 class="text-xl font-semibold text-white mb-6 pb-3 border-b border-border" data-ru="Текущий статус">Current Status</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="rounded-lg border border-border-strong bg-bg-surface p-4 text-center">
          <p class="text-xs text-white/30 font-mono mb-1" data-ru="Режим">Mode</p>
          <p class="text-sm text-amber-400/80 font-medium" data-ru="Paper trading">Paper Trading</p>
        </div>
        <div class="rounded-lg border border-border-strong bg-bg-surface p-4 text-center">
          <p class="text-xs text-white/30 font-mono mb-1" data-ru="Капитал">Capital</p>
          <p class="text-sm text-white/70 font-medium">$100k USDC</p>
        </div>
        <div class="rounded-lg border border-border-strong bg-bg-surface p-4 text-center">
          <p class="text-xs text-white/30 font-mono mb-1" data-ru="Старт">Start</p>
          <p class="text-sm text-white/70 font-medium" data-ru="10 июня 2026">Jun 10, 2026</p>
        </div>
        <div class="rounded-lg border border-border-strong bg-bg-surface p-4 text-center">
          <p class="text-xs text-white/30 font-mono mb-1">Go-Live</p>
          <p class="text-sm text-white/70 font-medium" data-ru="Июль 2026">Jul 2026</p>
        </div>
      </div>
      <div class="mt-4 rounded-lg border border-green-400/20 bg-green-400/5 p-4 flex items-center justify-between">
        <div>
          <p class="text-sm text-white/70">GoLiveChecker</p>
          <p class="text-xs text-white/40" data-ru="Автоматические критерии готовности">Automated readiness criteria</p>
        </div>
        <span class="text-sm font-mono text-green-400" data-ru="27/29 пройдено (НЕ ГОТОВО)">27/29 passing (NOT READY)</span>
      </div>
    </section>

    <!-- Strategy Status -->
    <section class="mb-14">
      <h2 class="text-xl font-semibold text-white mb-6 pb-3 border-b border-border" data-ru="Статус стратегий">Strategy Status</h2>
      <div class="overflow-x-auto rounded-xl border border-border-strong">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border-strong bg-bg-surface">
              <th class="text-left text-white/40 font-mono text-xs p-3" data-ru="Стратегия">Strategy</th>
              <th class="text-left text-white/40 font-mono text-xs p-3" data-ru="Статус">Status</th>
              <th class="text-left text-white/40 font-mono text-xs p-3" data-ru="Paper-трекинг">Paper Tracking</th>
            </tr>
          </thead>
          <tbody class="text-white/55">
            <tr class="border-b border-border">
              <td class="p-3 text-white/70 font-medium">Core</td>
              <td class="p-3"><span class="text-xs font-mono text-green-400/70 bg-green-400/10 px-2 py-0.5 rounded" data-ru="На paper-трекинге">Paper tracked</span></td>
              <td class="p-3 text-white/60" data-ru="С 10 июня 2026">Since Jun 10, 2026</td>
            </tr>
            <tr class="border-b border-border">
              <td class="p-3 text-white/70 font-medium">Preserve</td>
              <td class="p-3"><span class="text-xs font-mono text-white/40 bg-bg-surface-2 px-2 py-0.5 rounded" data-ru="Целевой профиль">Target profile</span></td>
              <td class="p-3 text-white/40" data-ru="Запланировано">Planned</td>
            </tr>
            <tr>
              <td class="p-3 text-white/70 font-medium">Max Yield</td>
              <td class="p-3"><span class="text-xs font-mono text-white/40 bg-bg-surface-2 px-2 py-0.5 rounded" data-ru="Целевой профиль">Target profile</span></td>
              <td class="p-3 text-white/40" data-ru="Запланировано">Planned</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Live Data Links -->
    <section class="mb-14">
      <h2 class="text-xl font-semibold text-white mb-6 pb-3 border-b border-border" data-ru="Ссылки на живые данные">Live Data Links</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a href="/#live-stats" class="rounded-xl border border-border-strong bg-bg-surface p-5 hover:border-green-400/30 transition-colors group">
          <p class="text-sm font-semibold text-white/80 group-hover:text-white mb-1" data-ru="Дашборд">Dashboard</p>
          <p class="text-xs text-white/40" data-ru="Живые paper-метрики: дни трека, APY, Sharpe, просадка">Live paper metrics: Track Days, APY, Sharpe, Drawdown</p>
        </a>
        <a href="/#live-stats" class="rounded-xl border border-border-strong bg-bg-surface p-5 hover:border-green-400/30 transition-colors group">
          <p class="text-sm font-semibold text-white/80 group-hover:text-white mb-1" data-ru="Блокировки риска">Risk Blocks</p>
          <p class="text-xs text-white/40" data-ru="Все заблокированные ребалансировки залогированы и с временными метками">All blocked rebalances logged and timestamped</p>
        </a>
        <a href="/#live-stats" class="rounded-xl border border-border-strong bg-bg-surface p-5 hover:border-green-400/30 transition-colors group">
          <p class="text-sm font-semibold text-white/80 group-hover:text-white mb-1" data-ru="Логи сделок">Trade Logs</p>
          <p class="text-xs text-white/40" data-ru="Каждый цикл залогирован с обоснованием">Every cycle logged with reasoning</p>
        </a>
        <a href="/#live-stats" class="rounded-xl border border-border-strong bg-bg-surface p-5 hover:border-green-400/30 transition-colors group">
          <p class="text-sm font-semibold text-white/80 group-hover:text-white mb-1">GoLiveChecker</p>
          <p class="text-xs text-white/40" data-ru="27/29 критериев пройдено (НЕ ГОТОВО) — готовность в реальном времени">27/29 criteria passing (NOT READY) — real-time readiness</p>
        </a>
      </div>
    </section>

    <!-- Documentation -->
    <section class="mb-14">
      <h2 class="text-xl font-semibold text-white mb-6 pb-3 border-b border-border" data-ru="Документация">Documentation</h2>
      <div class="space-y-3">
        <a href="/trust" class="flex items-center justify-between rounded-lg border border-border-strong bg-bg-surface p-4 hover:border-green-400/30 transition-colors group">
          <div>
            <p class="text-sm text-white/80 group-hover:text-white" data-ru="Архитектура доверия">Trust Architecture</p>
            <p class="text-xs text-white/40" data-ru="Модель контроля, кастоди, 9 ключевых вопросов">Control model, custody, 9 key questions</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="text-white/20 group-hover:text-green-400/60">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
          </svg>
        </a>
        <a href="/risk" class="flex items-center justify-between rounded-lg border border-border-strong bg-bg-surface p-4 hover:border-green-400/30 transition-colors group">
          <div>
            <p class="text-sm text-white/80 group-hover:text-white" data-ru="Риск">Risk</p>
            <p class="text-xs text-white/40" data-ru="Категории, матрица, стресс-сценарии">Categories, matrix, stress scenarios</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="text-white/20 group-hover:text-green-400/60">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
          </svg>
        </a>
        <a href="/risk-disclosure" class="flex items-center justify-between rounded-lg border border-border-strong bg-bg-surface p-4 hover:border-green-400/30 transition-colors group">
          <div>
            <p class="text-sm text-white/80 group-hover:text-white" data-ru="Раскрытие рисков">Risk Disclosure</p>
            <p class="text-xs text-white/40" data-ru="Полное юридическое раскрытие">Full legal disclosure</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="text-white/20 group-hover:text-green-400/60">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
          </svg>
        </a>
        <div class="flex items-center justify-between rounded-lg border border-border bg-bg-surface p-4 opacity-50">
          <div>
            <p class="text-sm text-white/60" data-ru="Базовая безопасность">Security Baseline</p>
            <p class="text-xs text-white/30" data-ru="Скоро">Coming soon</p>
          </div>
          <span class="text-xs text-white/20 font-mono" data-ru="запланировано">planned</span>
        </div>
        <div class="flex items-center justify-between rounded-lg border border-border bg-bg-surface p-4 opacity-50">
          <div>
            <p class="text-sm text-white/60" data-ru="Экстренный вывод">Emergency Withdrawal</p>
            <p class="text-xs text-white/30" data-ru="Скоро">Coming soon</p>
          </div>
          <span class="text-xs text-white/20 font-mono" data-ru="запланировано">planned</span>
        </div>
      </div>
    </section>

    <!-- Protocol Whitelist -->
    <section class="mb-14">
      <h2 class="text-xl font-semibold text-white mb-6 pb-3 border-b border-border" data-ru="Вайтлист протоколов">Protocol Whitelist</h2>
      <div class="overflow-x-auto rounded-xl border border-border-strong">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border-strong bg-bg-surface">
              <th class="text-left text-white/40 font-mono text-xs p-3" data-ru="Протокол">Protocol</th>
              <th class="text-left text-white/40 font-mono text-xs p-3" data-ru="Уровень">Tier</th>
              <th class="text-left text-white/40 font-mono text-xs p-3" data-ru="Сеть">Chain</th>
              <th class="text-left text-white/40 font-mono text-xs p-3">TVL</th>
            </tr>
          </thead>
          <tbody class="text-white/55">
            <tr class="border-b border-border">
              <td class="p-3 text-white/70">Aave V3</td>
              <td class="p-3"><span class="text-xs font-mono text-green-400/70">Tier 1</span></td>
              <td class="p-3">Ethereum</td>
              <td class="p-3">$15B+</td>
            </tr>
            <tr class="border-b border-border">
              <td class="p-3 text-white/70">Compound V3</td>
              <td class="p-3"><span class="text-xs font-mono text-green-400/70">Tier 1</span></td>
              <td class="p-3">Ethereum</td>
              <td class="p-3">$3B+</td>
            </tr>
            <tr class="border-b border-border">
              <td class="p-3 text-white/70">Morpho Blue</td>
              <td class="p-3"><span class="text-xs font-mono text-green-400/70">Tier 1</span></td>
              <td class="p-3">Ethereum</td>
              <td class="p-3">$4B+</td>
            </tr>
            <tr class="border-b border-border">
              <td class="p-3 text-white/70">Spark</td>
              <td class="p-3"><span class="text-xs font-mono text-green-400/70">Tier 1</span></td>
              <td class="p-3">Ethereum</td>
              <td class="p-3">$5B+</td>
            </tr>
            <tr class="border-b border-border">
              <td class="p-3 text-white/70">Sky/sUSDS</td>
              <td class="p-3"><span class="text-xs font-mono text-green-400/70">Tier 1</span> <span class="text-xs text-white/30" data-ru="(условно)">(conditional)</span></td>
              <td class="p-3">Ethereum</td>
              <td class="p-3">$8B+</td>
            </tr>
            <tr class="border-b border-border">
              <td class="p-3 text-white/70">Yearn V3</td>
              <td class="p-3"><span class="text-xs font-mono text-amber-400/70">Tier 2</span></td>
              <td class="p-3">Ethereum</td>
              <td class="p-3">$500M+</td>
            </tr>
            <tr class="border-b border-border">
              <td class="p-3 text-white/70">Euler V2</td>
              <td class="p-3"><span class="text-xs font-mono text-amber-400/70">Tier 2</span></td>
              <td class="p-3">Ethereum</td>
              <td class="p-3">$500M+</td>
            </tr>
            <tr class="border-b border-border">
              <td class="p-3 text-white/70">Aave V3</td>
              <td class="p-3"><span class="text-xs font-mono text-amber-400/70">Tier 2</span></td>
              <td class="p-3">Base</td>
              <td class="p-3">$2B+</td>
            </tr>
            <tr>
              <td class="p-3 text-white/70">Morpho Blue</td>
              <td class="p-3"><span class="text-xs font-mono text-amber-400/70">Tier 2</span></td>
              <td class="p-3">Base</td>
              <td class="p-3">$500M+</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Audit & Review Status -->
    <section class="mb-14">
      <h2 class="text-xl font-semibold text-white mb-6 pb-3 border-b border-border" data-ru="Статус аудита и ревью">Audit &amp; Review Status</h2>
      <div class="space-y-4">
        <div class="flex items-center gap-4 rounded-lg border border-border-strong bg-bg-surface p-4">
          <span class="flex-shrink-0 w-2 h-2 rounded-full bg-white/20"></span>
          <div>
            <p class="text-sm text-white/70" data-ru="Аудиты смарт-контрактов">Smart contract audits</p>
            <p class="text-xs text-white/40" data-ru="Пока неприменимо (этап paper trading, нет live-контрактов)">Not yet applicable (paper trading phase, no live contracts)</p>
          </div>
        </div>
        <div class="flex items-center gap-4 rounded-lg border border-border-strong bg-bg-surface p-4">
          <span class="flex-shrink-0 w-2 h-2 rounded-full bg-green-400/60"></span>
          <div>
            <p class="text-sm text-white/70" data-ru="Ревью кода">Code review</p>
            <p class="text-xs text-white/40" data-ru="Внутреннее ревью завершено">Internal review complete</p>
          </div>
        </div>
        <div class="flex items-center gap-4 rounded-lg border border-border-strong bg-bg-surface p-4">
          <span class="flex-shrink-0 w-2 h-2 rounded-full bg-amber-400/60"></span>
          <div>
            <p class="text-sm text-white/70" data-ru="Внешний аудит">External audit</p>
            <p class="text-xs text-white/40" data-ru="Запланирован перед go-live">Planned before go-live</p>
          </div>
        </div>
        <div class="flex items-center gap-4 rounded-lg border border-border-strong bg-bg-surface p-4">
          <span class="flex-shrink-0 w-2 h-2 rounded-full bg-amber-400/60"></span>
          <div>
            <p class="text-sm text-white/70" data-ru="Bug bounty">Bug bounty</p>
            <p class="text-xs text-white/40" data-ru="Пока не активна — запланирована к go-live">Not yet active &mdash; planned for go-live</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Backtest Methodology -->
    <section id="backtest-methodology" class="mb-14">
      <h2 class="text-xl font-semibold text-white mb-6 pb-3 border-b border-border" data-ru="Методология бэктеста и стандарт доказательств">Backtest Methodology &amp; Evidence Standard</h2>

      <!-- Point-in-Time Standard -->
      <div class="mb-8">
        <h3 class="text-base font-semibold text-white/80 mb-3" data-ru="Стандарт point-in-time бэктеста">Point-in-Time Backtest Standard</h3>
        <p class="text-sm text-white/55 leading-relaxed mb-4" data-ru="Мы проводим бэктесты по методологии Capital Preservation Algorithm (CPA), которая обеспечивает строгую point-in-time целостность данных.">
          We run our backtests using the Capital Preservation Algorithm (CPA) methodology,
          which enforces strict point-in-time data integrity.
        </p>
        <div class="space-y-3">
          <div class="rounded-lg border border-border-strong bg-bg-surface p-4">
            <p class="text-sm font-medium text-white/80 mb-1" data-ru="Без look-ahead bias">No Look-Ahead Bias</p>
            <p class="text-xs text-white/45 leading-relaxed" data-ru="Исторические симуляции используют только протоколы и данные, существовавшие на дату симуляции. Протокол, запущенный в 2023 году, не может появиться в данных бэктеста 2022 года — даже если его данные APY доступны сегодня.">
              Historical simulations only use protocols and data that existed on the simulation date.
              A protocol launched in 2023 cannot appear in 2022 backtest data — even if its APY
              data is available today.
            </p>
          </div>
        </div>
      </div>

      <!-- Four-Stage Gate -->
      <div class="mb-8">
        <h3 class="text-base font-semibold text-white/80 mb-3" data-ru="Четырёхэтапный гейт доказательств">Four-Stage Evidence Gate</h3>
        <p class="text-sm text-white/55 leading-relaxed mb-4" data-ru="Прежде чем будет задействован любой капитал, наши стратегии проходят четыре этапа валидации:">
          Before any capital is deployed, our strategies pass through four validation stages:
        </p>
        <div class="overflow-x-auto rounded-xl border border-border-strong">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-border-strong bg-bg-surface">
                <th class="text-left text-white/40 font-mono text-xs p-3" data-ru="Этап">Stage</th>
                <th class="text-left text-white/40 font-mono text-xs p-3" data-ru="Название">Name</th>
                <th class="text-left text-white/40 font-mono text-xs p-3" data-ru="Описание">Description</th>
                <th class="text-left text-white/40 font-mono text-xs p-3" data-ru="Статус">Status</th>
              </tr>
            </thead>
            <tbody class="text-white/55">
              <tr class="border-b border-border">
                <td class="p-3 font-mono text-white/40 text-xs">1</td>
                <td class="p-3 text-white/70 font-medium" data-ru="Гейт бэктеста">Backtest Gate</td>
                <td class="p-3 text-white/50 text-xs" data-ru="4-летняя историческая симуляция по строгим PIT-правилам">4-year historical simulation under strict PIT rules</td>
                <td class="p-3"><span class="text-xs font-mono text-green-400/80 bg-green-400/10 px-2 py-0.5 rounded" data-ru="✅ ПРОЙДЕНО">✅ PASS</span></td>
              </tr>
              <tr class="border-b border-border">
                <td class="p-3 font-mono text-white/40 text-xs">2</td>
                <td class="p-3 text-white/70 font-medium" data-ru="Гейт перед paper">Pre-Paper Gate</td>
                <td class="p-3 text-white/50 text-xs" data-ru="Усиление кода, обзор расширенного набора протоколов">Code hardening, expanded protocol universe review</td>
                <td class="p-3"><span class="text-xs font-mono text-green-400/80 bg-green-400/10 px-2 py-0.5 rounded" data-ru="✅ ПРОЙДЕНО">✅ PASS</span></td>
              </tr>
              <tr class="border-b border-border">
                <td class="p-3 font-mono text-white/40 text-xs">3</td>
                <td class="p-3 text-white/70 font-medium">Paper Trading</td>
                <td class="p-3 text-white/50 text-xs" data-ru="Живая симуляция на реальных ончейн-данных, без реального капитала">Live simulation with real on-chain data, no real capital</td>
                <td class="p-3"><span class="text-xs font-mono text-amber-400/80 bg-amber-400/10 px-2 py-0.5 rounded" data-ru="⏳ В ПРОЦЕССЕ">⏳ IN PROGRESS</span></td>
              </tr>
              <tr>
                <td class="p-3 font-mono text-white/40 text-xs">4</td>
                <td class="p-3 text-white/70 font-medium" data-ru="Живой капитал">Live Capital</td>
                <td class="p-3 text-white/50 text-xs" data-ru="Требуется авторизация, подписанная владельцем">Owner-signed authorization required</td>
                <td class="p-3"><span class="text-xs font-mono text-white/30 bg-bg-surface-2 px-2 py-0.5 rounded" data-ru="🔒 ЗАБЛОКИРОВАНО">🔒 BLOCKED</span></td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="text-xs text-white/30 mt-3 font-mono" id="dd-paper-day" data-ru="5 подтверждённых дней (якорь 2026-06-22) — цель 30 (ADR-002) · реестр на /track-record">
          5 evidenced days (anchor 2026-06-22) — target 30 (ADR-002) · ledger at /track-record
        </p>
        <script is:inline>
          // HONEST count: only cycle-log-evidenced days count (we reset the track —
          // earlier days were flat-rate backfill). Pull real_track_days live; the
          // static literal above is the last honest snapshot for offline. NEVER derive
          // from 2026-06-10 (that inflates the count with backfill bars).
          (function () {
            var el = document.getElementById("dd-paper-day");
            if (!el) return;
            var API = (location.hostname === 'localhost' || location.hostname === '127.0.0.1')
              ? 'http://localhost:8765' : 'https://api.earn-defi.com';
            fetch(API + '/api/v1/golive').then(function (r) { return r.json(); }).then(function (d) {
              if (!d || d.real_track_days == null) return;
              var n = d.real_track_days;
