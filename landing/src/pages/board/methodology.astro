---
// /board/methodology — DFB · How the DeFi Risk Board grades risk (Lane-3 / WS-3.3).
//
// The public, self-verifying methodology + about page for DFB. The differentiator
// ("DeBank shows yield; DFB shows the risk behind it — provably"), how to read a
// pool row (A/B/C/D, exit-liquidity-by-size, refusal verdict), and the "verify any
// pool" flow (the per-pool verifier + the proof endpoint). Every claim cites the
// real engine; the human-readable companion is docs/DFB_METHODOLOGY.md.
//
// Renders in <Layout> (canonical SiteHeader + PaperStrip + SiteFooter + Console
// design tokens), bilingual EN|RU via the site's data-ru / spa_lang mechanism.
// Advisory / read-only / paper-project — static content, no API dependency, so it
// never goes stale and never fabricates a number.
import Layout from '../../layouts/Layout.astro';
import Disclaimer from '../../components/Disclaimer.astro';

// The verdict vocabulary the engine ACTUALLY emits today (risk_overlay.overlay()).
// WATCH is reserved-not-yet-emitted (see docs/DFB_METHODOLOGY.md §7) — we list only
// what the engine produces, so this page never over-claims a live 3-tier verdict.
const classes = [
  { c: 'A', fg: '#34D399', en: 'alpha', enDesc: 'Desk would enter; structurally clean, harvestable edge over the ~3.4% RWA floor.', ruDesc: 'Стол вошёл бы; структурно чисто, edge выше ~3.4% RWA-флора.', cond: 'approved · net_edge > rwa_floor' },
  { c: 'B', fg: '#79A4F5', en: 'beta-floor', enDesc: 'Desk would enter; ~baseline yield ("own-the-floor", no real edge).', ruDesc: 'Стол вошёл бы; ~базовая доходность (без реального edge).', cond: 'approved · net_edge ≤ rwa_floor' },
  { c: 'C', fg: '#F2B53C', en: 'risk-comp', enDesc: 'Desk refuses — the yield is mostly risk compensation, or unexitable at size.', ruDesc: 'Стол отказывается — доходность это в основном компенсация риска / не выйти на размере.', cond: 'REFUSED · economics / size' },
  { c: 'D', fg: '#F26D6D', en: 'incentive', enDesc: 'Desk REFUSES on structural toxicity — at ANY size (the tail-veto; cannot be sized around).', ruDesc: 'Стол ОТКАЗЫВАЕТ на структурной токсичности — на ЛЮБОМ размере (tail-veto, не обойти размером).', cond: 'REFUSED · structural tail-veto' },
  { c: 'UNKNOWN', fg: '#9aa3b2', en: 'fail-closed', enDesc: 'Data too thin / stale / unresolvable — published as a visible hole, never silently graded safe.', ruDesc: 'Данных слишком мало / устарели — публикуется как видимая «дыра», никогда не помечается safe по-тихому.', cond: 'thin / stale / unknown kind' },
];
---

<Layout
  title="Methodology — How DFB grades risk | earn-defi.com"
  description="How the DeFi Risk Board grades risk, provably: the A/B/C/D taxonomy and exact criteria, the structural-haircut + tail-veto (size-independent toxicity), the conservative exit-liquidity-by-size lower bound, the refusal gate, the NO-FORK guarantee (DFB's verdict == the desk's), and the proof/verify chain. Don't trust us — check us. Paper research, advisory, not live."
  canonical="https://earn-defi.com/board/methodology"
>
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- breadcrumb -->
    <section class="pt-14 pb-2">
      <p class="text-xs font-mono mb-4">
        <a href="/board" style="color:var(--text-muted)" data-ru="← DFB риск-борд">← DFB risk board</a>
      </p>
    </section>

    <!-- ============ a. WHAT DFB IS (the differentiator) ============ -->
    <section class="pb-8">
      <div class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full text-xs font-mono"
           style="background:var(--accent-bg);border:1px solid var(--accent-dim);color:var(--accent-hover)">
        <span class="w-1.5 h-1.5 rounded-full" style="background:var(--accent)" aria-hidden="true"></span>
        <span data-ru="DFB · Методология · advisory · read-only · не live">DFB · Methodology · advisory · read-only · not live</span>
      </div>

      <p class="text-xs font-mono uppercase tracking-[0.12em] mb-3" style="color:var(--text-faint)"
         data-ru="Как DFB оценивает риск — доказуемо">How DFB grades risk — provably</p>
      <h1 class="text-4xl sm:text-5xl font-bold mb-5 leading-tight" style="color:var(--text-primary)"
          data-ru="DeBank показывает доходность. DFB показывает РИСК — и его можно перепроверить.">
        DeBank shows yield. DFB shows the <span style="color:var(--accent)">risk</span> behind it — provably.
      </h1>
      <p class="text-lg leading-relaxed max-w-3xl mb-4" style="color:var(--text-secondary)"
         data-ru="Каждый продукт аналитики DeFi отвечает на «сколько это приносит?». Только Exponential.fi оценивает риск — и непрозрачно (чёрный ящик A–F). Никто не публикует ПО КАЖДОМУ пулу все три: консервативный график ликвидности-на-выход-по-размеру; детерминированный вердикт «отказался бы стол?»; воспроизводимый proof-хэш строки.">
        Every DeFi analytics product answers <em>"what does this earn?"</em>. Only one grades risk —
        and opaquely (a black-box A–F). <strong style="color:var(--text-primary)">Nobody publishes, per
        pool, all three of:</strong> a conservative exit-liquidity-by-size schedule; a deterministic
        would-the-desk-refuse-it verdict; and a reproducible per-row proof hash.
      </p>
      <p class="text-base leading-relaxed max-w-3xl" style="color:var(--text-secondary)"
         data-ru="SPA уже считает все три — для своей собственной книги — в риск-движке rates-desk. DFB — это обобщение того же движка с позиций стола на ЛЮБОЙ отслеживаемый рынок. Путь риска детерминирован, LLM-free и fail-closed (аудируемый, в отличие от «AI risk scoring»).">
        SPA already computes all three — for its own book — in the rates-desk risk engine.
        <strong style="color:var(--text-primary)">DFB is the generalization of that same engine</strong>
        from the desk's positions to any followed market. The risk path is deterministic, LLM-free, and
        fail-closed (auditable — unlike "AI risk scoring").
      </p>
    </section>

    <!-- ============ b. THE HONEST FRAME ============ -->
    <section class="pb-8">
      <div class="rounded-xl p-6" style="background:var(--bg-surface);border:1px solid var(--accent-dim)">
        <p class="text-xs uppercase tracking-wider font-mono mb-3" style="color:var(--accent-hover)"
           data-ru="Честная рамка (заявлено, не спрятано)">The honest frame (stated, not hidden)</p>
        <ul class="space-y-2.5 text-sm leading-relaxed" style="color:var(--text-secondary)">
          <li class="flex gap-2.5"><span class="shrink-0 mt-0.5" style="color:var(--accent)" aria-hidden="true">▸</span>
            <span data-ru="DFB — это ГЛУБИНА + правда о риске на курируемом вайтлисте (~38 рынков сегодня), а НЕ клон DeBank/DefiLlama на 10 000 пулов.">
              DFB is <strong style="color:var(--text-primary)">depth + risk-truth on a curated whitelist</strong>
              (~38 live markets today), <strong style="color:var(--text-primary)">not</strong> a 10,000-pool clone.</span></li>
          <li class="flex gap-2.5"><span class="shrink-0 mt-0.5" style="color:var(--accent)" aria-hidden="true">▸</span>
            <span data-ru="Широта растёт ПОЗАДИ того же риск-оверлея — широта никогда не смягчает оценку.">
              Breadth grows <strong style="color:var(--text-primary)">behind the identical overlay</strong> —
              breadth never relaxes the grade.</span></li>
          <li class="flex gap-2.5"><span class="shrink-0 mt-0.5" style="color:var(--accent)" aria-hidden="true">▸</span>
            <span data-ru="DFB на 100% read-only, advisory, paper-проект: не двигает капитал и не трогает go-live трек.">
              DFB is 100% read-only, advisory, a paper-project: it moves
              <strong style="color:var(--text-primary)">no capital</strong> and never touches the go-live track.</span></li>
        </ul>
      </div>
    </section>

    <!-- ============ c. HOW TO READ A POOL ROW ============ -->
    <section class="py-10 border-t" style="border-color:var(--border)">
      <p class="text-xs uppercase tracking-wider font-mono mb-4" style="color:var(--text-faint)"
         data-ru="Как читать строку пула">How to read a pool row</p>

      <!-- c1. the A/B/C/D taxonomy -->
      <h2 class="text-2xl font-bold mb-2" style="color:var(--text-primary)" data-ru="1 · Класс риска A/B/C/D">1 · The A/B/C/D risk class</h2>
      <p class="text-sm leading-relaxed mb-5 max-w-3xl" style="color:var(--text-secondary)"
         data-ru="Класс — НЕ выдуманная DFB оценка. Это детерминированная карта-представление собственного вердикта движка (одобрение / причина отказа / разложение). DFB не изобретает score.">
        The class is <strong style="color:var(--text-primary)">not a DFB-invented score.</strong> It is a
        deterministic presentation map of the engine's own verdict (approval / kill-reason / decomposition).
        DFB invents no score — it reads the letter off the engine's <span class="font-mono">classify()</span>.
      </p>
      <div class="space-y-2.5 mb-4">
        {classes.map((k) => (
          <div class="flex items-start gap-4 rounded-lg p-4" style="background:var(--bg-surface);border:1px solid var(--border)">
            <span class="shrink-0 inline-flex items-center justify-center rounded-md font-mono text-sm font-bold px-2.5 py-1"
                  style={`color:${k.fg};background:${k.fg}1f;border:1px solid ${k.fg}59;min-width:3.2rem`}>{k.c}</span>
            <div>
              <p class="text-sm font-semibold mb-0.5" style="color:var(--text-primary)">
                <span style={`color:${k.fg}`}>{k.c}</span> — {k.en}
                <span class="font-mono ml-2 text-xs" style="color:var(--text-faint)">{k.cond}</span>
              </p>
              <p class="text-sm leading-relaxed" style="color:var(--text-secondary)" data-ru={k.ruDesc}>{k.enDesc}</p>
            </div>
          </div>
        ))}
      </div>
      <p class="text-xs leading-relaxed max-w-3xl" style="color:var(--text-muted)"
         data-ru="Раскол D-vs-C — несущий: структурный отказ (D) НЕ зависит от размера; отказ по размеру/экономике (C) зависит. DFB читает это из enum KillReason движка, никогда не пере-выводя токсичность.">
        The <strong>D-vs-C split is load-bearing</strong>: a structural refusal (D) is size-independent;
        a size/economics refusal (C) is not. DFB reads this off the engine's <span class="font-mono">KillReason</span>
        enum — it never re-derives toxicity.
      </p>
    </section>

    <!-- c2. structural haircut + tail-veto -->
    <section class="py-10 border-t" style="border-color:var(--border)">
      <h2 class="text-2xl font-bold mb-2" style="color:var(--text-primary)" data-ru="2 · Структурный haircut + tail-veto (токсичность вне зависимости от размера)">
        2 · Structural haircut + tail-veto (size-independent toxicity)</h2>
      <p class="text-sm leading-relaxed mb-4 max-w-3xl" style="color:var(--text-secondary)"
         data-ru="Гейт refusal-first: отказывает в tail-comp ДО того, как смотрит на экономику. Fair-value разложение это baseline минус пять haircut'ов.">
        The gate is <strong style="color:var(--text-primary)">refusal-first</strong>: it vetoes tail-comp
        <em>before</em> it ever looks at the economics. The fair-value decomposition is baseline minus five haircuts:
      </p>
      <pre class="rounded-lg p-4 mb-4 text-xs overflow-x-auto font-mono" style="background:var(--bg-surface);border:1px solid var(--border);color:var(--text-secondary)">total_haircut      = peg + funding_flip + oracle + liquidity + protocol
structural_haircut = peg + funding_flip + oracle + protocol      (EXCLUDES the size-dependent liquidity term)</pre>
      <ul class="space-y-2.5 text-sm leading-relaxed max-w-3xl" style="color:var(--text-secondary)">
        <li class="flex gap-2.5"><span class="shrink-0 mt-0.5" style="color:#F26D6D" aria-hidden="true">▸</span>
          <span data-ru="TAIL_VETO (токсичность, не зависит от размера): structural_haircut > 0.06 (калибровано). Так как структурный haircut ИСКЛЮЧАЕТ размер-зависимый член ликвидности, tail-токсичная книга отказана на ЛЮБОМ размере — уменьшение размера двигает только haircut ликвидности, не вердикт токсичности.">
            <strong style="color:var(--text-primary)">TAIL_VETO (toxicity, size-PROOF):</strong>
            <span class="font-mono">structural_haircut &gt; 0.06</span> (calibrated). Because the structural
            haircut excludes the size-dependent liquidity term, a tail-toxic book is refused at
            <strong style="color:var(--text-primary)">any</strong> size — sizing down only shrinks the
            liquidity haircut, never the toxicity verdict.</span></li>
        <li class="flex gap-2.5"><span class="shrink-0 mt-0.5" style="color:#F26D6D" aria-hidden="true">▸</span>
          <span data-ru="TAIL_VETO (экономика, зависит от размера): total_haircut > 0.12. Затем UNDERLYING_DEPEG (peg > 1%), ORACLE_STALE (> 1ч), STABLE_DEPEG (> 0.5%), FUNDING_FLIP (стрик ≥ 5), ECONOMICS, SIZE.">
            <strong style="color:var(--text-primary)">TAIL_VETO (economics, size-aware):</strong>
            <span class="font-mono">total_haircut &gt; 0.12</span>. Then UNDERLYING_DEPEG (peg &gt; 1%),
            ORACLE_STALE (&gt; 1h), STABLE_DEPEG (&gt; 0.5%), FUNDING_FLIP (streak ≥ 5), ECONOMICS, SIZE.</span></li>
      </ul>
    </section>

    <!-- c3. exit-liquidity-by-size -->
    <section class="py-10 border-t" style="border-color:var(--border)">
      <h2 class="text-2xl font-bold mb-2" style="color:var(--text-primary)" data-ru="3 · Ликвидность-на-выход-по-размеру (консервативная нижняя граница)">
        3 · Exit-liquidity-by-size (a conservative lower bound)</h2>
      <p class="text-sm leading-relaxed mb-3 max-w-3xl" style="color:var(--text-secondary)"
         data-ru="По каждому пулу DFB публикует график выхода на $1M / $5M / $10M OUT через движок depth_at_size — DFB не считает НИ ОДНО из этих чисел. Применяется консервативная константно-продуктовая доля impact против СОБСТВЕННОЙ ончейн ликвидности рынка — никогда агрегированной — так что граница это НИЖНЯЯ граница: рынок как минимум настолько глубок.">
        Per pool, DFB publishes the exit schedule at <strong style="color:var(--text-primary)">$1M / $5M / $10M
        OUT</strong> via the engine's <span class="font-mono">depth_at_size</span> — DFB computes
        <strong style="color:var(--text-primary)">none</strong> of these numbers. A conservative
        constant-product impact fraction is applied against that market's <em>own</em> on-chain liquidity —
        never an aggregated cross-venue number — so the bound is a <strong style="color:var(--text-primary)">lower
        bound</strong>: the real market is at least this deep, often deeper.
      </p>
      <p class="text-sm leading-relaxed max-w-3xl" style="color:var(--text-secondary)"
         data-ru="fail-CLOSED — несущее правило: тикет, который рынок не может поглотить, публикуется как ПОМЕЧЕННАЯ дыра (absorbable_usd: null, flagged: true) — НИКОГДА не заполняется выдуманным числом. Нет пути кода, который синтезирует зелёную ячейку выхода поверх дыры.">
        <strong style="color:var(--text-primary)">fail-CLOSED is the load-bearing rule:</strong> a ticket the
        market cannot absorb is published as a <strong style="color:var(--text-primary)">flagged hole</strong>
        (<span class="font-mono">absorbable_usd: null, flagged: true</span>) — never backfilled with a
        fabricated fill. There is no code path that synthesizes a green exit cell over a depth hole.
      </p>
    </section>

    <!-- ============ d. THE NO-FORK GUARANTEE ============ -->
    <section class="py-10 border-t" style="border-color:var(--border)">
      <p class="text-xs uppercase tracking-wider font-mono mb-3" style="color:var(--accent-hover)"
         data-ru="Гарантия NO-FORK (AST-проверяемая)">The NO-FORK guarantee (AST-enforced)</p>
      <h2 class="text-2xl font-bold mb-3" style="color:var(--text-primary)"
          data-ru="Вердикт DFB по пулу == вердикт стола по тому же рынку — до байта.">
        DFB's verdict == the desk's verdict on the same market — to the byte.
      </h2>
      <p class="text-sm leading-relaxed mb-3 max-w-3xl" style="color:var(--text-secondary)"
         data-ru="DFB ВЫЗЫВАЕТ движок, а не переписывает его: refusal-вердикт ← evaluate_entry, haircut'ы ← GateResult.decomposition, ликвидность-на-выход ← depth_at_size, A/B/C/D ← classify() (карта собственного GateResult движка), engine_proof_hash ← GateResult.proof_hash() (байт-в-байт как у стола).">
        DFB <strong style="color:var(--text-primary)">calls</strong> the engine, it does not re-implement it:
        the refusal verdict ← <span class="font-mono">evaluate_entry</span>, the haircuts ←
        <span class="font-mono">GateResult.decomposition</span>, exit-liquidity ←
        <span class="font-mono">depth_at_size</span>, A/B/C/D ← <span class="font-mono">classify()</span>
        (a map of the engine's own GateResult), and <span class="font-mono">engine_proof_hash</span> ←
        <span class="font-mono">GateResult.proof_hash()</span> (byte-identical to the desk).
      </p>
      <p class="text-sm leading-relaxed max-w-3xl" style="color:var(--text-secondary)"
         data-ru="Это AST-проверяется test_dfb_no_fork.py: ни один модуль DFB не ОПРЕДЕЛЯЕТ риск-математику движка; точки входа, которые использует DFB, — это СОБСТВЕННЫЕ объекты движка (та же идентичность модуля); и overlay(pool).engine_proof_hash == evaluate_entry(...).proof_hash(). Так два продукта никогда не разойдутся.">
        This is <strong style="color:var(--text-primary)">AST-enforced</strong> by
        <span class="font-mono">test_dfb_no_fork.py</span>: no DFB module <em>defines</em> the engine's risk
        math; the entrypoints DFB uses <strong style="color:var(--text-primary)">are the engine's own
        objects</strong> (same module identity); and <span class="font-mono">overlay(pool).engine_proof_hash
        == evaluate_entry(...).proof_hash()</span>. So the two products can never drift.
      </p>
    </section>

    <!-- ============ e. VERIFY ANY POOL ============ -->
    <section class="py-10 border-t" style="border-color:var(--border)">
      <p class="text-xs uppercase tracking-wider font-mono mb-3" style="color:var(--accent-hover)"
         data-ru="Проверь любой пул — «не верь, проверь»">Verify any pool — "don't trust us, check us"</p>
      <h2 class="text-2xl font-bold mb-3" style="color:var(--text-primary)"
          data-ru="Каждая строка несёт воспроизводимый proof. Перепроверь сам — без нашего кода.">
        Every row carries a reproducible proof. Re-derive it yourself — without our code.
      </h2>
      <p class="text-sm leading-relaxed mb-4 max-w-3xl" style="color:var(--text-secondary)"
         data-ru="row_hash = sha256 канонического JSON тела строки (строка минус prev_hash/row_hash) + prev_hash. Он связывает И опубликованные входы (apy/tvl), И выходы (risk_class / refusal / exit_liquidity / haircuts / engine_proof_hash). Подмени любую ячейку — пересчёт разойдётся. prev_hash сцепляет строки (генезис «0»×64), так что переставленная / удалённная / вставленная строка ловится.">
        <span class="font-mono">row_hash</span> = sha256 of the canonical JSON of the row body (the row minus
        <span class="font-mono">prev_hash/row_hash</span>) + its <span class="font-mono">prev_hash</span>. It
        binds <strong style="color:var(--text-primary)">both</strong> the published inputs (apy/tvl) and the
        outputs (risk_class / refusal / exit_liquidity / haircuts / engine_proof_hash). Forge any cell → the
        recompute diverges. <span class="font-mono">prev_hash</span> chains the rows (genesis "0"×64), so a
        reordered / dropped / inserted row is caught.
      </p>
      <p class="text-xs leading-relaxed mb-2" style="color:var(--text-muted)"
         data-ru="Один файл, ноль зависимостей, ноль импорта spa_core. Скачай scripts/verify_dfb_pool.py + публичные JSON и запусти:">
        One file, zero dependencies, zero <span class="font-mono">spa_core</span> import. Download
        <span class="font-mono">scripts/verify_dfb_pool.py</span> + the public JSON and run:
      </p>
      <pre class="rounded-lg p-4 mb-4 text-xs overflow-x-auto font-mono" style="background:var(--bg-surface);border:1px solid var(--border);color:var(--text-secondary)"># whole DFB data dir (pools.json + pool/*.json + history/*.jsonl):
python3 scripts/verify_dfb_pool.py data/dfb

# one pool by id, or its detail file:
python3 scripts/verify_dfb_pool.py pendle__ethereum__susde</pre>
      <p class="text-sm leading-relaxed max-w-3xl" style="color:var(--text-secondary)"
         data-ru="Exit 0 = каждая строка воспроизводится байт-в-байт (и каждая цепочка сцепляется); 1 = любое расхождение (с точным broken_at и полем); 2 = вход не найден (fail-closed). Рецепт в верификаторе зеркалит риск-движок до байта — так число стола и независимый пересчёт сходятся при нуле общего кода.">
        Exit <span class="font-mono">0</span> = every row reproduces byte-for-byte (and every chain links);
        <span class="font-mono">1</span> = any mismatch (with the precise broken_at + field); <span class="font-mono">2</span>
        = no input found (fail-closed). The verifier's recipe mirrors the risk engine to the byte — so the
        desk's number and an independent recompute agree with zero shared code.
      </p>

      <!-- verdict-vocabulary honesty note -->
      <div class="rounded-xl p-5 mt-6" style="background:var(--bg-surface);border:1px solid var(--border)">
        <p class="text-xs uppercase tracking-wider font-mono mb-2" style="color:var(--text-faint)"
           data-ru="Вердикт, который движок выдаёт сегодня">The verdict the engine emits today</p>
        <p class="text-sm leading-relaxed" style="color:var(--text-secondary)"
