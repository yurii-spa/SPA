---
import SiteHeader from '../components/SiteHeader.astro';
import PaperStrip from '../components/PaperStrip.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  admin?: boolean;
  // Q2-15: when a page is a blog post, pass {headline, datePublished, description?} and Layout appends a
  // BlogPosting node to the JSON-LD @graph (Article schema → richer indexing + AI answer-engine ingestion).
  article?: { headline: string; datePublished: string; description?: string };
}

const {
  title,
  description = "SPA — systematic onchain stablecoin yield. Personal research project in paper validation and tuning.",
  ogImage = "/og-image.png",
  canonical,
  admin = false,
  article,
} = Astro.props;

const siteUrl = "https://earn-defi.com";
// The site builds with Astro's directory format: the canonical 200 URL carries a trailing
// slash (`/faq/`), and the no-slash form 308-redirects to it. Both the explicit `canonical`
// props and the Astro.url.pathname fallback emit the NO-slash form, so every page was
// declaring a canonical that redirects — split SEO signals. Normalise to the trailing-slash
// 200 form (matches the server + sitemap.xml). Root and real files (with an extension) untouched.
function canonicalUrl(u: string): string {
  const m = /^(https?:\/\/[^/]+)(\/[^?#]*)?([?#].*)?$/.exec(u);
  if (!m) return u;
  const origin = m[1];
  let path = m[2] || "/";
  const rest = m[3] || "";
  const last = path.split("/").pop() || "";
  if (path !== "/" && !path.endsWith("/") && !last.includes(".")) path += "/";
  return `${origin}${path}${rest}`;
}
const pageUrl = canonicalUrl(canonical || `${siteUrl}${Astro.url.pathname}`);
const ogImageAbsolute = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;

// Structured data (SPA-12): an Organization + WebSite graph so search engines
// can attribute the site to a publisher (knowledge-panel eligibility) rather than
// a bare WebSite node. Honest, static site identity — no fabricated claims.
const schemaData = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${siteUrl}/#organization`,
      "name": "SPA — earn-defi.com",
      "url": siteUrl,
      "logo": `${siteUrl}/og-image.png`,
      "description": "Systematic onchain stablecoin yield — a personal research project in paper validation, risk measurement and honest evidence levels.",
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "name": "SPA — systematic onchain stablecoin yield",
      "url": siteUrl,
      "description": description,
      "publisher": { "@id": `${siteUrl}/#organization` },
    },
    // Q2-15: BlogPosting node for blog posts (Article schema). Only added when the page passes `article`.
    ...(article ? [{
      "@type": "BlogPosting",
      "@id": `${pageUrl}#article`,
      "headline": article.headline,
      "datePublished": article.datePublished,
      "dateModified": article.datePublished,
      "description": article.description || description,
      "url": pageUrl,
      "mainEntityOfPage": pageUrl,
      "author": { "@id": `${siteUrl}/#organization` },
      "publisher": { "@id": `${siteUrl}/#organization` },
    }] : []),
  ],
});
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- Public pages are indexable; the /admin Operator Console (admin={true}) is NOT
         — it holds no auth yet, so keep it out of search indexes entirely. -->
    <meta name="robots" content={admin ? "noindex, nofollow" : "index, follow"} />
    <meta name="theme-color" content="#0A0C10" />

    <!-- Canonical -->
    <link rel="canonical" href={pageUrl} />
    <!-- Q2-15: RSS autodiscovery — feed readers + AI answer engines find the changelog automatically. -->
    <link rel="alternate" type="application/rss+xml" title="SPA — earn-defi.com" href="https://earn-defi.com/rss.xml" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:site_name" content="SPA — systematic onchain stablecoin yield" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- Fonts: Inter + JetBrains Mono (spec §3.2 — load BOTH) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={schemaData} />

    <!-- Unified design tokens (docs/SITE_DESIGN_SYSTEM.md §3) — applied globally so the
         whole site inherits one palette/type/radius/shadow system. -->
    <style is:global>
      :root{
        /* Backgrounds — single near-black scale */
        --bg-base:#0A0C10; --bg-surface:#11141A; --bg-surface-2:#181C24; --bg-elevated:#1E232C;
        --border:#232934; --border-strong:#313945;
        /* Text — faint bumped #444B57→#565E6D for AA on non-decorative text (V2 a11y) */
        --text-primary:#E8EAF0; --text-secondary:#A6ADBB; --text-muted:#6B7280; --text-faint:#565E6D;
        /* Brand accent — indigo */
        --accent:#5B8DEF; --accent-hover:#79A4F5; --accent-dim:#2C4A8A;
        --accent-bg:rgba(91,141,239,0.10); --accent-border:rgba(91,141,239,0.30);
        /* Secondary accent — quant teal (A-tier + data-viz/live-tick, NEVER a verdict) */
        --data-teal:#36C2B4; --teal-bg:rgba(54,194,180,0.12); --teal-border:rgba(54,194,180,0.30);
        /* Semantic — canonical risk-color language (V2 §3.3, ONE map site-wide):
           SAFE/PASS/live=ok · WATCH/PENDING=warn · REFUSE/FAIL/kill/offline=danger · UNKNOWN=text-muted */
        --ok:#34D399; --warn:#F2B53C; --danger:#F26D6D; --info:#5B8DEF;
        /* Semantic tint/border tokens (tokenize the ~20× rgba literals once) */
        --ok-bg:rgba(52,211,153,0.10); --ok-border:rgba(52,211,153,0.30);
        --warn-bg:rgba(242,181,60,0.10); --warn-border:rgba(242,181,60,0.30);
        --danger-bg:rgba(242,109,109,0.12); --danger-border:rgba(242,109,109,0.35);
        --muted-bg:var(--bg-surface-2); --muted-border:var(--border-strong);
        /* Type */
        --font-sans:'Inter',system-ui,-apple-system,sans-serif;
        --font-mono:'JetBrains Mono','SFMono-Regular',ui-monospace,monospace;
        /* Radius */
        --r-sm:8px; --r-md:12px; --r-lg:16px; --r-xl:24px; --r-full:9999px;
        /* Shadow */
        --shadow-sm:0 1px 2px rgba(0,0,0,.4); --shadow-md:0 4px 16px rgba(0,0,0,.45);
        --shadow-cta:0 6px 20px rgba(91,141,239,.25);
        /* Motion */
        --ease:cubic-bezier(.4,0,.2,1);
      }
      html { background-color: var(--bg-base); }
      body { background: var(--bg-base); color: var(--text-secondary); font-family: var(--font-sans); }
      @keyframes pulse{0%,100%{opacity:1}50%{opacity:.35}}
      /* Global keyboard focus ring — one accessible :focus-visible treatment site-wide (V2 a11y).
         Mouse users see nothing; keyboard/AT users get a clear 2px accent ring on every
         interactive element. Never removes the outline without a visible replacement. */
      :where(a,button,input,select,textarea,summary,[tabindex]):focus-visible{
        outline:2px solid var(--accent); outline-offset:2px; border-radius:var(--r-sm);
      }
      :focus:not(:focus-visible){ outline:none; }
      @media (prefers-reduced-motion:reduce){
        *{animation:none !important; transition:none !important; scroll-behavior:auto !important}
      }
      /* Operator Console chrome (admin={true}) — slim internal bar, no public nav */
      .admin-bar{position:sticky; top:0; z-index:50; display:flex; align-items:center; gap:14px;
        height:52px; padding:0 24px; background:var(--bg-surface); border-bottom:1px solid var(--border-strong)}
      .ab-brand{font-weight:700; color:var(--text-primary); font-size:.9375rem; text-decoration:none}
      .ab-brand b{color:var(--accent); font-weight:700}
      .ab-tag{font-family:var(--font-mono); font-size:.6875rem; text-transform:uppercase; letter-spacing:.08em;
        color:var(--warn); border:1px solid var(--border); border-radius:var(--r-full); padding:2px 9px}
      .ab-exit{margin-left:auto; font-size:.8125rem; color:var(--text-muted); text-decoration:none}
      .ab-exit:hover{color:var(--text-secondary)}
      .admin-foot{padding:26px 24px; text-align:center; color:var(--text-faint); font-size:.75rem;
        font-family:var(--font-mono); border-top:1px solid var(--border)}
    </style>
  </head>

  <body class="text-text-secondary antialiased" style="background:var(--bg-base)">
    <!-- Canonical chrome on EVERY page that uses Layout (spec §4). Admin pages get a slim
         internal bar instead of the public header/footer (Operator Console — Phase 3). -->
    {admin ? (
      <header class="admin-bar">
        <a href="/admin" class="ab-brand">SPA <b>Operator Console</b></a>
        <span class="ab-tag">internal</span>
        <a href="/" class="ab-exit">← Public site</a>
      </header>
    ) : (
      <SiteHeader />
    )}
    {!admin && <PaperStrip />}

    <slot />

    {!admin && <SiteFooter />}
    {admin && (
      <footer class="admin-foot">SPA Operator Console · internal · not public · access control in Phase 5</footer>
    )}

    <!-- i18n runtime INLINED (external /i18n.js was shadowed by the CF soft-404 → served
         HTML instead of JS, which broke the toggle). Inlining guarantees it always runs.
         Toggle now lives inside SiteHeader (#spa-lang-toggle); same runtime wires it. -->
    <script is:inline>
      (function () {
        "use strict";
        var STORAGE_KEY = "spa_lang", SUPPORTED = ["en", "ru"];
        function getLang() {
          try { var v = window.localStorage.getItem(STORAGE_KEY); if (v && SUPPORTED.indexOf(v) !== -1) return v; } catch (e) {}
          return "en";
        }
        function storeLang(l) { try { window.localStorage.setItem(STORAGE_KEY, l); } catch (e) {} }
        function applyTranslations(lang) {
          var nodes = document.querySelectorAll("[data-ru]");
          for (var i = 0; i < nodes.length; i++) {
            var el = nodes[i];
            if (!el.hasAttribute("data-en-orig")) el.setAttribute("data-en-orig", el.innerHTML);
            if (lang === "ru") { var ru = el.getAttribute("data-ru"); if (ru != null) el.innerHTML = ru; }
            else { var en = el.getAttribute("data-en-orig"); if (en != null) el.innerHTML = en; }
          }
        }
        function updateToggleState(lang) {
          var t = document.getElementById("spa-lang-toggle"); if (!t) return;
          var b = t.querySelectorAll("[data-lang]");
          for (var i = 0; i < b.length; i++) {
            var a = b[i].getAttribute("data-lang") === lang;
            b[i].setAttribute("aria-pressed", a ? "true" : "false");
            b[i].classList.toggle("spa-lang-active", a);
          }
        }
        function setLang(lang) {
          if (SUPPORTED.indexOf(lang) === -1) lang = "en";
          storeLang(lang);
          try { document.documentElement.setAttribute("lang", lang); } catch (e) {}
          applyTranslations(lang); updateToggleState(lang);
          if (window.__renderLive) { try { window.__renderLive(); } catch (e) {} }
        }
        function wireToggle() {
          var t = document.getElementById("spa-lang-toggle");
          if (!t || t.getAttribute("data-wired") === "1") return;
          t.setAttribute("data-wired", "1");
          t.addEventListener("click", function (ev) {
            var n = ev.target;
            while (n && n !== t && !(n.getAttribute && n.getAttribute("data-lang"))) n = n.parentNode;
            if (n && n.getAttribute && n.getAttribute("data-lang")) setLang(n.getAttribute("data-lang"));
          });
        }
        function init() { wireToggle(); setLang(getLang()); }
        window.setLang = setLang;
        window.spaI18n = { setLang: setLang, getLang: getLang, apply: applyTranslations };
        if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", init);
        else init();
      })();
    </script>
    <!-- Site analytics beacon (privacy-friendly MVP): fires a page-view + exposes window.spaTrack
         for click events. No cookies, no IP stored server-side, no PII. Fails silently. -->
    <script is:inline>
      (function(){
        var API = (location.hostname==='localhost'||location.hostname==='127.0.0.1') ? 'http://localhost:8765' : 'https://api.earn-defi.com';
        // Q2-9: capture campaign attribution once on arrival (e.g. the DeFi Checkup deep-link
        // utm_source=defi-checkup&utm_campaign=depeg) and carry it on every beacon this session, so a
        // routed visit is measurable end-to-end. Privacy-friendly: only source/campaign strings, no PII.
        var src='', camp='';
        try {
          var q = new URLSearchParams(location.search);
          src = (q.get('utm_source')||'').slice(0,48);
          camp = (q.get('utm_campaign')||'').slice(0,48);
          if(src||camp){ sessionStorage.setItem('spa_utm', JSON.stringify({s:src,c:camp})); }
          else { var st = JSON.parse(sessionStorage.getItem('spa_utm')||'null'); if(st){ src=st.s||''; camp=st.c||''; } }
        } catch(e){}
        function send(ev){ try{ fetch(API+'/api/analytics/event',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({page:location.pathname,event:ev||'view',utm_source:src,utm_campaign:camp}),keepalive:true}).catch(function(){}); }catch(e){} }
        window.spaTrack = send;
        send('view');
        document.addEventListener('click', function(e){
          var t = e.target && e.target.closest && e.target.closest('[data-track]');
          if(t){ send(t.getAttribute('data-track')); }
        });
      })();
    </script>
  </body>
</html>
