---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title,
  description = "SPA — systematic onchain stablecoin yield. Personal research project in paper validation and tuning.",
  ogImage = "/og-image.png",
  canonical,
} = Astro.props;

const siteUrl = "https://earn-defi.com";
const pageUrl = canonical || `${siteUrl}${Astro.url.pathname}`;
const ogImageAbsolute = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;

const schemaData = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "SPA — systematic onchain stablecoin yield",
  "url": siteUrl,
  "description": description,
});
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#0a0a0a" />

    <!-- Canonical -->
    <link rel="canonical" href={pageUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:site_name" content="SPA — Stablecoin Portfolio Algorithm" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- Fonts: Inter via Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={schemaData} />

    <!-- Prevent flash of unstyled dark content -->
    <style>
      html { background-color: #0a0a0a; }

      /* Site-wide EN|RU language toggle (fixed top-right) */
      #spa-lang-toggle {
        position: fixed;
        top: 14px;
        right: 14px;
        z-index: 9999;
        display: inline-flex;
        align-items: center;
        gap: 1px;
        padding: 2px;
        border-radius: 9999px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.12);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        font-size: 11px;
        line-height: 1;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
      }
      #spa-lang-toggle button {
        appearance: none;
        background: transparent;
        border: 0;
        cursor: pointer;
        color: rgba(255, 255, 255, 0.5);
        font-weight: 600;
        letter-spacing: 0.04em;
        padding: 5px 10px;
        border-radius: 9999px;
        transition: color 0.15s, background 0.15s;
      }
      #spa-lang-toggle button:hover { color: rgba(255, 255, 255, 0.85); }
      #spa-lang-toggle button.spa-lang-active {
        color: #fff;
        background: rgba(255, 255, 255, 0.12);
      }
      #spa-lang-toggle .spa-lang-sep {
        color: rgba(255, 255, 255, 0.2);
        padding: 0 1px;
        user-select: none;
      }
    </style>
  </head>

  <body class="bg-[#0a0a0a] text-white antialiased">
    <!-- Site-wide EN|RU language toggle (wired by /i18n.js) -->
    <div id="spa-lang-toggle" role="group" aria-label="Language">
      <button type="button" data-lang="en" aria-pressed="true">EN</button>
      <span class="spa-lang-sep" aria-hidden="true">|</span>
      <button type="button" data-lang="ru" aria-pressed="false">RU</button>
    </div>

    <slot />

    <!-- i18n runtime: loaded on every page; swaps any [data-ru] element's text -->
    <script src="/i18n.js" is:inline></script>
  </body>
</html>
