<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  com.spa.work_digest — «что сделано за вчера» (РАБОТА, простым языком) в Telegram, 09:00 local.
  Owner-requested 2026-07-16. РАЗЛИЧАЕТСЯ от com.spa.digest_daily (тот = ПОРТФЕЛЬ: equity/P&L/APY/
  позиции). Переименован с ретайренного com.spa.morning_digest, чтобы не коллидировать с RETIRED_LABELS.
  bash-wrapper + /tmp logs (invariant #12). RunAtLoad=false. Чистый claude -p пересказ (без skip-perms).
-->
<plist version="1.0">
<dict>
	<key>EnvironmentVariables</key>
	<dict>
		<key>HOME</key>
		<string>/Users/yuriikulieshov</string>
		<key>PATH</key>
		<string>/Users/yuriikulieshov/.local/bin:/opt/homebrew/bin:/Users/yuriikulieshov/miniconda3/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
	</dict>
	<key>Label</key>
	<string>com.spa.work_digest</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>/Users/yuriikulieshov/Documents/SPA_Claude/scripts/agent_work_digest.sh</string>
	</array>
	<key>RunAtLoad</key>
	<false/>
	<key>StandardErrorPath</key>
	<string>/tmp/spa_work_digest.launchd.err</string>
	<key>StandardOutPath</key>
	<string>/tmp/spa_work_digest.launchd.out</string>
	<key>StartCalendarInterval</key>
	<dict>
		<key>Hour</key>
		<integer>9</integer>
		<key>Minute</key>
		<integer>0</integer>
	</dict>
	<key>ThrottleInterval</key>
	<integer>30</integer>
	<key>WorkingDirectory</key>
	<string>/Users/yuriikulieshov/Documents/SPA_Claude</string>
</dict>
</plist>
