<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  com.spa.cc-kanban — claude-code-kanban backup monitor (ENV_SETUP_BRIEF_v3 §4.1).
  Read-only web UI over ~/.claude on http://localhost:4455. KeepAlive + RunAtLoad.
  Logs to /tmp per CLAUDE.md invariant #12 (bash-wrapper, never direct binary).
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.spa.cc-kanban</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/yuriikulieshov/Documents/SPA_Claude/scripts/agent_cc_kanban.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/yuriikulieshov/Documents/SPA_Claude</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/spa_cc_kanban.plist.out.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/spa_cc_kanban.plist.err.log</string>
</dict>
</plist>
